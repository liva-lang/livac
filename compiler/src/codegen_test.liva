// ============================================================================
// codegen_test.liva — RustEmitter extension: test framework emission
// ============================================================================
// Extracted from codegen.liva via `extend RustEmitter { ... }`.
//
// Owns the lowering of:
//   - `describe("name", () => { ... })` → `#[cfg(test)] mod test_<name>`
//   - `test("case",     () => { ... })` → `#[test] fn test_<name>()`
// And the helper that walks a describe block, routing nested describe()
// or test() calls back here while delegating everything else to _emitStmt.
//
// Fields it touches on RustEmitter:
//   _inTestBlock, _usedTestNames.

import { Expr, Stmt, BlockStmt, LambdaBody, Literal } from "./ast"
import { RustEmitter } from "./codegen"

extend RustEmitter {

    // -- Test framework: describe() --

    _emitDescribe(args: [Expr]) {
        if args.length < 2 { return }

        // Extract the name string
        let modName = "unnamed"
        switch args[0] {
            Expr.Literal(lit) => {
                switch lit {
                    Literal.Str(s) => { modName = this._sanitizeTestName(s) }
                }
            }
        }

        this._writeln("#[cfg(test)]")
        this._writeln($"mod test_{modName} {{")
        this._indent()
        this._writeln("use super::*;")
        this._writeRaw("")

        let wasInTest = this._inTestBlock
        this._inTestBlock = true

        // Lifecycle hooks (Jest-style): save outer scope and reset for this block.
        // Inner describes shadow but the outer hooks restore on exit.
        let savedBefore = this._testBeforeEach
        let savedAfter = this._testAfterEach
        this._testBeforeEach = []
        this._testAfterEach = []

        // Extract lambda body and emit its statements
        switch args[1] {
            Expr.Lambda(lambda) => {
                switch lambda.body {
                    LambdaBody.Block(block) => {
                        // Pass 1: collect beforeEach/afterEach hook bodies.
                        for stmt in block.stmts {
                            this._collectTestHook(stmt)
                        }
                        // Pass 2: emit tests + nested describes; skip hook calls.
                        for stmt in block.stmts {
                            if not this._isTestHookStmt(stmt) {
                                this._emitTestStmt(stmt)
                            }
                        }
                    },
                    LambdaBody.Expr(exprs) => {
                        for e in exprs {
                            this._writeIndent()
                            this._emitExpr(e)
                            this._write(";")
                            this._newline()
                        }
                    }
                }
            }
        }

        // Restore outer lifecycle scope and test flag
        this._testBeforeEach = savedBefore
        this._testAfterEach = savedAfter
        this._inTestBlock = wasInTest
        this._dedent()
        this._writeln("}")
    }

    // -- Lifecycle hook detection --
    // Returns true if the stmt is a top-level beforeEach()/afterEach() call.
    _isTestHookStmt(stmt: Stmt): bool {
        switch stmt {
            Stmt.ExprStmt(expr) => {
                switch expr {
                    Expr.Call(callee, _, _, _) => {
                        switch callee {
                            Expr.Identifier(n) => {
                                if n == "beforeEach" { return true }
                                if n == "afterEach"  { return true }
                            }
                        }
                    }
                }
            }
        }
        return false
    }

    // Capture the lambda body of a beforeEach/afterEach call into the
    // current hook lists, so _emitTestCase can prepend/append them.
    _collectTestHook(stmt: Stmt) {
        switch stmt {
            Stmt.ExprStmt(expr) => {
                switch expr {
                    Expr.Call(callee, callArgs, _, _) => {
                        let fnName = ""
                        switch callee {
                            Expr.Identifier(n) => { fnName = n }
                        }
                        if fnName != "beforeEach" && fnName != "afterEach" { return }
                        if callArgs.length < 1 { return }

                        switch callArgs[0] {
                            Expr.Lambda(lambda) => {
                                switch lambda.body {
                                    LambdaBody.Block(block) => {
                                        for hookStmt in block.stmts {
                                            if fnName == "beforeEach" {
                                                this._testBeforeEach.push(hookStmt)
                                            } else {
                                                this._testAfterEach.push(hookStmt)
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // -- Helper: emit a statement inside a describe block --
    // Detects test() and other calls, delegates the rest to _emitStmt

    _emitTestStmt(stmt: Stmt) {
        switch stmt {
            Stmt.ExprStmt(expr) => {
                switch expr {
                    Expr.Call(callee, callArgs, _, _) => {
                        let fnName = ""
                        switch callee {
                            Expr.Identifier(n) => { fnName = n }
                        }
                        if fnName == "test" {
                            this._emitTestCase(callArgs)
                        } else if fnName == "describe" {
                            // Nested describe
                            this._emitDescribe(callArgs)
                        } else {
                            this._emitStmt(stmt)
                        }
                    },
                    _ => { this._emitStmt(stmt) }
                }
            },
            _ => { this._emitStmt(stmt) }
        }
    }

    // -- Test framework: test() --

    _emitTestCase(args: [Expr]) {
        if args.length < 2 { return }

        // Extract and deduplicate test name
        let testName = "unnamed"
        switch args[0] {
            Expr.Literal(lit) => {
                switch lit {
                    Literal.Str(s) => { testName = this._sanitizeTestName(s) }
                }
            }
        }
        // Deduplicate
        if this._usedTestNames.has(testName) {
            let count = this._usedTestNames.get(testName)
            count += 1
            this._usedTestNames.set(testName, count)
            testName = $"{testName}_{count}"
        } else {
            this._usedTestNames.set(testName, 1)
        }

        this._writeln("#[test]")
        this._writeln($"fn test_{testName}() {{")
        this._indent()

        // Emit body wrapped with beforeEach (prepend) / afterEach (append).
        // Construct a synthetic BlockStmt so _emitBlock peephole optimizations
        // still apply to the original test body's statements.
        switch args[1] {
            Expr.Lambda(lambda) => {
                switch lambda.body {
                    LambdaBody.Block(block) => {
                        let wrappedStmts: [Stmt] = []
                        for h in this._testBeforeEach { wrappedStmts.push(h) }
                        for s in block.stmts        { wrappedStmts.push(s) }
                        for h in this._testAfterEach  { wrappedStmts.push(h) }
                        this._emitBlock(BlockStmt { stmts: wrappedStmts })
                    },
                    LambdaBody.Expr(exprs) => {
                        for h in this._testBeforeEach { this._emitStmt(h) }
                        for e in exprs {
                            this._writeIndent()
                            this._emitExpr(e)
                            this._write(";")
                            this._newline()
                        }
                        for h in this._testAfterEach { this._emitStmt(h) }
                    }
                }
            }
        }

        this._dedent()
        this._writeln("}")
    }
}

// Sentinel symbol so main.liva can import this module and bring its
// `extend RustEmitter { ... }` block into the compile graph.
codegenTestExtensionLoaded(): bool { return true }
