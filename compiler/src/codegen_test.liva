// ============================================================================
// codegen_test.liva — RustEmitter extension: test framework emission
// ============================================================================
// Extracted from codegen.liva via `extend RustEmitter { ... }`.
//
// Owns the lowering of:
//   - `describe("name", () => { ... })` → `#[cfg(test)] mod test_<name>`
//   - `test("case",     () => { ... })` → `#[test] fn test_<name>()`
// And the helper that walks a describe block, routing nested describe()
// or test() calls back here while delegating everything else to _emitStmt.
//
// Fields it touches on RustEmitter:
//   _inTestBlock, _usedTestNames.

import { Expr, Stmt, LambdaBody, Literal } from "./ast"
import { RustEmitter } from "./codegen"

extend RustEmitter {

    // -- Test framework: describe() --

    _emitDescribe(args: [Expr]) {
        if args.length < 2 { return }

        // Extract the name string
        let modName = "unnamed"
        switch args[0] {
            Expr.Literal(lit) => {
                switch lit {
                    Literal.Str(s) => { modName = this._sanitizeTestName(s) }
                }
            }
        }

        this._writeln("#[cfg(test)]")
        this._writeln($"mod test_{modName} {{")
        this._indent()
        this._writeln("use super::*;")
        this._writeRaw("")

        let wasInTest = this._inTestBlock
        this._inTestBlock = true

        // Extract lambda body and emit its statements
        switch args[1] {
            Expr.Lambda(lambda) => {
                switch lambda.body {
                    LambdaBody.Block(block) => {
                        for stmt in block.stmts {
                            this._emitTestStmt(stmt)
                        }
                    },
                    LambdaBody.Expr(exprs) => {
                        for e in exprs {
                            this._writeIndent()
                            this._emitExpr(e)
                            this._write(";")
                            this._newline()
                        }
                    }
                }
            }
        }

        this._inTestBlock = wasInTest
        this._dedent()
        this._writeln("}")
    }

    // -- Helper: emit a statement inside a describe block --
    // Detects test() and other calls, delegates the rest to _emitStmt

    _emitTestStmt(stmt: Stmt) {
        switch stmt {
            Stmt.ExprStmt(expr) => {
                switch expr {
                    Expr.Call(callee, callArgs, _, _) => {
                        let fnName = ""
                        switch callee {
                            Expr.Identifier(n) => { fnName = n }
                        }
                        if fnName == "test" {
                            this._emitTestCase(callArgs)
                        } else if fnName == "describe" {
                            // Nested describe
                            this._emitDescribe(callArgs)
                        } else {
                            this._emitStmt(stmt)
                        }
                    },
                    _ => { this._emitStmt(stmt) }
                }
            },
            _ => { this._emitStmt(stmt) }
        }
    }

    // -- Test framework: test() --

    _emitTestCase(args: [Expr]) {
        if args.length < 2 { return }

        // Extract and deduplicate test name
        let testName = "unnamed"
        switch args[0] {
            Expr.Literal(lit) => {
                switch lit {
                    Literal.Str(s) => { testName = this._sanitizeTestName(s) }
                }
            }
        }
        // Deduplicate
        if this._usedTestNames.has(testName) {
            let count = this._usedTestNames.get(testName)
            count += 1
            this._usedTestNames.set(testName, count)
            testName = $"{testName}_{count}"
        } else {
            this._usedTestNames.set(testName, 1)
        }

        this._writeln("#[test]")
        this._writeln($"fn test_{testName}() {{")
        this._indent()

        // Emit body
        switch args[1] {
            Expr.Lambda(lambda) => {
                switch lambda.body {
                    LambdaBody.Block(block) => {
                        this._emitBlock(block)
                    },
                    LambdaBody.Expr(exprs) => {
                        for e in exprs {
                            this._writeIndent()
                            this._emitExpr(e)
                            this._write(";")
                            this._newline()
                        }
                    }
                }
            }
        }

        this._dedent()
        this._writeln("}")
    }
}

// Sentinel symbol so main.liva can import this module and bring its
// `extend RustEmitter { ... }` block into the compile graph.
codegenTestExtensionLoaded(): bool { return true }
