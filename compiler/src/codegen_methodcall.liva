// ============================================================================
// codegen_methodcall.liva — RustEmitter extension: method-call dispatch
// ============================================================================
// Extracted from codegen.liva via `extend RustEmitter { ... }`.
//
// Owns `_emitMethodCall(obj, method, args)`, the type-directed dispatcher
// for every `obj.method(args)` expression. Handles:
//   - HTTP server routing (delegates to codegen_server.liva)
//   - String / Array / Map / Set / Date method lowering
//     (delegates to codegen_stdlib_methods.liva)
//   - Static stdlib calls (File.*, Dir.*, Date.*, HTTP.*, Server.*, etc.)
//   - Expect / assertion chains
//   - User method calls (with mut-self propagation)
//
// Pure relocation — only calls back into existing RustEmitter helpers.

import { Expr } from "./ast"
import { RustEmitter } from "./codegen"

extend RustEmitter {

    _emitMethodCall(obj: Expr, method: string, args: [Expr]) {
        // Response.status(N).text(body) / .json(body) chain.
        // `Response.status(N)` alone emits an `axum::http::StatusCode`, which
        // has no `.text`/`.json` methods. When the immediate receiver is a
        // `Response.status(...)` call, fold the chain into the `(StatusCode,
        // body)` tuple form that axum accepts as a response.
        if method == "text" or method == "json" {
            let isResponseStatusChain = false
            let statusCodeExpr: Expr? = null
            switch obj {
                Expr.MethodCall(innerObj, innerMethod, innerArgs) => {
                    if innerMethod == "status" {
                        switch innerObj {
                            Expr.Identifier(innerName) => {
                                if innerName == "Response" && innerArgs.length >= 1 {
                                    isResponseStatusChain = true
                                    statusCodeExpr = innerArgs[0]
                                }
                            }
                        }
                    }
                }
            }
            if isResponseStatusChain {
                if statusCodeExpr != null {
                    this._write("(axum::http::StatusCode::from_u16(")
                    this._emitExpr(statusCodeExpr)
                    this._write(" as u16).unwrap_or(axum::http::StatusCode::INTERNAL_SERVER_ERROR), ")
                    if method == "json" && args.length >= 1 {
                        this._write("axum::Json(serde_json::json!(")
                        this._emitJsonArg(args[0])
                        this._write(")))")
                    } else if args.length >= 1 {
                        // Use format!() with _emitFormatArg so that
                        // err-bindings (Option<liva_rt::Error>) and other
                        // non-Display values are coerced to String safely.
                        this._write("format!(\"{}\", ")
                        this._emitFormatArg(args[0])
                        this._write("))")
                    } else {
                        this._write("String::new())")
                    }
                    return
                }
            }
        }

        // A.3: HTTP routing — `app.get/post/put/delete/listen` where app
        // is a tracked server var (assigned from Server.create()).
        let isServerCall = false
        let serverVarName = ""
        switch obj {
            Expr.Identifier(svName) => {
                let svSan = this._sanitizeName(svName)
                if this._serverVars.has(svSan) {
                    isServerCall = true
                    serverVarName = svSan
                }
            }
        }
        if isServerCall {
            if method == "get" or method == "post" or method == "put" or method == "delete" {
                this._emitServerRoute(serverVarName, method, args)
                return
            }
            if method == "listen" {
                this._emitServerListen(serverVarName, args)
                return
            }
        }

        // WS module: ws.send / ws.recv / ws.close where ws was from WS.connect()
        let isWsCall = false
        switch obj {
            Expr.Identifier(wsName) => {
                let wsSan = this._sanitizeName(wsName)
                if this._wsVars.has(wsSan) { isWsCall = true }
            }
        }
        if isWsCall {
            if method == "send" {
                this._emitExpr(obj)
                this._write(".send(tungstenite::Message::Text(")
                if args.length > 0 { this._emitExpr(args[0]) }
                this._write(".to_string())).ok()")
                return
            }
            if method == "recv" {
                this._emitExpr(obj)
                this._write(".read().ok().and_then(|__m| if let tungstenite::Message::Text(__s) = __m { Some(__s) } else { None }).unwrap_or_default()")
                return
            }
            if method == "close" {
                this._emitExpr(obj)
                this._write(".close(None).ok()")
                return
            }
        }

        // A.3: inside a server handler, `req.params.get("id")` →
        // `__params.get(&"id".to_string()).cloned().unwrap_or_default()`.
        if this._serverRequestParam != "" && method == "get" {
            let isReqParamsGet = false
            switch obj {
                Expr.MemberAccess(reqObj, reqProp) => {
                    if reqProp == "params" {
                        switch reqObj {
                            Expr.Identifier(reqName) => {
                                if reqName == this._serverRequestParam { isReqParamsGet = true }
                            }
                        }
                    }
                }
            }
            if isReqParamsGet {
                // BUG-3 fix: avoid `"k".to_string().to_string()` — for a bare
                // string literal arg, emit the raw `"k"` and let the trailing
                // `.to_string()` lift it to String once.
                this._write("__params.get(&")
                let argIsRawStrLit = false
                if args.length >= 1 {
                    switch args[0] {
                        Expr.Literal(litK) => {
                            switch litK {
                                Literal.Str(ks) => {
                                    this._write("\"")
                                    this._write(ks)
                                    this._write("\"")
                                    argIsRawStrLit = true
                                }
                            }
                        }
                    }
                    if !argIsRawStrLit {
                        this._emitExpr(args[0])
                    }
                }
                this._write(".to_string()).cloned().unwrap_or_default()")
                return
            }
        }

        let savedSuppressIdx = this._suppressIndexElemClone
        this._suppressIndexElemClone = false
        switch obj {
            Expr.Index(idxObj, idxExpr) => { this._suppressIndexElemClone = true }
        }
        // ── liva/test: expect(x).toBe(y) chain → assert_eq!(x, y) ──
        // Check first WITHOUT consuming args (avoids E0382 move error)
        let isExpectChain = false
        switch obj {
            Expr.Call(callee, _, _, _) => {
                let fnName = ""
                switch callee {
                    Expr.Identifier(n) => { fnName = n }
                }
                if fnName == "expect" { isExpectChain = true }
            },
            Expr.MemberAccess(maObj, prop) => {
                if prop == "not" {
                    switch maObj {
                        Expr.Call(callee2, _, _, _) => {
                            let fnName2 = ""
                            switch callee2 {
                                Expr.Identifier(n2) => { fnName2 = n2 }
                            }
                            if fnName2 == "expect" { isExpectChain = true }
                        }
                    }
                }
            }
        }
        if isExpectChain {
            this._tryEmitExpectChain(obj, method, args)
            return
        }

        // RC3 fix: Detect mutating method calls on self.field → skip .clone()
        // Methods like push/pop/insert/remove/clear/reverse/sort mutate the receiver.
        // If obj is self.field, we must NOT clone it (otherwise mutation is lost).
        let isMutatingCall = method == "push" or method == "pop" or method == "insert" or method == "remove" or method == "clear" or method == "reverse" or method == "sort" or method == "set"

        // Optimization: suppress self.field auto-clone for ALL method calls.
        // self._classes.clone().contains_key(x) → self._classes.contains_key(x)
        // Borrowing &self means methods like .get(), .contains_key(), .len() work via &self.
        let isSelfField = false
        switch obj {
            Expr.MemberAccess(maInner, _) => {
                switch maInner {
                    Expr.Identifier(iName) => {
                        if iName == "this" { isSelfField = true }
                    },
                    // 2-level deep: this.field.subfield.method()
                    Expr.MemberAccess(maInner2, _) => {
                        switch maInner2 {
                            Expr.Identifier(iName2) => {
                                if iName2 == "this" { isSelfField = true }
                            }
                        }
                    }
                }
            }
        }
        if isSelfField {
            this._inAssignTarget = true
        }

        // Handle stdlib type static calls (File, Dir, Process, Sys, Config, CSV, JSON, DB, Server, Http, Response)
        let stdlibName = ""
        switch obj {
            Expr.Identifier(sn) => { stdlibName = sn }
        }
        // Accept both `Http.*` and `HTTP.*` — bootstrap accepts either casing.
        if stdlibName == "HTTP" { stdlibName = "Http" }

        // ── File module (11 functions) ──
        if stdlibName == "File" {
            if method == "read" {
                this._write("match std::fs::read_to_string(&")
                this._emitExpr(args[0])
                this._write(") { Ok(content) => (Some(content), String::new()), Err(e) => (None, format!(\"File read error: {}\", e)) }")
                return
            }
            if method == "write" {
                this._write("match std::fs::write(&")
                this._emitExpr(args[0])
                this._write(", &")
                this._emitExpr(args[1])
                this._write(") { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"File write error: {}\", e)) }")
                return
            }
            if method == "append" {
                this._write("match std::fs::OpenOptions::new().create(true).append(true).open(&")
                this._emitExpr(args[0])
                this._write(").and_then(|mut file| { use std::io::Write; file.write_all(")
                this._emitExpr(args[1])
                this._write(".as_bytes()) }) { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"File append error: {}\", e)) }")
                return
            }
            if method == "exists" {
                this._write("{ let __arg = (")
                this._emitExpr(args[0])
                this._write(").to_string(); std::path::Path::new(&__arg).exists() }")
                return
            }
            if method == "delete" {
                this._write("(match std::fs::remove_file(&")
                this._emitExpr(args[0])
                this._write(") { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"File delete error: {}\", e)) })")
                return
            }
            if method == "copy" {
                this._write("match std::fs::copy(&")
                this._emitExpr(args[0])
                this._write(", &")
                this._emitExpr(args[1])
                this._write(") { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"File copy error: {}\", e)) }")
                return
            }
            if method == "move" {
                this._write("match std::fs::rename(&")
                this._emitExpr(args[0])
                this._write(", &")
                this._emitExpr(args[1])
                this._write(") { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"File move error: {}\", e)) }")
                return
            }
            if method == "size" {
                this._write("match std::fs::metadata(&")
                this._emitExpr(args[0])
                this._write(") { Ok(m) => (Some(m.len() as i64), String::new()), Err(e) => (None, format!(\"File size error: {}\", e)) }")
                return
            }
            if method == "extension" {
                this._write("{ let __arg = (")
                this._emitExpr(args[0])
                this._write(").to_string(); std::path::Path::new(&__arg).extension().and_then(|e| e.to_str()).unwrap_or(\"\").to_string() }")
                return
            }
            if method == "readLines" {
                this._write("match std::fs::read_to_string(&")
                this._emitExpr(args[0])
                this._write(") { Ok(content) => (Some(content.lines().map(|l| l.to_string()).collect::<Vec<String>>()), String::new()), Err(e) => (None, format!(\"File readLines error: {}\", e)) }")
                return
            }
            if method == "writeLines" {
                this._write("match std::fs::write(&")
                this._emitExpr(args[0])
                this._write(", ")
                this._emitExpr(args[1])
                this._write(".join(\"\\n\")) { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"File writeLines error: {}\", e)) }")
                return
            }
        }

        // ── Dir module (7 functions) ──
        if stdlibName == "Dir" {
            if method == "create" {
                this._write("match std::fs::create_dir_all(&")
                this._emitExpr(args[0])
                this._write(") { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"Dir.create error: {}\", e)) }")
                return
            }
            if method == "list" {
                this._write("match std::fs::read_dir(&")
                this._emitExpr(args[0])
                this._write(") { Ok(entries) => { let mut names: Vec<String> = entries.filter_map(|e| e.ok().map(|e| e.file_name().to_string_lossy().to_string())).collect(); names.sort(); (Some(names), String::new()) }, Err(e) => (None, format!(\"Dir.list error: {}\", e)) }")
                return
            }
            if method == "exists" {
                this._write("{ let __arg = (")
                this._emitExpr(args[0])
                this._write(").to_string(); let p = std::path::Path::new(&__arg); p.exists() && p.is_dir() }")
                return
            }
            if method == "isDir" {
                this._write("{ let __arg = (")
                this._emitExpr(args[0])
                this._write(").to_string(); std::path::Path::new(&__arg).is_dir() }")
                return
            }
            if method == "delete" {
                this._write("match std::fs::remove_dir_all(&")
                this._emitExpr(args[0])
                this._write(") { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"Dir.delete error: {}\", e)) }")
                return
            }
            if method == "listRecursive" || method == "walk" {
                this._write("{ fn walk_dir(dir: &std::path::Path, result: &mut Vec<String>, base: &std::path::Path) -> Result<(), std::io::Error> { for entry in std::fs::read_dir(dir)? { let entry = entry?; let path = entry.path(); if let Some(rel) = path.strip_prefix(base).ok().and_then(|p| p.to_str()) { result.push(rel.to_string()); } if path.is_dir() { walk_dir(&path, result, base)?; } } Ok(()) } let __arg = (")
                this._emitExpr(args[0])
                this._write(").to_string(); let base = std::path::Path::new(&__arg); let mut names = Vec::new(); match walk_dir(base, &mut names, base) { Ok(_) => { names.sort(); (Some(names), String::new()) }, Err(e) => (None, format!(\"Dir.walk error: {}\", e)) } }")
                return
            }
        }

        // ── Process module (4 functions) ──
        if stdlibName == "Process" {
            if method == "exec" {
                this._write("{ let __cmd = &")
                this._emitExpr(args[0])
                this._write("; let (__sh, __flag) = if cfg!(windows) { (\"cmd\", \"/C\") } else { (\"sh\", \"-c\") }; match std::process::Command::new(__sh).arg(__flag).arg(__cmd).output() { Ok(output) => { let stdout = String::from_utf8_lossy(&output.stdout).trim().to_string(); let stderr = String::from_utf8_lossy(&output.stderr).trim().to_string(); let combined = if !stdout.is_empty() && !stderr.is_empty() { format!(\"{}{}\", stdout, stderr) } else if !stdout.is_empty() { stdout } else { stderr }; (Some(combined), String::new()) }, Err(e) => (None, format!(\"Process.exec error: {}\", e)) } }")
                return
            }
            if method == "spawn" {
                this._write("{ let __cmd = &")
                this._emitExpr(args[0])
                this._write("; let (__sh, __flag) = if cfg!(windows) { (\"cmd\", \"/C\") } else { (\"sh\", \"-c\") }; match std::process::Command::new(__sh).arg(__flag).arg(__cmd).spawn() { Ok(child) => (Some(child.id() as i64), String::new()), Err(e) => (None, format!(\"Process.spawn error: {}\", e)) } }")
                return
            }
            if method == "pid" {
                this._write("(std::process::id() as i64)")
                return
            }
            if method == "exit" {
                this._write("std::process::exit(")
                this._emitExpr(args[0])
                this._write(" as i32)")
                return
            }
        }

        // ── Sys module ──
        if stdlibName == "Sys" {
            if method == "args" {
                this._write("std::env::args().collect::<Vec<String>>()")
                return
            }
            if method == "env" {
                this._write("std::env::var(")
                this._emitExpr(args[0])
                this._write(").unwrap_or_default()")
                return
            }
            if method == "exit" {
                this._write("std::process::exit(")
                this._emitExpr(args[0])
                this._write(" as i32)")
                return
            }
            if method == "input" {
                // Sys.input(prompt: string): string — read a line from stdin.
                // Prints the prompt without newline, flushes, then reads one line
                // (with the trailing '\n' stripped).
                this._write("{ use std::io::{Write as _, BufRead as _}; print!(\"{}\", ")
                this._emitExpr(args[0])
                this._write("); std::io::stdout().flush().ok(); let mut __ln = String::new(); std::io::stdin().lock().read_line(&mut __ln).ok(); let __ln = __ln.trim_end_matches('\\n').trim_end_matches('\\r').to_string(); __ln }")
                return
            }
            if method == "exe" {
                // Sys.exe(): string — absolute path of the current executable.
                this._write("std::env::current_exe().ok().and_then(|p| p.to_str().map(|s| s.to_string())).unwrap_or_default()")
                return
            }
            if method == "os" {
                // Sys.os(): string — "linux" | "macos" | "windows" | other Rust target_os values.
                this._write("std::env::consts::OS.to_string()")
                return
            }
            if method == "arch" {
                // Sys.arch(): string — "x86_64" | "aarch64" | other Rust target_arch values.
                this._write("std::env::consts::ARCH.to_string()")
                return
            }
        }

        // ── Console module — JS/TS familiarity ──
        if stdlibName == "Console" || stdlibName == "console" {
            if method == "log" || method == "info" {
                this._write("println!(\"{}\", ")
                this._emitExpr(args[0])
                this._write(")")
                return
            }
            if method == "error" || method == "warn" {
                this._write("eprintln!(\"{}\", ")
                this._emitExpr(args[0])
                this._write(")")
                return
            }
            if method == "input" || method == "prompt" {
                // Console.input/prompt(message: string): string — read a line from stdin.
                this._write("{ use std::io::{Write as _, BufRead as _}; print!(\"{}\", ")
                this._emitExpr(args[0])
                this._write("); std::io::stdout().flush().ok(); let mut __ln = String::new(); std::io::stdin().lock().read_line(&mut __ln).ok(); let __ln = __ln.trim_end_matches('\\n').trim_end_matches('\\r').to_string(); __ln }")
                return
            }
        }

        // ── Env module (5 functions) — D.4 PLAN ──
        if stdlibName == "Env" {
            if method == "get" {
                // Env.get(key) -> string (empty if missing). Mirrors Sys.env.
                this._write("std::env::var(")
                this._emitExpr(args[0])
                this._write(").unwrap_or_default()")
                return
            }
            if method == "has" {
                // Env.has(key) -> bool
                this._write("std::env::var(")
                this._emitExpr(args[0])
                this._write(").is_ok()")
                return
            }
            if method == "set" {
                // Env.set(key, value) -> void; SAFETY: process-global mutation.
                this._write("{ unsafe { std::env::set_var(")
                this._emitExpr(args[0])
                this._write(", ")
                this._emitExpr(args[1])
                this._write(") } }")
                return
            }
            if method == "unset" {
                // Env.unset(key) -> void
                this._write("{ unsafe { std::env::remove_var(")
                this._emitExpr(args[0])
                this._write(") } }")
                return
            }
            if method == "all" {
                // Env.all() -> Map<string, string>
                this._write("std::env::vars().collect::<std::collections::HashMap<String, String>>()")
                return
            }
        }

        // ── Path module (7 functions) — D.3 PLAN ──
        if stdlibName == "Path" {
            if method == "join" {
                // Path.join(a, b) -> string
                this._write("std::path::Path::new(&")
                this._emitExpr(args[0])
                this._write(".to_string()).join(&")
                this._emitExpr(args[1])
                this._write(".to_string()).to_string_lossy().to_string()")
                return
            }
            if method == "parent" {
                // Path.parent(p) -> string ("" if no parent)
                this._write("std::path::Path::new(&")
                this._emitExpr(args[0])
                this._write(".to_string()).parent().map(|p| p.to_string_lossy().to_string()).unwrap_or_default()")
                return
            }
            if method == "extension" {
                // Path.extension(p) -> string (no leading dot, "" if none)
                this._write("std::path::Path::new(&")
                this._emitExpr(args[0])
                this._write(".to_string()).extension().and_then(|e| e.to_str()).map(|s| s.to_string()).unwrap_or_default()")
                return
            }
            if method == "basename" {
                // Path.basename(p) -> string
                this._write("std::path::Path::new(&")
                this._emitExpr(args[0])
                this._write(".to_string()).file_name().and_then(|n| n.to_str()).map(|s| s.to_string()).unwrap_or_default()")
                return
            }
            if method == "exists" {
                // Path.exists(p) -> bool
                this._write("std::path::Path::new(&")
                this._emitExpr(args[0])
                this._write(".to_string()).exists()")
                return
            }
            if method == "isAbsolute" {
                // Path.isAbsolute(p) -> bool
                this._write("std::path::Path::new(&")
                this._emitExpr(args[0])
                this._write(".to_string()).is_absolute()")
                return
            }
            if method == "normalize" {
                // Path.normalize(p) -> string (lexical, collapses . and ..)
                this._write("{ let __p = ")
                this._emitExpr(args[0])
                this._write(".to_string(); let __path = std::path::Path::new(&__p); let mut __out = std::path::PathBuf::new(); for __c in __path.components() { match __c { std::path::Component::ParentDir => { __out.pop(); }, std::path::Component::CurDir => {}, __other => { __out.push(__other.as_os_str()); } } } __out.to_string_lossy().to_string() }")
                return
            }
        }

        // ── Config module (5 functions) ──
        if stdlibName == "Config" {
            if method == "load" {
                this._write("{ match std::fs::read_to_string(&")
                this._emitExpr(args[0])
                this._write(") { Ok(content) => { let mut map = std::collections::HashMap::<String, String>::new(); for line in content.lines() { let line = line.trim(); if line.is_empty() || line.starts_with('#') { continue; } if let Some(eq) = line.find('=') { let key = line[..eq].trim().to_string(); let mut val = line[eq+1..].trim().to_string(); if (val.starts_with('\"') && val.ends_with('\"')) || (val.starts_with('\\'') && val.ends_with('\\'')) { val = val[1..val.len()-1].to_string(); } map.insert(key, val); } } (Some(map), String::new()) }, Err(e) => (None, format!(\"Config.load error: {}\", e)) } }")
                return
            }
            if method == "get" {
                this._write("{ let __map = &")
                this._emitExpr(args[0])
                this._write("; let __key = ")
                this._emitExpr(args[1])
                this._write("; match __map.get(&__key) { Some(v) => (Some(v.clone()), String::new()), None => (None, format!(\"Key not found: {}\", __key)) } }")
                return
            }
            if method == "getInt" {
                this._write("{ let __map = &")
                this._emitExpr(args[0])
                this._write("; let __key = ")
                this._emitExpr(args[1])
                this._write("; match __map.get(&__key) { Some(v) => match v.parse::<i64>() { Ok(n) => (Some(n), String::new()), Err(_) => (None, format!(\"Not a number: {}\", v)) }, None => (None, format!(\"Key not found: {}\", __key)) } }")
                return
            }
            if method == "getBool" {
                this._write("{ let __map = &")
                this._emitExpr(args[0])
                this._write("; let __key = ")
                this._emitExpr(args[1])
                this._write("; match __map.get(&__key) { Some(v) => { let lower = v.to_lowercase(); (Some(lower == \"true\" || lower == \"1\" || lower == \"yes\"), String::new()) }, None => (None, format!(\"Key not found: {}\", __key)) } }")
                return
            }
            if method == "getAll" {
                this._write("{ let __src = &")
                this._emitExpr(args[0])
