                this._write("{ let __s = ")
                this._emitExpr(args[0])
                this._write(".to_string(); match chrono::NaiveDateTime::parse_from_str(&__s, \"%Y-%m-%dT%H:%M:%S\").or_else(|_| chrono::NaiveDateTime::parse_from_str(&__s, \"%Y-%m-%d %H:%M:%S\")) { Ok(dt) => (dt, String::new()), Err(e) => (chrono::NaiveDateTime::default(), format!(\"Date.parseIso error: {}\", e)) } }")
                return
            }
        }
        // Regex module
        if stdlibName == "Regex" {
            if method == "isMatch" || method == "test" {
                this._write("regex::Regex::new(&")
                this._emitExpr(args[0])
                this._write(").map(|re| re.is_match(&")
                this._emitExpr(args[1])
                this._write(")).unwrap_or(false)")
                return
            }
            if method == "findAll" {
                this._write("regex::Regex::new(&")
                this._emitExpr(args[0])
                this._write(").map(|re| re.find_iter(&")
                this._emitExpr(args[1])
                this._write(").map(|m| m.as_str().to_string()).collect::<Vec<String>>()).unwrap_or_default()")
                return
            }
            if method == "split" {
                this._write("regex::Regex::new(&")
                this._emitExpr(args[0])
                this._write(").map(|re| re.split(&")
                this._emitExpr(args[1])
                this._write(").map(|s| s.to_string()).collect::<Vec<String>>()).unwrap_or_else(|_| vec![")
                this._emitExpr(args[1])
                this._write(".to_string()])")
                return
            }
            if method == "replace" {
                this._write("{ let __repl = (")
                this._emitExpr(args[2])
                this._write(").to_string(); regex::Regex::new(&")
                this._emitExpr(args[0])
                this._write(").map(|re| re.replace_all(&")
                this._emitExpr(args[1])
                this._write(", __repl.as_str()).to_string()).unwrap_or_else(|_| ")
                this._emitExpr(args[1])
                this._write(".to_string()) }")
                return
            }
        }

        // Enum variant constructor: EnumName.Variant(args) → EnumName::Variant(args)
        // Only when EnumName is a known enum OR the variant is registered.
        // Without this guard, ANY uppercase identifier (e.g. an imported
        // const like MAX_GRADE) gets misemitted as `MAX_GRADE::method(...)`
        // — see m6_diamond regression.
        let isEnumVariant = false
        let enumNameMC = ""
        switch obj {
            Expr.Identifier(name) => {
                if name.length > 0 {
                    let fc = name.charAt(0)
                    if fc >= "A" && fc <= "Z" {
                        let candidateKey = name + "::" + method
                        if this._globalEnums.has(name) or this._enumVariantFields.has(candidateKey) {
                            isEnumVariant = true
                            enumNameMC = name
                        }
                    }
                }
            }
        }
        if isEnumVariant {
            // Look up field names for struct-style variant constructor
            let variantKey = enumNameMC + "::" + method
            if this._enumVariantFields.has(variantKey) {
                let fieldNames = this._enumVariantFields.get(variantKey)
                // Check boxing and optional info
                let fieldBoxed: [bool] = []
                let fieldOptional: [bool] = []
                if this._enumVariantFieldBoxed.has(variantKey) {
                    fieldBoxed = this._enumVariantFieldBoxed.get(variantKey)
                }
                if this._enumVariantFieldOptional.has(variantKey) {
                    fieldOptional = this._enumVariantFieldOptional.get(variantKey)
                }
                this._write(enumNameMC + "::" + method + " { ")
                let mcIdx = 0
                for a in args {
                    if mcIdx > 0 { this._write(", ") }
                    if mcIdx < fieldNames.length {
                        this._write(fieldNames[mcIdx] + ": ")
                    }
                    // Check if field is boxed or optional
                    let isBoxed = false
                    if mcIdx < fieldBoxed.length {
                        isBoxed = fieldBoxed[mcIdx]
                    }
                    let isOptional = false
                    if mcIdx < fieldOptional.length {
                        isOptional = fieldOptional[mcIdx]
                    }
                    // Check if arg is already null (None) — don't wrap with Some
                    let isNullArg = this._isNullExpr(a)
                    if isBoxed && isOptional {
                        if isNullArg {
                            this._write("None")
                        } else {
                            this._write("Some(Box::new(")
                            this._emitClonedArg(a)
                            this._write("))")
                        }
                    } else if isBoxed {
                        this._write("Box::new(")
                        this._emitClonedArg(a)
                        this._write(")")
                    } else if isOptional {
                        if isNullArg {
                            this._write("None")
                        } else {
                            this._write("Some(")
                            this._emitClonedArg(a)
                            this._write(")")
                        }
                    } else {
                        this._emitClonedArg(a)
                    }
                    mcIdx += 1
                }
                this._write(" }")
            } else {
                // Fallback: tuple-style (for unknown variants or unit variants)
                this._write(enumNameMC + "::" + method + "(")
                let mcIdx = 0
                for a in args {
                    if mcIdx > 0 { this._write(", ") }
                    this._emitExpr(a)
                    mcIdx += 1
                }
                this._write(")")
            }
            return
        }

        let objTag = this._getExprTypeName(obj)

        // B146: detect if `obj` is an instance of a user class.
        // If so, force generic dispatch — don't promote to array/string/etc.
        // (User class instances are typed as `TypeRef.Simple(ClassName)`, never
        // as Array/Map/Set/etc., so any array-method-name lookup is wrong.)
        let isUserClassInstance = false
        switch obj {
            Expr.Identifier(uName) => {
                if uName == "this" {
                    if this._currentClassName != "" {
                        isUserClassInstance = true
                    }
                } else {
                    let uType = this._lookupVarTypeRef(uName)
                    switch uType {
                        TypeRef.Simple(cn) => {
                            if cn != "" and this._typeCtx.classes.has(cn) {
                                isUserClassInstance = true
                            }
                        }
                    }
                }
            }
        }

        // Classify method target without consuming args
        let target = "generic"
        if isUserClassInstance {
            // skip — leave target as "generic" so we hit _emitGenericMethodCall
        } else if objTag == "string" && this._isKnownStringMethod(method) {
            target = "string"
        } else if objTag == "array" && this._isKnownArrayMethod(method) {
            target = "array"
        } else if objTag == "map" && this._isKnownMapMethod(method) {
            target = "map"
        } else if objTag == "set" && this._isKnownSetMethod(method) {
            target = "set"
        } else if this._isKnownDateMethod(method) {
            target = "date"
        }
        // Secondary dispatch: if target is still generic but method is a known array-only method,
        // assume array (type detection often fails for array variables)
        // Exclude methods that overlap with Map/Set/user/String (insert, remove, has, get, set, forEach, isEmpty, contains, clear, count, slice, indexOf)
        if not isUserClassInstance && target == "generic" && this._isKnownArrayMethod(method) {
            if method != "insert" && method != "remove" && method != "has" && method != "get" && method != "set" && method != "forEach" && method != "isEmpty" && method != "contains" && method != "clear" && method != "count" && method != "slice" && method != "indexOf" {
                target = "array"
            }
        }
        // Same for set methods — if generic and method is a known set-only method, assume set
        // Exclude common user-defined method names like 'add', 'size', 'count'.
        if not isUserClassInstance && target == "generic" && this._isKnownSetMethod(method) {
            if method != "has" && method != "delete" && method != "clear" && method != "values" && method != "forEach" && method != "isEmpty" && method != "add" && method != "size" && method != "count" {
                target = "set"
            }
        }
        // Same for string-only methods — if generic and method is a clearly
        // string-only operation (parsing, char-iteration, etc.), assume string.
        if not isUserClassInstance && target == "generic" {
            if method == "toInt" || method == "toFloat" || method == "chars" || method == "bytes" || method == "padStart" || method == "padEnd" || method == "removePrefix" || method == "removeSuffix" || method == "trimStart" || method == "trimEnd" || method == "capitalize" || method == "isBlank" || method == "countMatches" || method == "toUpperCase" || method == "toLowerCase" {
                target = "string"
            }
        }
        // Tertiary: if still generic, try runtime variable tracking for Map/String fallback
        if not isUserClassInstance && target == "generic" {
            let objIdName = ""
            switch obj {
                Expr.Identifier(oName) => { objIdName = this._sanitizeName(oName) }
            }
            if objIdName != "" {
                if this._mapVars.has(objIdName) && this._isKnownMapMethod(method) { target = "map" }
                else if this._setVars.has(objIdName) && this._isKnownSetMethod(method) { target = "set" }
                else if this._stringVars.has(objIdName) && this._isKnownStringMethod(method) { target = "string" }
            }
        }

        // Dispatch — args consumed in exactly ONE branch
        if target == "string" {
            this._emitStringMethod(obj, method, args)
        } else if target == "array" {
            this._emitArrayMethod(obj, method, args)
        } else if target == "map" {
            this._emitMapMethod(obj, method, args)
        } else if target == "set" {
            this._emitSetMethod(obj, method, args)
        } else if target == "date" {
            this._emitDateMethod(obj, method, args)
        } else {
            this._emitGenericMethodCall(obj, method, args)
        }
        // Reset the self.field auto-clone suppression after dispatch
        if isSelfField {
            this._inAssignTarget = false
        }
        this._suppressIndexElemClone = savedSuppressIdx
    }
}

// Sentinel symbol so main.liva can import this module and bring its
// `extend RustEmitter { ... }` block into the compile graph.
codegenMethodCallExtensionLoaded(): bool { return true }
