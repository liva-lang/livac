                            this._write("None")
                        } else {
                            this._write("Some(Box::new(")
                            this._emitClonedArg(a)
                            this._write("))")
                        }
                    } else if isBoxed {
                        this._write("Box::new(")
                        this._emitClonedArg(a)
                        this._write(")")
                    } else if isOptional {
                        if isNullArg {
                            this._write("None")
                        } else {
                            this._write("Some(")
                            this._emitClonedArg(a)
                            this._write(")")
                        }
                    } else {
                        this._emitClonedArg(a)
                    }
                    mcIdx += 1
                }
                this._write(" }")
            } else {
                // Fallback: tuple-style (for unknown variants or unit variants)
                this._write(enumNameMC + "::" + method + "(")
                let mcIdx = 0
                for a in args {
                    if mcIdx > 0 { this._write(", ") }
                    this._emitExpr(a)
                    mcIdx += 1
                }
                this._write(")")
            }
            return
        }

        let objTag = this._getExprTypeName(obj)

        // B146: detect if `obj` is an instance of a user class.
        // If so, force generic dispatch — don't promote to array/string/etc.
        // (User class instances are typed as `TypeRef.Simple(ClassName)`, never
        // as Array/Map/Set/etc., so any array-method-name lookup is wrong.)
        let isUserClassInstance = false
        switch obj {
            Expr.Identifier(uName) => {
                if uName == "this" {
                    if this._currentClassName != "" {
                        isUserClassInstance = true
                    }
                } else {
                    let uType = this._lookupVarTypeRef(uName)
                    switch uType {
                        TypeRef.Simple(cn) => {
                            if cn != "" and this._typeCtx.classes.has(cn) {
                                isUserClassInstance = true
                            }
                        }
                    }
                }
            }
        }

        // Classify method target without consuming args
        let target = "generic"
        if isUserClassInstance {
            // skip — leave target as "generic" so we hit _emitGenericMethodCall
        } else if objTag == "string" && this._isKnownStringMethod(method) {
            target = "string"
        } else if objTag == "array" && this._isKnownArrayMethod(method) {
            target = "array"
        } else if objTag == "map" && this._isKnownMapMethod(method) {
            target = "map"
        } else if objTag == "set" && this._isKnownSetMethod(method) {
            target = "set"
        } else if this._isKnownDateMethod(method) {
            target = "date"
        }
        // Secondary dispatch: if target is still generic but method is a known array-only method,
        // assume array (type detection often fails for array variables)
        // Exclude methods that overlap with Map/Set/user/String (insert, remove, has, get, set, forEach, isEmpty, contains, clear, count, slice, indexOf)
        if not isUserClassInstance && target == "generic" && this._isKnownArrayMethod(method) {
            if method != "insert" && method != "remove" && method != "has" && method != "get" && method != "set" && method != "forEach" && method != "isEmpty" && method != "contains" && method != "clear" && method != "count" && method != "slice" && method != "indexOf" {
                target = "array"
            }
        }
        // Same for set methods — if generic and method is a known set-only method, assume set
        // Exclude common user-defined method names like 'add', 'size', 'count'.
        if not isUserClassInstance && target == "generic" && this._isKnownSetMethod(method) {
            if method != "has" && method != "delete" && method != "clear" && method != "values" && method != "forEach" && method != "isEmpty" && method != "add" && method != "size" && method != "count" {
                target = "set"
            }
        }
        // Same for string-only methods — if generic and method is a clearly
        // string-only operation (parsing, char-iteration, etc.), assume string.
        if not isUserClassInstance && target == "generic" {
            if method == "toInt" || method == "toFloat" || method == "chars" || method == "bytes" || method == "padStart" || method == "padEnd" || method == "removePrefix" || method == "removeSuffix" || method == "trimStart" || method == "trimEnd" || method == "capitalize" || method == "isBlank" || method == "countMatches" || method == "toUpperCase" || method == "toLowerCase" {
                target = "string"
            }
        }
        // Tertiary: if still generic, try runtime variable tracking for Map/String fallback
        if not isUserClassInstance && target == "generic" {
            let objIdName = ""
            switch obj {
                Expr.Identifier(oName) => { objIdName = this._sanitizeName(oName) }
            }
            if objIdName != "" {
                if this._mapVars.has(objIdName) && this._isKnownMapMethod(method) { target = "map" }
                else if this._setVars.has(objIdName) && this._isKnownSetMethod(method) { target = "set" }
                else if this._stringVars.has(objIdName) && this._isKnownStringMethod(method) { target = "string" }
            }
        }

        // Dispatch — args consumed in exactly ONE branch
        if target == "string" {
            this._emitStringMethod(obj, method, args)
        } else if target == "array" {
            this._emitArrayMethod(obj, method, args)
        } else if target == "map" {
            this._emitMapMethod(obj, method, args)
        } else if target == "set" {
            this._emitSetMethod(obj, method, args)
        } else if target == "date" {
            this._emitDateMethod(obj, method, args)
        } else {
            this._emitGenericMethodCall(obj, method, args)
        }
        // Reset the self.field auto-clone suppression after dispatch
        if isSelfField {
            this._inAssignTarget = false
        }
        this._suppressIndexElemClone = savedSuppressIdx
    }

    _isKnownStringMethod(m: string): bool { return isKnownStringMethod(m) }

    _isKnownArrayMethod(m: string): bool { return isKnownArrayMethod(m) }

    _isKnownMapMethod(m: string): bool { return isKnownMapMethod(m) }

    _isKnownSetMethod(m: string): bool { return isKnownSetMethod(m) }

    _isKnownDateMethod(m: string): bool { return isKnownDateMethod(m) }

    // -- Date methods → Rust equivalents (chrono) --

    _emitDateMethod(obj: Expr, method: string, args: [Expr]) {
        if method == "format" && args.length >= 1 {
            this._emitExpr(obj)
            this._write(".format(&")
            this._emitExpr(args[0])
            this._write(".replace(\"YYYY\", \"%Y\").replace(\"MM\", \"%m\").replace(\"DD\", \"%d\").replace(\"HH\", \"%H\").replace(\"mm\", \"%M\").replace(\"ss\", \"%S\")).to_string()")
            return
        }
        if method == "add" && args.length >= 2 {
            this._write("{ let __liva_unit = (")
            this._emitExpr(args[1])
            this._write(").to_string(); let __liva_n = ")
            this._emitExpr(args[0])
            this._write(" as i64; let __liva_dur = match __liva_unit.as_str() { \"days\" => chrono::Duration::days(__liva_n), \"hours\" => chrono::Duration::hours(__liva_n), \"minutes\" => chrono::Duration::minutes(__liva_n), \"seconds\" => chrono::Duration::seconds(__liva_n), \"weeks\" => chrono::Duration::weeks(__liva_n), _ => chrono::Duration::days(__liva_n), }; ")
            this._emitExpr(obj)
            this._write(" + __liva_dur }")
            return
        }
        if method == "diff" && args.length >= 2 {
            this._write("{ let __liva_diff = ")
            this._emitExpr(obj)
            this._write(".signed_duration_since(")
            this._emitExpr(args[0])
            this._write("); let __liva_unit = (")
            this._emitExpr(args[1])
            this._write(").to_string(); (match __liva_unit.as_str() { \"days\" => __liva_diff.num_days(), \"hours\" => __liva_diff.num_hours(), \"minutes\" => __liva_diff.num_minutes(), \"seconds\" => __liva_diff.num_seconds(), \"weeks\" => __liva_diff.num_weeks(), \"years\" => __liva_diff.num_days() / 365, \"months\" => __liva_diff.num_days() / 30, _ => __liva_diff.num_days(), }) as i32 }")
            return
        }
        // Fallback — user method on a Date-like object
        let sanitizedMethod = this._sanitizeName(method)
        this._emitExpr(obj)
        this._write($".{sanitizedMethod}(")
        let aIdx = 0
        for a in args {
            if aIdx > 0 { this._write(", ") }
            this._emitExpr(a)
            aIdx += 1
        }
        this._write(")")
    }

    // -- Helper: emit `obj.<mName>(...) or default` as
    // -- `obj.get(k).cloned().unwrap_or(default)` for collections
    // -- whose `get`/`first`/`last`/`find` returns Option<V>.

    _emitOptionGetWithDefault(obj: Expr, mName: string, args: [Expr], defaultExpr: Expr) {
        this._emitExpr(obj)
        if mName == "get" {
            this._write(".get(")
            if args.length > 0 { this._emitMapKeyArg(args[0]) }
            this._write(").cloned().unwrap_or(")
        } else {
            this._write(".")
            this._write(mName)
            this._write("().cloned().unwrap_or(")
        }
        this._emitExpr(defaultExpr)
        this._write(")")
    }

    // -- Generic fallback for user-defined methods + unknown types --

    _emitGenericMethodCall(obj: Expr, method: string, args: [Expr]) {
        // Use type detection for Map dispatch
        let objTag = this._getExprTypeName(obj)

        // Detect user-class receiver (TypeRef.Simple matching a registered class).
        // When present, skip Map-style default dispatch for `get`/`has` —
        // the call should be a plain user-method call instead.
        let isUserClassRecv = false
        switch obj {
            Expr.Identifier(uName) => {
                if uName == "this" || uName == "self" {
                    if this._currentClassName != "" { isUserClassRecv = true }
                } else {
                    let uType = this._lookupVarTypeRef(uName)
                    switch uType {
                        TypeRef.Simple(cn) => {
                            if cn != "" && this._typeCtx.classes.has(cn) {
                                isUserClassRecv = true
                            }
                        }
                    }
                }
            }
        }

        // Map/Set .get() with type detection or runtime tracking
        if method == "get" && not isUserClassRecv {
            let isMap = objTag == "map"
            if not isMap {
                let getObjIdName = ""
                switch obj {
                    Expr.Identifier(gn) => { getObjIdName = this._sanitizeName(gn) }
                }
                if getObjIdName != "" && this._mapVars.has(getObjIdName) {
                    isMap = true
                }
            }
            if isMap {
                this._emitExpr(obj)
                this._write(".get(")
                if args.length > 0 { this._emitMapKeyArg(args[0]) }
                this._write(").cloned().unwrap()")
            } else if objTag == "set" || objTag == "array" || objTag == "string" {
                this._emitExpr(obj)
                this._write(".get(")
                let gi = 0
                for ga in args {
                    if gi > 0 { this._write(", ") }
                    this._emitExpr(ga)
                    gi += 1
                }
                this._write(")")
            } else {
                // Default: assume Map-style get for unknown types
                this._emitExpr(obj)
                this._write(".get(")
                if args.length > 0 { this._emitMapKeyArg(args[0]) }
                this._write(").cloned().unwrap()")
            }
            return
        }
        // Map/Set .has() with type detection or runtime tracking
        if method == "has" && not isUserClassRecv {
            let isMap = objTag == "map"
            if not isMap {
                let objIdName = ""
                switch obj {
                    Expr.Identifier(hn) => { objIdName = this._sanitizeName(hn) }
                }
                if objIdName != "" && this._mapVars.has(objIdName) {
                    isMap = true
                }
            }
            if isMap {
                this._emitExpr(obj)
                this._write(".contains_key(")
                if args.length > 0 { this._emitMapKeyArg(args[0]) }
                this._write(")")
            } else if objTag == "set" {
                this._emitExpr(obj)
                this._write(".contains(")
                if args.length > 0 { this._emitMapKeyArg(args[0]) }
                this._write(")")
            } else {
                // Default: assume Map (has() is predominantly used on Maps)
                this._emitExpr(obj)
                this._write(".contains_key(")
                if args.length > 0 { this._emitMapKeyArg(args[0]) }
                this._write(")")
            }
            return
        }
        // .length/.len — works for any collection
        if method == "length" || method == "len" {
            this._write("(")
            this._emitExpr(obj)
            this._write(".len() as i32)")
            return
        }
        // .as_array() on JSON Values — disambiguate from native Value::as_array
        // (which returns Option<&Vec<Value>>) by routing through the
        // JsonValueExt trait method that returns Vec<Value> directly.
        if method == "as_array" {
            this._emitExpr(obj)
            this._write(".as_array_owned()")
            return
        }
        // .forEach on a tracked JSON Value variable — Value is not Iterator,
        // so route through the trait helper that returns Vec<Value>.
        if method == "forEach" {
            let jvName = ""
            switch obj {
                Expr.Identifier(jn) => { jvName = this._sanitizeName(jn) }
            }
            if jvName != "" && this._jsonValueVars.has(jvName) {
                this._emitExpr(obj)
                this._write(".as_array_owned().into_iter().for_each(")
                if args.length > 0 { this._emitExpr(args[0]) }
                this._write(")")
                return
            }
        }

        // String methods that require &str args — handle in generic fallback
        // These methods are common on String but type detection may fail for local vars
        if method == "contains" || method == "startsWith" || method == "endsWith" || method == "trim" || method == "trimStart" || method == "trimEnd" {
            let rustMethod = ""
            if method == "startsWith" { rustMethod = "starts_with" }
            else if method == "endsWith" { rustMethod = "ends_with" }
            else if method == "trimStart" { rustMethod = "trim_start" }
            else if method == "trimEnd" { rustMethod = "trim_end" }
            else if method == "contains" { rustMethod = "contains" }
            else if method == "trim" { rustMethod = "trim" }
            this._emitExpr(obj)
            if method == "trim" || method == "trimStart" || method == "trimEnd" {
                this._write($".{rustMethod}().to_string()")
            } else {
                this._write($".{rustMethod}(")
                if args.length > 0 { this._emitRefArg(args[0]) }
                this._write(")")
            }
            return
        }
        // split — collect into Vec for compatibility
        if method == "split" {
            this._emitExpr(obj)
            this._write(".split(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(").map(|s| s.to_string()).collect::<Vec<_>>()")
            return
        }
        // keys/values — collect into Vec (Map methods)
        if method == "keys" {
            this._emitExpr(obj)
            this._write(".keys().cloned().collect::<Vec<_>>()")
            return
        }
        if method == "values" {
            this._emitExpr(obj)
            this._write(".values().cloned().collect::<Vec<_>>()")
            return
        }
        if method == "replace" || method == "replaceAll" {
            this._emitExpr(obj)
            this._write(".replace(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            if args.length > 1 {
                this._write(", ")
                this._emitRefArg(args[1])
            }
            this._write(")")
            return
        }
        // Case/char methods — correct snake_case for Rust
        if method == "toLowerCase" || method == "toUpperCase" {
            this._emitExpr(obj)
            if method == "toLowerCase" { this._write(".to_lowercase().to_string()") }
            else { this._write(".to_uppercase().to_string()") }
            return
        }
        if method == "charAt" {
            this._emitExpr(obj)
            this._write(".chars().nth((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize).map(|c| c.to_string()).unwrap_or_default()")
            return
        }
        if method == "substring" {
            // C.10: char-indexed (UTF-8 safe).
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); let __a = (")
            if args.length > 0 { this._emitExpr(args[0]) } else { this._write("0") }
            this._write(") as usize; ")
            if args.length > 1 {
                this._write("let __b = (")
                this._emitExpr(args[1])
                this._write(") as usize; __s.chars().skip(__a).take(__b.saturating_sub(__a)).collect::<String>() }")
            } else {
                this._write("__s.chars().skip(__a).collect::<String>() }")
            }
            return
        }
        if method == "indexOf" {
            this._emitExpr(obj)
            this._write(".find(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(").map(|i| i as i32).unwrap_or(-1)")
            return
        }
        // slice — default to string semantics when type unknown.
        // C.10: char-indexed (UTF-8 safe).
        if method == "slice" {
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); let __a = (")
            if args.length > 0 { this._emitExpr(args[0]) } else { this._write("0") }
            this._write(") as usize; ")
            if args.length > 1 {
                this._write("let __b = (")
                this._emitExpr(args[1])
                this._write(") as usize; __s.chars().skip(__a).take(__b.saturating_sub(__a)).collect::<String>() }")
            } else {
                this._write("__s.chars().skip(__a).collect::<String>() }")
            }
            return
        }

        // Catch-all: user-defined method → obj.method(args...)
        let sanitizedMethod = this._sanitizeName(method)
        this._emitExpr(obj)
        this._write($".{sanitizedMethod}(")
        // Phase 8.5: resolve callee for borrowed-param lookup on self methods
        let methodCalleeForBorrow = ""
        switch obj {
            Expr.Identifier(oName) => {
                if oName == "this" && this._currentClassName != "" {
                    methodCalleeForBorrow = $"{this._currentClassName}.{sanitizedMethod}"
                }
            }
        }
        let aIdx = 0
        for a in args {
            if aIdx > 0 { this._write(", ") }
            let bKey = $"{methodCalleeForBorrow}:{aIdx}"
            if methodCalleeForBorrow != "" && this._borrowedParamIndices.has(bKey) {
                if this._borrowedParamMutIndices.has(bKey) {
                    this._emitMutBorrowedArg(a)
                } else {
                    this._emitBorrowedArg(a)
                }
            } else {
                this._emitClonedArg(a)
            }
            aIdx += 1
        }
        this._write(")")
    }

    // -- String methods → Rust equivalents --

    _emitStringMethod(obj: Expr, method: string, args: [Expr]): bool {
        if method == "contains" {
            this._emitExpr(obj)
            this._write(".contains(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "replace" {
            this._emitExpr(obj)
            this._write(".replace(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            if args.length > 1 {
                this._write(", ")
                this._emitRefArg(args[1])
            }
            this._write(")")
            return true
        }
        if method == "replaceAll" {
            this._emitExpr(obj)
            this._write(".replace(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            if args.length > 1 {
                this._write(", ")
                this._emitRefArg(args[1])
            }
            this._write(")")
            return true
        }
        if method == "split" {
            this._emitExpr(obj)
            this._write(".split(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(").map(|s| s.to_string()).collect::<Vec<String>>()")
            return true
        }
        if method == "trim" {
            this._emitExpr(obj)
            this._write(".trim().to_string()")
            return true
        }
        if method == "trimStart" {
            this._emitExpr(obj)
            this._write(".trim_start().to_string()")
            return true
        }
        if method == "trimEnd" {
            this._emitExpr(obj)
            this._write(".trim_end().to_string()")
            return true
        }
        if method == "toUpperCase" {
            this._emitExpr(obj)
            this._write(".to_uppercase()")
            return true
        }
        if method == "toLowerCase" {
            this._emitExpr(obj)
            this._write(".to_lowercase()")
            return true
        }
        if method == "startsWith" {
            this._emitExpr(obj)
            this._write(".starts_with(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "endsWith" {
            this._emitExpr(obj)
            this._write(".ends_with(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "charAt" {
            this._emitExpr(obj)
            this._write(".chars().nth((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize).map(|c| c.to_string()).unwrap_or_default()")
            return true
        }
        if method == "substring" {
            // C.10: char-indexed (UTF-8 safe).
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); let __a = (")
            if args.length > 0 { this._emitExpr(args[0]) } else { this._write("0") }
            this._write(") as usize; ")
            if args.length > 1 {
                this._write("let __b = (")
                this._emitExpr(args[1])
                this._write(") as usize; __s.chars().skip(__a).take(__b.saturating_sub(__a)).collect::<String>() }")
            } else {
                this._write("__s.chars().skip(__a).collect::<String>() }")
            }
            return true
        }
        if method == "indexOf" {
            if args.length >= 2 {
                this._write("{ let __s = ")
                this._emitExpr(obj)
                this._write(".clone(); let __from = (")
                this._emitExpr(args[1])
                this._write(") as usize; if __from >= __s.len() { -1i32 } else { __s[__from..].find(")
                this._emitRefArg(args[0])
                this._write(").map(|i| (i + __from) as i32).unwrap_or(-1) } }")
                return true
            }
            this._emitExpr(obj)
            this._write(".find(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(").map(|i| i as i32).unwrap_or(-1)")
            return true
        }
        if method == "lastIndexOf" {
            if args.length >= 2 {
                this._write("{ let __s = ")
                this._emitExpr(obj)
                this._write(".clone(); let __to = (")
                this._emitExpr(args[1])
                this._write(") as usize; let __end = if __to > __s.len() { __s.len() } else { __to }; __s[..__end].rfind(")
                this._emitRefArg(args[0])
                this._write(").map(|i| i as i32).unwrap_or(-1) }")
                return true
            }
            this._emitExpr(obj)
            this._write(".rfind(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(").map(|i| i as i32).unwrap_or(-1)")
            return true
        }
        if method == "repeat" {
            this._emitExpr(obj)
            this._write(".repeat((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize)")
            return true
        }
        if method == "isEmpty" {
            this._emitExpr(obj)
            this._write(".is_empty()")
            return true
        }
        if method == "reverse" {
            this._emitExpr(obj)
            this._write(".chars().rev().collect::<String>()")
            return true
        }
        if method == "toInt" {
            this._emitExpr(obj)
            this._write(".parse::<i32>().unwrap_or(0)")
            return true
        }
        if method == "toFloat" {
            this._emitExpr(obj)
            this._write(".parse::<f64>().unwrap_or(0.0)")
            return true
        }
        if method == "toString" {
            this._emitExpr(obj)
            this._write(".to_string()")
            return true
        }
        if method == "chars" {
            this._emitExpr(obj)
            this._write(".chars().map(|c| c.to_string()).collect::<Vec<String>>()")
            return true
        }
        if method == "bytes" {
            // bytes() -> Vec<i32> with raw UTF-8 byte values
            this._emitExpr(obj)
            this._write(".bytes().map(|b| b as i32).collect::<Vec<i32>>()")
            return true
        }
        if method == "slice" {
            // C.10: char-indexed (UTF-8 safe).
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); let __a = (")
            if args.length > 0 { this._emitExpr(args[0]) } else { this._write("0") }
            this._write(") as usize; ")
            if args.length > 1 {
                this._write("let __b = (")
                this._emitExpr(args[1])
                this._write(") as usize; __s.chars().skip(__a).take(__b.saturating_sub(__a)).collect::<String>() }")
            } else {
                this._write("__s.chars().skip(__a).collect::<String>() }")
            }
            return true
        }
        if method == "capitalize" {
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); let mut __c = __s.chars(); match __c.next() { None => String::new(), Some(__f) => __f.to_uppercase().to_string() + __c.as_str() } }")
            return true
        }
        if method == "countMatches" {
            this._emitExpr(obj)
            this._write(".matches(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(").count() as i32")
            return true
        }
        if method == "padStart" {
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); let __len = (")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize; if __s.len() >= __len { __s.to_string() } else { ")
            if args.length > 1 {
                this._emitExpr(args[1])
            } else {
                this._write("\" \"")
            }
            this._write(".repeat(__len - __s.len()) + __s } }")
            return true
        }
        if method == "padEnd" {
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); let __len = (")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize; if __s.len() >= __len { __s.to_string() } else { __s.to_string() + &")
            if args.length > 1 {
                this._emitExpr(args[1])
            } else {
                this._write("\" \"")
            }
            this._write(".repeat(__len - __s.len()) } }")
            return true
        }
        if method == "isBlank" {
            this._emitExpr(obj)
            this._write(".trim().is_empty()")
            return true
        }
        if method == "truncate" {
            this._emitExpr(obj)
            this._write(".chars().take((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize).collect::<String>()")
            return true
        }
        if method == "removePrefix" {
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); match __s.strip_prefix(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(") { Some(r) => r.to_string(), None => __s.to_string() } }")
            return true
        }
        if method == "removeSuffix" {
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); match __s.strip_suffix(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(") { Some(r) => r.to_string(), None => __s.to_string() } }")
            return true
        }
        // Not a known string method
        return false
    }

    // -- Helper: emit iterator prefix, detecting .par() chains --
    _emitIterPrefix(obj: Expr, withCloned: bool) {
        // Phase 10.3: if obj is itself a chainable iterator method, emit it
        // as a bare iterator (no .iter().cloned() prefix, no .collect() suffix)
        // so the new method extends the same iterator chain.
        let isChain = false
        switch obj {
            Expr.MethodCall(_, m2, _) => {
                if m2 == "map" || m2 == "filter" || m2 == "flatMap" {
                    isChain = true
                }
            }
        }
        if isChain {
            let savedChain = this._inIterChain
            this._inIterChain = true
            this._emitExpr(obj)
            this._inIterChain = savedChain
            // Already an iterator — no .iter() / .copied() needed.
            return
        }

        // Check if obj is arr.par() → use par_iter instead of iter
        let isPar = false
        switch obj {
            Expr.MethodCall(inner, m, _) => {
                if m == "par" {
                    isPar = true
                    this._emitExpr(inner)
                }
            }
        }
        if not isPar {
            this._emitExpr(obj)
        }
        if isPar {
            this._write(".par_iter()")
        } else {
            this._write(".iter()")
        }
        if withCloned {
            // Phase 9.6: emit .copied() for Copy element types (LLVM inlines
            // trivially; semantically identical to .cloned() for Copy).
            let elemType = this._getArrayElemTypeRef(obj)
            if this._isCopyType(elemType) {
                this._write(".copied()")
            } else {
                this._write(".cloned()")
            }
        }
    }

    // -- Array methods → Rust equivalents --

    _emitArrayMethod(obj: Expr, method: string, args: [Expr]): bool {
        // Phase 10.4: capture statement-position flag and clear it for nested
        // expression emissions (only sort/reverse/reversed consult it).
        let isStmtCtx = this._inExprStmt
        this._inExprStmt = false
        if method == "push" {
            this._emitExpr(obj)
            this._write(".push(")
            if args.length > 0 { this._emitClonedArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "pop" {
            this._emitExpr(obj)
            this._write(".pop().expect(\"pop from empty array\")")
            return true
        }
        if method == "join" {
            this._emitExpr(obj)
            this._write(".join(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "reverse" {
            // B147: in expression context, emit a block returning the reversed Vec.
            // (`Vec::reverse` is mutating and returns `()`, which fails when used
            // as an expression like `let asc = desc.reverse()`.)
            if isStmtCtx {
                this._emitExpr(obj)
                this._write(".reverse()")
                return true
            }
            let useMoveR = this._canMoveIdent(obj)
            this._write("{ let mut __v = ")
            this._emitExpr(obj)
            if useMoveR {
                this._write("; __v.reverse(); __v }")
            } else {
                this._write(".clone(); __v.reverse(); __v }")
            }
            return true
        }
        if method == "reversed" {
            // Phase 10.4: in statement position, emit `obj.reverse()` directly
            // (mutates in place — block-expression result is discarded anyway).
            if isStmtCtx {
                this._emitExpr(obj)
                this._write(".reverse()")
                return true
            }
            // Phase 10.4: move when single-use + declaredInLoop
            let useMove = this._canMoveIdent(obj)
            this._write("{ let mut __v = ")
            this._emitExpr(obj)
            if useMove {
                this._write("; __v.reverse(); __v }")
            } else {
                this._write(".clone(); __v.reverse(); __v }")
            }
            return true
        }
        // arr.sortBy(fn) — sort by key extraction function (Liva idiom).
        // Bootstrap parity: emit a closure that re-evaluates the key
        // extractor for both compare sides, since sort_by requires Ord
        // on the cmp result rather than on the key directly.
        if method == "sortBy" && args.length > 0 {
            let isLamSB = false
            switch args[0] {
                Expr.Lambda(_) => { isLamSB = true }
            }
            if isLamSB {
                switch args[0] {
                    Expr.Lambda(lamSB) => {
                        let paramSB = "__x"
                        for lp in lamSB.params {
                            switch lp.pattern {
                                BindingPattern.Identifier(pn) => { paramSB = this._sanitizeName(pn) }
                            }
                            break
                        }
                        this._write("{ let mut __v = ")
                        this._emitExpr(obj)
                        this._write(".clone(); __v.sort_by(|__a, __b| { let " + paramSB + " = (*__a).clone(); let __ka = ")
                        this._emitLambdaBodyInline(lamSB)
                        this._write("; let " + paramSB + " = (*__b).clone(); let __kb = ")
                        this._emitLambdaBodyInline(lamSB)
                        this._write("; __ka.partial_cmp(&__kb).unwrap_or(std::cmp::Ordering::Equal) }); __v }")
                    }
                }
                return true
            }
        }
        // arr.groupBy(fn) — group by key extractor → HashMap<K, Vec<V>>.
        if method == "groupBy" && args.length > 0 {
            let isLamGB = false
            switch args[0] {
                Expr.Lambda(_) => { isLamGB = true }
            }
            if isLamGB {
                switch args[0] {
                    Expr.Lambda(lamGB) => {
                        let paramGB = "__x"
                        for lp in lamGB.params {
                            switch lp.pattern {
                                BindingPattern.Identifier(pn) => { paramGB = this._sanitizeName(pn) }
                            }
                            break
                        }
                        this._write("{ let mut __m: std::collections::HashMap<_, Vec<_>> = std::collections::HashMap::new(); for __item in ")
                        this._emitExpr(obj)
                        this._write(".iter() { let " + paramGB + " = (*__item).clone(); let __key = ")
                        this._emitLambdaBodyInline(lamGB)
                        this._write("; __m.entry(__key).or_insert_with(Vec::new).push((*__item).clone()); } __m }")
                    }
                }
                return true
            }
        }
        if method == "sort" {
            // Phase 10.4: in statement position, emit `obj.sort()` directly so the
            // user's `arr.sort()` mutates in place — no clone, no temp Vec.
            if isStmtCtx {
                let elemTypeS = this._getArrayElemTypeRef(obj)
                let tagS = this._typeRefToTag(elemTypeS)
                this._emitExpr(obj)
                if tagS == "number" || tagS == "bool" || tagS == "char" {
                    this._write(".sort()")
                } else {
                    this._write(".sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal))")
                }
                return true
            }
            // Phase 9.5: use .sort() for primitive Copy types (avoids partial_cmp overhead)
            // Phase 10.4: move (no clone) when obj is an Identifier that is single-use
            // and declared inside a loop (each iteration is a fresh binding).
            let elemType = this._getArrayElemTypeRef(obj)
            let tag = this._typeRefToTag(elemType)
            let useMove = this._canMoveIdent(obj)
            this._write("{ let mut __v = ")
            this._emitExpr(obj)
            if useMove {
                if tag == "number" || tag == "bool" || tag == "char" {
                    this._write("; __v.sort(); __v }")
                } else {
                    this._write("; __v.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal)); __v }")
                }
            } else {
                if tag == "number" || tag == "bool" || tag == "char" {
                    this._write(".clone(); __v.sort(); __v }")
                } else {
                    this._write(".clone(); __v.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal)); __v }")
                }
            }
            return true
        }
        if method == "isEmpty" {
            this._emitExpr(obj)
            this._write(".is_empty()")
            return true
        }
        if method == "contains" {
            this._emitExpr(obj)
            this._write(".contains(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "remove" {
            this._emitExpr(obj)
            this._write(".remove((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize)")
            return true
        }
        if method == "insert" {
            this._emitExpr(obj)
            this._write(".insert((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize, ")
            if args.length > 1 { this._emitExpr(args[1]) }
            this._write(")")
            return true
        }
        if method == "first" {
            this._emitExpr(obj)
            // Phase 9.3: .copied() for Copy element types
            let elemType = this._getArrayElemTypeRef(obj)
            if this._isCopyType(elemType) {
                this._write(".first().copied().unwrap()")
            } else {
                this._write(".first().cloned().unwrap()")
            }
            return true
        }
        if method == "last" {
            this._emitExpr(obj)
            let elemType = this._getArrayElemTypeRef(obj)
            if this._isCopyType(elemType) {
                this._write(".last().copied().unwrap()")
            } else {
                this._write(".last().cloned().unwrap()")
            }
            return true
        }
        if method == "slice" {
            this._emitExpr(obj)
            this._write("[(")
            if args.length > 0 { this._emitExpr(args[0]) }
            if args.length > 1 {
                this._write(") as usize..(")
                this._emitExpr(args[1])
                this._write(") as usize].to_vec()")
            } else {
                this._write(") as usize..].to_vec()")
            }
            return true
        }
        if method == "take" {
            this._emitExpr(obj)
            this._write("[..(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize].to_vec()")
            return true
        }
        if method == "drop" {
            this._emitExpr(obj)
            this._write("[(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize..].to_vec()")
            return true
        }
        if method == "flat" {
            this._emitExpr(obj)
            this._write(".concat()")
            return true
        }
        if method == "flatten" {
            this._emitExpr(obj)
            this._write(".concat()")
            return true
        }
        if method == "sum" {
            this._emitExpr(obj)
            this._write(".iter().sum::<i32>()")
            return true
        }
        // Iterator pipeline methods: map, filter, forEach, find, reduce, some, every, etc.
        if method == "map" {
            this._emitIterPrefix(obj, true)
            this._write(".map(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")")
            if not this._inIterChain { this._write(".collect::<Vec<_>>()") }
            return true
        }
        if method == "filter" {
            // Bootstrap parity: for non-Copy element types (e.g. classes),
            // emit `.iter().filter(...).cloned().collect()` (cloned AFTER filter)
            // because pre-cloning yields an owned-iterator over T, and the
            // closure pattern `|&x|` would then try to move out of `&T`.
            // For Copy element types we keep the original `.iter().copied().filter(...)`
            // form because the closure already destructures one ref-level
            // via `_derefClosureParams`.
            let elemTypeF = this._getArrayElemTypeRef(obj)
            let isCopyF = this._isCopyType(elemTypeF)
            this._emitIterPrefix(obj, isCopyF)
            this._write(".filter(")
            // Check if arg is a point-free function ref (Identifier) vs Lambda
            let filterArgIsRef = false
            if args.length > 0 {
                switch args[0] {
                    Expr.Lambda(_) => {},
                    _ => { filterArgIsRef = true }
                }
            }
            if filterArgIsRef {
                // Wrap point-free ref: filter(|&x| fn(x))
                this._write("|&__x| ")
                if args.length > 0 { this._emitExpr(args[0]) }
                this._write("(__x)")
            } else {
                this._derefClosureParams = true
                if args.length > 0 { this._emitExpr(args[0]) }
                this._derefClosureParams = false
            }
            this._write(")")
            if not this._inIterChain {
                if not isCopyF {
                    // Append .cloned() AFTER filter so resulting Vec contains
                    // owned values (filter alone yields &T iterator).
                    this._write(".cloned()")
                }
                this._write(".collect::<Vec<_>>()")
            }
            return true
        }
        if method == "forEach" {
            this._emitIterPrefix(obj, true)
            this._write(".for_each(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")")
            return true
        }
        if method == "find" {
            this._emitIterPrefix(obj, true)
            this._write(".find(")
            this._derefClosureParams = true
            if args.length > 0 { this._emitExpr(args[0]) }
            this._derefClosureParams = false
            this._write(").unwrap()")
            return true
        }
        if method == "includes" {
            this._emitExpr(obj)
            this._write(".iter().any(|__x| __x == &(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("))")
            return true
        }
        if method == "indexOf" {
            this._emitExpr(obj)
            this._write(".iter().position(|__x| __x == &(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")).map(|i| i as i32).unwrap_or(-1)")
            return true
        }
        if method == "some" {
            this._emitIterPrefix(obj, true)
            this._write(".any(")
            // any() passes T directly (not &T), so no deref needed
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")")
            return true
        }
        if method == "every" {
            this._emitIterPrefix(obj, true)
            this._write(".all(")
            // all() passes T directly (not &T), so no deref needed
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")")
            return true
        }
        if method == "reduce" {
            this._emitIterPrefix(obj, false)
            this._write(".fold(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(", ")
            if args.length > 1 {
                let isLam = false
                switch args[1] {
                    Expr.Lambda(_) => { isLam = true }
                }
                if isLam {
                    this._write("|acc, x| { let x = x.clone(); (")
                    this._emitExpr(args[1])
                    this._write(")(acc, x) }")
                } else {
                    // Function reference — wrap explicitly
                    this._write("|acc, x| ")
                    this._emitExpr(args[1])
                    this._write("(acc, x.clone())")
                }
            }
            this._write(")")
            return true
        }
        if method == "flatMap" {
            this._emitIterPrefix(obj, false)
            this._write(".flat_map(|x| (")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")(x.clone()))")
            if not this._inIterChain { this._write(".collect::<Vec<_>>()") }
            return true
        }
        if method == "findIndex" {
            this._emitExpr(obj)
            this._write(".iter().position(|x| { let x = x.clone(); (")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")(x) }).map(|i| i as i32).unwrap_or(-1)")
            return true
        }
        if method == "count" {
            this._emitExpr(obj)
            this._write(".iter().filter(|x| { let x = (*x).clone(); (")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")(x) }).count() as i32")
            return true
        }
        if method == "distinct" {
            this._write("{ let mut __seen = std::collections::HashSet::new(); ")
            this._emitExpr(obj)
            this._write(".iter().filter(|x| __seen.insert((*x).clone())).cloned().collect::<Vec<_>>() }")
            return true
        }
        if method == "chunks" {
            this._emitExpr(obj)
            this._write(".chunks((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize).map(|c| c.to_vec()).collect::<Vec<Vec<_>>>()")
            return true
        }
        if method == "zip" {
            this._emitExpr(obj)
            this._write(".iter().zip(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(".iter()).map(|(a, b)| (a.clone(), b.clone())).collect::<Vec<_>>()")
            return true
        }
        if method == "concat" {
            this._write("{ let mut __v = ")
            this._emitExpr(obj)
            this._write(".clone(); __v.extend(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("); __v }")
            return true
        }
        if method == "min" {
            this._emitExpr(obj)
            this._write(".iter().min_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal)).cloned().unwrap()")
            return true
        }
        if method == "max" {
            this._emitExpr(obj)
            this._write(".iter().max_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal)).cloned().unwrap()")
            return true
        }
        // Not a known array method
        return false
    }

    // -- Map methods → Rust equivalents --

    _emitMapMethod(obj: Expr, method: string, args: [Expr]): bool {
        if method == "get" {
            this._emitExpr(obj)
            this._write(".get(")
            if args.length > 0 { this._emitMapKeyArg(args[0]) }
            // Phase 9.2: use .copied() for Copy value types (zero-cost)
            let valType = this._getMapValueTypeRef(obj)
            if this._isCopyType(valType) {
                this._write(").copied().unwrap()")
            } else {
                this._write(").cloned().unwrap()")
            }
            return true
        }
        if method == "set" {
            this._emitExpr(obj)
            this._write(".insert(")
            if args.length > 0 {
                this._emitClonedArg(args[0])
            }
            this._write(", ")
            if args.length > 1 {
                this._emitClonedArg(args[1])
            }
            this._write(")")
            return true
        }
        if method == "has" {
            this._emitExpr(obj)
            this._write(".contains_key(")
            if args.length > 0 { this._emitMapKeyArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "delete" {
            this._emitExpr(obj)
            this._write(".remove(")
            if args.length > 0 { this._emitMapKeyArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "keys" {
            this._emitExpr(obj)
            this._write(".keys().cloned().collect::<Vec<_>>()")
            return true
        }
        if method == "values" {
            this._emitExpr(obj)
            this._write(".values().cloned().collect::<Vec<_>>()")
            return true
        }
        if method == "entries" {
            this._emitExpr(obj)
            this._write(".iter().map(|(k, v)| (k.clone(), v.clone())).collect::<Vec<_>>()")
            return true
        }
        if method == "clear" {
            this._emitExpr(obj)
            this._write(".clear()")
            return true
        }
        if method == "forEach" {
            this._emitExpr(obj)
            this._write(".iter().for_each(|(k, v)| { (")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")(k.clone(), v.clone()); })")
            return true
        }
        if method == "isEmpty" {
            this._emitExpr(obj)
            this._write(".is_empty()")
            return true
        }
        // Not a known map method
        return false
    }

    // -- Set methods → Rust equivalents --

    _emitSetMethod(obj: Expr, method: string, args: [Expr]): bool {
        if method == "add" {
            this._emitExpr(obj)
            this._write(".insert(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")")
            return true
        }
        if method == "has" {
            this._emitExpr(obj)
            this._write(".contains(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("))")
            return true
        }
        if method == "delete" {
            this._emitExpr(obj)
            this._write(".remove(")
            if args.length > 0 { this._emitMapKeyArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "clear" {
            this._emitExpr(obj)
            this._write(".clear()")
            return true
        }
        if method == "values" {
            this._emitExpr(obj)
            this._write(".iter().cloned().collect::<Vec<_>>()")
            return true
        }
        if method == "forEach" {
            this._emitExpr(obj)
            this._write(".iter().for_each(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")")
            return true
        }
        if method == "union" {
            this._emitExpr(obj)
            this._write(".union(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")).cloned().collect::<std::collections::HashSet<_>>()")
            return true
        }
        if method == "intersection" {
            this._emitExpr(obj)
            this._write(".intersection(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")).cloned().collect::<std::collections::HashSet<_>>()")
            return true
        }
        if method == "difference" {
            this._emitExpr(obj)
            this._write(".difference(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")).cloned().collect::<std::collections::HashSet<_>>()")
            return true
        }
        if method == "isEmpty" {
            this._emitExpr(obj)
            this._write(".is_empty()")
            return true
        }
        if method == "size" || method == "count" {
            this._write("(")
            this._emitExpr(obj)
            this._write(".len() as i32)")
            return true
        }
        // Not a known set method
        return false
    }

    // -- Member access (type-directed) --

    // Phase 8.8: emit expr suppressing self.field clone if expr is a direct MemberAccess
    // Used in comparison contexts where clone is wasteful (String: PartialEq<str>)
    _emitExprNoMemberClone(expr: Expr) {
        let isMember = false
        switch expr {
            Expr.MemberAccess(_, _) => { isMember = true }
        }
        if isMember {
            let saved = this._inAssignTarget
            this._inAssignTarget = true
            this._emitExpr(expr)
            this._inAssignTarget = saved
        } else {
            this._emitExpr(expr)
        }
    }

    _emitMemberAccess(obj: Expr, prop: string) {
        // A.3: inside a server handler, `req.params` → `__params`,
        // `req.body` → `body.clone()`.
        if this._serverRequestParam != "" {
            let isReqMember = false
            switch obj {
                Expr.Identifier(reqName) => {
                    if reqName == this._serverRequestParam { isReqMember = true }
                }
            }
            if isReqMember {
                if prop == "params" { this._write("__params"); return }
                if prop == "body" { this._write("body.clone()"); return }
            }
        }

        // B148: in constructor body, rewrite `this.X` reads to `__field_X`
        // for fields already assigned (so reads in conditions/prints/etc work).
        if this._inConstructor {
            let isThisX = false
            switch obj {
                Expr.Identifier(thisName) => {
                    if thisName == "this" || thisName == "self" { isThisX = true }
                }
            }
            if isThisX {
                let sanProp = this._sanitizeName(prop)
                if this._constructorAssignedFields.has(sanProp) {
                    this._write($"__field_{sanProp}")
                    return
                }
            }
        }

        let objTag = this._getExprTypeName(obj)

        // B130 (gen-2): err-binding `.message` access inside an
        // `if err { ... }` block — emit the unwrapped form so it satisfies
        // `String` return types / format args. Outside truthy-narrow we
        // leave emission unchanged (the binding may already be unwrapped
        // in nested scopes).
        switch obj {
            Expr.Identifier(idn) => {
                let snErr2 = this._sanitizeName(idn)
                if prop == "message" && this._errBindings.has(snErr2) && this._truthyErrBindings.has(snErr2) {
                    this._write(snErr2 + ".as_ref().unwrap().message.clone()")
                    return
                }
            }
        }

        // Stdlib module property access before generic enum/class handling
        let stdlibPropName = ""
        switch obj {
            Expr.Identifier(sn) => { stdlibPropName = sn }
        }
        // Math constants: Math.PI, Math.E
        if stdlibPropName == "Math" && prop == "PI" { this._write("std::f64::consts::PI"); return }
        if stdlibPropName == "Math" && prop == "E" { this._write("std::f64::consts::E"); return }
        // Date property access: d.year, d.month, d.day, d.hour, d.minute, d.second
        if prop == "year" { this._write("(chrono::Datelike::year(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "month" { this._write("(chrono::Datelike::month(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "day" { this._write("(chrono::Datelike::day(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "hour" { this._write("(chrono::Timelike::hour(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "minute" { this._write("(chrono::Timelike::minute(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "second" { this._write("(chrono::Timelike::second(&"); this._emitExpr(obj); this._write(") as i32)"); return }

        // Enum variant access: EnumName.Variant → EnumName::Variant
        // Heuristic: PascalCase identifier = enum/class → use :: syntax
        let isEnumAccess = false
        let enumName = ""
        switch obj {
            Expr.Identifier(name) => {
                if name.length > 0 {
                    let firstChar = name.charAt(0)
                    if firstChar >= "A" && firstChar <= "Z" {
                        isEnumAccess = true
                        enumName = name
                    }
                }
            }
        }
        if isEnumAccess {
            this._write(enumName + "::" + prop)
            return
        }

        // .length → .len() as i32 for strings and arrays.
        // But if the receiver is a user class with a declared `length` field,
        // treat it as a regular field access instead.
        if prop == "length" {
            let isUserClassWithLengthField = false
            switch obj {
                Expr.Identifier(idn) => {
                    if idn != "this" && idn != "self" {
                        let varType = this._lookupVarTypeRef(idn)
                        let className = ""
                        switch varType {
                            TypeRef.Simple(cn) => { className = cn }
                        }
                        if className != "" && this._typeCtx.classes.has(className) {
                            let fkeyLen = className + ".length"
                            if this._typeCtx.fieldTypes.has(fkeyLen) {
                                isUserClassWithLengthField = true
                            }
                        }
                    }
                }
            }
            if not isUserClassWithLengthField {
                let savedAT = this._inAssignTarget
                this._inAssignTarget = true
                this._write("(")
                this._emitExpr(obj)
                this._write(".len() as i32)")
                this._inAssignTarget = savedAT
                return
            }
        }

        // .size → .len() as i32 for maps and sets
        if prop == "size" {
            if objTag == "map" {
                let savedAT = this._inAssignTarget
                this._inAssignTarget = true
                this._write("(")
                this._emitExpr(obj)
                this._write(".len() as i32)")
                this._inAssignTarget = savedAT
                return
            }
            if objTag == "set" {
                let savedAT = this._inAssignTarget
                this._inAssignTarget = true
                this._write("(")
                this._emitExpr(obj)
                this._write(".len() as i32)")
                this._inAssignTarget = savedAT
                return
            }
        }

        // Default: emit as field access
        // If accessing self fields in a method, clone to avoid move-from-borrow
        let isSelfAccess = false
        switch obj {
            Expr.Identifier(oName) => {
                if oName == "this" {
                    isSelfAccess = true
                }
            }
        }
        this._emitExpr(obj)
        let snField = this._sanitizeName(prop)
        this._write($".{snField}")
        // Clone self.field when accessed as a value (return, let binding, etc.)
        // Skip clone for Copy-type fields (int, bool, float) — they don't need it
        // Skip clone when _inAssignTarget is set (indexing, .length, method call base)
        if isSelfAccess && not this._inAssignTarget {
            // Check field type — skip clone for Copy types
            let fieldTag = "unknown"
            if this._currentClassName != "" {
                let fkey = $"{this._currentClassName}.{prop}"
                if this._typeCtx.fieldTypes.has(fkey) {
                    let fidx = this._typeCtx.fieldTypes.get(fkey)
                    let ftype = this._typeCtx.typePool[fidx]
                    fieldTag = this._typeRefToTag(ftype)
                }
            }
            if fieldTag != "number" && fieldTag != "bool" && fieldTag != "float" {
                this._write(".clone()")
            }
        }
    }

    // =====================================================================
    //  Phase 3.6 — Ownership emission helpers
    // =====================================================================
    // Emit &arg for String/Vec args to methods that take references.
    // Uses a simple heuristic: if the arg is a variable (not a literal),
    // emit &arg. For literals, emit directly (refs created automatically).

    _emitRefArg(argExpr: Expr) {
        // String literals don't need & prefix (auto-refs) but must suppress .to_string()
        let isLiteral = false
        switch argExpr {
            Expr.Literal(_) => { isLiteral = true },
            Expr.StringTemplate(_) => { isLiteral = true }
        }
        if isLiteral {
            this._suppressToString = true
            this._emitExpr(argExpr)
            this._suppressToString = false
        } else {
            this._write("&")
            this._emitExpr(argExpr)
        }
    }

    // Phase 10.4: returns true if `e` is an Identifier that the compiler can
    // move (consume) safely instead of clone — used by sort/reversed/etc to
    // avoid Vec::clone() in the dominant pattern `let arr = ...; arr.sort()`
    // inside a loop body where arr is dead after the call.
    _canMoveIdent(e: Expr): bool {
        let result = false
        switch e {
            Expr.Identifier(n) => {
                let liveKey = $"{this._currentFunc}:{n}"
                if this._liveCtx.useCounts.has(liveKey) {
                    let uc = this._liveCtx.useCounts.get(liveKey)
                    let declaredInLoop = this._liveCtx.declaredInLoop.has(liveKey)
                    if uc <= 1 && declaredInLoop { result = true }
                }
            }
        }
        return result
    }

    // Phase 10.4: peephole — fuse `let X = expr.split(sep); for Y in X { body }`
    // into `for Y in expr.split(sep).map(|s| s.to_string()) { body }` when X is
    // single-use. The fusion is performed inline in `_emitBlock` (see above).
    // Phase 8.6: Emit map/set key arg — &str params don't need &() wrapping
    // HashMap<String,_>::contains_key/get takes &Q where String: Borrow<Q>.
    // Since String: Borrow<str>, passing &str directly works. Adding &() creates &&str which fails.
    //
    // Phase 10.4: when key is an Identifier holding a String, emit `key.as_str()` instead
    // of `&(key)` so the Map APIs lookup against `&str` directly (skips one auto-deref).
    _emitMapKeyArg(argExpr: Expr) {
        let isStrRef = false
        let isStringIdent = false
        let identSan = ""
        switch argExpr {
            Expr.Identifier(aName) => {
                let aNameCopy = $"{aName}"
                let sn = this._sanitizeName(aName)
                if this._strRefParams.has(sn) {
                    isStrRef = true
                } else {
                    let varType = this._lookupVarTypeRef(aNameCopy)
                    let tag = this._typeRefToTag(varType)
                    if tag == "string" {
                        isStringIdent = true
                        identSan = sn
                    }
                }
            }
        }
        if isStrRef {
            this._emitExpr(argExpr)
        } else if isStringIdent {
            this._write(identSan)
            this._write(".as_str()")
        } else {
            this._write("&(")
            this._emitExpr(argExpr)
            this._write(")")
        }
    }

    // Phase 8.5: Emit arg for &str param — string literals as-is, others with & prefix
    _emitBorrowedArg(argExpr: Expr) {
        let isStrLit = false
        switch argExpr {
            Expr.Literal(aLit) => {
                switch aLit {
                    Literal.Str(_) => { isStrLit = true }
                }
            }
        }
        if isStrLit {
            // String literal is already &str in Rust — just suppress .to_string()
            this._suppressCloneForBorrow = true
            this._emitExpr(argExpr)
            this._suppressCloneForBorrow = false
        } else {
            // & prefix converts String → &str via Deref, &&str auto-derefs
            // Suppress .clone() from _emitMemberAccess → direct borrow is cheaper
            let savedAT = this._inAssignTarget
            this._inAssignTarget = true
            this._write("&")
            this._emitExpr(argExpr)
            this._inAssignTarget = savedAT
        }
    }

    // Cycle 39: emit `&mut <arg>` for params declared as `&mut T`. Skips the
    // identifier-clone path so we get a direct mutable borrow.
    _emitMutBorrowedArg(argExpr: Expr) {
        let savedAT = this._inAssignTarget
        this._inAssignTarget = true
        this._write("&mut ")
        this._emitExpr(argExpr)
        this._inAssignTarget = savedAT
    }

    // Emit expression with .clone() for non-Copy types (identifiers, member access)
    _emitClonedArg(argExpr: Expr) {
        let needsClone = false
        switch argExpr {
            Expr.Identifier(name) => {
                // Don't clone literals-like identifiers (this is handled by emitExpr)
                if name != "true" && name != "false" && name != "null" {
                    // Phase 9.1: skip clone for Copy types via unified helper
                    let varType = this._lookupVarTypeRef(name)
                    if this._isCopyType(varType) {
                        needsClone = false
                    } else {
                        // Phase 8: skip clone for single-use vars NOT in loops
                        // Phase 10.2: also skip clone when var is declared inside the
                        // current loop body (single-use-per-iteration is move-safe).
                        let isSingleUse = false
                        let liveKey = $"{this._currentFunc}:{name}"
                        if this._liveCtx.useCounts.has(liveKey) {
                            let uc = this._liveCtx.useCounts.get(liveKey)
                            let inLoop = this._liveCtx.loopUseCounts.has(liveKey)
                            let declaredInLoop = this._liveCtx.declaredInLoop.has(liveKey)
                            if uc <= 1 && (not inLoop || declaredInLoop) { isSingleUse = true }
                        }
                        // Cycle 40: params emitted as `&Vec/&HashMap/&HashSet`
                        // (or `&mut`) cannot be moved — force a clone so the
                        // call site dereferences the borrow into an owned value.
                        let sanCheck = this._sanitizeName(name)
                        if this._collRefParams.has(sanCheck) {
                            isSingleUse = false
                        }
                        if isSingleUse {
                            needsClone = false
                        } else {
                            needsClone = true
                        }
                    }
                }
            },
            Expr.MemberAccess(maObj, _) => {
                // this.field is auto-cloned in _emitMemberAccess — skip here
                // Enum/type variant (PascalCase) is a value constructor — always owned, no clone
                // other.field needs clone when passed as arg
                let isSelf = false
                let isEnumOrType = false
                switch maObj {
                    Expr.Identifier(oName) => {
                        if oName == "this" { isSelf = true }
                        if oName.length > 0 {
                            let fc = oName.charAt(0)
                            if fc >= "A" && fc <= "Z" { isEnumOrType = true }
                        }
                    }
                }
                if not isSelf && not isEnumOrType { needsClone = true }
            }
        }
        this._emitExpr(argExpr)
        if needsClone {
            // Phase 8.6: &str params — .into() works universally (String or &str callees)
            if this._lastEmittedStrRef {
                this._write(".into()")
            } else {
                this._write(".clone()")
            }
        } else if this._lastEmittedStrRef {
            // Single-use &str params: .into() converts to expected type (String or &str)
            this._write(".into()")
        }
    }

    // -- Struct literal (constructor call) --

    _emitStructLiteral(typeName: string, fields: [ObjField]) {
        this._write($"{typeName}::new(")
        let fIdx = 0
        for f in fields {
            if fIdx > 0 { this._write(", ") }
            this._emitClonedArg(f.value)
            fIdx += 1
        }
        this._write(")")
    }

    // -- Object literal (anonymous Map) --

    _emitObjectLiteral(fields: [ObjField]) {
        this._write("{ let mut _map = HashMap::new(); ")
        for f in fields {
            let key = $"{f.key}"
            this._write($"_map.insert(\"{key}\".to_string(), ")
            this._emitExpr(f.value)
            this._write("); ")
        }
        this._write("_map }")
    }

    // -- JSON literal arg for serde_json::json!() — emits {"key": expr, ...} --

    _emitJsonArg(expr: Expr) {
        switch expr {
            Expr.ObjectLiteral(jFields) => {
                this._emitJsonObjectFields(jFields)
            },
            Expr.MapLiteral(jEntries) => {
                this._emitJsonMapEntries(jEntries)
            },
            Expr.ArrayLiteral(jElems) => {
                this._emitJsonArrayElems(jElems)
            },
            _ => {
                this._emitExpr(expr)
            }
        }
    }

    _emitJsonObjectFields(fields: [ObjField]) {
        this._write("{")
        let jIdx = 0
        for f in fields {
            if jIdx > 0 { this._write(", ") }
            let key = $"{f.key}"
            this._write($"\"{key}\": ")
            this._emitJsonArg(f.value)
            jIdx += 1
        }
        this._write("}")
    }

    _emitJsonMapEntries(entries: [MapEntry]) {
        this._write("{")
        let jIdx = 0
        for e in entries {
            if jIdx > 0 { this._write(", ") }
            this._emitJsonKey(e.key)
            this._write(": ")
            this._emitJsonArg(e.value)
            jIdx += 1
        }
        this._write("}")
    }

    // serde_json::json! requires raw string-literal keys; emit string-lit
    // keys bare without `.to_string()`, and fall back to _emitJsonArg
    // (which adds .to_string()) for non-literal keys (rare/dynamic).
    _emitJsonKey(key: Expr) {
        switch key {
            Expr.Literal(klit) => {
                switch klit {
                    Literal.Str(ks) => { this._write("\"" + ks + "\"") },
                    _ => { this._emitLiteral(klit) }
                }
            },
            _ => { this._emitJsonArg(key) }
        }
    }

    // BUG-3 fix: emit the `__params` Vec<String> binding for a DB.exec/query
    // params argument. When the param expr is an `ArrayLiteral`, emit each
    // element with a trailing `.to_string()` directly inside `vec![]` so
    // String identifiers are cloned (`.to_string()` returns a new String)
    // instead of moved by `vec!`. Mirrors bootstrap `generate_db_params_vec`.
    // Fallback path (non-literal expr) keeps the `.iter().map(...)` form
    // which is fine for &[T] / Vec<T> references.
    _emitDbParamsVec(expr: Expr) {
        switch expr {
            Expr.ArrayLiteral(elems) => {
                this._write("let __params: Vec<String> = vec![")
                let i = 0
                for elem in elems {
                    if i > 0 { this._write(", ") }
                    this._emitExpr(elem)
                    this._write(".to_string()")
                    i += 1
                }
                this._write("]; let __param_refs: Vec<&dyn rusqlite::types::ToSql> = __params.iter().map(|s| s as &dyn rusqlite::types::ToSql).collect();")
            },
            _ => {
                this._write($"{DB_PARAM_BINDING}")
                this._emitExpr(expr)
                this._write($"{DB_PARAM_BINDING_TAIL}")
            }
        }
    }

    // Emit an expression in `format!`-arg position. If the expr is an
    // identifier bound as Option<liva_rt::Error> via a fallible
    // destructure (let v, err = call()), unwrap with as_ref().map().
    // Without this, `"prefix" + err` would emit
    //   format!("{}{}", "prefix".to_string(), err)
    // which fails: Option<liva_rt::Error> doesn't impl Display.
    // Mirrors the existing handling in _emitStringTemplateInner.
    _emitFormatArg(expr: Expr) {
        let isErrBinding = false
        switch expr {
            Expr.Identifier(spName) => {
                let snErr = this._sanitizeName(spName)
                if this._errBindings.has(snErr) {
                    isErrBinding = true
                }
            }
        }
        if isErrBinding {
            this._emitExpr(expr)
            this._write(".as_ref().map(|e| format!(\"{}\", e)).unwrap_or_default()")
        } else {
            this._emitExpr(expr)
        }
    }

    _emitJsonArrayElems(elements: [Expr]) {
        this._write("[")
        let jIdx = 0
        for e in elements {
            if jIdx > 0 { this._write(", ") }
            this._emitJsonArg(e)
            jIdx += 1
        }
        this._write("]")
    }

    // -- Array literal --

    _emitArrayLiteral(elements: [Expr]) {
        if elements.length == 0 {
            this._write("vec![]")
        } else {
            this._write("vec![")
            let aIdx = 0
            for e in elements {
                if aIdx > 0 { this._write(", ") }
                // Clone non-Copy identifiers (String / array / map / set / class)
                // to avoid moving a binding that may be used after the literal.
                // Mirrors the bootstrap behavior `vec![start.clone()]`.
                let cloned = false
                switch e {
                    Expr.Identifier(elName) => {
                        let elNameCopy = $"{elName}"
                        let varType = this._lookupVarTypeRef(elNameCopy)
                        let elTag = this._typeRefToTag(varType)
                        let isNonCopy = false
                        if elTag == "string" { isNonCopy = true }
                        if elTag == "array" { isNonCopy = true }
                        if elTag == "map" { isNonCopy = true }
                        if elTag == "set" { isNonCopy = true }
                        if elTag == "class" { isNonCopy = true }
                        if isNonCopy {
                            this._emitExpr(e)
                            this._write(".clone()")
                            cloned = true
                        }
                    }
                }
                if not cloned {
                    this._emitExpr(e)
                }
                aIdx += 1
            }
            this._write("]")
        }
    }

    // -- Map literal --

    _emitMapLiteral(entries: [MapEntry]) {
        if entries.length == 0 {
            this._write("HashMap::new()")
        } else {
            this._write("{ let mut _map = HashMap::new(); ")
            for e in entries {
                this._write("_map.insert(")
                this._emitExpr(e.key)
                this._write(", ")
                this._emitExpr(e.value)
                this._write("); ")
            }
            this._write("_map }")
        }
    }

    // -- Set literal --

    _emitSetLiteral(elements: [Expr]) {
        if elements.length == 0 {
            this._write("HashSet::new()")
        } else {
            this._write("{ let mut _set = HashSet::new(); ")
            for e in elements {
                this._write("_set.insert(")
                this._emitExpr(e)
                this._write("); ")
            }
            this._write("_set }")
        }
    }

    // -- Lambda --

    // Emit only the body of a lambda as an expression (no |params| header).
    // Used by stdlib synthesizers (sortBy/groupBy) that wrap the body
    // in their own scope and parameter bindings.
    _emitLambdaBodyInline(lam: LambdaExpr) {
        switch lam.body {
            LambdaBody.Expr(lamExprs) => {
                if lamExprs.length == 1 {
                    for le in lamExprs { this._emitExpr(le); break }
                } else {
                    this._write("{ ")
                    for e in lamExprs {
                        this._emitExpr(e)
                        this._write("; ")
                    }
                    this._write("}")
                }
            },
            LambdaBody.Block(lamBlock) => {
                this._write("{")
                this._newline()
                this._indent()
                this._emitBlock(lamBlock)
                this._dedent()
                this._writeIndent()
                this._write("}")
            }
        }
    }

    _emitLambda(lam: LambdaExpr) {
        if lam.isMove {
            this._write("move ")
        }
        this._write("|")
        let pIdx = 0
        let needDeref = this._derefClosureParams
        this._derefClosureParams = false
        for p in lam.params {
            if pIdx > 0 { this._write(", ") }
            let pName = switch p.pattern {
                BindingPattern.Identifier(n) => n,
                _ => "_"
            }
            let snP = this._sanitizeName(pName)
            if needDeref {
                this._write("&" + snP)
            } else {
                this._write(snP)
            }
            pIdx += 1
        }
        this._write("| ")
        switch lam.body {
            LambdaBody.Expr(lamExprs) => {
                if lamExprs.length == 1 {
                    for le in lamExprs { this._emitExpr(le); break }
                } else {
                    this._write("{ ")
                    for e in lamExprs {
                        this._emitExpr(e)
                        this._write("; ")
                    }
                    this._write("}")
                }
            },
            LambdaBody.Block(lamBlock) => {
                this._write("{")
                this._newline()
                this._indent()
                this._emitBlock(lamBlock)
                this._dedent()
                this._writeIndent()
                this._write("}")
            }
        }
    }

    // -- String template --

    _emitStringTemplate(parts: [StringTemplatePart]) {
        // Phase 8.7: single-expression template $"{x}" → x.to_string() instead of format!("{}", x)
        if parts.length == 1 {
            let isSingleExpr = false
            switch parts[0] {
                StringTemplatePart.ExprPart(_) => { isSingleExpr = true }
            }
            if isSingleExpr {
                switch parts[0] {
                    StringTemplatePart.ExprPart(expr) => {
                        this._emitExpr(expr)
                        this._write(".to_string()")
                    }
                }
                return
            }
        }
        // Multi-part template: format!("...", args)
        this._write("format!(")
        this._emitStringTemplateInner(parts)
        this._write(")")
    }

    // Phase 8: emit string template format string + args WITHOUT format!() wrapper
    // Used for println!($"...") → println!("fmt", args) optimization
    _emitStringTemplateInline(expr: Expr) {
        switch expr {
            Expr.StringTemplate(parts) => {
                this._emitStringTemplateInner(parts)
            },
            _ => { this._emitExpr(expr) }
        }
    }

    _emitStringTemplateInner(parts: [StringTemplatePart]) {
        let fmtStr = ""
        let fmtArgs: [string] = []

        for p in parts {
            switch p {
                StringTemplatePart.Text(text) => {
                    // Escape inner double quotes and braces for format!
                    let escaped = text.replace("\\", "\\\\")
                    escaped = escaped.replace("\"", "\\\"")
                    escaped = escaped.replace("{", "{{")
                    escaped = escaped.replace("}", "}}")
                    fmtStr += escaped
                },
                StringTemplatePart.ExprPart(spExpr) => {
                    // Use {:?} for types that only impl Debug (Vec, HashMap, HashSet)
                    let pTag = this._getExprTypeName(spExpr)
                    if pTag == "array" || pTag == "map" || pTag == "set" {
                        fmtStr += "{:?}"
                    } else {
                        fmtStr += "{}"
                    }
                    // Capture expr to string — simplified: inline the expr
                    // We'll write args after the format string
                    fmtArgs.push("__arg__")
                }
            }
        }

        // Emit format string and inline expressions
        this._write($"\"{fmtStr}\"")
        for p in parts {
            switch p {
                StringTemplatePart.ExprPart(spExpr) => {
                    this._write(", ")
                    // Option<Error> err-bindings: unwrap with as_ref().map().unwrap_or_default()
                    let isErrBinding = false
                    switch spExpr {
                        Expr.Identifier(spName) => {
                            let snErr = this._sanitizeName(spName)
                            if this._errBindings.has(snErr) {
                                isErrBinding = true
                            }
                        }
                    }
                    if isErrBinding {
                        this._emitExpr(spExpr)
                        this._write(".as_ref().map(|e| format!(\"{}\", e)).unwrap_or_default()")
                    } else {
                        this._emitExpr(spExpr)
                    }
                }
            }
        }
    }

    // -- Switch expression (match) --

    _isStringSwitchPattern(arms: [SwitchArm]): bool {
        if arms.length == 0 { return false }
        let isStr = false
        for arm in arms {
            switch arm.pattern {
                Pattern.LiteralPat(lit) => {
                    switch lit {
                        Literal.Str(_) => { isStr = true }
                    }
                },
                Pattern.OrPat(patterns) => {
                    // Check first sub-pattern in OR pattern
                    for subP in patterns {
                        switch subP {
                            Pattern.LiteralPat(lit2) => {
                                switch lit2 {
                                    Literal.Str(_) => { isStr = true }
                                }
                            }
                        }
                        break
                    }
                }
            }
            break
        }
        return isStr
    }

    // B130 (gen-2 truthy narrow): detect `if errBinding { ... }` so the
    // then-branch can rewrite `err.message` to the unwrapped form, AND emit
    // the condition expression. We do both inside this helper because `cond`
    // is bound as a method parameter — bootstrap auto-clones parameters at
    // every use, but does NOT auto-clone field accesses (`stmt.condition`),
    // so doing match + emit at the call-site would E0382. Returns the
    // sanitized binding name (or "" if not applicable).
    _emitIfConditionAndDetectTruthy(cond: Expr): string {
        let result = ""
        switch cond {
            Expr.Identifier(condName) => {
                let sn2 = this._sanitizeName(condName)
                if this._errBindings.has(sn2) {
                    result = sn2
                }
            }
        }
        this._inIfCondition = true
        this._emitExpr(cond)
        this._inIfCondition = false
        return result
    }

    // Helper: emit `match <disc>` or `match &<disc>` (with optional `.as_str()`)
    // depending on whether it's a string switch or a Copy-type discriminant.
    // Taking `disc` as a parameter lets bootstrap codegen auto-clone the value
    // across multiple uses inside this method (B135).
    _emitSwitchHead(disc: Expr, isStringSwitch: bool) {
        if isStringSwitch {
            this._write("match ")
            this._emitExpr(disc)
            if !this._lastEmittedStrRef {
                this._write(".as_str()")
            }
            return
        }
        // B135 fix: Copy-type (number/bool/float) discriminants don't need `&`.
        let discTag = this._getExprTypeName(disc)
        if discTag == "number" || discTag == "bool" || discTag == "float" {
            this._write("match ")
            this._emitExpr(disc)
        } else {
            this._write("match &")
            this._emitExpr(disc)
        }
    }

    _emitSwitchExpr(disc: Expr, arms: [SwitchArm]) {
        // Detect string switch from first arm pattern (inline to avoid moving arms)
        let stringSwitch = false
        for arm in arms {
            switch arm.pattern {
                Pattern.LiteralPat(lit) => {
                    switch lit {
                        Literal.Str(_) => { stringSwitch = true }
                    }
                },
                Pattern.OrPat(patterns) => {
                    for subP in patterns {
                        switch subP {
                            Pattern.LiteralPat(lit2) => {
                                switch lit2 {
                                    Literal.Str(_) => { stringSwitch = true }
                                }
                            }
                        }
                        break
                    }
                }
            }
            break
        }

        let cloneDisc = true
        if stringSwitch { cloneDisc = false }
        // Use shared head emitter (B135 — Copy-type discriminants skip `&`).
        this._emitSwitchHead(disc, stringSwitch)
        this._write(" { ")

        for arm in arms {
            this._emitSwitchArm(arm)
        }

        // Statement-position switch: if the user did not write a catch-all
        // `_ => ...` arm, synthesize `_ => {}`. Otherwise Rust's match would
        // be non-exhaustive (E0004). For expression-position switches the
        // user must still provide all arms (they produce a value).
        if this._switchInStmtPosition {
            let hasWildcard = false
            for arm in arms {
                switch arm.pattern {
                    Pattern.Wildcard => { hasWildcard = true }
                }
            }
            if not hasWildcard {
                this._write("_ => {}, ")
            }
        }

        this._write("}")
    }

    _emitSwitchArm(arm: SwitchArm) {
        // Clear pending derefs/clones before emitting pattern
        this._pendingDerefs = []
        this._pendingRefClones = []
        this._emitPattern(arm.pattern)

        let guardExpr = arm.guard
        if guardExpr != null {
            this._write(" if ")
            this._emitExpr(guardExpr)
        }

        this._write(" => ")

        // Fields become references due to match &x.
        // Boxed fields need *field.clone(), non-boxed need field.clone()
        let hasDerefs = this._pendingDerefs.length > 0
        let hasClones = this._pendingRefClones.length > 0
        let derefs = this._pendingDerefs
        let clones = this._pendingRefClones
        switch arm.body {
            SwitchArmBody.Expr(armExpr) => {
                if this._switchInStmtPosition {
                    // Force `()`-typed arm so a statement-position match unifies.
                    this._write("{ ")
                    for d in derefs {
                        this._write("let " + d + " = *" + d + ".clone(); ")
                    }
                    for c in clones {
                        this._write("let " + c + " = " + c + ".clone(); ")
                    }
                    this._emitExpr(armExpr)
                    this._write("; }, ")
                } else if hasDerefs || hasClones {
                    this._write("{ ")
                    for d in derefs {
                        this._write("let " + d + " = *" + d + ".clone(); ")
                    }
                    for c in clones {
                        this._write("let " + c + " = " + c + ".clone(); ")
                    }
                    this._emitExpr(armExpr)
                    this._write(" }, ")
                } else {
                    this._emitExpr(armExpr)
                    this._write(", ")
                }
            },
            SwitchArmBody.Block(armStmts) => {
                this._write("{ ")
                for d2 in derefs {
                    this._write("let " + d2 + " = *" + d2 + ".clone(); ")
                }
                for c2 in clones {
                    this._write("let " + c2 + " = " + c2 + ".clone(); ")
                }
                if this._switchInStmtPosition {
                    // Statement-position arm: every stmt (incl. last) terminates
                    // with its normal `;`, so the block evaluates to `()`.
                    let savedExprBlock = this._inExprBlock
                    this._inExprBlock = false
                    for s in armStmts {
                        this._stmtIsLastInBlock = false
                        this._emitStmt(s)
                    }
                    this._inExprBlock = savedExprBlock
                } else {
                    // Switch arm bodies are expression positions — the last stmt is a tail expr.
                    let savedExprBlock = this._inExprBlock
                    this._inExprBlock = true
                    let aTotal = armStmts.length
                    let aIdx = 0
                    for s in armStmts {
                        this._stmtIsLastInBlock = (aIdx == aTotal - 1)
                        this._emitStmt(s)
                        aIdx += 1
                    }
                    this._stmtIsLastInBlock = false
                    this._inExprBlock = savedExprBlock
                }
                this._write("}, ")
            }
        }
    }

    // Emit literal in pattern context — no .to_string() for strings
    _emitLiteralPattern(lit: Literal) {
        switch lit {
            Literal.Int(v) => { this._write($"{v}") },
            Literal.Float(v) => { this._write($"{v}") },
            Literal.Str(v) => {
                let escaped = this._escapeRustStr(v)
                this._write("\"" + escaped + "\"")
            },
            Literal.Char(v) => {
                let escapedC = this._escapeRustChar(v)
                this._write("'" + escapedC + "'")
            },
            Literal.Bool(v) => {
                if v { this._write("true") } else { this._write("false") }
            },
            Literal.Null => { this._write("None") }
        }
    }

    _emitPattern(pat: Pattern) {
        switch pat {
            Pattern.LiteralPat(lit) => { this._emitLiteralPattern(lit) },
            Pattern.Wildcard => { this._write("_") },
            Pattern.Binding(name) => {
                let snBind = this._sanitizeName(name)
                this._write(snBind)
            },
            Pattern.Typed(name, typeRef) => {
                let snTyped = this._sanitizeName(name)
                this._write(snTyped)
            },
            Pattern.Range(rangeStart, rangeEnd, inclusive) => {
                let rs = rangeStart
                if rs != null { this._emitExpr(rs) }
                if inclusive {
                    this._write("..=")
                } else {
                    this._write("..")
                }
                let re = rangeEnd
                if re != null { this._emitExpr(re) }
            },
            Pattern.TuplePat(patterns) => {
                this._write("(")
                let tpIdx = 0
                for tp in patterns {
                    if tpIdx > 0 { this._write(", ") }
                    this._emitPattern(tp)
                    tpIdx += 1
                }
                this._write(")")
            },
            Pattern.ArrayPat(patterns) => {
                this._write("[")
                let apIdx = 0
                for ap in patterns {
                    if apIdx > 0 { this._write(", ") }
                    this._emitPattern(ap)
                    apIdx += 1
                }
                this._write("]")
            },
            Pattern.OrPat(patterns) => {
                let opIdx = 0
                for op in patterns {
                    if opIdx > 0 { this._write(" | ") }
                    this._emitPattern(op)
                    opIdx += 1
                }
            },
            Pattern.EnumVariant(enumName, variantName, bindings) => {
                this._write($"{enumName}::{variantName}")
                if bindings.length > 0 {
                    // Check if all bindings are wildcards
                    let allWildcard = true
                    for bnd in bindings {
                        if bnd != "_" { allWildcard = false }
                    }
                    if allWildcard {
                        this._write(" { .. }")
                    } else {
                        // Look up field names and boxing info
                        let variantKey = enumName + "::" + variantName
                        let fieldNames: [string] = []
                        let fieldBoxed: [bool] = []
                        if this._enumVariantFields.has(variantKey) {
                            fieldNames = this._enumVariantFields.get(variantKey)
                        }
                        if this._enumVariantFieldBoxed.has(variantKey) {
                            fieldBoxed = this._enumVariantFieldBoxed.get(variantKey)
                        }
                        this._write(" { ")
                        let bIdx = 0
                        for bnd in bindings {
                            if bIdx > 0 { this._write(", ") }
                            if bnd == "_" {
                                // Use field_name: _ if we know the field name
                                if bIdx < fieldNames.length {
                                    this._write(fieldNames[bIdx] + ": _")
                                } else {
                                    this._write("_")
                                }
                            } else {
                                let sanitized = this._sanitizeName(bnd)
                                if bIdx < fieldNames.length {
                                    let fieldName = fieldNames[bIdx]
                                    if fieldName != sanitized {
                                        this._write(fieldName + ": " + sanitized)
                                    } else {
                                        this._write(sanitized)
                                    }
                                } else {
                                    this._write(sanitized)
                                }
                                // Register pending deref if field is boxed
                                let isBoxed = false
                                if bIdx < fieldBoxed.length {
                                    isBoxed = fieldBoxed[bIdx]
                                }
                                if isBoxed {
                                    this._pendingDerefs.push(sanitized)
                                } else {
                                    // Non-boxed field: needs .clone() when matching by reference
                                    this._pendingRefClones.push(sanitized)
                                }
                            }
                            bIdx += 1
                        }
                        this._write(" }")
                    }
                }
            }
        }
    }

    // =====================================================================
    //  Phase 3.7 — Cargo.toml generation
    // =====================================================================

    generateCargoToml(projectName: string, usesAsync: bool, usesRegex: bool,
                      usesHttp: bool, usesDb: bool, usesJson: bool,
                      usesChrono: bool, usesRandom: bool, usesCrypto: bool,
                      usesRayon: bool, usesHttpClient: bool): string {
        let lines: [string] = []
        lines.push("[package]")
        lines.push($"name = \"{projectName}\"")
        lines.push("version = \"0.1.0\"")
        lines.push("edition = \"2021\"")
        lines.push("")
        lines.push("[dependencies]")

        // Core async runtime
        if usesAsync {
            lines.push("tokio = { version = \"1\", features = [\"full\"] }")
        }

        // HTTP server
        if usesHttp {
            lines.push("axum = \"0.8\"")
            lines.push("tower = \"0.4\"")
            lines.push("tower-http = { version = \"0.5\", features = [\"cors\"] }")
            // HTTP implies async
            if not usesAsync {
                lines.push("tokio = { version = \"1\", features = [\"full\"] }")
            }
        }

        // Database
        if usesDb {
            lines.push("rusqlite = { version = \"0.31\", features = [\"bundled\"] }")
        }

        // JSON
        if usesJson {
            lines.push("serde = { version = \"1\", features = [\"derive\"] }")
            lines.push("serde_json = \"1\"")
        }

        // Regex
        if usesRegex {
            lines.push("regex = \"1\"")
        }

        // Date/Time
        if usesChrono {
            lines.push("chrono = \"0.4\"")
        }

        // Random (includes uuid)
        if usesRandom {
            lines.push("rand = \"0.8\"")
            lines.push("uuid = { version = \"1\", features = [\"v4\"] }")
        }

        // Crypto
        if usesCrypto {
            lines.push("sha2 = \"0.10\"")
            lines.push("hmac = \"0.12\"")
            lines.push("hex = \"0.4\"")
            lines.push("md5 = \"0.7\"")
            lines.push("base64 = \"0.22\"")
        }

        // Parallel
        if usesRayon {
            lines.push("rayon = \"1\"")
        }

        // HTTP Client
        if usesHttpClient {
            lines.push("reqwest = { version = \"0.11\", features = [\"blocking\"] }")
        }

        return lines.join("\n")
    }

    // ── A.3: HTTP server route emission ──

    // Convert axum 0.7 path syntax `:param` to axum 0.8 `{param}` (matches
    // bootstrap codegen.rs:15053). Returns the converted path or the input
    // unchanged if no `:`-prefixed segments.
    _convertRoutePath(path: string): string {
        let result = ""
        let segments = path.split("/")
        let isFirst = true
        for seg in segments {
            if isFirst {
                isFirst = false
            } else {
                result += "/"
            }
            if seg.length > 0 && seg.substring(0, 1) == ":" {
                let name = seg.substring(1, seg.length)
                result += "{" + name + "}"
            } else {
                result += seg
            }
        }
        return result
    }

    // app.METHOD(path, handler) → app = app.route(path, axum::routing::METHOD(|...| async move { ... }))
    _emitServerRoute(serverVar: string, method: string, args: [Expr]) {
        // Determine path (compile-time string literal → convert :param syntax)
        let pathLiteral = ""
        let havePathLit = false
        switch args[0] {
            Expr.Literal(litVal) => {
                switch litVal {
                    Literal.Str(s) => { pathLiteral = s; havePathLit = true }
                }
            }
        }
        let hasParams = false
        if havePathLit && pathLiteral.contains(":") { hasParams = true }
        // Convert :param → {param} only when we have a literal path
        let convertedPath = ""
        if havePathLit { convertedPath = this._convertRoutePath(pathLiteral) }

        let isWrite = method == "post" || method == "put"

        // BUG-3 fix: wrap each route in `{ let db = db.clone(); ... }` for every
        // tracked DB connection var. Each async closure consumes its own Arc
        // clone instead of moving the outer var (bootstrap parity).
        let hasDbClones = false
        for _k in this._dbVars.keys() { hasDbClones = true }
        if hasDbClones {
            this._write("{ ")
            for dbName in this._dbVars.keys() {
                this._write($"let {dbName} = {dbName}.clone(); ")
            }
        }

        this._write(serverVar)
        this._write(" = ")
        this._write(serverVar)
        this._write(".route(")
        if havePathLit {
            this._write("\"")
            this._write(convertedPath)
            this._write("\"")
        } else {
            this._emitExpr(args[0])
        }
        this._write(", axum::routing::")
        this._write(method)
        this._write("(")

        // Handler must be a lambda. We process args[1] inline via switch.
        switch args[1] {
            Expr.Lambda(lam) => {
                // Closure signature based on (hasParams, isWrite)
                if hasParams && isWrite {
                    this._write("|axum::extract::Path(__params): axum::extract::Path<std::collections::HashMap<String, String>>, body: String| async move {")
                } else if hasParams {
                    this._write("|axum::extract::Path(__params): axum::extract::Path<std::collections::HashMap<String, String>>| async move {")
                } else if isWrite {
                    this._write("|body: String| async move {")
                } else {
                    this._write("|| async move {")
                }
                this._newline()
                this._indent()

                // Save and set request param tracking, then emit body with last
                // statement as tail expression (so it becomes the return value).
                let prevReqParam = $"{this._serverRequestParam}"
                let firstParamName = ""
                let _fp_seen = false
                for p in lam.params {
                    if !_fp_seen {
                        _fp_seen = true
                        switch p.pattern {
                            BindingPattern.Identifier(pn) => { firstParamName = pn }
                        }
                    }
                }
                this._serverRequestParam = firstParamName

                switch lam.body {
                    LambdaBody.Block(blk) => {
                        let stmts = blk.stmts
                        let n = stmts.length
                        let i = 0
                        for s in stmts {
                            let isLast = i == n - 1
                            if isLast {
                                let isExprStmt = false
                                switch s {
                                    Stmt.ExprStmt(eExpr) => {
                                        isExprStmt = true
                                        this._writeIndent()
                                        this._emitExpr(eExpr)
                                        this._newline()
                                    }
                                }
                                if !isExprStmt {
                                    this._emitStmt(s)
                                }
                            } else {
                                this._emitStmt(s)
                            }
                            i += 1
                        }
                    },
                    LambdaBody.Expr(exprs) => {
                        if exprs.length >= 1 {
                            this._writeIndent()
                            this._emitExpr(exprs[0])
                            this._newline()
                        }
                    }
                }

                this._serverRequestParam = prevReqParam
                this._dedent()
                this._writeIndent()
                this._write("}))")
                if hasDbClones { this._write(" }") }
            },
            _ => {
                // Non-lambda: emit unchanged (likely user error).
                this._emitExpr(args[1])
                this._write("))")
                if hasDbClones { this._write(" }") }
            }
        }
    }

    // app.listen(port) → start axum server (blocks until shutdown).
    _emitServerListen(serverVar: string, args: [Expr]) {
        this._write("{ let __addr = format!(\"0.0.0.0:{}\", ")
        this._emitExpr(args[0])
        this._write("); let __listener = tokio::net::TcpListener::bind(&__addr).await.unwrap(); axum::serve(__listener, ")
        this._write(serverVar)
        this._write(").await.unwrap(); }")
    }

    // Async-inference: pre-pass detector. Set _mainNeedsAsync if the program
    // contains any HTTP-server / listen trigger anywhere in `main`. Called from
    // `generate()` before per-function emission. Shallow scan of `main`'s body
    // statements (server setup is conventionally at top level).
    _detectMainAsync(program: Program) {
        for item in program.items {
            switch item {
                TopLevel.Function(fd) => {
                    if fd.name == "main" {
                        this._scanStmtsForAsyncOpt(fd.body)
                    }
                }
            }
        }
    }

    _scanStmtsForAsyncOpt(blkOpt: BlockStmt?) {
        if blkOpt != null {
            this._scanStmtsForAsync(blkOpt)
        }
    }

    _scanStmtsForAsync(blk: BlockStmt) {
        for s in blk.stmts {
            this._scanStmtForAsync(s)
        }
    }

    _scanStmtForAsync(s: Stmt) {
        switch s {
            Stmt.VarDecl(d) => {
                if this._exprIsAsyncTrigger(d.init) { this._mainNeedsAsync = true }
            },
            Stmt.ConstDecl(d) => {
                if this._exprIsAsyncTrigger(d.init) { this._mainNeedsAsync = true }
            },
            Stmt.Assign(a) => {
                if this._exprIsAsyncTrigger(a.target) { this._mainNeedsAsync = true }
                if this._exprIsAsyncTrigger(a.value) { this._mainNeedsAsync = true }
            },
            Stmt.ExprStmt(e) => {
                if this._exprIsAsyncTrigger(e) { this._mainNeedsAsync = true }
            },
            Stmt.Return(re) => {
                let rOpt = re
                if rOpt != null {
                    if this._exprIsAsyncTrigger(rOpt) { this._mainNeedsAsync = true }
                }
            },
            Stmt.Throw(e) => {
                if this._exprIsAsyncTrigger(e) { this._mainNeedsAsync = true }
            },
            Stmt.While(ws) => {
                if this._exprIsAsyncTrigger(ws.condition) { this._mainNeedsAsync = true }
                this._scanStmtsForAsync(ws.body)
            },
            Stmt.For(fs) => {
                if this._exprIsAsyncTrigger(fs.iterable) { this._mainNeedsAsync = true }
                this._scanStmtsForAsync(fs.body)
            },
            Stmt.TryCatch(tc) => {
                this._scanStmtsForAsync(tc.tryBlock)
                this._scanStmtsForAsync(tc.catchBlock)
            },
            Stmt.Block(b) => {
                this._scanStmtsForAsync(b)
            }
        }
    }

    // Direct trigger detection on an expression — matches MethodCall on Server,
    // HTTP.{get,post,put,delete}, or any `.listen(`.
    _exprIsAsyncTrigger(e: Expr): bool {
        let result = false
        switch e {
            Expr.MethodCall(obj, method, args) => {
                if method == "listen" { result = true }
                switch obj {
                    Expr.Identifier(n) => {
                        if n == "Server" { result = true }
                        if n == "HTTP" || n == "Http" {
                            if method == "get" || method == "post" || method == "put" || method == "delete" {
                                result = true
                            }
                        }
                    }
                }
                if this._exprIsAsyncTrigger(obj) { result = true }
                for a in args {
                    if this._exprIsAsyncTrigger(a) { result = true }
                }
            },
            Expr.Unary(op, sub) => {
                let isAwait = switch op {
                    UnOp.Await => true,
                    _ => false
                }
                if isAwait { result = true }
                if this._exprIsAsyncTrigger(sub) { result = true }
            },
            Expr.Binary(_, lhs, rhs) => {
                if this._exprIsAsyncTrigger(lhs) { result = true }
                if this._exprIsAsyncTrigger(rhs) { result = true }
            },
            Expr.Call(callee, callArgs, policy, _) => {
                let isAsyncPolicy = switch policy {
                    ExecPolicy.Async => true,
                    ExecPolicy.Par => true,
                    ExecPolicy.TaskAsync => true,
                    ExecPolicy.TaskPar => true,
                    _ => false
                }
                if isAsyncPolicy { result = true }
                // Cycle 35 — call to a user-defined async fn (transitive).
                switch callee {
                    Expr.Identifier(fnName) => {
                        if this._asyncFnNames.has(this._sanitizeName(fnName)) { result = true }
                    }
                }
                if this._exprIsAsyncTrigger(callee) { result = true }
                for a2 in callArgs {
                    if this._exprIsAsyncTrigger(a2) { result = true }
                }
            },
            Expr.MemberAccess(base, _) => {
                if this._exprIsAsyncTrigger(base) { result = true }
            },
            Expr.Index(base2, idx) => {
                if this._exprIsAsyncTrigger(base2) { result = true }
                if this._exprIsAsyncTrigger(idx) { result = true }
            },
            Expr.Ternary(c, t, f) => {
                if this._exprIsAsyncTrigger(c) { result = true }
                if this._exprIsAsyncTrigger(t) { result = true }
                if this._exprIsAsyncTrigger(f) { result = true }
            },
            Expr.RustBlock(code) => {
                if code.indexOf(".await") >= 0 { result = true }
            }
        }
        return result
    }
}
// =====================================================================
//  Public API
// =====================================================================

generateRust(program: Program, typeCtx: TypeContext, liveCtx: LivenessContext, enumFields: Map<string, [string]>, enumFieldBoxed: Map<string, [bool]>, enumFieldOptional: Map<string, [bool]>, globalBorrow: Map<string, bool>): string {
    let emitter = RustEmitter(typeCtx, liveCtx)
    // Cross-module enum registry — each enum name appears as a key in enumFields
    // (registered as "EnumName::Variant"). Extract enum names BEFORE assigning
    // enumFields away (move semantics) so field-type checks (Default-derive)
    // recognize cross-module enums.
    for vk in enumFields.keys() {
        let vkCopy = $"{vk}"
        let cIdx = vkCopy.indexOf("::")
        if cIdx > 0 {
            let eName = vkCopy.substring(0, cIdx)
            emitter.primeGlobalEnum(eName)
        }
    }
    emitter._enumVariantFields = enumFields
    emitter._enumVariantFieldBoxed = enumFieldBoxed
    emitter._enumVariantFieldOptional = enumFieldOptional
    // Phase 10.5 Bloque 1: prime cross-module borrow registry so call sites in
    // this module can detect that free functions defined in OTHER modules take
    // their String params as `&str`.
    for k in globalBorrow.keys() {
        let kCopy = $"{k}"
        emitter.primeBorrowedParam(kCopy)
    }
    return emitter.generate(program)
}

generateModuleRust(program: Program, typeCtx: TypeContext, liveCtx: LivenessContext, enumFields: Map<string, [string]>, enumFieldBoxed: Map<string, [bool]>, enumFieldOptional: Map<string, [bool]>, globalBorrow: Map<string, bool>): string {
    let emitter = RustEmitter(typeCtx, liveCtx)
    emitter.setIsMainModule(false)
    // Cross-module enum registry (see generateRust).
    for vk in enumFields.keys() {
        let vkCopy = $"{vk}"
        let cIdx = vkCopy.indexOf("::")
        if cIdx > 0 {
            let eName = vkCopy.substring(0, cIdx)
            emitter.primeGlobalEnum(eName)
        }
    }
    emitter._enumVariantFields = enumFields
    emitter._enumVariantFieldBoxed = enumFieldBoxed
    emitter._enumVariantFieldOptional = enumFieldOptional
    // Phase 10.5 Bloque 1: prime cross-module borrow registry (see generateRust).
    for k in globalBorrow.keys() {
        let kCopy = $"{k}"
        emitter.primeBorrowedParam(kCopy)
    }
    return emitter.generate(program)
}

// Phase 10.5 Bloque 1: collect borrowable (&str) free-function params for one
// module. Returns a Map<bKey, bool> where bKey = "{sanFuncName}:{paramIdx}".
// Run by main.liva once per module BEFORE codegen, then merged into a global
// registry shared across all modules so cross-module call sites see borrow info.
//
// Standalone implementation (no TypeContext needed) — matches TypeRef directly.
// Mirrors the gate in `_buildParam`: param type must be `string` (Simple) and
// liveness must say paramBorrow=1 && paramEscapes=0. `main` excluded.
collectBorrowedParams(program: Program, liveCtx: LivenessContext): Map<string, bool> {
    let registry: Map<string, bool> = Map {}
    for item in program.items {
        switch item {
            TopLevel.Function(fd) => {
                if fd.name != "main" {
                    let rawFK = $"{fd.name}"
                    let sanFK = sanitizeName(fd.name)
                    let pIdx = 0
                    for p in fd.params {
                        let rawName = switch p.pattern {
                            BindingPattern.Identifier(n) => n,
                            _ => "_"
                        }
                        let isBorrowable = paramTypeIsBorrowable(p.typeRef)
                        if isBorrowable {                            let livenessKey = $"{rawFK}:{rawName}"
                            let isBorrow = 0
                            if liveCtx.paramBorrow.has(livenessKey) {
                                isBorrow = liveCtx.paramBorrow.get(livenessKey)
                            }
                            let isEscape = 0
                            if liveCtx.paramEscapes.has(livenessKey) {
                                isEscape = liveCtx.paramEscapes.get(livenessKey)
                            }
                            if isBorrow == 1 && isEscape == 0 {
                                let bKey = $"{sanFK}:{pIdx}"
                                registry.set(bKey, true)
                            }
                        }
                        pIdx += 1
                    }
                }
            }
        }
    }
    return registry
}

// Standalone helper: returns true iff `optRef` is `Some(TypeRef.Simple("string"))`.
paramTypeIsString(optRef: TypeRef?): bool {
    if optRef != null {
        return _typeRefIsStringSimple(optRef)
    }
    return false
}

// Standalone helper: returns true iff `optRef` wraps a Map type.
paramTypeIsMap(optRef: TypeRef?): bool {
    if optRef != null {
        return _typeRefIsMap(optRef)
    }
    return false
}

// Combined helper: returns true if `optRef` is a borrowable type (string or Map).
// Used by `collectBorrowedParams` to avoid double-consuming the Option<TypeRef>.
paramTypeIsBorrowable(optRef: TypeRef?): bool {
    if optRef != null {
        return _typeRefIsBorrowable(optRef)
    }
    return false
}

_typeRefIsBorrowable(t: TypeRef): bool {
    let result = false
    switch t {
        TypeRef.Simple(tn) => {
            if tn == "string" { result = true }
        },
        TypeRef.MapType(k, v) => { result = true },
        TypeRef.Array(inner) => { result = true },
        TypeRef.SetType(inner) => { result = true },
        _ => {}
    }
    return result
}

_typeRefIsMap(t: TypeRef): bool {
    let result = false
    switch t {
        TypeRef.MapType(k, v) => { result = true },
        _ => {}
    }
    return result
}

_typeRefIsStringSimple(t: TypeRef): bool {
    let result = false
    switch t {
        TypeRef.Simple(tn) => {
            if tn == "string" { result = true }
        }
    }
    return result
}

// Reusable name sanitization: camelCase → snake_case + keyword escaping
sanitizeFieldName(name: string): string {
    // camelCase → snake_case: insert _ before uppercase, then lowercase
    let result = ""
    let i = 0
    for ch in name {
        if ch >= "A" && ch <= "Z" {
            if i > 0 {
                result += "_"
            }
            result += ch.toLowerCase()
        } else {
            result += ch
        }
        i += 1
    }
    return result
}

// Standalone version of `_toSnakeCase` (used by `collectBorrowedParams`).
toSnakeCaseStandalone(name: string): string {
    let allCaps = true
    for ch in name {
        let isUpper = ch >= "A" && ch <= "Z"
        let isUnderscore = ch == "_"
        let isDigit = ch >= "0" && ch <= "9"
        if not isUpper && not isUnderscore && not isDigit {
            allCaps = false
        }
    }
    if allCaps && name.length > 1 {
        return name
    }
    let result = ""
    let i = 0
    for ch in name {
        if ch >= "A" && ch <= "Z" {
            if i > 0 {
                result += "_"
            }
            result += ch.toLowerCase()
        } else {
            result += ch
        }
        i += 1
    }
    return result
}

// Standalone version of `_sanitizeName` (used by `collectBorrowedParams`).
sanitizeName(name: string): string {
    if name == "type" { return "r#type" }
    if name == "match" { return "r#match" }
    if name == "ref" { return "r#ref" }
    if name == "mod" { return "r#mod" }
    if name == "use" { return "r#use" }
    if name == "impl" { return "r#impl" }
    if name == "trait" { return "r#trait" }
    if name == "where" { return "r#where" }
    if name == "async" { return "r#async" }
    if name == "await" { return "r#await" }
    if name == "move" { return "r#move" }
    if name == "self" { return "self_" }
    if name == "default" { return "default_val" }
    return toSnakeCaseStandalone(name)
}

// Cycle 42 PoC — free function operating on a RustEmitter instance via
// `e: RustEmitter` and accessing private fields via `e._field`. Mirrors the
// pattern that A1 (modularize codegen.liva into multiple files) will use to
// move methods out of the class without needing partial-class support.
// Pattern validated: Liva already permits `e._privateField` access from
// outside the class (see `generateRust` which writes `emitter._enumVariantFields`).
inferArrowReturnType(e: RustEmitter, expr: Expr): string {
    let inferred = ""
    switch expr {
        Expr.Literal(lit) => {
            switch lit {
                Literal.Int(_) => { inferred = " -> i32" },
                Literal.Float(_) => { inferred = " -> f64" },
                Literal.Bool(_) => { inferred = " -> bool" },
                Literal.Str(_) => { inferred = " -> String" }
            }
        },
        Expr.Binary(op, _, _) => {
            switch op {
                BinOp.Lt => { inferred = " -> bool" },
                BinOp.Le => { inferred = " -> bool" },
                BinOp.Gt => { inferred = " -> bool" },
                BinOp.Ge => { inferred = " -> bool" },
                BinOp.Eq => { inferred = " -> bool" },
                BinOp.Ne => { inferred = " -> bool" },
                BinOp.And => { inferred = " -> bool" },
                BinOp.Or => { inferred = " -> bool" },
                _ => { inferred = " -> i32" }
            }
        },
        Expr.StringTemplate(_) => { inferred = " -> String" },
        Expr.Unary(_, _) => { inferred = " -> i32" },
        // `this.field` lookup using per-class field map populated by
        // `_emitClassImpl`. Only fires inside an `impl` block.
        Expr.MemberAccess(obj, prop) => {
            let isThis = false
            switch obj {
                Expr.Identifier(name) => {
                    if name == "this" {
                        isThis = true
                    }
                }
            }
            if isThis {
                if e._currentClassFieldRetSuffix.has(prop) {
                    inferred = e._currentClassFieldRetSuffix.get(prop)
                }
            }
        }
    }
    return inferred
}

// Cycle 43 (A1 step 1): pure helper `_isAllUnitEnum` extracted to a
// free function. Doesn't access RustEmitter state.
//
// NOTE on bootstrap limitation: the frozen Rust-based bootstrap has a
// latent bug — defining a SECOND free function in this file that
// `switch`-es on `Expr` corrupts the codegen state used by the
// `+=` → `.push_str(&...)` String concatenation optimization,
// producing invalid Rust (`String += String`) downstream. Until the
// bootstrap is regenerated, only ONE switch-on-Expr free function is
// supported (currently `inferArrowReturnType`). Other helpers that
// need pattern matching on Expr/Literal must remain class methods.
// See BACKLOG § Cycle 43 for the bisect log.
isAllUnitEnum(decl: EnumDecl): bool {
    for v in decl.variants {
        if v.fields.length > 0 { return false }
    }
    return true
}

// Cycle 45 (A1 step 2) — pure string-escape helpers extracted to free
// functions. No Expr switch, no RustEmitter state — not subject to
// BS-FRAG-1.
escapeRustStr(s: string): string {
    let result = s
    result = result.replace("\\", "\\\\")
    result = result.replace("\"", "\\\"")
    result = result.replace("\n", "\\n")
    result = result.replace("\t", "\\t")
    result = result.replace("\r", "\\r")
    result = result.replace("\0", "\\0")
    return result
}

escapeRustChar(s: string): string {
    let result = s
    result = result.replace("\\", "\\\\")
    result = result.replace("'", "\\'")
    result = result.replace("\n", "\\n")
    result = result.replace("\t", "\\t")
    result = result.replace("\r", "\\r")
    result = result.replace("\0", "\\0")
    return result
}

// Cycle 46 (A1 step 3) — pure BinOp → Rust operator string mapper.
binOpToRust(op: BinOp): string {
    let result = "/* op */"
    switch op {
        BinOp.Add => { result = "+" },
        BinOp.Sub => { result = "-" },
        BinOp.Mul => { result = "*" },
        BinOp.Div => { result = "/" },
        BinOp.Mod => { result = "%" },
        BinOp.Lt => { result = "<" },
        BinOp.Le => { result = "<=" },
        BinOp.Gt => { result = ">" },
        BinOp.Ge => { result = ">=" },
        BinOp.Eq => { result = "==" },
        BinOp.Ne => { result = "!=" },
        BinOp.And => { result = "&&" },
        BinOp.Or => { result = "||" },
        BinOp.Range => { result = ".." },
        BinOp.RangeInclusive => { result = "..=" }
    }
    return result
}

// Cycle 49 (A1 step 5) — pure method-name predicates extracted to free
// functions. No switches at all. BS-FRAG-1 safe.
isMutatingMethodName(m: string): bool {
    return m == "push" || m == "pop" || m == "remove" || m == "clear" || m == "insert" || m == "sort" || m == "reverse" || m == "extend" || m == "retain" || m == "truncate" || m == "set" || m == "add" || m == "delete" || m == "set_str" || m == "push_str"
}

isKnownStringMethod(m: string): bool {
    return m == "contains" || m == "replace" || m == "replaceAll" || m == "split" || m == "trim" || m == "trimStart" || m == "trimEnd" || m == "startsWith" || m == "endsWith" || m == "toUpperCase" || m == "toLowerCase" || m == "substring" || m == "indexOf" || m == "lastIndexOf" || m == "slice" || m == "padStart" || m == "padEnd" || m == "repeat" || m == "charAt" || m == "chars" || m == "bytes" || m == "capitalize" || m == "isBlank" || m == "isEmpty" || m == "removePrefix" || m == "removeSuffix" || m == "countMatches" || m == "truncate" || m == "reverse" || m == "toInt" || m == "toFloat" || m == "toString"
}

isKnownArrayMethod(m: string): bool {
    return m == "push" || m == "pop" || m == "map" || m == "filter" || m == "forEach" || m == "join" || m == "includes" || m == "indexOf" || m == "find" || m == "findIndex" || m == "some" || m == "every" || m == "reduce" || m == "slice" || m == "concat" || m == "sort" || m == "sortBy" || m == "groupBy" || m == "reverse" || m == "reversed" || m == "flat" || m == "flatMap" || m == "flatten" || m == "first" || m == "last" || m == "count" || m == "min" || m == "max" || m == "isEmpty" || m == "contains" || m == "distinct" || m == "sum" || m == "take" || m == "drop" || m == "zip" || m == "chunks" || m == "insert" || m == "remove"
}

isKnownMapMethod(m: string): bool {
    return m == "get" || m == "set" || m == "has" || m == "delete" || m == "keys" || m == "values" || m == "entries" || m == "clear" || m == "forEach" || m == "isEmpty"
}

isKnownSetMethod(m: string): bool {
    return m == "add" || m == "has" || m == "delete" || m == "clear" || m == "values" || m == "forEach" || m == "union" || m == "intersection" || m == "difference" || m == "isEmpty" || m == "size" || m == "count"
}

isKnownDateMethod(m: string): bool {
    return m == "format" || m == "add" || m == "diff"
}

// Cycle 50 (A1 step 6) — more pure helpers extracted to free functions.
emitSimpleType(name: string): string {
    if name == "string" { return "String" }
    if name == "number" { return "i32" }
    if name == "int" { return "i32" }
    if name == "float" { return "f64" }
    if name == "bool" { return "bool" }
    if name == "char" { return "char" }
    if name == "void" { return "()" }
    if name == "never" { return "!" }
    if name == "any" { return "serde_json::Value" }
    // User-defined type (class, enum) — keep PascalCase
    return name
}

sanitizeTestName(name: string): string {
    let result = ""
    for ch in name {
        let isLetter = ch >= "a" and ch <= "z"
        let isUpperLetter = ch >= "A" and ch <= "Z"
        let isDigit = ch >= "0" and ch <= "9"
        if isLetter or isUpperLetter or isDigit {
            result += ch.toLowerCase()
        } else if ch == " " or ch == "-" or ch == "/" {
            result += "_"
        }
        // skip other characters
    }
    return result
}

extractModuleName(source: string): string {
    // "./token.liva" → "token", "../utils.liva" → "utils"
    let name = $"{source}"
    let lastSlash = -1
    let idx = 0
    for ch in name {
        if ch == "/" {
            lastSlash = idx
        }
        idx += 1
    }
    if lastSlash >= 0 {
        name = name.slice(lastSlash + 1, name.length)
    }
    if name.endsWith(".liva") {
        name = name.slice(0, name.length - 5)
    }
    return name
}

// Cycle 51 (A1 step 7) — pure TypeRef helpers extracted to free functions.
// Switch on TypeRef (not Expr) so BS-FRAG-1 safe.
fieldDefault(optRef: TypeRef?): string {
    if optRef == null { return "Default::default()" }
    let result = "Default::default()"
    if optRef != null {
        let tref = optRef
        switch tref {
            TypeRef.Simple(n) => {
                if n == "number" || n == "int" { result = "0" }
                else if n == "float" { result = "0.0" }
                else if n == "bool" { result = "false" }
                else if n == "string" || n == "String" { result = "String::new()" }
                else if n == "char" { result = "'\\0'" }
            },
            TypeRef.Array(_) => { result = "Vec::new()" },
            TypeRef.MapType(_, _) => { result = "HashMap::new()" },
            TypeRef.SetType(_) => { result = "HashSet::new()" },
            TypeRef.OptionalType(_) => { result = "None" }
        }
    }
    return result
}

isMapType(optRef: TypeRef?): bool {
    if optRef != null {
        let isMap = false
        switch optRef {
            TypeRef.MapType(_, _) => { isMap = true }
        }
        return isMap
    }
    return false
}

// Cycle 53 — buildParamType extracted using e: RustEmitter pattern
// (proven by inferArrowReturnType in Cycle 42).
buildParamType(e: RustEmitter, optRef: TypeRef?): string {
    if optRef != null {
        return e._emitType(optRef)
    }
    return "/* inferred */"
}

buildReturnType(e: RustEmitter, optRef: TypeRef?, isFallible: bool): string {
    if optRef != null {
        let isAlreadyFallible = false
        switch optRef {
            TypeRef.Fallible(_) => { isAlreadyFallible = true }
        }
        let typeStr = e._emitType(optRef)
        if isFallible && not isAlreadyFallible {
            return $" -> Result<{typeStr}, liva_rt::Error>"
        }
        return $" -> {typeStr}"
    }
    if isFallible {
        return " -> Result<(), liva_rt::Error>"
    }
    return ""
}

fieldNeedsDebug(e: RustEmitter, optRef: TypeRef?): bool {
    if optRef != null {
        let needs = false
        switch optRef {
            TypeRef.Array(_) => { needs = true },
            TypeRef.MapType(_, _) => { needs = true },
            TypeRef.SetType(_) => { needs = true },
            TypeRef.OptionalType(_) => { needs = true },
            TypeRef.Tuple(_) => { needs = true },
            TypeRef.Simple(name) => {
                if e._globalEnums.has(name) { needs = true }
            }
        }
        return needs
    }
    return false
}

emitTupleType(em: RustEmitter, elems: [TypeRef]): string {
    let parts: [string] = []
    for e in elems {
        parts.push(em._emitType(e))
    }
    return $"({parts.join(", ")})"
}

emitGenericType(em: RustEmitter, base: string, args: [TypeRef]): string {
    let argParts: [string] = []
    for a in args {
        argParts.push(em._emitType(a))
    }
    return $"{base}<{argParts.join(", ")}>"
}

main() {
    print("codegen module loaded")
}
