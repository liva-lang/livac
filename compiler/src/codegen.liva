// ============================================================================
// codegen.liva — Rust Code Generator for the Liva self-hosting compiler
// ============================================================================
// Phase 3: Clean codegen that generates Rust mechanically from AST + TypeContext.
//
// Unlike the bootstrap codegen (~16K lines with ~20 HashSets guessing types),
// this codegen is TYPE-DIRECTED: every decision is based on resolved types
// from the semantic analyzer. No guessing, no heuristics, no name-based hacks.
//
// Architecture:
//   AST + TypeContext + LivenessContext → RustEmitter.generate() → String (Rust code)
//
// The RustEmitter accumulates output in a string buffer with indent management.
// Each AST node type has a dedicated emit method that writes Rust syntax.
//
// Codegen compat notes (bootstrap limitations — same as previous modules):
//   - W-001: No return inside switch arm blocks
//   - W-002: Variable name collisions across switch arms — use unique names
//   - W-003: $"{field}" for string copies to avoid move
//   - W-005: option_value_vars leak — use unique param names for Optional
//   - W-006: No bare return after => — use { return } blocks

import { TokenKind, Token } from "./token"
import {
    TypeRef, Expr, Stmt, BlockStmt, TopLevel, Program,
    FunctionDecl, ClassDecl, EnumDecl, EnumVariant, EnumField,
    MethodDecl, FieldDecl, Param, Member, Visibility,
    VarDeclStmt, VarBinding, ConstDecl, AssignStmt,
    IfStmt, IfBody, WhileStmt, ForStmt, SwitchStmt, TryCatchStmt,
    LambdaExpr, LambdaParam, LambdaBody, BindingPattern,
    SwitchArm, SwitchArmBody, Pattern, Literal, BinOp, UnOp,
    ExecPolicy, TypeParameter, TypeAliasDecl, ObjField, MapEntry,
    StringTemplatePart, ImportDecl, CaseClause, TestDecl
} from "./ast"
import {
    TypeContext, SemanticAnalyzer, FunctionSig, ParamSig,
    ClassInfo, FieldInfo, EnumInfo, VariantInfo, EnumFieldInfo,
    TypeAliasInfo, Symbol, SymbolKind, DiagnosticLevel, Diagnostic
} from "./semantic"
import {
    LivenessContext, isCopyTypeName
} from "./liveness"
import {
    isMutatingMethodName, isKnownStringMethod, isKnownArrayMethod,
    isKnownMapMethod, isKnownSetMethod, isKnownDateMethod
} from "./codegen_methods"
import {
    sanitizeFieldName, toSnakeCaseStandalone, sanitizeName,
    escapeRustStr, escapeRustChar, emitSimpleType,
    sanitizeTestName, extractModuleName
} from "./codegen_utils"
import {
    isAllUnitEnum, binOpToRust, fieldDefault, isMapType,
    typeRefToTag, isCopyType, getLiteralTypeName, blockStmts,
    buildTypeParamStr, paramTypeIsString, paramTypeIsMap,
    paramTypeIsBorrowable
} from "./codegen_types"

// =====================================================================
//  Stdlib runtime snippets (Phase 11 § A3)
// =====================================================================
// These are large Rust expressions emitted verbatim by stdlib lowering
// (DB, CSV, …). They previously lived as string literals duplicated up
// to 3× inside `_write(...)` calls, which made auditing impossible and
// drift between with/without-params variants likely. Centralizing them
// here keeps the lowering call-sites short and the snippets reviewable.

// CSV row-parsing closure body — used by CSV.read, CSV.readTable,
// CSV.parse. Takes a single `line: &str` (closed over via .map()) and
// returns Vec<String>.
const CSV_PARSE_LINE = "let mut fields = Vec::new(); let mut current = String::new(); let mut in_quotes = false; let mut chars = line.chars().peekable(); while let Some(c) = chars.next() { if in_quotes { if c == '\"' { if chars.peek() == Some(&'\"') { current.push('\"'); chars.next(); } else { in_quotes = false; } } else { current.push(c); } } else if c == '\"' { in_quotes = true; } else if c == ',' { fields.push(current.trim().to_string()); current = String::new(); } else { current.push(c); } } fields.push(current.trim().to_string()); fields"

// CSV row-escape used by CSV.write, CSV.writeTable, CSV.stringify.
const CSV_ESCAPE_FIELD = "if field.contains(',') || field.contains('\"') || field.contains('\\n') { format!(\"\\\"{}\\\"\" , field.replace('\"', \"\\\"\\\"\")) } else { field.clone() }"

// SQLite row → HashMap<String,String> closure body for DB.query.
// The closure takes `row: &rusqlite::Row` and returns Ok(map).
const DB_ROW_TO_MAP = "let count = row.as_ref().column_count(); let mut map = std::collections::HashMap::<String, String>::new(); for i in 0..count { let col_name = row.as_ref().column_name(i).unwrap_or(\"\").to_string(); let val: String = row.get::<_, rusqlite::types::Value>(i).map(|v| match v { rusqlite::types::Value::Null => String::new(), rusqlite::types::Value::Integer(n) => n.to_string(), rusqlite::types::Value::Real(f) => f.to_string(), rusqlite::types::Value::Text(s) => s, rusqlite::types::Value::Blob(b) => format!(\"{:?}\", b), }).unwrap_or_default(); map.insert(col_name, val); } Ok(map)"

// SQL parameter binding boilerplate — turns a Vec<String> into the
// `&[&dyn ToSql]` slice rusqlite wants. Used by DB.exec/DB.query when
// the user passes a 3rd arg with the bind list.
const DB_PARAM_BINDING = "let __params: Vec<String> = "  // followed by `<expr>.iter()…`
const DB_PARAM_BINDING_TAIL = ".iter().map(|s| s.to_string()).collect(); let __param_refs: Vec<&dyn rusqlite::types::ToSql> = __params.iter().map(|s| s as &dyn rusqlite::types::ToSql).collect();"

// =====================================================================
//  RustEmitter — accumulates Rust source code with indent management
// =====================================================================
// Design: output is a [string] buffer (one entry per write call).
// Final output is joined at the end. This avoids repeated string concat.
// Indent is tracked as a number; write_indent pushes spaces.

RustEmitter {
    _lines: [string]
    _currentLine: string
    _indentLevel: number
    _typeCtx: TypeContext
    _liveCtx: LivenessContext
    _currentFunc: string
    _inMethod: bool
    _currentClassName: string
    _classTypeParamStr: string
    _classTypeParamStrNoBounds: string
    _isMainModule: bool
    _inCompoundAdd: bool
    _suppressToString: bool
    _pushStrTarget: string
    _pushStrUsed: bool
    _enumVariantFields: Map<string, [string]>
    _enumVariantFieldBoxed: Map<string, [bool]>
    _enumVariantFieldOptional: Map<string, [bool]>
    _pendingDerefs: [string]
    _pendingRefClones: [string]
    _optionalVars: Map<string, bool>
    _mapVars: Map<string, bool>
    _setVars: Map<string, bool>
    _stringVars: Map<string, bool>
    _jsonValueVars: Map<string, bool>
    _currentReturnOptional: bool
    _currentReturnFallible: bool
    _inIfCondition: bool
    // ERR-UNIFY: tracks identifiers bound as Option<liva_rt::Error> via fallible
    // tuple destructure (let v, err = call()). Used to rewrite `if err` to
    // `if err.is_some()` since Rust requires bool.
    _errBindings: Map<string, bool>
    // B130 (truthy form, gen-2): err-bindings currently inside an
    // `if err { ... }` block. Within this scope, `err.message` must emit
    // `err.as_ref().unwrap().message.clone()` because the binding is still
    // `Option<liva_rt::Error>` but guaranteed `Some`.
    _truthyErrBindings: Map<string, bool>
    _inTestBlock: bool
    _derefClosureParams: bool
    _inAssignTarget: bool
    // B157: when true, suppress the trailing .clone() that Expr.Index
    // appends to non-Copy element accesses. Set by _emitMethodCall when
    // its receiver is an IndexExpr, so that arr[i].method() does not
    // clone the element first (which would silently lose mutations on
    // and-mut self methods like Particle.step (see B157 / RESULTS.md F.4).
    _suppressIndexElemClone: bool
    _usedTestNames: Map<string, int>
    _functionParamCount: Map<string, int>
    // GAP-007: for each function, a "fn-type-param" mask. Stored as a string
    // of "1"/"0" per param position so a Map<string,string> entry suffices.
    // At call sites, Lambda args at "1" positions are wrapped in Box::new.
    _functionFnParamMask: Map<string, string>
    _functionDefaultStrs: Map<string, string>
    _borrowedParamIndices: Map<string, bool>
    // Cycle 39: parallel registry — `bKey` entries here mean the borrowed
    // param is taken by `&mut T` (not just `&T`). Call sites emit `&mut arg`.
    _borrowedParamMutIndices: Map<string, bool>
    _suppressCloneForBorrow: bool
    _strRefParams: Map<string, bool>
    // Cycle 40: params emitted as `&HashMap`, `&Vec`, `&HashSet`, `&mut HashMap`, etc.
    // When such a name is used in arg position with isSingleUse=true, we still
    // need `.clone()` (dereferencing the borrow) instead of moving — you can't
    // move out of a `&T`. Without this, `parse(tokens) { Parser(tokens, ...) }`
    // tries to move `&Vec<Token>` into `Parser::new(tokens: Vec<Token>)`.
    _collRefParams: Map<string, bool>
    // Cross-module enum registry: populated via primeGlobalEnum() before generate()
    // so that field-type checks (e.g. _emitClassStruct's Default-derive logic)
    // recognize enums declared in OTHER modules. Without this, _typeCtx.enums
    // only contains enums from the current module.
    _globalEnums: Map<string, bool>
    // Per-class transitive set of methods that need &mut self.
    // Built once per class in _emitClass via fixpoint: direct mutations seed
    // the set, then any method that calls `this.<m>()` for m already in set
    // is added until no change. Mirrors bootstrap's `mut_self_methods`.
    _classMutMethods: Map<string, bool>
    // Per-program set of class names whose struct must NOT derive Default,
    // either because they directly contain an enum field (enums don't impl
    // Default) or because they transitively contain a class that doesn't
    // derive Default. Built once in `generate` via fixpoint.
    _noDefaultClasses: Map<string, bool>
    _enableStrRef: bool
    _buildParamIdx: number
    _currentFuncIsMethod: bool
    _lastEmittedStrRef: bool
    _currentFuncBorrowKey: string
    _forNeedsInnerClone: bool
    // Phase 10.1: tracks whether the statement currently being emitted is
    // the LAST one in its enclosing block. The entry-API peephole uses this,
    // combined with `liveCtx.declaredInLoop`, to elide defensive `.clone()`
    // on the key when the binding is dead after the rewrite.
    _stmtIsLastInBlock: bool
    // Phase 10.3: when true, iterator methods (map/filter/flatMap/take/skip/
    // takeWhile/skipWhile) emit only the iterator step and skip both the
    // leading `.iter().copied()` and the trailing `.collect::<Vec<_>>()` so
    // adjacent methods fuse into one iterator chain (no intermediate Vec).
    _inIterChain: bool
    // Phase 10.4: true when emitting an Expr in statement position (Stmt.ExprStmt).
    // Used by `arr.sort()` / `arr.reverse()` / `arr.reversed()` to elide the
    // `{ let mut __v = obj.clone(); __v.sort(); __v }` wrapper and emit just
    // `obj.sort()` (mutates in place — the wrapper's return value is discarded).
    _inExprStmt: bool
    // When true, the current block is in expression position (e.g. switch
    // arm body). The last stmt of such a block is a tail expression, so a
    // trailing `;` would discard the value. Propagated through if/else
    // bodies so nested if-as-tail works inside switch arms.
    _inExprBlock: bool
    // When true, the switch arm currently being emitted is in statement
    // position (parser produced `Stmt.ExprStmt(Expr.SwitchExpr(...))`).
    // Each arm body is wrapped to evaluate to `()` so arm types unify and
    // no `switch ... { ...; 0 }, _ => { 0 } }` workaround is needed.
    _switchInStmtPosition: bool
    // Cycle 29: pre-built return-type suffix per field for the class
    // currently being emitted. Used by `_inferArrowReturnType` so an arrow
    // method `_get() => this.value` infers its return type from the
    // class field declaration instead of falling back to `-> ()`. Keys are
    // field names; values are the Rust suffix string (e.g. " -> i32",
    // " -> String"). Empty when not inside a class impl.
    _currentClassFieldRetSuffix: Map<string, string>
    // B148: when emitting a constructor body, `this.X` reads are rewritten
    // to `__field_X` for fields that have already been assigned earlier
    // in the body. This lets constructors use field reads in conditions,
    // method calls (e.g. `this.items.push(...)`), and prints.
    _inConstructor: bool
    _constructorAssignedFields: Map<string, bool>
    // A.3: HTTP server routing. Vars assigned to `Server.create()` (axum::Router).
    // Detected at let init; used by _emitMethodCall to rewrite
    // `app.get(path, handler)` into `app = app.route(...)` etc.
    _serverVars: Map<string, bool>
    // BUG-3 fix: Vars assigned to `DB.open()` (Arc<Mutex<rusqlite::Connection>>).
    // Detected at fallible-destructure `let v, err = DB.open(...)`. Used by
    // `_emitServerRoute` to wrap each route in `{ let v = v.clone(); ... }` so
    // each async closure gets its own Arc clone (bootstrap parity).
    _dbVars: Map<string, bool>
    // A.3: when emitting an HTTP route handler lambda body, name of the
    // request param (lambda's first param). Inside the body, `req.params`
    // → `__params`, `req.body` → `body.clone()`,
    // `req.params.get("k")` → `__params.get(&"k".to_string()).cloned().unwrap_or_default()`.
    // Empty string means we're not inside a server handler.
    _serverRequestParam: string
    // A.3: pre-pass result. True iff the program contains a Server.create()
    // initializer or a top-level *.listen( call in the `main` function. When
    // set, `_emitFunction` will emit `#[tokio::main] async fn main`.
    _mainNeedsAsync: bool
    _taskHandleVars: Map<string, bool>
    // Cycle 32: pre-pass result. Set of free-function names (sanitized)
    // that are declared async (via `async fn` or `isAsyncInferred`). Used
    // by `task async f(args)` codegen to emit `.await` inside the spawned
    // closure so it returns the actual value, not a nested Future. Without
    // this `tokio::spawn(async move { fetch_page(&url) })` produces
    // JoinHandle<Future<...>> and `for t in &tasks { let r = t.await }`
    // fails to compile.
    _asyncFnNames: Map<string, bool>
    _warnings: [string]

    constructor(typeCtx: TypeContext, liveCtx: LivenessContext) {
        this._lines = []
        this._currentLine = ""
        this._indentLevel = 0
        this._typeCtx = typeCtx
        this._liveCtx = liveCtx
        this._currentFunc = ""
        this._inMethod = false
        this._currentClassName = ""
        this._classTypeParamStr = ""
        this._classTypeParamStrNoBounds = ""
        this._isMainModule = true
        this._inCompoundAdd = false
        this._suppressToString = false
        this._pushStrTarget = ""
        this._pushStrUsed = false
        this._enumVariantFields = Map {}
        this._enumVariantFieldBoxed = Map {}
        this._enumVariantFieldOptional = Map {}
        this._pendingDerefs = []
        this._pendingRefClones = []
        this._optionalVars = Map {}
        this._mapVars = Map {}
        this._setVars = Map {}
        this._stringVars = Map {}
        this._jsonValueVars = Map {}
        this._currentReturnOptional = false
        this._currentReturnFallible = false
        this._inIfCondition = false
        this._errBindings = Map {}
        this._truthyErrBindings = Map {}
        this._inTestBlock = false
        this._derefClosureParams = false
        this._inAssignTarget = false
        this._suppressIndexElemClone = false
        this._usedTestNames = Map {}
        this._functionParamCount = Map {}
        this._functionFnParamMask = Map {}
        this._functionDefaultStrs = Map {}
        this._borrowedParamIndices = Map {}
        this._borrowedParamMutIndices = Map {}
        this._globalEnums = Map {}
        this._classMutMethods = Map {}
        this._noDefaultClasses = Map {}
        this._suppressCloneForBorrow = false
        this._strRefParams = Map {}
        this._collRefParams = Map {}
        this._enableStrRef = true
        this._buildParamIdx = 0
        this._lastEmittedStrRef = false
        this._currentFuncBorrowKey = ""
        this._currentFuncIsMethod = false
        this._forNeedsInnerClone = false
        this._stmtIsLastInBlock = false
        this._inIterChain = false
        this._inExprStmt = false
        this._inExprBlock = false
        this._switchInStmtPosition = false
        this._currentClassFieldRetSuffix = Map {}
        this._inConstructor = false
        this._constructorAssignedFields = Map {}
        this._serverVars = Map {}
        this._dbVars = Map {}
        this._serverRequestParam = ""
        this._mainNeedsAsync = false
        this._taskHandleVars = Map {}
        this._asyncFnNames = Map {}
        this._warnings = []
    }

    setIsMainModule(isMain: bool) {
        this._isMainModule = isMain
    }

    // Phase 10.5 Bloque 1: register a borrowed param index from outside.
    // Public method so callers can prime the registry; uses `this` so the
    // self-host codegen recognizes `_borrowedParamIndices` as a Map field.
    primeBorrowedParam(bKey: string) {
        this._borrowedParamIndices.set(bKey, true)
    }

    // Cycle 39: register a `&mut`-borrowed param index from outside.
    primeBorrowedParamMut(bKey: string) {
        this._borrowedParamIndices.set(bKey, true)
        this._borrowedParamMutIndices.set(bKey, true)
    }

    // Cross-module enum registry: register an enum name declared in another
    // module so that field-type checks recognize it as an enum.
    primeGlobalEnum(name: string) {
        this._globalEnums.set(name, true)
    }

    getWarnings(): [string] {
        return this._warnings
    }

    _warn(msg: string) { warn(this, msg) }

    // -- Output primitives --

    _write(text: string) {
        this._currentLine += text
    }

    _writeln(text: string) {
        this._writeIndent()
        this._currentLine += text
        this._lines.push($"{this._currentLine}")
        this._currentLine = ""
    }

    _writeRaw(text: string) { writeRaw(this, text) }

    _newline() {
        this._lines.push($"{this._currentLine}")
        this._currentLine = ""
    }

    _writeIndent() { writeIndent(this) }

    _indent() { indent(this) }

    _dedent() { dedent(this) }

    _getOutput(): string {
        // Flush any remaining current line
        if this._currentLine != "" {
            this._lines.push($"{this._currentLine}")
            this._currentLine = ""
        }
        return this._lines.join("\n")
    }

    // -- Name sanitization --
    // Converts Liva identifiers to valid Rust identifiers.
    // camelCase → snake_case, keywords → r#keyword or renamed.

    _sanitizeName(name: string): string { return sanitizeName(name) }

    // A.5: Stdlib tuple-returning calls — File/Dir/CSV/DB/Process methods
    // that codegen emits as `(Option<T>, String)` directly (NOT Result).
    // For `let x, e = File.write(...)` we must skip the Result-wrap match.
    _isStdlibTupleCall(init: Expr): bool {
        let isMethodCall = false
        let nsName = ""
        switch init {
            Expr.MethodCall(obj, _method, _args) => {
                isMethodCall = true
                switch obj {
                    Expr.Identifier(name) => {
                        nsName = name
                    }
                }
            }
        }
        if !isMethodCall {
            // Async/par-wrapped form: `async HTTP.get(url)` parses as
            // Expr.Call(MethodCall(...), [], Async). Peek through the
            // empty-args wrapper so stdlib tuple destructuring still
            // works on those call sites.
            switch init {
                Expr.Call(inner, _wargs, _wpol, _wt) => {
                    switch inner {
                        Expr.MethodCall(obj2, _m2, _a2) => {
                            isMethodCall = true
                            switch obj2 {
                                Expr.Identifier(n2) => { nsName = n2 }
                            }
                        }
                    }
                }
            }
        }
        if !isMethodCall { return false }
        if nsName == "File" { return true }
        if nsName == "Dir" { return true }
        if nsName == "CSV" { return true }
        if nsName == "DB" { return true }
        if nsName == "Process" { return true }
        if nsName == "Http" || nsName == "HTTP" { return true }
        if nsName == "JSON" { return true }
        return false
    }

    // A.5 sub-2: stdlib tuple call where T has no Rust `Default` impl.
    // Returns a Rust expression to use as fallback in `__opt.unwrap_or_else(|| <expr>)`.
    // Empty string means T is Default-able and we use `__opt.unwrap_or_default()`.
    _stdlibTupleNoDefaultFallback(init: Expr): string {
        let objName = ""
        let methodName = ""
        switch init {
            Expr.MethodCall(obj, m, _) => {
                methodName = m
                switch obj {
                    Expr.Identifier(n) => { objName = n }
                }
            }
        }
        if objName == "DB" && methodName == "open" {
            return "std::sync::Arc::new(std::sync::Mutex::new(rusqlite::Connection::open_in_memory().unwrap()))"
        }
        return ""
    }

    _toSnakeCase(name: string): string { return toSnakeCaseStandalone(name) }

    // -- Type emission --
    // Converts Liva TypeRef to Rust type string.

    _emitType(t: TypeRef): string {
        // Defensive default: switch below covers all variants of TypeRef.
        // If a new variant is added without updating this function, _warn surfaces it.
        let result = "()"
        let matched = false
        switch t {
            TypeRef.Simple(name) => {
                result = this._emitSimpleType(name)
                matched = true
            },
            TypeRef.Array(inner) => {
                let arrInner = this._emitType(inner)
                result = "Vec<" + arrInner + ">"
                matched = true
            },
            TypeRef.MapType(k, v) => {
                let kStr = this._emitType(k)
                let vStr = this._emitType(v)
                result = "HashMap<" + kStr + ", " + vStr + ">"
                matched = true
            },
            TypeRef.SetType(inner) => {
                let setInner = this._emitType(inner)
                result = "HashSet<" + setInner + ">"
                matched = true
            },
            TypeRef.OptionalType(inner) => {
                let optInner = this._emitType(inner)
                result = "Option<" + optInner + ">"
                matched = true
            },
            TypeRef.Fallible(inner) => {
                let failInner = this._emitType(inner)
                result = "Result<" + failInner + ", liva_rt::Error>"
                matched = true
            },
            TypeRef.Tuple(elems) => {
                result = this._emitTupleType(elems)
                matched = true
            },
            TypeRef.Generic(base, args) => {
                result = this._emitGenericType(base, args)
                matched = true
            },
            TypeRef.Union(types) => {
                // Rust doesn't have union types; use first type as approximation
                this._warn("Union type approximated to first variant")
                for t in types {
                    result = this._emitType(t)
                    break
                }
                matched = true
            },
            TypeRef.FnType(params, ret) => {
                // GAP-007: function type — Box<dyn Fn(args) -> ret>
                let parts: [string] = []
                for p in params {
                    parts.push(this._emitType(p))
                }
                let retStr = this._emitType(ret)
                result = "Box<dyn Fn(" + parts.join(", ") + ") -> " + retStr + ">"
                matched = true
            }
        }
        if not matched {
            this._warn("Unhandled TypeRef variant in _emitType — emitting () as fallback")
        }
        return result
    }

    _emitSimpleType(name: string): string { return emitSimpleType(name) }

    _emitTupleType(elems: [TypeRef]): string { return emitTupleType(this, elems) }

    _emitGenericType(base: string, args: [TypeRef]): string { return emitGenericType(this, base, args) }

    // -- Top-level generation --

    generate(program: Program): string {
        // Cycle 32 + Cycle 35: pre-collect async free-fn names (fixpoint).
        // Must run BEFORE `_detectMainAsync` so transitive callers are
        // discovered when main's body scan consults `_asyncFnNames` via
        // `_exprIsAsyncTrigger`.
        let changed = true
        while changed {
            changed = false
            for item in program.items {
                switch item {
                    TopLevel.Function(fd) => {
                        let sn = this._sanitizeName(fd.name)
                        if this._asyncFnNames.has(sn) { continue }
                        let isAsync = fd.isAsyncInferred
                        if !isAsync {
                            let prevNeed = this._mainNeedsAsync
                            this._mainNeedsAsync = false
                            this._scanStmtsForAsyncOpt(fd.body)
                            if this._mainNeedsAsync { isAsync = true }
                            this._mainNeedsAsync = prevNeed
                        }
                        if isAsync {
                            this._asyncFnNames.set(sn, true)
                            changed = true
                        }
                    }
                }
            }
        }
        // A.3: pre-detect async-needs for `main` (HTTP server / .listen).
        this._detectMainAsync(program)
        // Pre-populate enum variant field registry from AST items
        // This registers field names for all enums defined in this module
        for item in program.items {
            switch item {
                TopLevel.Enum(decl) => {
                    this._registerEnumDeclFields(decl)
                }
            }
        }

        // Pre-pass: register borrowed (&str) param indices for all functions/methods
        // This must happen before emission so call-sites can look up borrow info
        if this._enableStrRef {
            for item in program.items {
                switch item {
                    TopLevel.Function(fd) => {
                        // Phase 10.5 Bloque 1: free functions register too. Cross-
                        // module callers receive the registry via generateRust /
                        // generateModuleRust priming. `main` cannot take a string.
                        if fd.name != "main" {
                            let rawFK = $"{fd.name}"
                            let sanFK = this._sanitizeName(fd.name)
                            this._preRegisterBorrowedParams(rawFK, sanFK, fd.params)
                        }
                    },
                    TopLevel.Class(cd) => {
                        let cn = $"{cd.name}"
                        for m in cd.members {
                            switch m {
                                Member.Method(md) => {
                                    // Phase 8.6: only private methods (_prefix)
                                    let mFirst = md.name.substring(0, 1)
                                    if mFirst == "_" {
                                        let rawMK = $"{cn}.{md.name}"
                                        let sanMK = $"{cn}.{this._sanitizeName(md.name)}"
                                        this._preRegisterBorrowedParams(rawMK, sanMK, md.params)
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // Pre-pass: build no-Default class set (transitive closure).
        // A class can't derive Default if any field is an enum (enums don't
        // impl Default) OR any field is another class already known to not
        // derive Default. Iterates to fixpoint so transitive cases like
        //   class A { x: B }   class B { x: SomeEnum }
        // both end up in the set.
        this._buildNoDefaultClasses(program)

        // Preamble: suppress common warnings and standard imports
        // Inner attributes (#![allow(...)]) only valid at crate root (main module)
        // use statements needed in every module that uses HashMap/HashSet
        if this._isMainModule {
            this._writeln("#![allow(unused_imports, unused_variables, unused_mut, unused_parens, dead_code, unused_assignments, unreachable_code, non_snake_case, while_true)]")
            // ERR-UNIFY: emit minimal liva_rt module with Error struct so user code
            // can return Result<T, liva_rt::Error> with chained-error trace support.
            this._writeln("#[allow(dead_code)]")
            this._writeln("mod liva_rt {")
            this._writeln("    #[derive(Debug, Clone)]")
            this._writeln("    pub struct Error {")
            this._writeln("        pub message: String,")
            this._writeln("        pub cause: Option<Box<Error>>,")
            this._writeln("    }")
            this._writeln("    impl PartialEq for Error {")
            this._writeln("        fn eq(&self, other: &Self) -> bool { self.message == other.message }")
            this._writeln("    }")
            this._writeln("    impl Error {")
            this._writeln("        pub fn from<S: Into<String>>(message: S) -> Self {")
            this._writeln("            Error { message: message.into(), cause: None }")
            this._writeln("        }")
            this._writeln("        pub fn chain<S: Into<String>>(message: S, cause: Error) -> Self {")
            this._writeln("            Error { message: message.into(), cause: Some(Box::new(cause)) }")
            this._writeln("        }")
            this._writeln("    }")
            this._writeln("    impl std::fmt::Display for Error {")
            this._writeln("        fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {")
            this._writeln("            write!(f, \"{}\", self.message)")
            this._writeln("        }")
            this._writeln("    }")
            this._writeln("    impl std::error::Error for Error {}")
            this._writeln("    // HTTP Response (Http.get/post/put/delete return value)")
            this._writeln("    #[derive(Debug, Clone, Default)]")
            this._writeln("    pub struct LivaHttpResponse {")
            this._writeln("        pub status: i64,")
            this._writeln("        pub status_text: String,")
            this._writeln("        pub body: String,")
            this._writeln("        pub headers: Vec<String>,")
            this._writeln("    }")
            this._writeln("    // Extension methods on serde_json::Value to mirror the")
            this._writeln("    // bootstrap JsonValue wrapper API used in user code")
            this._writeln("    // (.as_int / .as_float / .as_string / .as_bool /")
            this._writeln("    //  .as_array / .length).")
            this._writeln("    pub trait JsonValueExt {")
            this._writeln("        fn as_int(&self) -> i64;")
            this._writeln("        fn as_float(&self) -> f64;")
            this._writeln("        fn as_string(&self) -> String;")
            this._writeln("        fn as_bool_or(&self, def: bool) -> bool;")
            this._writeln("        fn as_array_owned(&self) -> Vec<serde_json::Value>;")
            this._writeln("        fn length(&self) -> usize;")
            this._writeln("    }")
            this._writeln("    impl JsonValueExt for serde_json::Value {")
            this._writeln("        fn as_int(&self) -> i64 { self.as_i64().unwrap_or(0) }")
            this._writeln("        fn as_float(&self) -> f64 { self.as_f64().unwrap_or(0.0) }")
            this._writeln("        fn as_string(&self) -> String {")
            this._writeln("            match self { serde_json::Value::String(s) => s.clone(), _ => self.to_string() }")
            this._writeln("        }")
            this._writeln("        fn as_bool_or(&self, def: bool) -> bool { self.as_bool().unwrap_or(def) }")
            this._writeln("        fn as_array_owned(&self) -> Vec<serde_json::Value> {")
            this._writeln("            match self { serde_json::Value::Array(a) => a.clone(), _ => Vec::new() }")
            this._writeln("        }")
            this._writeln("        fn length(&self) -> usize {")
            this._writeln("            match self {")
            this._writeln("                serde_json::Value::Array(a) => a.len(),")
            this._writeln("                serde_json::Value::Object(o) => o.len(),")
            this._writeln("                serde_json::Value::String(s) => s.chars().count(),")
            this._writeln("                _ => 0,")
            this._writeln("            }")
            this._writeln("        }")
            this._writeln("    }")
            this._writeln("}")
            this._writeln("#[allow(unused_imports)]")
            this._writeln("use crate::liva_rt::JsonValueExt as _;")
        } else {
            // Non-main modules need to reference the liva_rt module declared
            // at crate root (main module) so that `liva_rt::Error` resolves
            // in fallible function signatures emitted from this module.
            this._writeln("use crate::liva_rt;")
            this._writeln("#[allow(unused_imports)]")
            this._writeln("use crate::liva_rt::JsonValueExt as _;")
        }
        // Detect user classes that shadow std collection names so we can avoid
        // re-importing them (would cause E0255: name defined multiple times).
        let userHasHashMap = false
        let userHasHashSet = false
        for itm in program.items {
            switch itm {
                TopLevel.Class(cd) => {
                    if cd.name == "HashMap" { userHasHashMap = true }
                    if cd.name == "HashSet" { userHasHashSet = true }
                }
            }
        }
        let importMap = not userHasHashMap
        let importSet = not userHasHashSet
        if importMap && importSet {
            this._writeln("use std::collections::{HashMap, HashSet};")
        } else if importMap {
            this._writeln("use std::collections::HashMap;")
        } else if importSet {
            this._writeln("use std::collections::HashSet;")
        }
        this._writeln("use std::fmt::Write;")
        this._writeRaw("")

        // Generate all top-level items
        for item in program.items {
            this._emitTopLevel(item)
        }

        return this._getOutput()
    }

    _registerEnumDeclFields(decl: EnumDecl) {
        let enumName = $"{decl.name}"
        for v in decl.variants {
            let key = enumName + "::" + v.name
            let fieldNames: [string] = []
            let fieldBoxed: [bool] = []
            let fieldOptional: [bool] = []
            for f in v.fields {
                fieldNames.push(this._sanitizeName(f.name))
                // Check boxing and optional in a single pass
                let needsBox = false
                let isOpt = false
                switch f.typeRef {
                    TypeRef.Simple(typeName) => {
                        if this._typeCtx.enums.has(typeName) {
                            needsBox = true
                        }
                    },
                    TypeRef.OptionalType(_) => { isOpt = true }
                }
                fieldBoxed.push(needsBox)
                fieldOptional.push(isOpt)
            }
            this._enumVariantFields.set(key, fieldNames)
            this._enumVariantFieldBoxed.set(key, fieldBoxed)
            this._enumVariantFieldOptional.set(key, fieldOptional)
        }
    }

    // Register enum variant fields for cross-module enums
    // Called externally before generate() for enums defined in other modules
    registerExternalEnumFields(enumName: string, variantName: string, fieldNames: [string]) {
        let key = enumName + "::" + variantName
        this._enumVariantFields.set(key, fieldNames)
    }

    _emitTopLevel(item: TopLevel) {
        switch item {
            TopLevel.Function(decl) => { this._emitFunction(decl) },
            TopLevel.Class(decl) => { this._emitClass(decl) },
            TopLevel.Enum(decl) => { this._emitEnum(decl) },
            TopLevel.TypeAlias(decl) => { this._emitTypeAlias(decl) },
            TopLevel.ConstDecl(decl) => { this._emitConstDecl(decl) },
            TopLevel.Import(decl) => { this._emitImport(decl) },
            TopLevel.Test(decl) => { this._emitTestDecl(decl) },
            TopLevel.ExprStmt(expr) => { this._emitTopLevelExpr(expr) },
            // ClassExtension items are hoisted into their owner ClassDecl
            // before codegen runs (see module.liva). Skip if any survive.
            TopLevel.ClassExtension(_) => {}
        }
    }

    // =====================================================================
    //  Phase 3.1 complete — infrastructure + type emission + name sanitization
    //  Phase 3.2 starts here — declarations
    // =====================================================================

    // -- Top-level expression statement (describe, etc.) --

    _emitTopLevelExpr(expr: Expr) {
        // Check if this is a describe() call
        switch expr {
            Expr.Call(callee, callArgs, _, _) => {
                let fnName = ""
                switch callee {
                    Expr.Identifier(n) => { fnName = n }
                }
                if fnName == "describe" {
                    this._emitDescribe(callArgs)
                }
            },
            _ => {
                // Generic top-level expr
                this._writeIndent()
                this._emitExpr(expr)
                this._write(";")
                this._newline()
            }
        }
    }

    // -- Test framework: describe() / test() --
    // Implementation moved to codegen_test.liva via `extend RustEmitter`.

    // -- Test name sanitizer: "my test name!" → "my_test_name" --

    _sanitizeTestName(name: string): string { return sanitizeTestName(name) }

    // -- Import emission --

    _emitImport(decl: ImportDecl) {
        // Skip virtual module imports (liva/test, etc.)
        if decl.source.startsWith("liva/") {
            return
        }

        // Imports become mod/use statements in Rust
        // Only main module should emit 'mod X;' declarations
        let modName = this._extractModuleName(decl.source)
        if this._isMainModule {
            this._writeln("mod " + modName + ";")
        }        // Sub-modules need crate:: prefix to reference sibling modules
        let usePrefix = "crate::"
        if this._isMainModule {
            usePrefix = ""
        }
        if decl.isWildcard {
            this._writeln("use " + usePrefix + modName + "::*;")
        } else {
            let names: [string] = []
            for n in decl.imports {
                // Sanitize function names (lowercase start) to snake_case
                // Keep type/class names (uppercase start) as-is
                if n.length > 0 {
                    let fc = n.charAt(0)
                    if fc >= "A" && fc <= "Z" {
                        names.push(n)
                    } else {
                        names.push(this._sanitizeName(n))
                    }
                } else {
                    names.push(n)
                }
            }
            if names.length > 0 {
                let joined = names.join(", ")
                this._writeln("use " + usePrefix + modName + "::{" + joined + "};")
            }
        }
        this._writeRaw("")
    }

    _extractModuleName(source: string): string { return extractModuleName(source) }

    // -- Function declaration --

    // Cycle 36 — does this block end with a statement that always returns?
    // Used to decide whether a fallible function body needs an implicit
    // trailing `Ok(())`. We treat `Stmt.Return`, `Stmt.Fail`, `Stmt.Throw`
    // and any `Stmt.If` where both branches end with one of those as a
    // "definite return". Conservative: any other stmt (including a `for`
    // loop or expression stmt) means we still need the trailing Ok(()).
    _stmtsAlwaysReturn(stmts: [Stmt]): bool {
        let n = stmts.length
        if n == 0 { return false }
        let i = 0
        let last: Stmt = Stmt.Continue
        for s in stmts {
            if i == n - 1 { last = s }
            i = i + 1
        }
        return this._stmtAlwaysReturns(last)
    }

    _blockEndsWithReturn(bOpt: BlockStmt?): bool {
        if bOpt == null { return false }
        let result = false
        if bOpt != null {
            let b: BlockStmt = bOpt
            result = this._stmtsAlwaysReturn(b.stmts)
        }
        return result
    }

    _stmtAlwaysReturns(s: Stmt): bool {
        switch s {
            Stmt.Return(_) => { return true },
            Stmt.Fail(_, _) => { return true },
            Stmt.Throw(_) => { return true },
            Stmt.If(ifs) => {
                let eb = ifs.elseBranch
                if eb == null { return false }
                let thenStmts = this._ifBodyStmts(ifs.thenBranch)
                if !this._stmtsAlwaysReturn(thenStmts) { return false }
                if eb != null {
                    let ebVal: IfBody = eb
                    let elseStmts = this._ifBodyStmts(ebVal)
                    return this._stmtsAlwaysReturn(elseStmts)
                }
                return false
            },
            Stmt.Block(b3) => {
                return this._stmtsAlwaysReturn(b3.stmts)
            }
        }
        return false
    }

    _emitFunction(decl: FunctionDecl) {
        let funcName = this._sanitizeName(decl.name)
        let prevFunc = $"{this._currentFunc}"
        this._currentFunc = $"{decl.name}"
        this._currentFuncBorrowKey = $"{funcName}"
        this._currentFuncIsMethod = false
        let prevRetOpt = this._currentReturnOptional
        let prevRetFail = this._currentReturnFallible
        let prevStrRefParams = this._strRefParams
        let prevErrBindings = this._errBindings
        let prevTruthyErrBindings = this._truthyErrBindings
        this._currentReturnOptional = false
        this._currentReturnFallible = false
        this._strRefParams = Map {}
        this._errBindings = Map {}
        this._truthyErrBindings = Map {}

        // Register default parameter values for call-site injection
        this._functionParamCount.set(funcName, decl.params.length)
        // GAP-007: build per-param fn-type mask (1 = Box<dyn Fn> param, 0 = other).
        let fnMask = ""
        for fp in decl.params {
            let isFn = false
            let fpType = fp.typeRef
            if fpType != null {
                switch fpType {
                    TypeRef.FnType(_, _) => { isFn = true }
                }
            }
            if isFn { fnMask += "1" } else { fnMask += "0" }
        }
        this._functionFnParamMask.set(funcName, fnMask)
        let dIdx = 0
        for dp in decl.params {
            let dv = dp.defaultVal
            if dv != null {
                // Detect if default is a string literal via AST tag
                let isStrLit = false
                switch dv {
                    Expr.Literal(lit) => {
                        switch lit {
                            Literal.Str(_) => { isStrLit = true }
                        }
                    }
                }
                let dvStr = this._exprToString(dv)
                if isStrLit {
                    dvStr = dvStr + ".to_string()"
                }
                let key = funcName + ":" + dIdx.toString()
                this._functionDefaultStrs.set(key, dvStr)
            }
            dIdx += 1
        }

        // Build parameter list (also registers borrowed param indices)
        let paramList = this._buildParamList(decl.params)

        // Build return type and detect Optional return
        let retStr = this._buildReturnType(decl.returnType, decl.containsFail)
        if retStr.contains("Option<") {
            this._currentReturnOptional = true
        }
        if retStr.contains("Result<") {
            this._currentReturnFallible = true
        }

        // Build generic type params: <T: Clone, U: Clone>
        let typeParamStr = this._buildTypeParamStr(decl.typeParams)

        // Extract expression body once
        let feb = decl.exprBody

        if feb != null {
            // One-liner function: infer return type if not explicit
            if retStr == "" {
                let febProbe = decl.exprBody
                if febProbe != null {
                    let inferredFn = inferArrowReturnType(this, febProbe)
                    if inferredFn != "" {
                        retStr = inferredFn
                    } else {
                        retStr = " -> i32"
                    }
                } else {
                    retStr = " -> i32"
                }
            }
            // Determine async keyword
            let effectiveAsync = decl.isAsyncInferred
            let asyncKw = ""
            if effectiveAsync {
                asyncKw = "async "
                if funcName == "main" {
                    this._writeln("#[tokio::main]")
                }
            }
            // Emit function signature
            this._writeln("pub " + asyncKw + "fn " + funcName + typeParamStr + "(" + paramList + ")" + retStr + " {")
            this._indent()
            // Emit one-liner body
            this._writeIndent()
            this._write("return ")
            if this._currentReturnOptional {
                this._emitSomeWrapped(feb)
            } else {
                this._emitExpr(feb)
            }
            this._write(";")
            this._newline()
        } else {
            // Block-bodied function
            let effectiveAsync2 = decl.isAsyncInferred
            if !effectiveAsync2 && funcName == "main" && this._mainNeedsAsync {
                effectiveAsync2 = true
            }
            // For non-main functions: scan body for triggers (await,
            // Server.listen, task-based calls). Reuse the same scanner used
            // for main inference by snapshotting _mainNeedsAsync.
            if !effectiveAsync2 && funcName != "main" {
                let prevNeed = this._mainNeedsAsync
                this._mainNeedsAsync = false
                let bOpt2 = decl.body
                if bOpt2 != null {
                    this._scanStmtsForAsync(bOpt2)
                }
                if this._mainNeedsAsync { effectiveAsync2 = true }
                this._mainNeedsAsync = prevNeed
            }
            let asyncKw2 = ""
            if effectiveAsync2 {
                asyncKw2 = "async "
                if funcName == "main" {
                    this._writeln("#[tokio::main]")
                }
            }
            this._writeln("pub " + asyncKw2 + "fn " + funcName + typeParamStr + "(" + paramList + ")" + retStr + " {")
            this._indent()
            // Cycle 36 — snapshot whether the body already ends with an
            // unconditional return/fail BEFORE we move `decl.body` into
            // _emitBlockOpt. We also detect whether the inferred result
            // type wraps `()` by inspecting the emitted retStr — fast and
            // avoids a second walk of `decl.returnType` (already moved).
            let bodyEndsInReturn = this._blockEndsWithReturn(decl.body.clone())
            this._emitBlockOpt(decl.body)
            // ERR-UNIFY: fallible function body must end with a value of
            // the Result type. For main we always emit Ok(()). For other
            // fallible fns we append Ok(()) when the return type is
            // Result<()...> and the body doesn't already end with a
            // return/fail statement (avoiding unreachable_code).
            if this._currentReturnFallible {
                let appendOk = false
                if funcName == "main" {
                    appendOk = true
                } else {
                    // retStr looks like " -> Result<(), liva_rt::Error>"
                    // or " -> Result<T, liva_rt::Error>". Check for unit.
                    let isUnitFallible = retStr.contains("Result<()")
                    if isUnitFallible && !bodyEndsInReturn {
                        appendOk = true
                    }
                }
                if appendOk {
                    this._writeln("Ok(())")
                }
            }
        }

        this._dedent()
        this._writeln("}")
        this._writeRaw("")

        this._currentFunc = prevFunc
        this._currentReturnOptional = prevRetOpt
        this._currentReturnFallible = prevRetFail
        this._strRefParams = prevStrRefParams
        this._errBindings = prevErrBindings
        this._truthyErrBindings = prevTruthyErrBindings
    }

    // B.4: emit `test "name" { ... }` as `#[test] fn test_<sanitized>() { ... }`.
    // Mirrors bootstrap `generate_test` (livac/src/codegen.rs:4745).
    _emitTestDecl(decl: TestDecl) {
        let testName = this._sanitizeTestName(decl.name)
        this._writeln("#[test]")
        this._writeln("fn test_" + testName + "() {")
        this._indent()
        let prevFunc = $"{this._currentFunc}"
        let prevRetOpt = this._currentReturnOptional
        let prevRetFail = this._currentReturnFallible
        let prevStrRefParams = this._strRefParams
        let prevErrBindings = this._errBindings
        let prevTruthyErrBindings = this._truthyErrBindings
        this._currentFunc = "test_" + testName
        this._currentFuncBorrowKey = "test_" + testName
        this._currentFuncIsMethod = false
        this._currentReturnOptional = false
        this._currentReturnFallible = false
        this._strRefParams = Map {}
        this._errBindings = Map {}
        this._truthyErrBindings = Map {}
        this._emitBlock(decl.body)
        this._dedent()
        this._writeln("}")
        this._writeRaw("")
        this._currentFunc = prevFunc
        this._currentReturnOptional = prevRetOpt
        this._currentReturnFallible = prevRetFail
        this._strRefParams = prevStrRefParams
        this._errBindings = prevErrBindings
        this._truthyErrBindings = prevTruthyErrBindings
    }

    _buildParamList(params: [Param]): string {
        let parts: [string] = []
        this._buildParamIdx = 0
        for p in params {
            let paramStr = this._buildParam(p)
            parts.push(paramStr)
            this._buildParamIdx += 1
        }
        return parts.join(", ")
    }

    _buildTypeParamStr(typeParams: [TypeParameter]): string { return buildTypeParamStr(typeParams) }

    _buildParam(p: Param): string {
        // Bootstrap workaround: switch consumes the value, so we extract the name
        // ONCE here and use the local string for both `rawName` and `paramName`.
        // Avoids E0382 (`use of moved value`) on the second switch arm.
        let extractedName = switch p.pattern {
            BindingPattern.Identifier(n) => n,
            _ => "_"
        }
        let rawName = $"{extractedName}"
        let paramName = $"{extractedName}"
        let sanitized = this._sanitizeName(paramName)
        let typeStr = this._buildParamType(p.typeRef)
        // Register collection params for `or value` / type dispatch tracking.
        if typeStr.contains("HashMap") { this._mapVars.set(sanitized, true) }
        else if typeStr.contains("HashSet") { this._setVars.set(sanitized, true) }
        else if typeStr == "String" || typeStr == "&str" { this._stringVars.set(sanitized, true) }
        // Phase 8.5: if param is borrowable string and doesn't escape → &str
        // BOOTSTRAP GATE: only apply &str opt when _enableStrRef is true
        // Phase 10.5 Bloque 1: extended to free functions. Cross-module callers
        // get borrow info via the global registry primed in generateRust /
        // generateModuleRust. `main` is excluded (cannot take a string param).
        if this._enableStrRef && (this._currentFuncIsMethod || not this._inMethod) && typeStr == "String" && this._currentFunc != "main" {
            let key = $"{this._currentFunc}:{rawName}"
            let isBorrow = 0
            if this._liveCtx.paramBorrow.has(key) {
                isBorrow = this._liveCtx.paramBorrow.get(key)
            }
            let isEscape = 0
            if this._liveCtx.paramEscapes.has(key) {
                isEscape = this._liveCtx.paramEscapes.get(key)
            }
            if isBorrow == 1 && isEscape == 0 {
                this._strRefParams.set(sanitized, true)
                // Also register borrowed param index for callers
                let bKey = $"{this._currentFuncBorrowKey}:{this._buildParamIdx}"
                this._borrowedParamIndices.set(bKey, true)
                return $"{sanitized}: &str"
            }
        }
        // Cycle 38 — auto-`&HashMap<K,V>` for Map params that are only read.
        // Cycle 39 — auto-`&mut HashMap<K,V>` for Map params mutated locally
        // but not escaping (return / this.field / other.field). Liveness
        // distinguishes mutated (mutating method receiver) from escape.
        // Cycle 40 — same treatment for Vec<T> (and Cycle 41 for HashSet<T>).
        let isBorrowableContainer = typeStr.contains("HashMap") || typeStr.startsWith("Vec<") || typeStr.startsWith("HashSet<")
        if this._enableStrRef && (this._currentFuncIsMethod || not this._inMethod) && isBorrowableContainer && this._currentFunc != "main" {
            let key = $"{this._currentFunc}:{rawName}"
            let isBorrow = 0
            if this._liveCtx.paramBorrow.has(key) {
                isBorrow = this._liveCtx.paramBorrow.get(key)
            }
            let isEscape = 0
            if this._liveCtx.paramEscapes.has(key) {
                isEscape = this._liveCtx.paramEscapes.get(key)
            }
            let isMutated = 0
            if this._liveCtx.paramMutated.has(key) {
                isMutated = this._liveCtx.paramMutated.get(key)
            }
            if isBorrow == 1 && isEscape == 0 {
                let bKey = $"{this._currentFuncBorrowKey}:{this._buildParamIdx}"
                this._borrowedParamIndices.set(bKey, true)
                this._collRefParams.set(sanitized, true)
                if isMutated == 1 {
                    this._borrowedParamMutIndices.set(bKey, true)
                    return $"{sanitized}: &mut {typeStr}"
                }
                return $"{sanitized}: &{typeStr}"
            }
        }
        return $"mut {sanitized}: {typeStr}"
    }

    // Pre-pass: register borrowed param indices for all functions/methods
    // so call-sites can look up borrow info before the method body is emitted
    _preRegisterBorrowedParams(rawFuncKey: string, sanFuncKey: string, params: [Param]) {
        let pIdx = 0
        for p in params {
            let rawName = switch p.pattern {
                BindingPattern.Identifier(n) => n,
                _ => "_"
            }
            let typeStr = this._buildParamType(p.typeRef)
            let isBorrowable = false
            if typeStr == "String" { isBorrowable = true }
            // Cycle 38/40/41 — register Map/Vec/Set params as borrowed when
            // liveness says they don't escape. Same gate as String above.
            else if typeStr.contains("HashMap") { isBorrowable = true }
            else if typeStr.startsWith("Vec<") { isBorrowable = true }
            else if typeStr.startsWith("HashSet<") { isBorrowable = true }
            if isBorrowable {
                // Liveness key uses raw func name and raw param name
                let livenessKey = $"{rawFuncKey}:{rawName}"
                let isBorrow = 0
                if this._liveCtx.paramBorrow.has(livenessKey) {
                    isBorrow = this._liveCtx.paramBorrow.get(livenessKey)
                }
                let isEscape = 0
                if this._liveCtx.paramEscapes.has(livenessKey) {
                    isEscape = this._liveCtx.paramEscapes.get(livenessKey)
                }
                let isMutated = 0
                if this._liveCtx.paramMutated.has(livenessKey) {
                    isMutated = this._liveCtx.paramMutated.get(livenessKey)
                }
                if isBorrow == 1 && isEscape == 0 {
                    // Borrow key uses sanitized func name and param index
                    let bKey = $"{sanFuncKey}:{pIdx}"
                    this._borrowedParamIndices.set(bKey, true)
                    if isMutated == 1 {
                        this._borrowedParamMutIndices.set(bKey, true)
                    }
                }
            }
            pIdx += 1
        }
    }

    _buildParamType(optRef: TypeRef?): string { return buildParamType(this, optRef) }

    // B148: default initializer for a field that the constructor body does
    // not explicitly assign to. Mirrors bootstrap behavior.
    _fieldDefault(optRef: TypeRef?): string { return fieldDefault(optRef) }

    // B125: Helper that returns true when the optional TypeRef is a Map<K,V>.
    _isMapType(optRef: TypeRef?): bool { return isMapType(optRef) }

    // Cycle 42 — _inferArrowReturnType extracted to free function
    // `inferArrowReturnType(e: RustEmitter, expr)` (see bottom of file). This
    // method is the thin wrapper kept for backwards-compat / readability; the
    // body lives below the class declaration as a proof-of-concept that the
    // partial-class-via-free-functions pattern works (unblocks A1).

    _buildReturnType(optRef: TypeRef?, isFallible: bool): string { return buildReturnType(this, optRef, isFallible) }

    // Infer Rust type from an expression (for one-liner functions without explicit return type)
    _inferExprType(expr: Expr): string {
        let result = ""
        switch expr {
            Expr.Literal(lit) => {
                switch lit {
                    Literal.Int(_) => { result = "i32" },
                    Literal.Float(_) => { result = "f64" },
                    Literal.Bool(_) => { result = "bool" },
                    Literal.Str(_) => { result = "String" }
                }
            },
            Expr.Binary(op, left, right) => {
                switch op {
                    BinOp.Lt => { result = "bool" },
                    BinOp.Le => { result = "bool" },
                    BinOp.Gt => { result = "bool" },
                    BinOp.Ge => { result = "bool" },
                    BinOp.Eq => { result = "bool" },
                    BinOp.Ne => { result = "bool" },
                    BinOp.And => { result = "bool" },
                    BinOp.Or => { result = "bool" },
                    _ => {
                        // Arithmetic ops: infer from operands
                        result = this._inferExprType(left)
                        if result == "" { result = this._inferExprType(right) }
                    }
                }
            },
            Expr.StringTemplate(_) => { result = "String" },
            Expr.ArrayLiteral(_) => { result = "Vec<i32>" },
            Expr.Unary(_, inner) => {
                result = this._inferExprType(inner)
            }
        }
        return result
    }

    // -- Class declaration --

    _emitTypeAlias(decl: TypeAliasDecl) {
        let aliasName = $"{decl.name}"
        let targetStr = this._emitType(decl.targetType)
        this._writeln($"pub type {aliasName} = {targetStr};")
        this._writeRaw("")
    }

    // -- Const declaration --

    _emitConstDecl(decl: ConstDecl) {
        let constName = this._sanitizeName(decl.name)
        let typeStr = this._buildParamType(decl.typeRef)
        let initExpr = decl.init
        // Infer const type from init expression when not explicit
        if typeStr == "/* inferred */" {
            switch initExpr {
                Expr.Literal(lit) => {
                    switch lit {
                        Literal.Int(_) => { typeStr = "i32" },
                        Literal.Float(_) => { typeStr = "f64" },
                        Literal.Bool(_) => { typeStr = "bool" },
                        Literal.Str(_) => { typeStr = "&str" }
                    }
                }
            }
        }
        // Const string must be &str, not String. Also coerce explicit
        // `string` annotations (which build to `String`) to `&str`, since
        // Rust forbids non-const `String::to_string` in const contexts
        // (E0015). Cycle 37.
        if typeStr == "String" { typeStr = "&str" }
        let isConstStr = typeStr == "&str"
        this._writeIndent()
        if isConstStr {
            this._write($"const {constName}: &str = ")
            // Emit string literal without .to_string() using buffer
            let initStr = this._exprToString(initExpr)
            if initStr.endsWith(".to_string()") {
                initStr = initStr.slice(0, initStr.length - 12)
            }
            this._write(initStr)
        } else {
            this._write($"pub const {constName}: {typeStr} = ")
            this._emitExpr(initExpr)
        }
        this._write(";")
        this._newline()
        this._writeRaw("")
    }

    // =====================================================================
    //  Phase 3.3 — Statements
    // =====================================================================

    // Helper: check if an expression is a simple non-reserved identifier
    // NOTE: This helper is not used inline due to move semantics.
    // Instead, .clone() is added unconditionally to match discriminants.

    _emitBlockOpt(body: BlockStmt?) {
        if body != null {
            this._emitBlock(body)
        }
    }

    _emitBlock(block: BlockStmt) {
        let stmts = block.stmts
        let total = stmts.length
        let prev = this._stmtIsLastInBlock
        // Phase 10.4: peephole — fuse `let X = e.split(s); for Y in X { ... }`
        // into a single `for Y in e.split(s) { ... }`. We use a [Stmt] buffer
        // (length 0 or 1) to hold the candidate let so we can fall back to
        // emitting it normally if the next stmt isn't the matching for-loop.
        let heldBuf: [Stmt] = []
        let heldName = ""
        let heldInit: Expr = Expr.Identifier("")
        let idx = 0
        for s in stmts {
            let isLast = (idx == total - 1) && (heldBuf.length == 0)
            let consumed = false
            // 1) If we hold a candidate, peek `s` to see if it matches.
            if heldBuf.length > 0 {
                let forVar = ""
                let forBody: BlockStmt = BlockStmt([])
                let matched = false
                switch s {
                    Stmt.For(fs) => {
                        if fs.variable2 == null {
                            switch fs.iterable {
                                Expr.Identifier(itn) => {
                                    if itn == heldName {
                                        forVar = fs.variable
                                        forBody = fs.body
                                        matched = true
                                    }
                                }
                            }
                        }
                    }
                }
                if matched {
                    let liveKey = $"{this._currentFunc}:{heldName}"
                    if this._liveCtx.useCounts.has(liveKey) && this._liveCtx.useCounts.get(liveKey) == 1 {
                        // Discard held; emit fused for-loop using held init.
                        let _ = heldBuf.pop()
                        this._stmtIsLastInBlock = isLast
                        let fused = ForStmt(forVar, null, heldInit, forBody)
                        this._emitFor(fused)
                        consumed = true
                    }
                }
                if not consumed {
                    // Fusion failed — flush the held let normally.
                    let heldStmt = heldBuf.pop()
                    this._stmtIsLastInBlock = false
                    this._emitStmt(heldStmt)
                }
            }
            // 2) If s wasn't fused, decide: hold or emit.
            if not consumed {
                let candName = ""
                let candInit: Expr = Expr.Identifier("")
                let isCandidate = false
                switch s {
                    Stmt.VarDecl(d) => {
                        if d.bindings.length == 1 && not d.isFallible {
                            let bIdx = 0
                            for b in d.bindings {
                                if bIdx == 0 {
                                    switch b.pattern {
                                        BindingPattern.Identifier(n) => { candName = n }
                                    }
                                }
                                bIdx += 1
                            }
                            let dInit = d.init
                            switch dInit {
                                Expr.MethodCall(_, m, mArgs) => {
                                    if m == "split" && mArgs.length > 0 {
                                        isCandidate = true
                                        candInit = dInit
                                    }
                                }
                            }
                        }
                    }
                }
                if isCandidate && candName != "" {
                    heldBuf.push(s)
                    heldName = candName
                    heldInit = candInit
                } else {
                    this._stmtIsLastInBlock = isLast
                    this._emitStmt(s)
                }
            }
            idx = idx + 1
        }
        if heldBuf.length > 0 {
            let heldStmt = heldBuf.pop()
            this._stmtIsLastInBlock = true
            this._emitStmt(heldStmt)
        }
        this._stmtIsLastInBlock = prev
    }

    _blockStmts(block: BlockStmt): [Stmt] { return blockStmts(block) }

    _emitStmt(stmt: Stmt) {
        switch stmt {
            Stmt.VarDecl(decl) => { this._emitVarDecl(decl) },
            Stmt.ConstDecl(cdecl) => { this._emitConstDecl(cdecl) },
            Stmt.Assign(asgn) => { this._emitAssign(asgn) },
            Stmt.If(ifStmt) => { this._emitIf(ifStmt) },
            Stmt.While(wStmt) => { this._emitWhile(wStmt) },
            Stmt.For(fStmt) => { this._emitFor(fStmt) },
            Stmt.Switch(swStmt) => { this._emitSwitch(swStmt) },
            Stmt.TryCatch(tcStmt) => { this._emitTryCatch(tcStmt) },
            Stmt.Throw(throwExpr) => {
                this._writeIndent()
                this._write("panic!(\"{}\"")
                // Simplified: just panic with the expression
                this._write(", ")
                this._emitExpr(throwExpr)
                this._write(");")
                this._newline()
            },
            Stmt.Fail(failExpr, line) => {
                this._writeIndent()
                // If failExpr is an identifier bound as an error binding
                // (Option<liva_rt::Error>), re-raise it directly using its
                // own message. Otherwise emit format!("{}", expr).
                let failIsErrBind = false
                let failErrName = ""
                switch failExpr {
                    Expr.Identifier(fn0) => {
                        let fSan = this._sanitizeName(fn0)
                        if this._errBindings.has(fSan) {
                            failIsErrBind = true
                            failErrName = fSan
                        }
                    }
                }
                if failIsErrBind {
                    this._write("return Err(liva_rt::Error::from(")
                    this._write(failErrName)
                    this._write(".as_ref().unwrap().message.clone()));")
                } else {
                    this._write("return Err(liva_rt::Error::from(format!(\"{}\", ")
                    this._emitExpr(failExpr)
                    this._write(")));")
                }
                this._newline()
            },
            Stmt.Return(retExpr) => { this._emitReturn(retExpr) },
            Stmt.Break => { this._writeln("break;") },
            Stmt.Continue => { this._writeln("continue;") },
            Stmt.ExprStmt(expr) => {
                // Modern arrow-form switch in statement position:
                // `switch x { Pat => stmt, _ => {} }` parses to
                // Stmt.ExprStmt(Expr.SwitchExpr(...)) — emit it as a Rust
                // `match { ... };` whose arms each evaluate to `()` so the
                // user does NOT need a `switch ... { ... }, _ => {} }`
                // wrapper or trailing `0` filler in each arm.
                let isSwitchStmt = false
                switch expr {
                    Expr.SwitchExpr(_, _) => { isSwitchStmt = true }
                }
                if isSwitchStmt {
                    switch expr {
                        Expr.SwitchExpr(disc, arms) => {
                            this._writeIndent()
                            let savedFlag = this._switchInStmtPosition
                            this._switchInStmtPosition = true
                            this._emitSwitchExpr(disc, arms)
                            this._switchInStmtPosition = savedFlag
                            this._write(";")
                            this._newline()
                        }
                    }
                    return
                }
                this._writeIndent()
                let savedExprStmt = this._inExprStmt
                this._inExprStmt = true
                this._emitExpr(expr)
                this._inExprStmt = savedExprStmt
                // Suppress trailing `;` when this is the tail expression of an
                // expression block (e.g. switch arm body, or an if-body nested
                // inside one). The value is yielded back to the surrounding
                // expression instead of being discarded.
                let isTailInExprBlock = false
                if this._inExprBlock {
                    if this._stmtIsLastInBlock {
                        isTailInExprBlock = true
                    }
                }
                if isTailInExprBlock {
                    // omit `;` — value yields from the expression block
                } else {
                    this._write(";")
                }
                this._newline()
            },
            Stmt.Block(blk) => {
                this._writeln("{")
                this._indent()
                this._emitBlock(blk)
                this._dedent()
                this._writeln("}")
            },
            Stmt.Defer(deferStmt) => {
                // Defer uses a guard pattern in Rust
                this._writeln("// defer (simplified — full impl in Phase 3 refinement)")
                this._emitStmt(deferStmt)
            }
        }
    }

    // -- Variable declaration --

    _emitVarDecl(decl: VarDeclStmt) {
        // Special case: let val, err = fallibleFn() — 2 Identifier bindings with isFallible
        if decl.isFallible && decl.bindings.length == 2 {
            let bName0 = ""
            let bName1 = ""
            let bIdx = 0
            for b in decl.bindings {
                switch b.pattern {
                    BindingPattern.Identifier(bn) => {
                        if bIdx == 0 { bName0 = bn }
                        else { bName1 = bn }
                    }
                }
                bIdx += 1
            }
            if bName0 != "" && bName1 != "" {
                let valName = this._sanitizeName(bName0)
                let errName = this._sanitizeName(bName1)
                // ERR-UNIFY: register err-binding for `if err` rewrite
                this._errBindings.set(errName, true)
                this._optionalVars.set(errName, true)
                // BUG-3 fix: track DB.open result so route closures get cloned
                let initSnapDb = decl.init
                switch initSnapDb {
                    Expr.MethodCall(dbObj, dbMethod, _) => {
                        if dbMethod == "open" {
                            switch dbObj {
                                Expr.Identifier(dbObjName) => {
                                    if dbObjName == "DB" && valName != "_" {
                                        this._dbVars.set(valName, true)
                                    }
                                }
                            }
                        }
                        if dbMethod == "parse" {
                            switch dbObj {
                                Expr.Identifier(jObjName) => {
                                    if jObjName == "JSON" && valName != "_" {
                                        this._jsonValueVars.set(valName, true)
                                    }
                                }
                            }
                        }
                    }
                }
                this._writeIndent()
                this._write("let (")
                if valName == "_" {
                    this._write("_")
                } else {
                    this._write("mut ")
                    this._write(valName)
                }
                this._write(", ")
                if errName == "_" {
                    this._write("_")
                } else {
                    this._write("mut ")
                    this._write(errName)
                }
                // A.5: stdlib calls (File/Dir/CSV/DB/Process) emit a tuple
                // `(Option<T>, String)` directly — no Result wrap. Convert
                // the String err to Option<liva_rt::Error> on the fly so
                // the `if err` rewrite (`.is_some()`) keeps working.
                let initExpr0 = decl.init
                let isStdlibTuple0 = this._isStdlibTupleCall(initExpr0)
                if isStdlibTuple0 {
                    let fallbackInit0 = decl.init
                    let fallback0 = this._stdlibTupleNoDefaultFallback(fallbackInit0)
                    this._write(") = { let (__opt, __err) = ")
                    this._emitExpr(decl.init)
                    if fallback0 == "" {
                        this._write("; (__opt.unwrap_or_default(), if __err.is_empty() { None } else { Some(liva_rt::Error::from(__err)) }) };")
                    } else {
                        this._write("; (__opt.unwrap_or_else(|| ")
                        this._write(fallback0)
                        this._write("), if __err.is_empty() { None } else { Some(liva_rt::Error::from(__err)) }) };")
                    }
                } else {
                    this._write(") = match ")
                    this._emitExpr(decl.init)
                    this._write(" { Ok(v) => (v, None), Err(e) => (Default::default(), Some(e)) };")
                }
                this._newline()
                return
            }
        }
        // Single-binding stdlib tuple unwrap: `let x = JSON.parse(s)` (or any
        // other File/Dir/CSV/DB/Http/JSON tuple-returning method) used WITHOUT
        // destructure should yield the bare value, not the (Option<T>, String)
        // tuple. Without this, downstream `x.method()` / `x[k]` would target
        // the tuple type and fail E0608/E0599. Mirrors the destructure path
        // by emitting `let mut x = { let (__opt, __err) = <call>; __opt.unwrap_or_default() };`.
        if not decl.isFallible && decl.bindings.length == 1 {
            let isSimpleIdent = false
            let bName = ""
            for bSingle in decl.bindings {
                switch bSingle.pattern {
                    BindingPattern.Identifier(n) => { isSimpleIdent = true; bName = n }
                }
            }
            let initProbeS = decl.init
            let isStdTupS = this._isStdlibTupleCall(initProbeS)
            if isSimpleIdent && isStdTupS {
                let sanU = this._sanitizeName(bName)
                // Track JSON.parse single-binding so .forEach / iteration on
                // the resulting serde_json::Value is rewritten correctly.
                let initProbeJ = decl.init
                switch initProbeJ {
                    Expr.MethodCall(jObj, jMethod, _) => {
                        if jMethod == "parse" {
                            switch jObj {
                                Expr.Identifier(jObjName) => {
                                    if jObjName == "JSON" && sanU != "_" {
                                        this._jsonValueVars.set(sanU, true)
                                    }
                                }
                            }
                        }
                    }
                }
                this._writeIndent()
                if sanU == "_" {
                    this._write("let _ = ")
                } else {
                    this._write($"let mut {sanU} = ")
                }
                this._write("{ let (__opt, __err) = ")
                this._emitExpr(decl.init)
                this._write("; let _ = __err; __opt.unwrap_or_default() };")
                this._newline()
                return
            }
        }
        for b in decl.bindings {
            this._emitBinding(b, decl)
        }
    }

    _emitBinding(b: VarBinding, decl: VarDeclStmt) {
        switch b.pattern {
            BindingPattern.Identifier(name) => {
                this._emitSimpleBinding(name, b.typeRef, decl)
            },
            BindingPattern.TuplePat(elements) => {
                this._emitTupleBinding(elements, decl)
            },
            BindingPattern.ObjectPat(fields) => {
                // Destructuring — emit let { field1, field2, .. } = expr;
                this._writeIndent()
                this._write("let ")
                // Simplified: treat as separate let bindings
                this._emitExpr(decl.init)
                this._write(";")
                this._newline()
            },
            BindingPattern.ArrayPat(elements, rest) => {
                this._writeIndent()
                this._write("let [")
                let idx = 0
                for e in elements {
                    if idx > 0 { this._write(", ") }
                    // W-010: e is string? — extract to local for null-check
                    let eName = e
                    if eName != null {
                        let sn = this._sanitizeName(eName)
                        this._write(sn)
                    }
                    idx += 1
                }
                this._write("] = ")
                this._emitExpr(decl.init)
                this._write(";")
                this._newline()
            }
        }
    }

    _emitSimpleBinding(name: string, optTypeRef: TypeRef?, decl: VarDeclStmt) {
        let sanitized = this._sanitizeName(name)

        // A.3: track `let app = Server.create()` so subsequent
        // `app.get/post/put/delete/listen` calls emit axum routing.
        let initSnap = decl.init
        switch initSnap {
            Expr.MethodCall(initObj, initMethod, _) => {
                if initMethod == "create" {
                    switch initObj {
                        Expr.Identifier(initObjName) => {
                            if initObjName == "Server" {
                                this._serverVars.set(sanitized, true)
                            }
                        }
                    }
                }
            }
        }

        // Propagate JSON-value tracking through index/member access so that
        // downstream operations (string-key indexing, .is_null() null check,
        // .forEach rewrite) work on derivatives like `let coin = data[coinId]`.
        let initJsonSnap = decl.init
        switch initJsonSnap {
            Expr.Index(jIdxObj, _) => {
                switch jIdxObj {
                    Expr.Identifier(jIdxObjName) => {
                        let jSan = this._sanitizeName(jIdxObjName)
                        if this._jsonValueVars.has(jSan) && sanitized != "_" {
                            this._jsonValueVars.set(sanitized, true)
                        }
                    }
                }
            },
            Expr.MemberAccess(jMaObj, _) => {
                switch jMaObj {
                    Expr.Identifier(jMaObjName) => {
                        let jSan2 = this._sanitizeName(jMaObjName)
                        if this._jsonValueVars.has(jSan2) && sanitized != "_" {
                            this._jsonValueVars.set(sanitized, true)
                        }
                    }
                }
            }
        }

        let initTaskSnap2 = decl.init
        switch initTaskSnap2 {
            Expr.Call(_, _, taskPolicy, _) => {
                let isTaskPolicy = switch taskPolicy {
                    ExecPolicy.TaskAsync => true,
                    ExecPolicy.TaskPar => true,
                    _ => false
                }
                if isTaskPolicy && sanitized != "_" {
                    this._taskHandleVars.set(sanitized, true)
                }
            }
        }

        this._writeIndent()

        // Determine mutability — skip mut for _ (Rust doesn't allow let mut _)
        if sanitized == "_" {
            this._write("let _")
        } else {
            this._write($"let mut {sanitized}")
        }

        // Emit type annotation if present, and detect Optional/Map/Set/String types
        let isOptionalType = false
        let initExprTag = ""
        if optTypeRef != null {
            let typeStr = this._emitType(optTypeRef)
            this._write($": {typeStr}")
            if typeStr.startsWith("Option<") {
                isOptionalType = true
            }
            // Track var type from annotation
            if typeStr.contains("HashMap") { initExprTag = "map" }
            else if typeStr.contains("HashSet") { initExprTag = "set" }
            else if typeStr == "String" || typeStr == "&str" { initExprTag = "string" }
        }
        if isOptionalType {
            this._optionalVars.set(sanitized, true)
        }
        if initExprTag == "map" { this._mapVars.set(sanitized, true) }
        if initExprTag == "set" { this._setVars.set(sanitized, true) }
        if initExprTag == "string" { this._stringVars.set(sanitized, true) }

        this._write(" = ")

        // Track whether init produces an owned value (binary ops, calls, etc.)
        let initIsOwned = false

        // Handle fallible init (or fail / or value)
        if decl.isFallible {
            let orVal = decl.orValue
            if orVal != null {
                // or <value> → expr.unwrap_or(fallback) — works for both Option AND Result
                this._emitExpr(decl.init)
                // Strip trailing .unwrap() if present (Map.get etc add it)
                let lineCheck = $"{this._currentLine}"
                if lineCheck.endsWith(".unwrap()") {
                    this._currentLine = lineCheck.substring(0, lineCheck.length - 9)
                }
                this._write(".unwrap_or(")
                this._emitExpr(orVal)
                this._write(")")
            } else {
                // ERR-UNIFY or fail msg variant
                let orMsg = decl.orFailMsg
                let bufBefore = this._currentLine.length
                this._emitExpr(decl.init)
                let emittedLine = $"{this._currentLine}"
                let isOptionInit = false
                if emittedLine.length > bufBefore {
                    let suffix = emittedLine.substring(bufBefore, emittedLine.length)
                    if suffix.endsWith(".unwrap()") {
                        isOptionInit = true
                        this._currentLine = emittedLine.substring(0, emittedLine.length - 9)
                    } else if suffix.endsWith(".parse::<i32>().unwrap_or(0)") {
                        // toInt() shortcut → strip default to expose Result<i32, _>
                        this._currentLine = emittedLine.substring(0, emittedLine.length - 13)
                    } else if suffix.endsWith(".parse::<f64>().unwrap_or(0.0)") {
                        this._currentLine = emittedLine.substring(0, emittedLine.length - 15)
                    }
                }
                if this._inTestBlock || not this._currentReturnFallible {
                    if isOptionInit {
                        this._write(" { Some(v) => v, None => panic!(\"{}\", ")
                        if orMsg != null { this._emitExpr(orMsg) } else { this._write("\"or fail\"") }
                        this._write(") }")
                    } else {
                        let initStr = this._currentLine.substring(bufBefore, this._currentLine.length)
                        this._currentLine = this._currentLine.substring(0, bufBefore)
                        this._write("match ")
                        this._write(initStr)
                        this._write(" { Ok(v) => v, Err(e) => panic!(\"{}\", e) }")
                    }
                } else {
                    if isOptionInit {
                        let initOpt = this._currentLine.substring(bufBefore, this._currentLine.length)
                        this._currentLine = this._currentLine.substring(0, bufBefore)
                        this._write("match ")
                        this._write(initOpt)
                        this._write(" { Some(v) => v, None => return Err(liva_rt::Error::from(format!(\"{}\", ")
                        if orMsg != null { this._emitExpr(orMsg) } else { this._write("\"or fail\"") }
                        this._write(")))}")
                    } else if orMsg != null {
                        let initRes = this._currentLine.substring(bufBefore, this._currentLine.length)
                        this._currentLine = this._currentLine.substring(0, bufBefore)
                        this._write("match ")
                        this._write(initRes)
                        this._write(" { Ok(v) => v, Err(e) => return Err(liva_rt::Error::chain(format!(\"{}\", ")
                        this._emitExpr(orMsg)
                        this._write("), liva_rt::Error::from(format!(\"{}\", e)))) }")
                    } else {
                        this._write("?")
                    }
                }
            }
        } else {
            // B?: empty object literal `{}` typed as Set should produce HashSet,
            // not the default ObjectLiteral lowering (HashMap-flavoured).
            // Detect via cloned init to avoid moving fields out.
            let emittedSetEmpty = false
            if initExprTag == "set" {
                let initClone = decl.init
                switch initClone {
                    Expr.ObjectLiteral(oFields) => {
                        if oFields.length == 0 {
                            this._write("HashSet::new()")
                            emittedSetEmpty = true
                        }
                    }
                }
            }
            if emittedSetEmpty {
                this._write(";")
                this._newline()
                return
            }
            // Check for or-value pattern: Binary(Or, Call/MethodCall, value)
            // All emission paths MUST be inside switch arms to avoid partial move
            switch decl.init {
                Expr.Binary(op, left, right) => {
                    initIsOwned = true
                    let isOr = false
                    switch op {
                        BinOp.Or => { isOr = true }
                    }
                    if isOr {
                        let isCall = false
                        let isFreeCall = false
                        switch left {
                            Expr.Call(_, _, _, _) => { isCall = true; isFreeCall = true },
                            Expr.MethodCall(_, _, _) => { isCall = true }
                        }
                        // Detect collection .get() returning Option<V> (NOT a fallible
                        // tuple). For these, emit `.cloned().unwrap_or(default)` directly.
                        let isOptionGet = false
                        switch left {
                            Expr.MethodCall(mObj, mName, _) => {
                                if mName == "get" || mName == "first" || mName == "last" || mName == "find" {
                                    let mTag = this._getExprTypeName(mObj)
                                    if mTag == "map" || mTag == "array" || mTag == "set" {
                                        isOptionGet = true
                                    } else {
                                        switch mObj {
                                            Expr.Identifier(gn) => {
                                                let sn = this._sanitizeName(gn)
                                                if this._mapVars.has(sn) { isOptionGet = true }
                                            },
                                            // B125: also handle `obj.field.get(...)` where
                                            // `field` is a known Map field/var name.
                                            Expr.MemberAccess(_, mp) => {
                                                let sp = this._sanitizeName(mp)
                                                if this._mapVars.has(sp) { isOptionGet = true }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        if isOptionGet {
                            // Re-emit the inner method call without the trailing
                            // .unwrap() that the standard Map.get path adds, so we
                            // can append .unwrap_or(default).
                            switch left {
                                Expr.MethodCall(mObj, mName, mArgs) => {
                                    this._emitOptionGetWithDefault(mObj, mName, mArgs, right)
                                }
                            }
                        } else if isFreeCall {
                            // User-defined fallible call → returns Result<T, Error>.
                            // Lower `expr or <default>` to `match expr { Ok(v) => v, Err(_) => default }`.
                            this._write("match ")
                            this._emitExpr(left)
                            this._write(" { Ok(v) => v, Err(_) => ")
                            this._emitExpr(right)
                            this._write(" }")
                        } else if isCall {
                            // B140: detect MethodCall toInt/toFloat first — these
                            // are NOT (Option<T>, String) tuples but `.parse::<T>()
                            // .unwrap_or(0)` chains. Re-emit as parse with custom
                            // default instead of falling through to the tuple path.
                            let isParseOr = false
                            let parseTy = ""
                            switch left {
                                Expr.MethodCall(_, mName, _) => {
                                    if mName == "toInt" { isParseOr = true; parseTy = "i32" }
                                    if mName == "toFloat" { isParseOr = true; parseTy = "f64" }
                                }
                            }
                            if isParseOr {
                                switch left {
                                    Expr.MethodCall(pObj, _, _) => {
                                        this._emitExpr(pObj)
                                        this._write(".parse::<")
                                        this._write(parseTy)
                                        this._write(">().unwrap_or(")
                                        this._emitExpr(right)
                                        this._write(")")
                                    }
                                }
                            } else {
                                // MethodCall (stdlib / user methods) → emits inline
                                // (Option<T>, String) tuple expression.
                                this._write("{ let (opt, err_str) = ")
                                this._emitExpr(left)
                                this._write("; if !err_str.is_empty() { ")
                                this._emitExpr(right)
                                this._write(" } else { opt.unwrap_or_default() } }")
                            }
                        } else {
                            this._emitBinary(op, left, right)
                        }
                    } else {
                        this._emitBinary(op, left, right)
                    }
                },
                _ => {
                    if isOptionalType {
                        this._emitSomeWrapped(decl.init)
                    } else {
                        this._emitExpr(decl.init)
                    }
                }
            }
        }

        // Detect Set/Map from emitted init expression (for untyped bindings like let s = Set {...})
        // Skip when the user has defined a class named HashSet/HashMap — that
        // would shadow std collections and the binding refers to the user class.
        if initExprTag == "" && sanitized != "_" {
            if this._currentLine.contains("HashSet") {
                if not this._typeCtx.classes.has("HashSet") {
                    this._setVars.set(sanitized, true)
                }
            } else if this._currentLine.contains("HashMap") {
                if not this._typeCtx.classes.has("HashMap") {
                    this._mapVars.set(sanitized, true)
                }
            }
        }

        // Clone let binding inits only for cases that need it (variables, field access)
        // Skip clone for: Copy literals, already cloned, function calls (return owned),
        // constructors, string literals, array/map literals, binary ops producing owned values
        let skipClone = true
        if sanitized != "_" {
            // Need clone: ends with a variable name or field access (not a call, literal, etc.)
            // Don't clone if line already has .clone()
            let line = this._currentLine
            if line.endsWith(".clone()") {
                skipClone = true
            } else if line.endsWith(")") {
                // Function call / constructor / Some() — returns owned value
                skipClone = true
            } else if line.endsWith("}") {
                // Block expression, map literal — returns owned
                skipClone = true
            } else if line.endsWith("]") {
                // Array literal — returns owned
                skipClone = true
            } else if line.endsWith("\"") {
                // String literal
                skipClone = true
            } else if line.endsWith("= false") || line.endsWith("= true") || line.endsWith("= 0") || line.endsWith("= 1") {
                // Copy literals
                skipClone = true
            } else if line.endsWith("_f64") || line.endsWith("_i32") || line.endsWith("as i32") || line.endsWith("as f64") {
                // Numeric casts
                skipClone = true
            } else if line.endsWith(".to_string()") {
                // String conversion — already owned
                skipClone = true
            } else if line.endsWith("= None") {
                // None is always Copy
                skipClone = true
            } else if initIsOwned {
                // Binary ops, etc. produce owned values — no clone needed
                skipClone = true
            } else {
                // Identifier or member access — needs clone
                // But enum variants (contain ::) are value constructors, always owned
                if line.contains("::") {
                    skipClone = true
                } else {
                    // Phase 8: Check if init is a numeric literal
                    // A line like "let mut x = 50" ends with "= <digits>"
                    // Detect by checking: init expression was a Copy literal
                    // Safe approach: search for "= " and verify what follows is numeric
                    let eqIdx = line.indexOf("= ")
                    let isNumLiteral = false
                    let afterEq = ""
                    if eqIdx >= 0 {
                        afterEq = line.substring(eqIdx + 2, line.length)
                        if afterEq.length > 0 {
                            let firstCh = afterEq.substring(0, 1)
                            let lastCh = afterEq.substring(afterEq.length - 1, afterEq.length)
                            // Starts and ends with digit = numeric literal
                            // Also handle negative: starts with - followed by digit
                            if firstCh >= "0" && firstCh <= "9" && lastCh >= "0" && lastCh <= "9" {
                                isNumLiteral = true
                            }
                            if firstCh == "-" && lastCh >= "0" && lastCh <= "9" && afterEq.length >= 2 {
                                isNumLiteral = true
                            }
                        }
                    }
                    if isNumLiteral {
                        skipClone = true
                    } else {
                        // Phase 8.9: liveness-based let-binding clone elision
                        if this._lastEmittedStrRef {
                            // &str param → always .to_string()
                            skipClone = false
                        } else {
                            // Check if afterEq is a simple identifier (no dots, calls, indexing)
                            let isSimpleIdent = afterEq.length > 0
                            if afterEq.contains(".") || afterEq.contains("(") || afterEq.contains("[") || afterEq.contains("{") || afterEq.contains("\"") || afterEq.contains("!") || afterEq.contains(" ") {
                                isSimpleIdent = false
                            }
                            if isSimpleIdent {
                                let origName = afterEq
                                if origName.startsWith("r#") { origName = origName.substring(2, origName.length) }
                                let liveKey = $"{this._currentFunc}:{origName}"
                                if this._liveCtx.useCounts.has(liveKey) {
                                    let uc = this._liveCtx.useCounts.get(liveKey)
                                    let inLoop = this._liveCtx.loopUseCounts.has(liveKey)
                                    let declaredInLoop = this._liveCtx.declaredInLoop.has(liveKey)
                                    if uc <= 1 && (not inLoop || declaredInLoop) {
                                        skipClone = true
                                    } else {
                                        skipClone = false
                                    }
                                } else {
                                    skipClone = false
                                }
                            } else {
                                skipClone = false
                            }
                        }
                    }
                }
            }
        }
        if not skipClone {
            // Phase 8.6: &str params — .clone() on &str gives &str, need .to_string() for String
            if this._lastEmittedStrRef {
                this._write(".to_string()")
            } else {
                this._write(".clone()")
            }
        }

        this._write(";")
        this._newline()
    }

    _emitTupleBinding(elements: [string], decl: VarDeclStmt) {
        // Special case: let val, err = fallibleFn() → match expr { Ok(v) => (v, None), Err(e) => (Default, Some(e)) }
        if decl.isFallible && elements.length == 2 {
            this._writeIndent()
            let valName = this._sanitizeName(elements[0])
            let errName = this._sanitizeName(elements[1])
            // ERR-UNIFY: register err-binding for if-condition rewrite (`if err` → `if err.is_some()`)
            this._errBindings.set(errName, true)
            this._optionalVars.set(errName, true)
            this._write("let (")
            if valName == "_" {
                this._write("_")
            } else {
                this._write("mut ")
                this._write(valName)
            }
            this._write(", ")
            if errName == "_" {
                this._write("_")
            } else {
                this._write("mut ")
                this._write(errName)
            }
            // A.5: stdlib tuple-returning calls — see `_isStdlibTupleCall`.
            let initExpr1 = decl.init
            let isStdlibTuple1 = this._isStdlibTupleCall(initExpr1)
            if isStdlibTuple1 {
                let fallbackInit1 = decl.init
                let fallback1 = this._stdlibTupleNoDefaultFallback(fallbackInit1)
                this._write(") = { let (__opt, __err) = ")
                this._emitExpr(decl.init)
                if fallback1 == "" {
                    this._write("; (__opt.unwrap_or_default(), if __err.is_empty() { None } else { Some(liva_rt::Error::from(__err)) }) };")
                } else {
                    this._write("; (__opt.unwrap_or_else(|| ")
                    this._write(fallback1)
                    this._write("), if __err.is_empty() { None } else { Some(liva_rt::Error::from(__err)) }) };")
                }
            } else {
                this._write(") = match ")
                this._emitExpr(decl.init)
                this._write(" { Ok(v) => (v, None), Err(e) => (Default::default(), Some(e)) };")
            }
            this._newline()
            return
        }
        this._writeIndent()
        this._write("let (")
        let idx = 0
        for e in elements {
            if idx > 0 { this._write(", ") }
            let sn = this._sanitizeName(e)
            this._write(sn)
            idx += 1
        }
        this._write(") = ")
        this._emitExpr(decl.init)
        this._write(";")
        this._newline()
    }

    // -- Some() wrapping for optional values --
    // Emits expression wrapped with Some() unless it's a Null literal (emits None)
    // Handles each Expr variant in ONE pass to avoid double-consume

    _emitSomeWrapped(expr: Expr) {
        switch expr {
            Expr.Literal(lit) => {
                switch lit {
                    Literal.Null => { this._write("None") },
                    _ => { this._write("Some("); this._emitLiteral(lit); this._write(")") }
                }
            },
            Expr.Identifier(iName) => {
                let san = this._sanitizeName(iName)
                if san == "null" or san == "None" {
                    this._write("None")
                } else if this._optionalVars.has(san) {
                    // Already Optional — don't double-wrap
                    this._write($"{san}.clone()")
                } else {
                    this._write($"Some({san}.clone())")
                }
            },
            Expr.Binary(op, left, right) => {
                this._write("Some(")
                this._emitBinary(op, left, right)
                this._write(")")
            },
            Expr.Call(callee, args, ep, ta) => {
                this._write("Some(")
                this._emitExpr(Expr.Call(callee, args, ep, ta))
                this._write(")")
            },
            Expr.MethodCall(mcObj, mcMethod, mcArgs) => {
                this._write("Some(")
                this._emitExpr(Expr.MethodCall(mcObj, mcMethod, mcArgs))
                this._write(")")
            },
            Expr.MemberAccess(maObj, maProp) => {
                this._write("Some(")
                this._emitExpr(Expr.MemberAccess(maObj, maProp))
                this._write(")")
            },
            Expr.StructLiteral(slName, slFields) => {
                this._write("Some(")
                this._emitExpr(Expr.StructLiteral(slName, slFields))
                this._write(")")
            },
            Expr.StringTemplate(parts) => {
                this._write("Some(")
                this._emitExpr(Expr.StringTemplate(parts))
                this._write(")")
            },
            Expr.Unary(op, operand) => {
                this._write("Some(")
                this._emitExpr(Expr.Unary(op, operand))
                this._write(")")
            },
            Expr.ArrayLiteral(elements) => {
                this._write("Some(")
                this._emitExpr(Expr.ArrayLiteral(elements))
                this._write(")")
            },
            Expr.SwitchExpr(disc, arms) => {
                this._write("Some(")
                this._emitExpr(Expr.SwitchExpr(disc, arms))
                this._write(")")
            },
            Expr.Lambda(lam) => {
                this._write("Some(")
                this._emitExpr(Expr.Lambda(lam))
                this._write(")")
            },
            Expr.Index(idxObj, idxExpr) => {
                this._write("Some(")
                this._emitExpr(Expr.Index(idxObj, idxExpr))
                this._write(")")
            },
            Expr.Ternary(cond, thenE, elseE) => {
                this._write("Some(")
                this._emitExpr(Expr.Ternary(cond, thenE, elseE))
                this._write(")")
            },
            _ => {
                // Phase 9.10: emit Some(<expr>) instead of todo!() — produces working code
                // for unhandled Expr variants. _warn surfaces the case for review.
                this._warn("Optional wrapping fallback for complex expression")
                this._write("Some(")
                this._emitExpr(expr)
                this._write(")")
            }
        }
    }

    // -- Assignment --

    _emitAssign(stmt: AssignStmt) {
        this._writeIndent()

        let assignOp = stmt.op
        if assignOp != null {
            let opStr = this._binOpToRust(assignOp)
            if opStr == "+" {
                this._emitCompoundAdd(stmt.target, stmt.value)
            } else {
                this._inAssignTarget = true
                this._emitExpr(stmt.target)
                this._inAssignTarget = false
                this._write($" {opStr}= ")
                this._emitExpr(stmt.value)
            }
        } else {
            // Handle assignment — check if target is an optional variable
            // We destructure stmt.target in ONE pass to avoid double-consume
            // Bootstrap workaround: bind target/value to locals to avoid partial-move E0382
            let stTarget = stmt.target
            let stValue = stmt.value
            switch stTarget {
                Expr.Identifier(varName) => {
                    let vnCopy = $"{varName}"
                    let san = this._sanitizeName(varName)
                    // Phase 8.4: detect x = x + y → push_str chain (only for Binary(+) rooted at target)
                    let isStringVar = this._isStringExpr(stTarget)
                    let isPushStrCandidate = false
                    if isStringVar && !this._optionalVars.has(san) {
                        switch stValue {
                            Expr.Binary(bop, left, _) => {
                                let bopStr = this._binOpToRust(bop)
                                if bopStr == "+" {
                                    isPushStrCandidate = this._leftmostLeafIsTarget(left, san)
                                }
                            }
                        }
                    }
                    if isPushStrCandidate {
                        this._pushStrTarget = $"{san}"
                        this._pushStrUsed = false
                        this._emitExpr(stValue)
                        this._pushStrTarget = ""
                    } else {
                        this._write(san)
                        this._write(" = ")
                        if this._optionalVars.has(san) {
                            this._emitSomeWrapped(stValue)
                        } else {
                            // Fallback: check type context for Optional
                            let varTypeRef = this._lookupVarTypeRef(vnCopy)
                            let varTag = this._typeRefToTag(varTypeRef)
                            if varTag == "optional" {
                                this._optionalVars.set(san, true)
                                this._emitSomeWrapped(stValue)
                            } else {
                                this._emitExpr(stValue)
                            }
                        }
                    }
                },
                Expr.MemberAccess(maObj, maProp) => {
                    this._emitExpr(maObj)
                    let snProp = this._sanitizeName(maProp)
                    this._write($".{snProp}")
                    this._write(" = ")
                    this._emitExpr(stValue)
                },
                Expr.Index(idxObj, idxExpr) => {
                    // B116: suppress self.field auto-clone on assign target
                    this._inAssignTarget = true
                    this._emitExpr(idxObj)
                    this._inAssignTarget = false
                    this._write("[(")
                    this._emitExpr(idxExpr)
                    this._write(") as usize]")
                    this._write(" = ")
                    this._emitExpr(stValue)
                },
                _ => {
                    // Fallback — emit without Some wrapping
                    this._write("/* assign */ ")
                    this._emitExpr(stValue)
                }
            }
        }

        this._write(";")
        this._newline()
    }

    _emitCompoundAdd(target: Expr, value: Expr) {
        // Check TARGET type to determine string vs numeric +=
        // Default to numeric unless target is known to be a string
        let isString = this._isStringExpr(target)
        // Also check if VALUE is a string — implies target must be string too
        if not isString {
            isString = this._isStringExpr(value)
        }

        if isString {
            // String compound add: target.push_str(&value)
            this._inAssignTarget = true
            this._emitExpr(target)
            this._inAssignTarget = false
            let isLitStr = false
            switch value {
                Expr.Literal(lit2) => {
                    switch lit2 {
                        Literal.Str(_) => { isLitStr = true }
                    }
                }
            }
            if isLitStr {
                this._write(".push_str(")
                this._inCompoundAdd = true
                this._emitExpr(value)
                this._inCompoundAdd = false
                this._write(")")
            } else {
                this._write(".push_str(&")
                this._inCompoundAdd = true
                this._emitExpr(value)
                this._inCompoundAdd = false
                this._write(")")
            }
        } else {
            // Numeric (default): target += value
            this._inAssignTarget = true
            this._emitExpr(target)
            this._inAssignTarget = false
            this._write(" += ")
            this._emitExpr(value)
        }
    }

    // -- If statement --

    _emitIf(stmt: IfStmt) {
        // Phase 9.8: peephole — has+get+set → entry API
        if this._tryEmitEntryApi(stmt) { return }

        // If this `if` has no `else`, it is an `if (cond) { … }` statement —
        // its branch must yield `()`. Clear `_inExprBlock` while emitting the
        // body so an inner `Stmt.ExprStmt` doesn't drop its `;` and create a
        // type mismatch (e.g. `String` instead of `()`).
        let elsePartCheck = stmt.elseBranch
        let savedExprBlockIf = this._inExprBlock
        if elsePartCheck == null {
            this._inExprBlock = false
        }

        this._writeIndent()
        this._write("if ")
        // B130 (truthy form): detect+emit in a single helper to avoid
        // double-consumption of `stmt.condition` (field accesses don't
        // auto-clone in bootstrap). Returns the sanitized err-binding name
        // when condition is `if errBinding`.
        let truthyErrName = this._emitIfConditionAndDetectTruthy(stmt.condition)
        this._write(" {")
        this._newline()
        this._indent()
        if truthyErrName != "" {
            this._truthyErrBindings.set(truthyErrName, true)
        }
        this._emitIfBody(stmt.thenBranch)
        if truthyErrName != "" {
            this._truthyErrBindings.delete(truthyErrName)
        }
        this._dedent()

        let elsePart = stmt.elseBranch
        if elsePart != null {
            this._writeln("} else {")
            this._indent()
            this._emitIfBody(elsePart)
            this._dedent()
        }
        this._writeln("}")
        this._inExprBlock = savedExprBlockIf
    }

    // Phase 9.8: detect the canonical "increment/decrement-or-init" pattern on a Map
    // and lower it to Rust's `*m.entry(k).or_insert(X) += R;` form.
    //
    //     if m.has(K) {
    //         let c = m.get(K)
    //         m.set(K, c + R)        // or c - R
    //     } else {
    //         m.set(K, INIT)
    //     }
    //
    //  →  *m.entry(K.clone()).or_insert(INIT - R) += R;        (Add)
    //  →  *m.entry(K.clone()).or_insert(INIT + R) -= R;        (Sub)
    //
    // Conservative guards: only when R and INIT are integer literals, the four
    // K occurrences are syntactically equal (Identifier or Int/Str literal),
    // and m is a known Map variable. Otherwise fall through to the regular
    // if/else lowering. Returns true iff the optimized form was emitted.
    _tryEmitEntryApi(stmt: IfStmt): bool {
        // 1. Condition: m.has(K)
        let condIsHas = false
        let condMapName = ""
        let condKeyE = ""
        switch stmt.condition {
            Expr.MethodCall(co, cm, ca) => {
                if cm == "has" and ca.length == 1 {
                    switch co {
                        Expr.Identifier(cn) => {
                            condIsHas = true
                            condMapName = cn
                            for k in ca { condKeyE = this._entryKeyEmit(k); break }
                        }
                    }
                }
            }
        }
        if not condIsHas { return false }
        if condKeyE == "" { return false }
        let condMapSan: string = this._sanitizeName(condMapName)
        if not this._mapVars.has(condMapSan) { return false }

        // 2. then-branch: must contain exactly 2 stmts
        let thenStmts: [Stmt] = this._ifBodyStmts(stmt.thenBranch)
        if thenStmts.length != 2 { return false }

        // 3. else-branch: must be present and contain exactly 1 stmt
        let elseBranch = stmt.elseBranch
        if elseBranch == null { return false }
        let elseStmts: [Stmt] = []
        if elseBranch != null {
            elseStmts = this._ifBodyStmts(elseBranch)
        }
        if elseStmts.length != 1 { return false }

        // 4. then[0]: VarDecl single Identifier `cName`, init = m.get(K)
        let cName = ""
        let getMapName = ""
        let getKeyE = ""
        let stmt0Ok = false
        for s0 in thenStmts {
            switch s0 {
                Stmt.VarDecl(decl) => {
                    if decl.bindings.length == 1 and not decl.isFallible {
                        for b in decl.bindings {
                            switch b.pattern {
                                BindingPattern.Identifier(bn) => { cName = bn }
                            }
                            break
                        }
                        if cName != "" {
                            switch decl.init {
                                Expr.MethodCall(go, gm, ga) => {
                                    if gm == "get" and ga.length == 1 {
                                        switch go {
                                            Expr.Identifier(gn) => {
                                                getMapName = gn
                                                for k in ga { getKeyE = this._entryKeyEmit(k); break }
                                                if getKeyE != "" { stmt0Ok = true }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            break
        }
        if not stmt0Ok { return false }

        // 5. then[1]: ExprStmt(MethodCall(m, "set", [K, Binary(Add|Sub, Identifier(cName), Int(R))]))
        let setMapName = ""
        let setKeyE = ""
        let opIsAdd = false
        let rVal = 0
        let stmt1Ok = false
        let idx0 = 0
        for s1 in thenStmts {
            if idx0 == 1 {
                switch s1 {
                    Stmt.ExprStmt(se) => {
                        switch se {
                            Expr.MethodCall(so, sm, sa) => {
                                if sm == "set" and sa.length == 2 {
                                    switch so {
                                        Expr.Identifier(sn) => { setMapName = sn }
                                    }
                                    if setMapName != "" {
                                        // First pass: extract key (idx 0) into a string
                                        let kIdx = 0
                                        for kArg in sa {
                                            if kIdx == 0 {
                                                setKeyE = this._entryKeyEmit(kArg)
                                            }
                                            kIdx += 1
                                        }
                                        // Second pass: validate value (idx 1) is `c <op> Int`
                                        let vIdx = 0
                                        for vArg in sa {
                                            if vIdx == 1 {
                                                switch vArg {
                                                    Expr.Binary(bop, bl, br) => {
                                                        let opOk = false
                                                        switch bop {
                                                            BinOp.Add => { opOk = true; opIsAdd = true },
                                                            BinOp.Sub => { opOk = true; opIsAdd = false }
                                                        }
                                                        if opOk {
                                                            let leftOk = false
                                                            switch bl {
                                                                Expr.Identifier(ln) => {
                                                                    if ln == cName { leftOk = true }
                                                                }
                                                            }
                                                            if leftOk {
                                                                switch br {
                                                                    Expr.Literal(rlit) => {
                                                                        switch rlit {
                                                                            Literal.Int(rv) => { rVal = rv; stmt1Ok = true }
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                            vIdx += 1
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
                break
            }
            idx0 += 1
        }
        if not stmt1Ok { return false }
        if setKeyE == "" { return false }

        // 6. else[0]: ExprStmt(MethodCall(m, "set", [K, Literal.Int(initN)]))
        let elseMapName = ""
        let elseKeyE = ""
        let initN = 0
        let stmt2Ok = false
        for e0 in elseStmts {
            switch e0 {
                Stmt.ExprStmt(ee) => {
                    switch ee {
                        Expr.MethodCall(eo, em, ea) => {
                            if em == "set" and ea.length == 2 {
                                switch eo {
                                    Expr.Identifier(en) => { elseMapName = en }
                                }
                                if elseMapName != "" {
                                    let kIdx2 = 0
                                    for kArg2 in ea {
                                        if kIdx2 == 0 {
                                            elseKeyE = this._entryKeyEmit(kArg2)
                                        }
                                        kIdx2 += 1
                                    }
                                    let vIdx2 = 0
                                    for vArg2 in ea {
                                        if vIdx2 == 1 {
                                            switch vArg2 {
                                                Expr.Literal(lit) => {
                                                    switch lit {
                                                        Literal.Int(iv) => { initN = iv; stmt2Ok = true }
                                                    }
                                                }
                                            }
                                        }
                                        vIdx2 += 1
                                    }
                                }
                            }
                        }
                    }
                }
            }
            break
        }
        if not stmt2Ok { return false }
        if elseKeyE == "" { return false }

        // 7. All four map references must name the same variable
        if condMapName != getMapName { return false }
        if condMapName != setMapName { return false }
        if condMapName != elseMapName { return false }

        // 8. All four keys must be syntactically equal
        if condKeyE != getKeyE { return false }
        if condKeyE != setKeyE { return false }
        if condKeyE != elseKeyE { return false }

        // 9. Compute the seed for or_insert so that, after the compound op,
        //    the "missing key" branch yields exactly INIT.
        let seed = initN - rVal
        let opStr = "+"
        if not opIsAdd {
            seed = initN + rVal
            opStr = "-"
        }

        // 10. Emit `*<m>.entry(<K>).or_insert(<seed>) <op>= <r>;`
        this._writeIndent()
        let mapName = this._sanitizeName(condMapName)
        this._write($"*{mapName}.entry({condKeyE}).or_insert({seed}) {opStr}= {rVal};")
        this._newline()
        return true
    }

    // Helper: flattens an IfBody (Block or SingleStmt) into a plain [Stmt].
    // Used by the entry-API peephole so the caller has a single use of the
    // IfBody value (avoiding self-host codegen move limitations).
    _ifBodyStmts(body: IfBody): [Stmt] {
        let result: [Stmt] = []
        switch body {
            IfBody.Block(b) => {
                for s in b.stmts { result.push(s) }
            },
            IfBody.SingleStmt(stmts) => {
                for s in stmts { result.push(s) }
            }
        }
        return result
    }

    // Helper: returns a Rust emission string for a key expression suitable
    // for use inside `HashMap::entry(...)`. Identifier emits as `name.clone()`
    // (a no-op for Copy types — accepting the small redundancy avoids a
    // second use of the binding inside the match arm, which the self-host
    // codegen doesn't clone yet). Int literal emits as the integer text.
    // Returns "" for any other shape so the peephole bails out cleanly.
    //
    // Phase 10.1: when the key is an identifier declared INSIDE a loop body
    // AND the if-statement being rewritten is the last statement of its
    // enclosing block (so the binding is dead after the rewrite), we emit
    // a move (`san`) instead of `.clone()`. This eliminates the dominant
    // allocation hot-path in the word-counting benchmark.
    _entryKeyEmit(e: Expr): string {
        let result = ""
        switch e {
            Expr.Identifier(n) => {
                let key = $"{this._currentFunc}:{n}"
                let san = this._sanitizeName(n)
                let canMove = this._stmtIsLastInBlock
                    && this._liveCtx.declaredInLoop.has(key)
                if canMove {
                    result = san
                } else {
                    result = $"{san}.clone()"
                }
            },
            Expr.Literal(l) => {
                switch l {
                    Literal.Int(v) => { result = $"{v}" }
                }
            }
        }
        return result
    }

    _emitIfBody(body: IfBody) {
        switch body {
            IfBody.Block(block) => { this._emitBlock(block) },
            IfBody.SingleStmt(stmts) => {
                for s in stmts {
                    this._emitStmt(s)
                }
            }
        }
    }

    // -- While loop --

    _emitWhile(stmt: WhileStmt) {
        this._writeIndent()
        this._write("while ")
        this._inIfCondition = true
        this._emitExpr(stmt.condition)
        this._inIfCondition = false
        this._write(" {")
        this._newline()
        this._indent()
        // The while-body is a stmt-only block; do not inherit expr-block
        // context from any enclosing switch arm.
        let savedExprBlockW = this._inExprBlock
        this._inExprBlock = false
        this._emitBlock(stmt.body)
        this._inExprBlock = savedExprBlockW
        this._dedent()
        this._writeln("}")
    }

    // -- For loop --

    // Cycle 35 — detect `await loopVar` inside the for-body so we iterate the
    // collection by value (move) instead of by reference. Required for
    // tokio::JoinHandle (which is not Clone), and harmless for any other
    // type since the array is consumed at end-of-scope anyway.
    _inAsyncContext(): bool { return inAsyncContext(this) }

    _blockAwaitsIdent(blk: BlockStmt, name: string): bool {
        for s in blk.stmts {
            if this._stmtAwaitsIdent(s, name) { return true }
        }
        return false
    }

    _stmtAwaitsIdent(s: Stmt, name: string): bool {
        switch s {
            Stmt.VarDecl(d) => {
                if this._exprAwaitsIdent(d.init, name) { return true }
            },
            Stmt.ConstDecl(d) => {
                if this._exprAwaitsIdent(d.init, name) { return true }
            },
            Stmt.Assign(a) => {
                if this._exprAwaitsIdent(a.value, name) { return true }
            },
            Stmt.ExprStmt(e) => {
                if this._exprAwaitsIdent(e, name) { return true }
            },
            Stmt.Return(re) => {
                let rOpt = re
                if rOpt != null {
                    if this._exprAwaitsIdent(rOpt, name) { return true }
                }
            },
            Stmt.If(ifs) => {
                if this._exprAwaitsIdent(ifs.condition, name) { return true }
                switch ifs.thenBranch {
                    IfBody.Block(b) => {
                        if this._blockAwaitsIdent(b, name) { return true }
                    },
                    IfBody.SingleStmt(ss) => {
                        for sub in ss {
                            if this._stmtAwaitsIdent(sub, name) { return true }
                        }
                    }
                }
                let eb = ifs.elseBranch
                if eb != null {
                    switch eb {
                        IfBody.Block(b) => {
                            if this._blockAwaitsIdent(b, name) { return true }
                        },
                        IfBody.SingleStmt(ss) => {
                            for sub in ss {
                                if this._stmtAwaitsIdent(sub, name) { return true }
                            }
                        }
                    }
                }
            },
            Stmt.While(ws) => {
                if this._exprAwaitsIdent(ws.condition, name) { return true }
                if this._blockAwaitsIdent(ws.body, name) { return true }
            },
            Stmt.For(fs) => {
                if this._exprAwaitsIdent(fs.iterable, name) { return true }
                if this._blockAwaitsIdent(fs.body, name) { return true }
            },
            Stmt.Block(b) => {
                if this._blockAwaitsIdent(b, name) { return true }
            }
        }
        return false
    }

    _exprAwaitsIdent(e: Expr, name: string): bool {
        switch e {
            Expr.Unary(op, operand) => {
                switch op {
                    UnOp.Await => {
                        switch operand {
                            Expr.Identifier(n) => {
                                if n == name { return true }
                            }
                        }
                    }
                }
                return this._exprAwaitsIdent(operand, name)
            },
            Expr.Binary(_op, l, r) => {
                if this._exprAwaitsIdent(l, name) { return true }
                return this._exprAwaitsIdent(r, name)
            },
            Expr.Call(callee, args, _ep, _ta) => {
                if this._exprAwaitsIdent(callee, name) { return true }
                for a in args {
                    if this._exprAwaitsIdent(a, name) { return true }
                }
            },
            Expr.MethodCall(obj, _m, args) => {
                if this._exprAwaitsIdent(obj, name) { return true }
                for a in args {
                    if this._exprAwaitsIdent(a, name) { return true }
                }
            },
            Expr.MemberAccess(obj, _p) => {
                return this._exprAwaitsIdent(obj, name)
            },
            Expr.Index(obj, idx) => {
                if this._exprAwaitsIdent(obj, name) { return true }
                return this._exprAwaitsIdent(idx, name)
            }
        }
        return false
    }

    _emitFor(stmt: ForStmt) {
        this._writeIndent()
        let varName = this._sanitizeName(stmt.variable.clone())
        let iterableExpr = stmt.iterable

        // Check if there's an index variable (for i, item in array)
        let var2 = stmt.variable2
        let hasVar2 = var2 != null
        let var2Name = ""
        if var2 != null {
            var2Name = this._sanitizeName(var2)
        }
        // Track map iteration outside the if so the body can suppress `i as i32` shadowing.
        let isMapIteration = false
        if hasVar2 {
            // Two-variable for loop
            let idxName = $"{varName}"
            let itemName = $"{var2Name}"
            // Detect Map iteration: for key, value in map → .iter()
            // B125: also recognize `obj.field` and `this.field` Map fields. We
            // pre-registered Map field names in `_mapVars` during _emitClass.
            switch iterableExpr {
                Expr.Identifier(iterName) => {
                    let sn = this._sanitizeName(iterName)
                    if this._mapVars.has(sn) {
                        isMapIteration = true
                    }
                },
                Expr.MemberAccess(_, prop) => {
                    let sp = this._sanitizeName(prop)
                    if this._mapVars.has(sp) {
                        isMapIteration = true
                    }
                }
            }
            if isMapIteration {
                this._write($"for ({idxName}, {itemName}) in ")
                this._emitExpr(iterableExpr)
                this._write(".iter()")
            } else {
                // Array: for i, item → .iter().enumerate()
                this._write($"for ({idxName}, {itemName}) in ")
                this._emitExpr(iterableExpr)
                this._write(".iter().enumerate()")
            }
        } else {
            // Cycle 35 — body awaits the loop variable (e.g. JoinHandle).
            // Iterate by value to consume each item; never insert the
            // borrow-with-clone wrapper (JoinHandle is not Clone).
            let awaitsLoopVar = this._blockAwaitsIdent(stmt.body.clone(), stmt.variable.clone())
            if awaitsLoopVar {
                // Register the loop var as a JoinHandle so `await t` emits
                // `t.await.unwrap()` (JoinHandle::await yields a Result).
                this._taskHandleVars.set(varName, true)
                this._write($"for {varName} in ")
                this._emitExpr(iterableExpr)
                this._forNeedsInnerClone = false
                this._write(" {")
                this._newline()
                this._indent()
                let savedExprBlockA = this._inExprBlock
                this._inExprBlock = false
                this._emitBlock(stmt.body)
                this._inExprBlock = savedExprBlockA
                this._dedent()
                this._writeln("}")
                return
            }
            // Phase 9.4: array of Copy elements → `for &x in &arr` (no inner clone)
            let useCopyDeref = false
            switch iterableExpr {
                Expr.Identifier(iterName) => {
                    if this._arrayIdentNameIsCopyElem(iterName) {
                        useCopyDeref = true
                    }
                }
            }
            if useCopyDeref {
                this._write($"for &{varName} in ")
                // Phase 9: with `&{var}` pattern we need an iterator over references.
                // Cycle 40: use `.iter()` instead of `&{ident}` so the pattern
                // works for both owned `Vec<T>` and borrowed `&Vec<T>` params.
                let emitted = false
                switch iterableExpr {
                    Expr.Identifier(iterName) => {
                        let san = this._sanitizeName(iterName)
                        this._write($"{san}.iter()")
                        emitted = true
                    }
                }
                if not emitted {
                    this._emitForIterable(iterableExpr)
                }
            } else {
                this._write($"for {varName} in ")
                this._emitForIterable(iterableExpr)
            }
            // Suppress inner clone — we already have the Copy value via deref pattern
            if useCopyDeref {
                this._forNeedsInnerClone = false
            }
        }

        this._write(" {")
        this._newline()
        this._indent()
        // If two-variable enumerate loop, shadow index var as i32
        if hasVar2 {
            if not isMapIteration {
                // enumerate(): index is usize → shadow as i32 (Liva number)
                this._writeln($"let {varName} = {varName} as i32;")
            } else {
                // map.iter(): key is &K → clone for owned access in body
                this._writeln($"let {varName} = {varName}.clone();")
            }
            // Clone item to avoid move issues
            this._writeln($"let {var2Name} = {var2Name}.clone();")
        }
        // Phase 8.6: inner clone for borrow-iteration (for x in &vec)
        if this._forNeedsInnerClone {
            this._writeln($"let {varName} = {varName}.clone();")
            this._forNeedsInnerClone = false
        }
        // The for-body is a stmt-only block; do not inherit expr-block context.
        let savedExprBlockF = this._inExprBlock
        this._inExprBlock = false
        this._emitBlock(stmt.body)
        this._inExprBlock = savedExprBlockF
        this._dedent()
        this._writeln("}")
    }

    // Helper: emit iterable expression with appropriate iteration suffix
    // Handles iterator methods (.keys/.values), ranges, and default (array) cases
    // Everything in one switch to avoid double-consuming the value
    _emitForIterable(iterable: Expr) {
        switch iterable {
            Expr.Identifier(name) => {
                // Check if variable is a string type → use .chars() instead of .iter()
                let varType = this._lookupVarTypeRef(name)
                let tag = this._typeRefToTag(varType)
                let sanitized = this._sanitizeName(name)
                if tag == "string" {
                    this._write(sanitized)
                    this._write(".chars().map(|c| c.to_string())")
                } else {
                    // Phase 8: move instead of clone if var is single-use and NOT in a loop
                    // Phase 10.2: also allow move when var is declared inside the loop body
                    // (each iteration is a fresh binding — safe to move on its single use).
                    let isSingleUse = false
                    let liveKey = $"{this._currentFunc}:{name}"
                    if this._liveCtx.useCounts.has(liveKey) {
                        let uc = this._liveCtx.useCounts.get(liveKey)
                        let inLoop = this._liveCtx.loopUseCounts.has(liveKey)
                        let declaredInLoop = this._liveCtx.declaredInLoop.has(liveKey)
                        if uc <= 1 && (not inLoop || declaredInLoop) { isSingleUse = true }
                    }
                    // Cycle 40: borrowed collection params cannot be moved.
                    if this._collRefParams.has(sanitized) {
                        isSingleUse = false
                    }
                    if isSingleUse {
                        this._write(sanitized)
                    } else {
                        // Phase 8.6: borrow instead of clone — saves Vec allocation.
                        // Cycle 40: emit `.iter()` instead of `&{name}` so the
                        // pattern works regardless of whether `name` is owned
                        // (Vec<T>) or already a reference (&Vec<T> from a Cycle 40
                        // borrowed param). Iteration semantics are identical.
                        this._write($"{sanitized}.iter()")
                        this._forNeedsInnerClone = true
                    }
                }
            },
            Expr.MethodCall(obj, m, args) => {
                if m == "keys" {
                    // map.keys() already returns an iterator
                    this._emitExpr(obj)
                    this._write(".keys().cloned()")
                } else if m == "values" {
                    this._emitExpr(obj)
                    this._write(".values().cloned()")
                } else if m == "chars" {
                    this._emitExpr(obj)
                    this._write(".chars().map(|c| c.to_string())")
                } else if m == "bytes" {
                    this._emitExpr(obj)
                    this._write(".bytes().map(|b| b as i32)")
                } else if m == "split" && args.length > 0 {
                    // Phase 10.4: in `for x in str.split(sep)`, skip the
                    // `.collect::<Vec<String>>()` — we iterate the lazy iterator
                    // directly. Saves O(n) Vec allocation per call.
                    // Phase 10.5 Bloque 1: when the source is an &str-borrowed
                    // identifier (function param in `_strRefParams`), the loop
                    // var can be &str directly. Skip `.map(|s| s.to_string())`
                    // so each iteration yields &str instead of an owned String.
                    let objIsStrRef = false
                    switch obj {
                        Expr.Identifier(on) => {
                            let osn = this._sanitizeName(on)
                            if this._strRefParams.has(osn) { objIsStrRef = true }
                        }
                    }
                    this._emitExpr(obj)
                    this._write(".split(")
                    this._emitRefArg(args[0])
                    if objIsStrRef {
                        this._write(")")
                    } else {
                        this._write(").map(|s| s.to_string())")
                    }
                } else {
                    // Other method call returns a collection
                    this._emitMethodCall(obj, m, args)
                }
            },
            // Range expressions: 1..5 or 1..=5 — don't add .iter().cloned()
            Expr.Binary(op, left, right) => {
                let isRange = false
                switch op {
                    BinOp.Range => { isRange = true },
                    BinOp.RangeInclusive => { isRange = true }
                }
                if isRange {
                    this._emitExpr(left)
                    let opStr = switch op {
                        BinOp.Range => " .. ",
                        BinOp.RangeInclusive => " ..= ",
                        _ => " .. "
                    }
                    this._write(opStr)
                    this._emitExpr(right)
                } else {
                    this._emitExpr(iterable)
                    this._write(".clone()")
                }
            },
            Expr.ArrayLiteral(_) => {
                // Inline array literal: [1, 2, 3] → vec![...] (already owned)
                this._emitExpr(iterable)
            },
            Expr.MemberAccess(_, _) => {
                // self.field: can't borrow with & if loop body mutates self
                // Must clone to avoid E0502 (immutable + mutable borrow of self)
                let savedAT = this._inAssignTarget
                this._inAssignTarget = true
                this._emitExpr(iterable)
                this._inAssignTarget = savedAT
                this._write(".clone()")
            },
            _ => {
                this._emitExpr(iterable)
                this._write(".clone()")
            }
        }
    }

    // -- Switch statement (match) --

    _isStringSwitchStmt(cases: [CaseClause]): bool {
        // NOTE: this method does NOT consume 'cases' — it only checks the first element
        if cases.length > 0 {
            let isStr = false
            // Using a simple heuristic: we'll check after we know
            return false  // Determined below from first case
        }
        return false
    }

    _emitSwitch(stmt: SwitchStmt) {
        // Detect string switch: if first case value is a string literal, use .as_str()
        let isStringSwitch = false
        for c in stmt.cases {
            switch c.value {
                Expr.Literal(lit) => {
                    switch lit {
                        Literal.Str(_) => { isStringSwitch = true }
                    }
                }
            }
            break
        }

        this._writeIndent()
        // Delegate to helper so the parameter (auto-cloned in bootstrap codegen)
        // can be used both for type-tag inspection and for emission. Field
        // access on `stmt.discriminant` is consumed on first use.
        this._emitSwitchHead(stmt.discriminant, isStringSwitch)
        this._write(" {")
        this._newline()
        this._indent()

        for c in stmt.cases {
            this._emitCaseClause(c, false)
        }

        // Default arm
        let defBody = stmt.defaultBody
        if defBody != null {
            this._writeln("_ => {")
            this._indent()
            for s in defBody {
                this._emitStmt(s)
            }
            this._dedent()
            this._writeln("}")
        }

        this._dedent()
        this._writeln("}")
    }

    _emitCaseClause(c: CaseClause, isStrSwitch: bool) {
        this._pendingDerefs = []
        this._pendingRefClones = []
        this._writeIndent()
        this._emitExpr(c.value)
        this._write(" => {")
        this._newline()
        this._indent()
        // Emit clone/deref bindings for match-by-reference fields
        for d in this._pendingDerefs {
            this._writeln("let " + d + " = *" + d + ".clone();")
        }
        for rc in this._pendingRefClones {
            this._writeln("let " + rc + " = " + rc + ".clone();")
        }
        for s in c.body {
            this._emitStmt(s)
        }
        this._dedent()
        this._writeln("}")
    }

    // -- Try/catch --

    _emitTryCatch(stmt: TryCatchStmt) {
        // Rust doesn't have try/catch — use a closure + match on Result
        this._writeln("match (|| -> Result<(), liva_rt::Error> {")
        this._indent()
        this._emitBlock(stmt.tryBlock)
        this._writeln("Ok(())")
        this._dedent()
        this._writeln("})() {")
        this._indent()
        this._writeln("Ok(()) => {}")
        let catchVar = this._sanitizeName(stmt.catchVar)
        this._writeln("Err(" + catchVar + ") => {")
        this._indent()
        this._emitBlock(stmt.catchBlock)
        this._dedent()
        this._writeln("}")
        this._dedent()
        this._writeln("}")
    }

    // -- Return --

    _emitReturn(optExpr: Expr?) {
        if optExpr != null {
            this._writeIndent()
            this._write("return ")
            if this._currentReturnOptional {
                this._emitSomeWrapped(optExpr)
            } else if this._currentReturnFallible {
                this._write("Ok(")
                this._emitExpr(optExpr)
                this._write(")")
            } else {
                this._emitExpr(optExpr)
            }
            this._write(";")
            this._newline()
        } else {
            if this._currentReturnFallible {
                this._writeln("return Ok(());")
            } else {
                this._writeln("return;")
            }
        }
    }

    // =====================================================================
    //  Phase 3.4 — Expressions
    // =====================================================================

    _emitExpr(expr: Expr) {
        switch expr {
            Expr.Literal(lit) => { this._emitLiteral(lit) },
            Expr.Identifier(name) => { this._emitIdentifier(name) },
            Expr.Binary(op, left, right) => {
                // Phase 11: wrap in parens to preserve precedence when used as
                // operand of another expression (e.g. `(idx - 1) / 2`).
                // Suppressed in two cases:
                //  - inside if/while conditions: the binary may lower to an
                //    if-let pattern (`let Some(x) = x`) which is not an expr.
                //  - when a `_pushStrTarget` chain is active: that path emits
                //    multi-statement push_str calls (`a.push_str(...); a.push_str(...)`)
                //    which cannot be parenthesised as a single expression.
                if this._inIfCondition or this._pushStrTarget != "" {
                    this._emitBinary(op, left, right)
                } else {
                    this._write("(")
                    this._emitBinary(op, left, right)
                    this._write(")")
                }
            },
            Expr.Unary(op, operand) => {
                this._emitUnary(op, operand)
            },
            Expr.Ternary(cond, thenE, elseE) => {
                this._write("if ")
                this._emitExpr(cond)
                this._write(" { ")
                this._emitExpr(thenE)
                this._write(" } else { ")
                this._emitExpr(elseE)
                this._write(" }")
            },
            Expr.Call(callee, callArgs, policy, tArgs) => {
                // Parser wraps `async X.m(args)` / `par X.m(args)` as
                // `Expr.Call(MethodCall(...), [], <policy>, _)`. Without
                // a full async runtime, emit the inner MethodCall and
                // drop the spurious empty-args invocation so generated
                // Rust stays well-typed. Only unwrap when the wrapper
                // carries a non-Normal policy (Normal+0args+MethodCall
                // can legitimately mean `obj.getFn()()`).
                let isExecWrap = switch policy {
                    ExecPolicy.Async => true,
                    ExecPolicy.Par => true,
                    ExecPolicy.TaskAsync => true,
                    ExecPolicy.TaskPar => true,
                    _ => false
                }
                let isTask = switch policy {
                    ExecPolicy.TaskAsync => true,
                    ExecPolicy.TaskPar => true,
                    _ => false
                }
                if isTask {
                    // Cycle 32: when the callee is a known-async free fn,
                    // we must `.await` it inside the spawned future so the
                    // JoinHandle yields the actual value rather than a
                    // nested Future. Detect by sanitizing the callee name.
                    let calleeIsAsync = false
                    switch callee {
                        Expr.Identifier(cn) => {
                            let scn = this._sanitizeName(cn)
                            if this._asyncFnNames.has(scn) {
                                calleeIsAsync = true
                            }
                        }
                    }
                    this._write("tokio::spawn(async move { ")
                    this._emitCall(callee, callArgs)
                    if calleeIsAsync {
                        this._write(".await")
                    }
                    this._write(" })")
                    return
                }
                let unwrapped = false
                if isExecWrap && callArgs.length == 0 {
                    switch callee {
                        Expr.MethodCall(_mco, _mcm, _mca) => {
                            this._emitExpr(callee)
                            unwrapped = true
                        }
                    }
                }
                if !unwrapped {
                    this._emitCall(callee, callArgs)
                    // Cycle 35: auto-`.await` direct calls to async user fns
                    // when we are emitting from inside an async context.
                    // Without this, a caller like
                    //   let r = process_batch(xs)
                    // emits a bare `process_batch(xs)` which yields an
                    // `impl Future<...>` instead of the awaited value.
                    if !isExecWrap {
                        let isAsyncCallee = false
                        switch callee {
                            Expr.Identifier(cn2) => {
                                let scn2 = this._sanitizeName(cn2)
                                if this._asyncFnNames.has(scn2) {
                                    isAsyncCallee = true
                                }
                            }
                        }
                        if isAsyncCallee && this._inAsyncContext() {
                            this._write(".await")
                        }
                    }
                }
            },
            Expr.MethodCall(mcObj, method, mcArgs) => {
                this._emitMethodCall(mcObj, method, mcArgs)
            },
            Expr.MemberAccess(maObj, prop) => {
                this._emitMemberAccess(maObj, prop)
            },
            Expr.Index(idxObj, idxExpr) => {
                // Detect string-literal index: emit map/json-style indexing
                // (no `as usize` cast). HashMap<String,V> impls Index<&Q>
                // where K: Borrow<Q>, so `m["k"]` works; serde_json::Value
                // impls Index<&str> directly. Either way, drop the usize
                // cast that the numeric-index path emits.
                let isStrIdx = false
                let strKey = ""
                switch idxExpr {
                    Expr.Literal(_il) => {
                        switch _il {
                            Literal.Str(sv) => { isStrIdx = true; strKey = sv }
                        }
                    }
                }
                if isStrIdx {
                    let savedAssignTargetS = this._inAssignTarget
                    this._inAssignTarget = true
                    this._emitExpr(idxObj)
                    this._inAssignTarget = savedAssignTargetS
                    // Emit raw string-literal index (no .to_string()) so
                    // HashMap<String,V> Borrow impl and serde_json::Value
                    // Index<&str> both resolve.
                    this._write("[\"")
                    this._write(strKey)
                    this._write("\"")
                    if this._suppressIndexElemClone {
                        this._write("]")
                    } else {
                        this._write("].clone()")
                    }
                    this._suppressIndexElemClone = false
                    return
                }
                // Suppress self.field auto-clone for the base object
                // We only need to clone the element, not the entire Vec
                let savedAssignTarget = this._inAssignTarget
                this._inAssignTarget = true
                // JSON-tracked receiver: serde_json::Value impls Index<&str>
                // and Index<usize>. Avoid the unconditional `as usize` cast
                // (which fails for string keys); pick the right form based
                // on whether the index identifier is a string-typed var.
                let jsonObjName = ""
                switch idxObj {
                    Expr.Identifier(jon) => { jsonObjName = this._sanitizeName(jon) }
                }
                let isJsonRecv = jsonObjName != "" && this._jsonValueVars.has(jsonObjName)
                this._emitExpr(idxObj)
                this._inAssignTarget = savedAssignTarget
                if isJsonRecv {
                    let idxIsStr = false
                    switch idxExpr {
                        Expr.Identifier(idn) => {
                            let idSan = this._sanitizeName(idn)
                            if this._stringVars.has(idSan) { idxIsStr = true }
                        }
                    }
                    if idxIsStr {
                        this._write("[&(")
                        this._emitExpr(idxExpr)
                        this._write(")[..]")
                        if this._suppressIndexElemClone {
                            this._write("]")
                        } else {
                            this._write("].clone()")
                        }
                    } else {
                        this._write("[(")
                        this._emitExpr(idxExpr)
                        if this._suppressIndexElemClone {
                            this._write(") as usize]")
                        } else {
                            this._write(") as usize].clone()")
                        }
                    }
                    this._suppressIndexElemClone = false
                    return
                }
                this._write("[(")
                this._emitExpr(idxExpr)
                // Phase 8: skip .clone() for Copy-type array elements
                let elemCopy = this._isIndexExprCopyType(idxObj)
                // B157: skip .clone() when the Index is the receiver of a
                // method call. Cloning would create a temporary the method
                // operates on, silently dropping any and-mut self mutations
                // (e.g. particles[i].step(0.01)). Rusts IndexMut gives
                // us the right borrow automatically when the clone is gone.
                if elemCopy or this._suppressIndexElemClone {
                    this._write(") as usize]")
                } else {
                    this._write(") as usize].clone()")
                }
                // B157: consume the single-shot flag so it does not leak
                // into argument expressions of the enclosing method call.
                this._suppressIndexElemClone = false
            },
            Expr.ObjectLiteral(objFields) => {
                this._emitObjectLiteral(objFields)
            },
            Expr.StructLiteral(typeName, sFields) => {
                this._emitStructLiteral(typeName, sFields)
            },
            Expr.ArrayLiteral(arrElems) => {
                this._emitArrayLiteral(arrElems)
            },
            Expr.MapLiteral(entries) => {
                this._emitMapLiteral(entries)
            },
            Expr.SetLiteral(setElems) => {
                this._emitSetLiteral(setElems)
            },
            Expr.TupleLiteral(tupElems) => {
                this._write("(")
                let tIdx = 0
                for e in tupElems {
                    if tIdx > 0 { this._write(", ") }
                    this._emitExpr(e)
                    tIdx += 1
                }
                this._write(")")
            },
            Expr.Lambda(lam) => { this._emitLambda(lam) },
            Expr.StringTemplate(parts) => { this._emitStringTemplate(parts) },
            Expr.Fail(fExpr) => {
                this._write("return Err(liva_rt::Error::from(format!(\"{}\", ")
                this._emitExpr(fExpr)
                this._write(")))")
            },
            Expr.SwitchExpr(disc, arms) => {
                let savedFlag = this._switchInStmtPosition
                this._switchInStmtPosition = false
                this._emitSwitchExpr(disc, arms)
                this._switchInStmtPosition = savedFlag
            },
            Expr.MethodRef(refObj, refMethod) => {
                // Point-free method reference
                let sanitizedMethod = this._sanitizeName(refMethod)
                this._write($"{refObj}::{sanitizedMethod}")
            },
            Expr.Unwrap(uwExpr) => {
                this._emitExpr(uwExpr)
                this._write(".unwrap()")
            },
            Expr.Try(tryExpr) => {
                // Postfix try: expr? → Rust `?` for error propagation.
                this._emitExpr(tryExpr)
                this._write("?")
                // Result is the function's success type, not a &str ref —
                // reset the flag so a downstream `let` binding does not
                // append `.to_string()` based on the inner argument.
                this._lastEmittedStrRef = false
            },
            Expr.OptionalChain(ocObj, ocProp) => {
                this._emitExpr(ocObj)
                let snOc = this._sanitizeName(ocProp)
                this._write($".as_ref().map(|v| v.{snOc})")
            },
            Expr.RustBlock(code) => {
                // Wrap in `{ ... }` so the embedded code can contain `use`
                // statements (and any other items/stmts) before its trailing
                // expression. The block evaluates to its last expression — the
                // semantics callers expect (the user wrote `return rust { ... }`).
                this._write("{ ")
                this._write(code)
                this._write(" }")
            }
        }
    }

    // -- Escape helpers for Rust output --
    // Cycle 45 — thin wrappers; real work happens in `escapeRustStr` /
    // `escapeRustChar` free functions at the bottom of the file. Pure
    // string transformations — no RustEmitter state, no switch on Expr,
    // so unaffected by BS-FRAG-1 (which only triggers on Expr switches).
    _escapeRustStr(s: string): string { return escapeRustStr(s) }

    _escapeRustChar(s: string): string { return escapeRustChar(s) }

    // -- Literals --

    _emitLiteral(lit: Literal) {
        switch lit {
            Literal.Int(v) => {
                this._write($"{v}")
            },
            Literal.Float(v) => {
                let floatStr = $"{v}"
                if not floatStr.contains(".") {
                    floatStr += ".0"
                }
                this._write(floatStr)
            },
            Literal.Str(v) => {
                let escaped = this._escapeRustStr(v)
                if this._inCompoundAdd || this._suppressToString || this._suppressCloneForBorrow {
                    this._write("\"" + escaped + "\"")
                } else {
                    this._write("\"" + escaped + "\".to_string()")
                }
            },
            Literal.Char(v) => {
                let escapedC = this._escapeRustChar(v)
                this._write("'" + escapedC + "'")
            },
            Literal.Bool(v) => {
                if v {
                    this._write("true")
                } else {
                    this._write("false")
                }
            },
            Literal.Null => {
                this._write("None")
            }
        }
    }

    // -- Identifier --

    _emitIdentifier(name: string) {
        if name == "this" {
            this._write("self")
            this._lastEmittedStrRef = false
        } else {
            let sn = this._sanitizeName(name)
            this._lastEmittedStrRef = this._strRefParams.has(sn)
            // ERR-UNIFY: rewrite plain `if err` (where err is fallible-tuple
            // err-binding holding Option<liva_rt::Error>) to `if err.is_some()`.
            if this._inIfCondition && this._errBindings.has(sn) {
                this._write(sn)
                this._write(".is_some()")
                return
            }
            this._write(sn)
        }
    }

    // -- Binary operations --

    _emitBinary(op: BinOp, left: Expr, right: Expr) {
        let opStr = this._binOpToRust(op)
        // `||` is always logical OR now — `or <value>` is handled at parser level
        // Wrap in parens to preserve precedence when used as operand of &&
        if opStr == "||" {
            // B140: detect `s.toInt() or default` and `s.toFloat() or default`
            // in expression position (not let-binding). The standard `toInt`
            // emission produces `.parse::<i32>().unwrap_or(0)`; with an explicit
            // default we need to thread it into the unwrap_or call instead of
            // emitting `<expr> || <default>` (boolean OR).
            let isParseOr = false
            let parseTy = ""
            switch left {
                Expr.MethodCall(_, mName, _) => {
                    if mName == "toInt" { isParseOr = true; parseTy = "i32" }
                    if mName == "toFloat" { isParseOr = true; parseTy = "f64" }
                }
            }
            if isParseOr {
                switch left {
                    Expr.MethodCall(pObj, _, _) => {
                        this._emitExpr(pObj)
                        this._write(".to_string().parse::<")
                        this._write(parseTy)
                        this._write(">().unwrap_or(")
                        this._emitExpr(right)
                        this._write(")")
                    }
                }
                return
            }

            // B?: detect `Map.get(k) or default` (or array.get/first/last/find)
            // outside of a var-decl. The parser only desugars these inside
            // `let x = call() or default`, so for `return call() or default`
            // (and similar expression positions) we lower here.
            let isOptionGet = false
            switch left {
                Expr.MethodCall(mObj, mName, _) => {
                    if mName == "get" or mName == "first" or mName == "last" or mName == "find" {
                        let mTag = this._getExprTypeName(mObj)
                        if mTag == "map" or mTag == "array" or mTag == "set" {
                            isOptionGet = true
                        } else {
                            switch mObj {
                                Expr.Identifier(gn) => {
                                    let sn = this._sanitizeName(gn)
                                    if this._mapVars.has(sn) or this._setVars.has(sn) { isOptionGet = true }
                                },
                                Expr.MemberAccess(_, _) => {
                                    // `this.fieldMap.get(...)` etc.
                                    if mTag == "" or mTag == "unknown" {
                                        // Conservatively treat field method-calls of `get` as
                                        // option-returning when the method name is a known
                                        // collection accessor; runtime type-tracking is too
                                        // weak to be sure, so prefer option-get lowering.
                                        isOptionGet = true
                                    }
                                }
                            }
                        }
                    }
                }
            }
            if isOptionGet {
                // Use the shared helper (suppresses the trailing .unwrap()
                // that the normal Map.get path emits).
                switch left {
                    Expr.MethodCall(mObj2, mName2, mArgs2) => {
                        this._emitOptionGetWithDefault(mObj2, mName2, mArgs2, right)
                    }
                }
                return
            }
            this._write("(")
            this._emitExpr(left)
            this._write(" || ")
            this._emitExpr(right)
            this._write(")")
            return
        }
        // Delegate to helper that classifies + emits right in ONE switch
        this._emitBinaryWithRight(opStr, left, right)
    }

    _emitBinaryWithRight(opStr: string, left: Expr, right: Expr) {
        // ERR-UNIFY: rewrite `err == ""` / `err != ""` (idiomatic Liva
        // "no error" check) to `err.is_none()` / `err.is_some()` when
        // `err` is a fallible-tuple err-binding holding
        // Option<liva_rt::Error>. Bootstrap stores err as String and
        // accepts the raw compare; self-host normalizes to Option, so
        // the literal `""` compare otherwise emits
        // `err.is_some() == ""` (under _inIfCondition rewrite) or
        // `err == ""` (outside it), neither of which type-checks.
        if opStr == "==" || opStr == "!=" {
            let isErrIdent = false
            switch left {
                Expr.Identifier(eName) => {
                    let eSan = this._sanitizeName(eName)
                    if this._errBindings.has(eSan) { isErrIdent = true }
                }
            }
            let rIsEmptyStr = false
            if isErrIdent {
                switch right {
                    Expr.Literal(rLitE) => {
                        switch rLitE {
                            Literal.Str(rs) => {
                                if rs == "" { rIsEmptyStr = true }
                            }
                        }
                    }
                }
            }
            if isErrIdent && rIsEmptyStr {
                let savedInIf = this._inIfCondition
                this._inIfCondition = false
                this._emitExpr(left)
                this._inIfCondition = savedInIf
                if opStr == "==" {
                    this._write(".is_none()")
                } else {
                    this._write(".is_some()")
                }
                return
            }
        }
        // Single switch on right that both classifies and handles output
        switch right {
            Expr.Literal(rLit) => {
                // Check if right is null
                let rIsNull = false
                let rIsString = false
                switch rLit {
                    Literal.Null => { rIsNull = true },
                    Literal.Str(_) => { rIsString = true }
                }
                if rIsNull && opStr == "==" {
                    this._emitExpr(left)
                    this._write(".is_none()")
                } else if rIsNull && opStr == "!=" {
                    // Detect variable for if-let narrowing (x != null → let Some(x) = x)
                    // ONLY valid directly in if/while conditions
                    if this._inIfCondition {
                        switch left {
                            Expr.Identifier(lName) => {
                                let san = this._sanitizeName(lName)
                                // JSON-value receivers are not Option<T>: emit
                                // an !is_null() guard instead of an if-let.
                                if this._jsonValueVars.has(san) {
                                    let savedJ = this._inIfCondition
                                    this._inIfCondition = false
                                    this._write($"!{san}.is_null()")
                                    this._inIfCondition = savedJ
                                } else {
                                    this._write($"let Some({san}) = {san}")
                                }
                            },
                            Expr.MemberAccess(maObj, maProp) => {
                                this._emitExpr(Expr.MemberAccess(maObj, maProp))
                                this._write(".is_some()")
                            },
                            _ => {
                                this._write("true /* != null */")
                            }
                        }
                    } else {
                        this._emitExpr(left)
                        this._write(".is_some()")
                    }
                } else if rIsString && opStr == "+" {
                    // Phase 8: push_str for string literal
                    if this._pushStrTarget != "" {
                        this._pushStrUsed = true
                        let leftIsTarget2 = false
                        switch left {
                            Expr.Identifier(lName2) => {
                                if this._sanitizeName(lName2) == this._pushStrTarget { leftIsTarget2 = true }
                            }
                        }
                        if leftIsTarget2 {
                            let pst1 = this._pushStrTarget
                            this._write(pst1)
                            this._write(".push_str(")
                            this._inCompoundAdd = true
                            this._emitLiteral(rLit)
                            this._inCompoundAdd = false
                            this._write(")")
                        } else {
                            this._emitExpr(left)
                            this._write(";")
                            this._newline()
                            this._writeIndent()
                            let pst2 = this._pushStrTarget
                            this._write(pst2)
                            this._write(".push_str(")
                            this._inCompoundAdd = true
                            this._emitLiteral(rLit)
                            this._inCompoundAdd = false
                            this._write(")")
                        }
                    } else {
                        this._write("format!(\"{}{}\", ")
                        this._emitFormatArg(left)
                        this._write(", ")
                        this._emitLiteral(rLit)
                        this._write(")")
                    }
                } else {
                    // Right is a non-null, non-string literal — check left for null
                    this._emitBinaryLeftCheck(opStr, left, rLit)
                }
            },
            Expr.StringTemplate(rParts) => {
                // Right is a string template — string concat
                if opStr == "+" {
                    if this._pushStrTarget != "" {
                        this._pushStrUsed = true
                        let leftIsTarget3 = false
                        switch left {
                            Expr.Identifier(lName3) => {
                                if this._sanitizeName(lName3) == this._pushStrTarget { leftIsTarget3 = true }
                            }
                        }
                        if leftIsTarget3 {
                            let pst3 = this._pushStrTarget
                            this._write(pst3)
                            this._write(".push_str(&")
                            this._emitStringTemplate(rParts)
                            this._write(")")
                        } else {
                            this._emitExpr(left)
                            this._write(";")
                            this._newline()
                            this._writeIndent()
                            let pst4 = this._pushStrTarget
                            this._write(pst4)
                            this._write(".push_str(&")
                            this._emitStringTemplate(rParts)
                            this._write(")")
                        }
                    } else {
                        this._write("format!(\"{}{}\", ")
                        this._emitFormatArg(left)
                        this._write(", ")
                        this._emitStringTemplate(rParts)
                        this._write(")")
                    }
                } else {
                    this._emitExpr(left)
                    this._write($" {opStr} ")
                    this._emitStringTemplate(rParts)
                }
            },
            _ => {
                // Right is a general expression — check left for null/string
                this._emitBinaryLeftDefault(opStr, left, right)
            }
        }
    }

    _emitBinaryLeftCheck(opStr: string, left: Expr, rightLit: Literal) {
        // Right was a normal literal. Check left for null.
        let leftIsNull = false
        switch left {
            Expr.Literal(lLit) => {
                switch lLit {
                    Literal.Null => { leftIsNull = true }
                }
            }
        }
        if leftIsNull && opStr == "==" {
            this._emitLiteral(rightLit)
            this._write(".is_none()")
        } else if leftIsNull && opStr == "!=" {
            this._emitLiteral(rightLit)
            this._write(".is_some()")
        } else {
            // Phase 8.5: emit left, then check if it was &str → suppress .to_string() on right
            // Phase 8.8: suppress self.field clone in comparison context
            this._emitExprNoMemberClone(left)
            let leftIsStrRef = this._lastEmittedStrRef
            this._write($" {opStr} ")
            // Suppress .to_string() for == and != — String implements PartialEq<str>
            // Also suppress for all comparisons when left is &str
            if opStr == "==" || opStr == "!=" || leftIsStrRef {
                let saved = this._suppressToString
                this._suppressToString = true
                this._emitLiteral(rightLit)
                this._suppressToString = saved
            } else {
                this._emitLiteral(rightLit)
            }
        }
    }

    _emitBinaryLeftDefault(opStr: string, left: Expr, right: Expr) {
        // Right is a general expr. Check left for null/string.
        switch left {
            Expr.Literal(lLit) => {
                let lIsNull = false
                let lIsString = false
                switch lLit {
                    Literal.Null => { lIsNull = true },
                    Literal.Str(_) => { lIsString = true }
                }
                if lIsNull && opStr == "==" {
                    this._emitExpr(right)
                    this._write(".is_none()")
                } else if lIsNull && opStr == "!=" {
                    this._emitExpr(right)
                    this._write(".is_some()")
                } else if lIsString && opStr == "+" {
                    this._write("format!(\"{}{}\", ")
                    this._emitLiteral(lLit)
                    this._write(", ")
                    this._emitFormatArg(right)
                    this._write(")")
                } else {
                    // Suppress .to_string() for == and != — String implements PartialEq<str>
                    if opStr == "==" || opStr == "!=" {
                        let saved = this._suppressToString
                        this._suppressToString = true
                        this._emitLiteral(lLit)
                        this._suppressToString = saved
                    } else {
                        this._emitLiteral(lLit)
                    }
                    this._write($" {opStr} ")
                    // Phase 8.8: suppress self.field clone on right of literal comparison
                    this._emitExprNoMemberClone(right)
                }
            },
            Expr.StringTemplate(lParts) => {
                if opStr == "+" {
                    this._write("format!(\"{}{}\", ")
                    this._emitStringTemplate(lParts)
                    this._write(", ")
                    this._emitFormatArg(right)
                    this._write(")")
                } else {
                    this._emitStringTemplate(lParts)
                    this._write($" {opStr} ")
                    this._emitExpr(right)
                }
            },
            _ => {
                // Array concatenation: arr1 + arr2 → [arr1, arr2].concat().
                // Rust's Vec does not implement Add; slice .concat() flattens
                // Vec<Vec<T>> back to Vec<T>.
                if opStr == "+" {
                    let lTag = this._getExprTypeName(left)
                    let rTag = this._getExprTypeName(right)
                    if lTag == "array" || rTag == "array" {
                        this._write("[")
                        this._emitExpr(left)
                        this._write(", ")
                        this._emitExpr(right)
                        this._write("].concat()")
                        return
                    }
                }
                if opStr == "+" and (this._isStringExpr(left) or this._isStringExpr(right)) {
                    // Phase 8: push_str chain — x = x + y → x.push_str(&y)
                    if this._pushStrTarget != "" {
                        this._pushStrUsed = true
                        // Check if left is the target identifier (1-level: x + y)
                        let leftIsTarget = false
                        switch left {
                            Expr.Identifier(lName) => {
                                if this._sanitizeName(lName) == this._pushStrTarget { leftIsTarget = true }
                            }
                        }
                        if leftIsTarget {
                            // x + y → x.push_str(&y) when y is already a String,
                            // else x.push_str(&(y).to_string()) for primitives.
                            let pst5 = this._pushStrTarget
                            let rightIsString = this._isStringExpr(right)
                            this._write(pst5)
                            if rightIsString {
                                // Phase 10.4: skip useless `.to_string()` on a String.
                                this._write(".push_str(&(")
                                this._emitExpr(right)
                                this._write("))")
                            } else {
                                this._write(".push_str(&(")
                                this._emitExpr(right)
                                this._write(").to_string())")
                            }
                        } else {
                            // Left is not the target (maybe nested: (x + a) + b)
                            // Emit left (which recurses and may emit push_str for inner chain)
                            this._emitExpr(left)
                            // Now emit push_str for right
                            this._write(";")
                            this._newline()
                            this._writeIndent()
                            let pst6 = this._pushStrTarget
                            let rightIsString2 = this._isStringExpr(right)
                            this._write(pst6)
                            if rightIsString2 {
                                this._write(".push_str(&(")
                                this._emitExpr(right)
                                this._write("))")
                            } else {
                                this._write(".push_str(&(")
                                this._emitExpr(right)
                                this._write(").to_string())")
                            }
                        }
                    } else {
                        // Normal string concat: format!("{}{}", left, right)
                        this._write("format!(\"{}{}\", ")
                        this._emitFormatArg(left)
                        this._write(", ")
                        this._emitFormatArg(right)
                        this._write(")")
                    }
                } else {
                    // Phase 8.8: suppress self.field clone in comparison context
                    let isComp = opStr == "==" || opStr == "!=" || opStr == "<" || opStr == ">" || opStr == "<=" || opStr == ">="
                    if isComp {
                        this._emitExprNoMemberClone(left)
                        this._write($" {opStr} ")
                        this._emitExprNoMemberClone(right)
                    } else {
                        this._emitExpr(left)
                        this._write($" {opStr} ")
                        this._emitExpr(right)
                    }
                }
            }
        }
    }

    _isNullExpr(expr: Expr): bool {
        let result = false
        switch expr {
            Expr.Literal(lit) => {
                switch lit {
                    Literal.Null => { result = true }
                }
            }
        }
        return result
    }

    _isCopyLiteral(expr: Expr): bool {
        let result = false
        switch expr {
            Expr.Literal(lit) => {
                switch lit {
                    Literal.Bool(_) => { result = true },
                    Literal.Int(_) => { result = true },
                    Literal.Float(_) => { result = true },
                    Literal.Null => { result = true }
                }
            }
        }
        return result
    }

    _leftmostLeafIsTarget(expr: Expr, target: string): bool {
        let result = false
        switch expr {
            Expr.Binary(bop, left, _) => {
                let bopStr = this._binOpToRust(bop)
                if bopStr == "+" {
                    result = this._leftmostLeafIsTarget(left, target)
                }
            },
            Expr.Identifier(lName) => {
                if this._sanitizeName(lName) == target { result = true }
            }
        }
        return result
    }

    _isStringExpr(expr: Expr): bool {
        let result = false
        switch expr {
            Expr.Literal(lit) => {
                switch lit {
                    Literal.Str(_) => { result = true }
                }
            },
            Expr.StringTemplate(_) => { result = true },
            Expr.Binary(op, left, right) => {
                let opCheck = this._binOpToRust(op)
                if opCheck == "+" && (this._isStringExpr(left) || this._isStringExpr(right)) {
                    result = true
                }
            },
            Expr.MethodCall(_, method, _) => {
                // Cycle 44: recognise string-returning methods so that
                // `result += ch.toLowerCase()` etc. emit `.push_str()`
                // instead of `String += String` (which is invalid Rust).
                if method == "toString" { result = true }
                if method == "toLowerCase" { result = true }
                if method == "toUpperCase" { result = true }
                if method == "trim" { result = true }
                if method == "trimStart" { result = true }
                if method == "trimEnd" { result = true }
                if method == "replace" { result = true }
                if method == "replaceAll" { result = true }
                if method == "substring" { result = true }
                if method == "padStart" { result = true }
                if method == "padEnd" { result = true }
                if method == "capitalize" { result = true }
                if method == "removePrefix" { result = true }
                if method == "removeSuffix" { result = true }
                if method == "repeat" { result = true }
            },
            Expr.Identifier(name) => {
                let tag = this._getExprTypeName(expr)
                if tag == "string" { result = true }
            }
        }
        return result
    }

    // Cycle 46 — thin wrapper around free function `binOpToRust(op)`.
    _binOpToRust(op: BinOp): string { return binOpToRust(op) }

    // -- Unary operations --

    _emitUnary(op: UnOp, operand: Expr) {
        switch op {
            UnOp.Neg => {
                this._write("-")
                this._emitExpr(operand)
            },
            UnOp.Not => {
                // RC9 fix: wrap operand in parens if it's a compound expression
                // to avoid `!a == b` instead of `!(a == b)`
                let needsParens = switch operand {
                    Expr.Binary(_, _, _) => true,
                    Expr.Ternary(_, _, _) => true,
                    Expr.Unary(_, _) => true,
                    _ => false
                }
                if needsParens {
                    this._write("!(")
                    this._emitExpr(operand)
                    this._write(")")
                } else {
                    this._write("!")
                    this._emitExpr(operand)
                }
            },
            UnOp.Await => {
                let isTaskHandle = false
                switch operand {
                    Expr.Identifier(awn) => {
                        let snAw = this._sanitizeName(awn)
                        if this._taskHandleVars.has(snAw) { isTaskHandle = true }
                    }
                }
                this._emitExpr(operand)
                if isTaskHandle {
                    this._write(".await.unwrap()")
                } else {
                    this._write(".await")
                }
            }
        }
    }

    // =====================================================================
    //  Phase 3.5 — Type-directed stdlib method dispatch
    // =====================================================================

    // -- Type lookup helpers --
    // These let codegen query TypeContext to know what type a variable/expr has.

    _lookupVarTypeRef(name: string): TypeRef {
        // Search scopes from highest to lowest for this variable name
        let scopeCount = this._typeCtx.scopes.length
        let sid = scopeCount - 1
        while sid >= 0 {
            let key = $"{sid}:{name}"
            if this._typeCtx.varTypes.has(key) {
                let idx = this._typeCtx.varTypes.get(key)
                return this._typeCtx.typePool[idx]
            }
            sid -= 1
        }
        return TypeRef.Simple("unknown")
    }

    _typeRefToTag(t: TypeRef): string { return typeRefToTag(t) }

    // Phase 9.1: Single source of truth for Rust Copy-type detection.
    // Used by clone elision, .copied() dispatch, and deref patterns.
    _isCopyType(t: TypeRef): bool { return isCopyType(t) }

    // Phase 9.1: Resolve the value type V of a Map<K,V> expression, or unknown.
    _getMapValueTypeRef(obj: Expr): TypeRef {
        let result = TypeRef.Simple("unknown")
        let baseType = TypeRef.Simple("unknown")
        switch obj {
            Expr.Identifier(name) => {
                baseType = this._lookupVarTypeRef(name)
            },
            Expr.MemberAccess(maObj, prop) => {
                let isThis = false
                switch maObj {
                    Expr.Identifier(idn) => {
                        if idn == "this" { isThis = true }
                    }
                }
                if isThis && this._currentClassName != "" {
                    let fkey = $"{this._currentClassName}.{prop}"
                    if this._typeCtx.fieldTypes.has(fkey) {
                        let fidx = this._typeCtx.fieldTypes.get(fkey)
                        baseType = this._typeCtx.typePool[fidx]
                    }
                }
            }
        }
        switch baseType {
            TypeRef.MapType(_, v) => { result = v }
        }
        return result
    }

    // Phase 9.1: Resolve the element type T of an Array<T>/[T] expression, or unknown.
    _getArrayElemTypeRef(obj: Expr): TypeRef {
        let result = TypeRef.Simple("unknown")
        let baseType = TypeRef.Simple("unknown")
        switch obj {
            Expr.Identifier(name) => {
                baseType = this._lookupVarTypeRef(name)
            },
            Expr.MemberAccess(maObj, prop) => {
                let isThis = false
                switch maObj {
                    Expr.Identifier(idn) => {
                        if idn == "this" { isThis = true }
                    }
                }
                if isThis && this._currentClassName != "" {
                    let fkey = $"{this._currentClassName}.{prop}"
                    if this._typeCtx.fieldTypes.has(fkey) {
                        let fidx = this._typeCtx.fieldTypes.get(fkey)
                        baseType = this._typeCtx.typePool[fidx]
                    }
                }
            }
        }
        switch baseType {
            TypeRef.Array(elem) => { result = elem }
        }
        return result
    }

    // Phase 8: Check if array indexing expression has Copy-type elements
    _isIndexExprCopyType(obj: Expr): bool { return isIndexExprCopyType(this, obj) }

    // Phase 9.4: returns true iff named var is Array<T> with T Copy.
    // (Map<K,V> is filtered automatically by the TypeRef.Array arm.)
    _arrayIdentNameIsCopyElem(name: string): bool {
        let vt = this._lookupVarTypeRef(name)
        let result = false
        switch vt {
            TypeRef.Array(elem) => {
                if this._isCopyType(elem) { result = true }
            }
        }
        return result
    }

    _getLiteralTypeName(lit: Literal): string { return getLiteralTypeName(lit) }

    _getExprTypeName(expr: Expr): string {
        // Lightweight type inference for codegen dispatch
        let tag = "unknown"
        switch expr {
            Expr.Identifier(name) => {
                let varType = this._lookupVarTypeRef(name)
                tag = this._typeRefToTag(varType)
                // Fallback: check runtime tracking maps
                if tag == "unknown" {
                    let sn = this._sanitizeName(name)
                    if this._mapVars.has(sn) { tag = "map" }
                    else if this._setVars.has(sn) { tag = "set" }
                    else if this._stringVars.has(sn) { tag = "string" }
                }
            },
            Expr.MemberAccess(maObj, prop) => {
                // Handle this.field — look up field type in TypeContext
                let isThis = false
                switch maObj {
                    Expr.Identifier(idn) => {
                        if idn == "this" { isThis = true }
                    }
                }
                if isThis && this._currentClassName != "" {
                    let fkey = $"{this._currentClassName}.{prop}"
                    if this._typeCtx.fieldTypes.has(fkey) {
                        let fidx = this._typeCtx.fieldTypes.get(fkey)
                        let ftype = this._typeCtx.typePool[fidx]
                        tag = this._typeRefToTag(ftype)
                    }
                }
                // B125: handle `var.field` where var is a class instance.
                if tag == "unknown" {
                    switch maObj {
                        Expr.Identifier(varName) => {
                            if varName != "this" && varName != "self" {
                                let varType = this._lookupVarTypeRef(varName)
                                let className = ""
                                switch varType {
                                    TypeRef.Simple(cn) => { className = cn }
                                }
                                if className != "" && this._typeCtx.classes.has(className) {
                                    let fkey2 = $"{className}.{prop}"
                                    if this._typeCtx.fieldTypes.has(fkey2) {
                                        let fidx2 = this._typeCtx.fieldTypes.get(fkey2)
                                        let ftype2 = this._typeCtx.typePool[fidx2]
                                        tag = this._typeRefToTag(ftype2)
                                    }
                                }
                            }
                        }
                    }
                }
                // Chain resolution: this.field.subField
                // If inner MemberAccess resolves to a class type, look up subfield on that class
                if tag == "unknown" {
                    let innerIsThis = false
                    let innerField = ""
                    switch maObj {
                        Expr.MemberAccess(innerObj, iProp) => {
                            switch innerObj {
                                Expr.Identifier(inn) => {
                                    if inn == "this" { innerIsThis = true }
                                }
                            }
                            innerField = iProp
                        }
                    }
                    if innerIsThis && innerField != "" && this._currentClassName != "" {
                        let innerKey = $"{this._currentClassName}.{innerField}"
                        if this._typeCtx.fieldTypes.has(innerKey) {
                            let innerIdx = this._typeCtx.fieldTypes.get(innerKey)
                            let innerType = this._typeCtx.typePool[innerIdx]
                            // If inner type is a class, look up prop on that class
                            let innerClassName = ""
                            switch innerType {
                                TypeRef.Simple(cn) => { innerClassName = cn }
                            }
                            if innerClassName != "" && this._typeCtx.classes.has(innerClassName) {
                                let subKey = $"{innerClassName}.{prop}"
                                if this._typeCtx.fieldTypes.has(subKey) {
                                    let subIdx = this._typeCtx.fieldTypes.get(subKey)
                                    let subType = this._typeCtx.typePool[subIdx]
                                    tag = this._typeRefToTag(subType)
                                }
                            }
                        }
                    }
                }
            },
            Expr.Literal(lit) => {
                tag = this._getLiteralTypeName(lit)
            },
            Expr.StringTemplate(_) => { tag = "string" },
            Expr.ArrayLiteral(_) => { tag = "array" },
            Expr.MapLiteral(_) => { tag = "map" },
            Expr.SetLiteral(_) => { tag = "set" }
        }
        return tag
    }

    // -- Function calls (with free function mapping) --

    _emitCall(callee: Expr, args: [Expr]) {
        // Classify the call type without consuming args
        let callType = ""
        switch callee {
            Expr.Identifier(fnName) => {
                if fnName == "print" { callType = "print" }
                else if fnName == "println" { callType = "println" }
                else if fnName == "toString" { callType = "toString" }
                else if fnName == "toInt" { callType = "toInt" }
                else if fnName == "toFloat" { callType = "toFloat" }
                else if fnName == "parseInt" { callType = "parseInt" }
                else if fnName == "parseFloat" { callType = "parseFloat" }
            }
        }

        // Dispatch — args consumed in exactly one branch
        if callType == "print" {
            this._emitPrintCall(args)
        } else if callType == "println" {
            this._emitPrintlnCall(args)
        } else if callType == "toString" && args.length > 0 {
            this._write("format!(\"{}\", ")
            this._emitExpr(args[0])
            this._write(")")
        } else if callType == "toInt" && args.length > 0 {
            this._emitExpr(args[0])
            this._write(".to_string().parse::<i32>().unwrap_or(0)")
        } else if callType == "toFloat" && args.length > 0 {
            this._emitExpr(args[0])
            this._write(".to_string().parse::<f64>().unwrap_or(0.0)")
        } else if callType == "parseInt" && args.length > 0 {
            // parseInt(x) → x.parse::<i32>() — returns Result
            this._emitExpr(args[0])
            this._write(".to_string().parse::<i32>()")
        } else if callType == "parseFloat" && args.length > 0 {
            // parseFloat(x) → x.parse::<f64>() — returns Result
            this._emitExpr(args[0])
            this._write(".to_string().parse::<f64>()")
        } else {
            // Check if this is a constructor call (class name starts with uppercase)
            let isConstructor = false
            let className = ""
            switch callee {
                Expr.Identifier(fnName) => {
                    if fnName.length > 0 {
                        let firstChar = fnName.substring(0, 1)
                        if firstChar >= "A" && firstChar <= "Z" {
                            isConstructor = true
                            className = fnName
                        }
                    }
                }
            }
            if isConstructor {
                this._write(className + "::new(")
            } else {
                this._emitExpr(callee)
                this._write("(")
            }
            // Phase 8.5: resolve callee for borrowed-param lookup
            let calleeForBorrow = ""
            if !isConstructor {
                switch callee {
                    Expr.Identifier(fnBorrow) => {
                        calleeForBorrow = this._sanitizeName(fnBorrow)
                    }
                }
            }
            let aIdx = 0
            for a in args {
                if aIdx > 0 { this._write(", ") }
                // GAP-007: if this position expects a Box<dyn Fn>, wrap a Lambda
                // arg in Box::new(...) so the Box<dyn Fn> param gets the right type.
                let isFnParam = false
                if calleeForBorrow != "" && this._functionFnParamMask.has(calleeForBorrow) {
                    let mask = this._functionFnParamMask.get(calleeForBorrow)
                    if aIdx < mask.length && mask.charAt(aIdx) == "1" {
                        isFnParam = true
                    }
                }
                let isLambdaArg = false
                switch a {
                    Expr.Lambda(_) => { isLambdaArg = true }
                }
                if isFnParam && isLambdaArg {
                    this._write("Box::new(")
                    this._emitExpr(a)
                    this._write(")")
                } else {
                    // Check if this arg position is a borrowed (&str) param
                    let bKey = calleeForBorrow + ":" + aIdx.toString()
                    if calleeForBorrow != "" && this._borrowedParamIndices.has(bKey) {
                        if this._borrowedParamMutIndices.has(bKey) {
                            this._emitMutBorrowedArg(a)
                        } else {
                            this._emitBorrowedArg(a)
                        }
                    } else {
                        this._emitClonedArg(a)
                    }
                }
                aIdx += 1
            }
            // Inject default parameter values for missing arguments
            let calleeFnName = ""
            switch callee {
                Expr.Identifier(fn2) => { calleeFnName = this._sanitizeName(fn2) }
            }
            if calleeFnName != "" && this._functionParamCount.has(calleeFnName) {
                let totalParams = this._functionParamCount.get(calleeFnName)
                let provided = args.length
                let fillIdx = provided
                while fillIdx < totalParams {
                    let dKey = calleeFnName + ":" + fillIdx.toString()
                    if this._functionDefaultStrs.has(dKey) {
                        if provided > 0 || fillIdx > 0 {
                            this._write(", ")
                        }
                        this._write(this._functionDefaultStrs.get(dKey))
                    }
                    fillIdx += 1
                }
            }
            this._write(")")
        }
    }

    _emitPrintCall(args: [Expr]) {
        if args.length == 0 {
            this._write("println!()")
        } else if args.length == 1 {
            // Phase 8: print("literal") → println!("literal") without format! wrapper
            let isLiteral = false
            let litVal = ""
            switch args[0] {
                Expr.Literal(lit) => {
                    switch lit {
                        Literal.Str(s) => { isLiteral = true; litVal = s }
                    }
                }
            }
            if isLiteral {
                // Escape Rust special chars first (\, ", \n, ...) then escape
                // braces for println! formatting placeholders.
                let escapedRust = this._escapeRustStr(litVal)
                let escaped = escapedRust.replaceAll("{", "{{").replaceAll("}", "}}")
                this._write($"println!(\"{escaped}\")")
            } else {
                // Phase 8: check if arg is StringTemplate → emit format directly
                let isTemplate = false
                switch args[0] {
                    Expr.StringTemplate(_) => { isTemplate = true }
                }
                if isTemplate {
                    // println($"...") → println!("fmt", args) instead of println!("{}", format!(...))
                    this._write("println!(")
                    this._emitStringTemplateInline(args[0])
                    this._write(")")
                } else {
                    // Use Debug format for collections, Display for scalars/strings
                    let argTag = this._getExprTypeName(args[0])
                    let useDebug = argTag == "array" or argTag == "map" or argTag == "set"
                    if useDebug {
                        this._write("println!(\"{:?}\", ")
                    } else {
                        this._write("println!(\"{}\", ")
                    }
                    this._emitExpr(args[0])
                    this._write(")")
                }
            }
        } else {
            // Multiple args: print each separated by space
            let fmtParts = ""
            let pIdx = 0
            while pIdx < args.length {
                if pIdx > 0 { fmtParts += " " }
                fmtParts += "{}"
                pIdx += 1
            }
            this._write("println!(\"" + fmtParts + "\"")
            for a in args {
                this._write(", ")
                this._emitExpr(a)
            }
            this._write(")")
        }
    }

    _emitPrintlnCall(args: [Expr]) {
        if args.length == 0 {
            this._write("println!()")
        } else if args.length == 1 {
            // Phase 8: println("literal") → println!("literal") without format! wrapper
            let isLiteral = false
            let litVal = ""
            switch args[0] {
                Expr.Literal(lit) => {
                    switch lit {
                        Literal.Str(s) => { isLiteral = true; litVal = s }
                    }
                }
            }
            if isLiteral {
                let escaped = litVal.replaceAll("{", "{{").replaceAll("}", "}}")
                this._write($"println!(\"{escaped}\")")
            } else {
                // Phase 8: check if arg is StringTemplate → emit format directly
                let isTemplate2 = false
                switch args[0] {
                    Expr.StringTemplate(_) => { isTemplate2 = true }
                }
                if isTemplate2 {
                    this._write("println!(")
                    this._emitStringTemplateInline(args[0])
                    this._write(")")
                } else {
                    let argTag2 = this._getExprTypeName(args[0])
                    let useDebug2 = argTag2 == "array" or argTag2 == "map" or argTag2 == "set"
                    if useDebug2 {
                        this._write("println!(\"{:?}\", ")
                    } else {
                        this._write("println!(\"{}\", ")
                    }
                    this._emitExpr(args[0])
                    this._write(")")
                }
            }
        } else {
            let fmtParts = ""
            let pIdx = 0
            while pIdx < args.length {
                if pIdx > 0 { fmtParts += " " }
                fmtParts += "{}"
                pIdx += 1
            }
            this._write("println!(\"" + fmtParts + "\"")
            for a in args {
                this._write(", ")
                this._emitExpr(a)
            }
            this._write(")")
        }
    }

    // -- Self method call with extracted args (avoids E0499 double mutable borrow) --

    _emitSelfMethodExtracted(method: string, args: [Expr]) {
        // For self.method(args) where args might contain self.other() calls,
        // use block expression: {let __t0 = arg0; let __t1 = arg1; self.method(__t0, __t1)}
        this._write("{ ")
        let tempNames: [string] = []
        let idx = 0
        for a in args {
            let tempName = $"__self_arg_{idx}"
            this._write($"let {tempName} = ")
            this._emitExpr(a)
            this._write("; ")
            tempNames.push(tempName)
            idx += 1
        }
        let sanitized = this._sanitizeName(method)
        this._write($"self.{sanitized}(")
        let i2 = 0
        for t in tempNames {
            if i2 > 0 { this._write(", ") }
            this._write(t)
            i2 += 1
        }
        this._write(") }")
    }

    // =====================================================================
    //  liva/test: expect(x).matcher(y) → assert_eq!/assert!/assert_ne! etc.
    // =====================================================================

    _tryEmitExpectChain(obj: Expr, method: string, args: [Expr]): bool {
        // Pattern: expect(actual).toBe(expected) or expect(actual).not.toBe(expected)
        // Generate actual code and expected code into buffers, then emit assertion

        let actualCode = ""
        let isNegated = false
        let isExpect = false
        let isOption = false

        // Direct: expect(x).toBe(y) — obj is Call(Identifier("expect"), [x])
        switch obj {
            Expr.Call(callee, cArgs, _, _) => {
                let fnName = ""
                switch callee {
                    Expr.Identifier(n) => { fnName = n }
                }
                if fnName == "expect" and cArgs.length > 0 {
                    isExpect = true
                    for ca in cArgs {
                        // Check if actual expr is Option type BEFORE consuming expr
                        switch ca {
                            Expr.Identifier(varName) => {
                                let vt = this._lookupVarTypeRef(varName)
                                switch vt {
                                    TypeRef.OptionalType(_) => { isOption = true }
                                }
                            }
                        }
                        actualCode = this._exprToString(ca)
                        break
                    }
                }
            },
            // Negated: expect(x).not.toBe(y)
            Expr.MemberAccess(maObj, prop) => {
                if prop == "not" {
                    switch maObj {
                        Expr.Call(callee2, cArgs2, _, _) => {
                            let fnName2 = ""
                            switch callee2 {
                                Expr.Identifier(n2) => { fnName2 = n2 }
                            }
                            if fnName2 == "expect" and cArgs2.length > 0 {
                                isExpect = true
                                isNegated = true
                                for ca2 in cArgs2 {
                                    switch ca2 {
                                        Expr.Identifier(varName2) => {
                                            let vt2 = this._lookupVarTypeRef(varName2)
                                            switch vt2 {
                                                TypeRef.OptionalType(_) => { isOption = true }
                                            }
                                        }
                                    }
                                    actualCode = this._exprToString(ca2)
                                    break
                                }
                            }
                        }
                    }
                }
            }
        }

        if not isExpect { return false }

        let expectedCode = ""
        if args.length > 0 {
            for a in args { expectedCode = this._exprToString(a); break }
        }

        // Check if expected is null
        let expectedIsNull = false
        if args.length > 0 {
            for a2 in args {
                switch a2 {
                    Expr.Literal(lit) => {
                        switch lit {
                            Literal.Null => { expectedIsNull = true }
                        }
                    }
                }
                break
            }
        }

        // Emit the appropriate assertion
        this._emitExpectAssertion(method, actualCode, expectedCode, isNegated, expectedIsNull, isOption)
        return true
    }

    // Helper: emit an expr into a string buffer without writing to output
    _exprToString(expr: Expr): string {
        let savedLine = $"{this._currentLine}"
        let savedLines: [string] = []
        for ln in this._lines { savedLines.push(ln) }
        this._currentLine = ""
        this._lines = []
        this._emitExpr(expr)
        let result = $"{this._currentLine}"
        this._currentLine = savedLine
        this._lines = savedLines
        return result
    }

    // Emit the correct assert_* macro
    _emitExpectAssertion(method: string, actual: string, expected: string, neg: bool, isNull: bool, isOption: bool) {
        if method == "toBe" or method == "toEqual" {
            if isNull {
                if neg { this._write($"assert!({actual}.is_some())") }
                else { this._write($"assert!({actual}.is_none())") }
            } else if neg {
                this._write($"assert_ne!({actual}, {expected})")
            } else {
                this._write($"assert_eq!({actual}, {expected})")
            }
        } else if method == "toBeTruthy" {
            if isOption {
                if neg { this._write($"assert!({actual}.is_none())") }
                else { this._write($"assert!({actual}.is_some())") }
            } else {
                if neg { this._write($"assert!(!({actual}))") }
                else { this._write($"assert!({actual})") }
            }
        } else if method == "toBeFalsy" {
            if isOption {
                if neg { this._write($"assert!({actual}.is_some())") }
                else { this._write($"assert!({actual}.is_none())") }
            } else {
                if neg { this._write($"assert!({actual})") }
                else { this._write($"assert!(!({actual}))") }
            }
        } else if method == "toBeGreaterThan" {
            if neg { this._write($"assert!({actual} <= {expected})") }
            else { this._write($"assert!({actual} > {expected})") }
        } else if method == "toBeLessThan" {
            if neg { this._write($"assert!({actual} >= {expected})") }
            else { this._write($"assert!({actual} < {expected})") }
        } else if method == "toBeGreaterThanOrEqual" {
            if neg { this._write($"assert!({actual} < {expected})") }
            else { this._write($"assert!({actual} >= {expected})") }
        } else if method == "toBeLessThanOrEqual" {
            if neg { this._write($"assert!({actual} > {expected})") }
            else { this._write($"assert!({actual} <= {expected})") }
        } else if method == "toContain" {
            if neg { this._write($"assert!(!{actual}.contains(&{expected}))") }
            else { this._write($"assert!({actual}.contains(&{expected}))") }
        } else if method == "toBeNull" {
            if neg { this._write($"assert!({actual}.is_some())") }
            else { this._write($"assert!({actual}.is_none())") }
        }
    }

    // -- Method calls (type-directed dispatch) --


    _isKnownStringMethod(m: string): bool { return isKnownStringMethod(m) }

    _isKnownArrayMethod(m: string): bool { return isKnownArrayMethod(m) }

    _isKnownMapMethod(m: string): bool { return isKnownMapMethod(m) }

    _isKnownSetMethod(m: string): bool { return isKnownSetMethod(m) }

    _isKnownDateMethod(m: string): bool { return isKnownDateMethod(m) }

    // Date / String / Array / Map / Set method lowering lives in
    // codegen_stdlib_methods.liva (extend RustEmitter).

    // Phase 8.8: emit expr suppressing self.field clone if expr is a direct MemberAccess
    // Used in comparison contexts where clone is wasteful (String: PartialEq<str>)
    _emitExprNoMemberClone(expr: Expr) {
        let isMember = false
        switch expr {
            Expr.MemberAccess(_, _) => { isMember = true }
        }
        if isMember {
            let saved = this._inAssignTarget
            this._inAssignTarget = true
            this._emitExpr(expr)
            this._inAssignTarget = saved
        } else {
            this._emitExpr(expr)
        }
    }

    _emitMemberAccess(obj: Expr, prop: string) {
        // A.3: inside a server handler, `req.params` → `__params`,
        // `req.body` → `body.clone()`.
        if this._serverRequestParam != "" {
            let isReqMember = false
            switch obj {
                Expr.Identifier(reqName) => {
                    if reqName == this._serverRequestParam { isReqMember = true }
                }
            }
            if isReqMember {
                if prop == "params" { this._write("__params"); return }
                if prop == "body" { this._write("body.clone()"); return }
            }
        }

        // B148: in constructor body, rewrite `this.X` reads to `__field_X`
        // for fields already assigned (so reads in conditions/prints/etc work).
        if this._inConstructor {
            let isThisX = false
            switch obj {
                Expr.Identifier(thisName) => {
                    if thisName == "this" || thisName == "self" { isThisX = true }
                }
            }
            if isThisX {
                let sanProp = this._sanitizeName(prop)
                if this._constructorAssignedFields.has(sanProp) {
                    this._write($"__field_{sanProp}")
                    return
                }
            }
        }

        let objTag = this._getExprTypeName(obj)

        // B130 (gen-2): err-binding `.message` access inside an
        // `if err { ... }` block — emit the unwrapped form so it satisfies
        // `String` return types / format args. Outside truthy-narrow we
        // leave emission unchanged (the binding may already be unwrapped
        // in nested scopes).
        switch obj {
            Expr.Identifier(idn) => {
                let snErr2 = this._sanitizeName(idn)
                if prop == "message" && this._errBindings.has(snErr2) && this._truthyErrBindings.has(snErr2) {
                    this._write(snErr2 + ".as_ref().unwrap().message.clone()")
                    return
                }
            }
        }

        // Stdlib module property access before generic enum/class handling
        let stdlibPropName = ""
        switch obj {
            Expr.Identifier(sn) => { stdlibPropName = sn }
        }
        // Math constants: Math.PI, Math.E
        if stdlibPropName == "Math" && prop == "PI" { this._write("std::f64::consts::PI"); return }
        if stdlibPropName == "Math" && prop == "E" { this._write("std::f64::consts::E"); return }
        // Date property access: d.year, d.month, d.day, d.hour, d.minute, d.second
        if prop == "year" { this._write("(chrono::Datelike::year(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "month" { this._write("(chrono::Datelike::month(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "day" { this._write("(chrono::Datelike::day(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "hour" { this._write("(chrono::Timelike::hour(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "minute" { this._write("(chrono::Timelike::minute(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "second" { this._write("(chrono::Timelike::second(&"); this._emitExpr(obj); this._write(") as i32)"); return }

        // Enum variant access: EnumName.Variant → EnumName::Variant
        // Heuristic: PascalCase identifier = enum/class → use :: syntax
        let isEnumAccess = false
        let enumName = ""
        switch obj {
            Expr.Identifier(name) => {
                if name.length > 0 {
                    let firstChar = name.charAt(0)
                    if firstChar >= "A" && firstChar <= "Z" {
                        isEnumAccess = true
                        enumName = name
                    }
                }
            }
        }
        if isEnumAccess {
            this._write(enumName + "::" + prop)
            return
        }

        // .length → .len() as i32 for strings and arrays.
        // But if the receiver is a user class with a declared `length` field,
        // treat it as a regular field access instead.
        if prop == "length" {
            let isUserClassWithLengthField = false
            switch obj {
                Expr.Identifier(idn) => {
                    if idn != "this" && idn != "self" {
                        let varType = this._lookupVarTypeRef(idn)
                        let className = ""
                        switch varType {
                            TypeRef.Simple(cn) => { className = cn }
                        }
                        if className != "" && this._typeCtx.classes.has(className) {
                            let fkeyLen = className + ".length"
                            if this._typeCtx.fieldTypes.has(fkeyLen) {
                                isUserClassWithLengthField = true
                            }
                        }
                    }
                }
            }
            if not isUserClassWithLengthField {
                let savedAT = this._inAssignTarget
                this._inAssignTarget = true
                this._write("(")
                this._emitExpr(obj)
                this._write(".len() as i32)")
                this._inAssignTarget = savedAT
                return
            }
        }

        // .size → .len() as i32 for maps and sets
        if prop == "size" {
            if objTag == "map" {
                let savedAT = this._inAssignTarget
                this._inAssignTarget = true
                this._write("(")
                this._emitExpr(obj)
                this._write(".len() as i32)")
                this._inAssignTarget = savedAT
                return
            }
            if objTag == "set" {
                let savedAT = this._inAssignTarget
                this._inAssignTarget = true
                this._write("(")
                this._emitExpr(obj)
                this._write(".len() as i32)")
                this._inAssignTarget = savedAT
                return
            }
        }

        // Default: emit as field access
        // If accessing self fields in a method, clone to avoid move-from-borrow
        let isSelfAccess = false
        switch obj {
            Expr.Identifier(oName) => {
                if oName == "this" {
                    isSelfAccess = true
                }
            }
        }
        this._emitExpr(obj)
        let snField = this._sanitizeName(prop)
        this._write($".{snField}")
        // Clone self.field when accessed as a value (return, let binding, etc.)
        // Skip clone for Copy-type fields (int, bool, float) — they don't need it
        // Skip clone when _inAssignTarget is set (indexing, .length, method call base)
        if isSelfAccess && not this._inAssignTarget {
            // Check field type — skip clone for Copy types
            let fieldTag = "unknown"
            if this._currentClassName != "" {
                let fkey = $"{this._currentClassName}.{prop}"
                if this._typeCtx.fieldTypes.has(fkey) {
                    let fidx = this._typeCtx.fieldTypes.get(fkey)
                    let ftype = this._typeCtx.typePool[fidx]
                    fieldTag = this._typeRefToTag(ftype)
                }
            }
            if fieldTag != "number" && fieldTag != "bool" && fieldTag != "float" {
                this._write(".clone()")
            }
        }
    }

    // =====================================================================
    //  Phase 3.6 — Ownership emission helpers
    // =====================================================================
    // Emit &arg for String/Vec args to methods that take references.
    // Uses a simple heuristic: if the arg is a variable (not a literal),
    // emit &arg. For literals, emit directly (refs created automatically).

    _emitRefArg(argExpr: Expr) {
        // String literals don't need & prefix (auto-refs) but must suppress .to_string()
        let isLiteral = false
        switch argExpr {
            Expr.Literal(_) => { isLiteral = true },
            Expr.StringTemplate(_) => { isLiteral = true }
        }
        if isLiteral {
            this._suppressToString = true
            this._emitExpr(argExpr)
            this._suppressToString = false
        } else {
            this._write("&")
            this._emitExpr(argExpr)
        }
    }

    // Phase 10.4: returns true if `e` is an Identifier that the compiler can
    // move (consume) safely instead of clone — used by sort/reversed/etc to
    // avoid Vec::clone() in the dominant pattern `let arr = ...; arr.sort()`
    // inside a loop body where arr is dead after the call.
    _canMoveIdent(e: Expr): bool {
        let result = false
        switch e {
            Expr.Identifier(n) => {
                let liveKey = $"{this._currentFunc}:{n}"
                if this._liveCtx.useCounts.has(liveKey) {
                    let uc = this._liveCtx.useCounts.get(liveKey)
                    let declaredInLoop = this._liveCtx.declaredInLoop.has(liveKey)
                    if uc <= 1 && declaredInLoop { result = true }
                }
            }
        }
        return result
    }

    // Phase 10.4: peephole — fuse `let X = expr.split(sep); for Y in X { body }`
    // into `for Y in expr.split(sep).map(|s| s.to_string()) { body }` when X is
    // single-use. The fusion is performed inline in `_emitBlock` (see above).
    // Phase 8.6: Emit map/set key arg — &str params don't need &() wrapping
    // HashMap<String,_>::contains_key/get takes &Q where String: Borrow<Q>.
    // Since String: Borrow<str>, passing &str directly works. Adding &() creates &&str which fails.
    //
    // Phase 10.4: when key is an Identifier holding a String, emit `key.as_str()` instead
    // of `&(key)` so the Map APIs lookup against `&str` directly (skips one auto-deref).
    _emitMapKeyArg(argExpr: Expr) {
        let isStrRef = false
        let isStringIdent = false
        let identSan = ""
        switch argExpr {
            Expr.Identifier(aName) => {
                let aNameCopy = $"{aName}"
                let sn = this._sanitizeName(aName)
                if this._strRefParams.has(sn) {
                    isStrRef = true
                } else {
                    let varType = this._lookupVarTypeRef(aNameCopy)
                    let tag = this._typeRefToTag(varType)
                    if tag == "string" {
                        isStringIdent = true
                        identSan = sn
                    }
                }
            }
        }
        if isStrRef {
            this._emitExpr(argExpr)
        } else if isStringIdent {
            this._write(identSan)
            this._write(".as_str()")
        } else {
            this._write("&(")
            this._emitExpr(argExpr)
            this._write(")")
        }
    }

    // Phase 8.5: Emit arg for &str param — string literals as-is, others with & prefix
    _emitBorrowedArg(argExpr: Expr) {
        let isStrLit = false
        switch argExpr {
            Expr.Literal(aLit) => {
                switch aLit {
                    Literal.Str(_) => { isStrLit = true }
                }
            }
        }
        if isStrLit {
            // String literal is already &str in Rust — just suppress .to_string()
            this._suppressCloneForBorrow = true
            this._emitExpr(argExpr)
            this._suppressCloneForBorrow = false
        } else {
            // & prefix converts String → &str via Deref, &&str auto-derefs
            // Suppress .clone() from _emitMemberAccess → direct borrow is cheaper
            let savedAT = this._inAssignTarget
            this._inAssignTarget = true
            this._write("&")
            this._emitExpr(argExpr)
            this._inAssignTarget = savedAT
        }
    }

    // Cycle 39: emit `&mut <arg>` for params declared as `&mut T`. Skips the
    // identifier-clone path so we get a direct mutable borrow.
    _emitMutBorrowedArg(argExpr: Expr) {
        let savedAT = this._inAssignTarget
        this._inAssignTarget = true
        this._write("&mut ")
        this._emitExpr(argExpr)
        this._inAssignTarget = savedAT
    }

    // Emit expression with .clone() for non-Copy types (identifiers, member access)
    _emitClonedArg(argExpr: Expr) {
        let needsClone = false
        switch argExpr {
            Expr.Identifier(name) => {
                // Don't clone literals-like identifiers (this is handled by emitExpr)
                if name != "true" && name != "false" && name != "null" {
                    // Phase 9.1: skip clone for Copy types via unified helper
                    let varType = this._lookupVarTypeRef(name)
                    if this._isCopyType(varType) {
                        needsClone = false
                    } else {
                        // Phase 8: skip clone for single-use vars NOT in loops
                        // Phase 10.2: also skip clone when var is declared inside the
                        // current loop body (single-use-per-iteration is move-safe).
                        let isSingleUse = false
                        let liveKey = $"{this._currentFunc}:{name}"
                        if this._liveCtx.useCounts.has(liveKey) {
                            let uc = this._liveCtx.useCounts.get(liveKey)
                            let inLoop = this._liveCtx.loopUseCounts.has(liveKey)
                            let declaredInLoop = this._liveCtx.declaredInLoop.has(liveKey)
                            if uc <= 1 && (not inLoop || declaredInLoop) { isSingleUse = true }
                        }
                        // Cycle 40: params emitted as `&Vec/&HashMap/&HashSet`
                        // (or `&mut`) cannot be moved — force a clone so the
                        // call site dereferences the borrow into an owned value.
                        let sanCheck = this._sanitizeName(name)
                        if this._collRefParams.has(sanCheck) {
                            isSingleUse = false
                        }
                        if isSingleUse {
                            needsClone = false
                        } else {
                            needsClone = true
                        }
                    }
                }
            },
            Expr.MemberAccess(maObj, _) => {
                // this.field is auto-cloned in _emitMemberAccess — skip here
                // Enum/type variant (PascalCase) is a value constructor — always owned, no clone
                // other.field needs clone when passed as arg
                let isSelf = false
                let isEnumOrType = false
                switch maObj {
                    Expr.Identifier(oName) => {
                        if oName == "this" { isSelf = true }
                        if oName.length > 0 {
                            let fc = oName.charAt(0)
                            if fc >= "A" && fc <= "Z" { isEnumOrType = true }
                        }
                    }
                }
                if not isSelf && not isEnumOrType { needsClone = true }
            }
        }
        this._emitExpr(argExpr)
        if needsClone {
            // Phase 8.6: &str params — .into() works universally (String or &str callees)
            if this._lastEmittedStrRef {
                this._write(".into()")
            } else {
                this._write(".clone()")
            }
        } else if this._lastEmittedStrRef {
            // Single-use &str params: .into() converts to expected type (String or &str)
            this._write(".into()")
        }
    }

    // -- Struct literal (constructor call) --

    _emitStructLiteral(typeName: string, fields: [ObjField]) {
        this._write($"{typeName}::new(")
        let fIdx = 0
        for f in fields {
            if fIdx > 0 { this._write(", ") }
            this._emitClonedArg(f.value)
            fIdx += 1
        }
        this._write(")")
    }

    // -- Object literal (anonymous Map) --

    _emitObjectLiteral(fields: [ObjField]) {
        this._write("{ let mut _map = HashMap::new(); ")
        for f in fields {
            let key = $"{f.key}"
            this._write($"_map.insert(\"{key}\".to_string(), ")
            this._emitExpr(f.value)
            this._write("); ")
        }
        this._write("_map }")
    }

    // -- JSON literal arg for serde_json::json!() — emits {"key": expr, ...} --

    _emitJsonArg(expr: Expr) {
        switch expr {
            Expr.ObjectLiteral(jFields) => {
                this._emitJsonObjectFields(jFields)
            },
            Expr.MapLiteral(jEntries) => {
                this._emitJsonMapEntries(jEntries)
            },
            Expr.ArrayLiteral(jElems) => {
                this._emitJsonArrayElems(jElems)
            },
            _ => {
                this._emitExpr(expr)
            }
        }
    }

    _emitJsonObjectFields(fields: [ObjField]) {
        this._write("{")
        let jIdx = 0
        for f in fields {
            if jIdx > 0 { this._write(", ") }
            let key = $"{f.key}"
            this._write($"\"{key}\": ")
            this._emitJsonArg(f.value)
            jIdx += 1
        }
        this._write("}")
    }

    _emitJsonMapEntries(entries: [MapEntry]) {
        this._write("{")
        let jIdx = 0
        for e in entries {
            if jIdx > 0 { this._write(", ") }
            this._emitJsonKey(e.key)
            this._write(": ")
            this._emitJsonArg(e.value)
            jIdx += 1
        }
        this._write("}")
    }

    // serde_json::json! requires raw string-literal keys; emit string-lit
    // keys bare without `.to_string()`, and fall back to _emitJsonArg
    // (which adds .to_string()) for non-literal keys (rare/dynamic).
    _emitJsonKey(key: Expr) {
        switch key {
            Expr.Literal(klit) => {
                switch klit {
                    Literal.Str(ks) => { this._write("\"" + ks + "\"") },
                    _ => { this._emitLiteral(klit) }
                }
            },
            _ => { this._emitJsonArg(key) }
        }
    }

    // BUG-3 fix: emit the `__params` Vec<String> binding for a DB.exec/query
    // params argument. When the param expr is an `ArrayLiteral`, emit each
    // element with a trailing `.to_string()` directly inside `vec![]` so
    // String identifiers are cloned (`.to_string()` returns a new String)
    // instead of moved by `vec!`. Mirrors bootstrap `generate_db_params_vec`.
    // Fallback path (non-literal expr) keeps the `.iter().map(...)` form
    // which is fine for &[T] / Vec<T> references.
    _emitDbParamsVec(expr: Expr) {
        switch expr {
            Expr.ArrayLiteral(elems) => {
                this._write("let __params: Vec<String> = vec![")
                let i = 0
                for elem in elems {
                    if i > 0 { this._write(", ") }
                    this._emitExpr(elem)
                    this._write(".to_string()")
                    i += 1
                }
                this._write("]; let __param_refs: Vec<&dyn rusqlite::types::ToSql> = __params.iter().map(|s| s as &dyn rusqlite::types::ToSql).collect();")
            },
            _ => {
                this._write($"{DB_PARAM_BINDING}")
                this._emitExpr(expr)
                this._write($"{DB_PARAM_BINDING_TAIL}")
            }
        }
    }

    // Emit an expression in `format!`-arg position. If the expr is an
    // identifier bound as Option<liva_rt::Error> via a fallible
    // destructure (let v, err = call()), unwrap with as_ref().map().
    // Without this, `"prefix" + err` would emit
    //   format!("{}{}", "prefix".to_string(), err)
    // which fails: Option<liva_rt::Error> doesn't impl Display.
    // Mirrors the existing handling in _emitStringTemplateInner.
    _emitFormatArg(expr: Expr) {
        let isErrBinding = false
        switch expr {
            Expr.Identifier(spName) => {
                let snErr = this._sanitizeName(spName)
                if this._errBindings.has(snErr) {
                    isErrBinding = true
                }
            }
        }
        if isErrBinding {
            this._emitExpr(expr)
            this._write(".as_ref().map(|e| format!(\"{}\", e)).unwrap_or_default()")
        } else {
            this._emitExpr(expr)
        }
    }

    _emitJsonArrayElems(elements: [Expr]) {
        this._write("[")
        let jIdx = 0
        for e in elements {
            if jIdx > 0 { this._write(", ") }
            this._emitJsonArg(e)
            jIdx += 1
        }
        this._write("]")
    }

    // -- Array literal --

    _emitArrayLiteral(elements: [Expr]) {
        if elements.length == 0 {
            this._write("vec![]")
        } else {
            this._write("vec![")
            let aIdx = 0
            for e in elements {
                if aIdx > 0 { this._write(", ") }
                // Clone non-Copy identifiers (String / array / map / set / class)
                // to avoid moving a binding that may be used after the literal.
                // Mirrors the bootstrap behavior `vec![start.clone()]`.
                let cloned = false
                switch e {
                    Expr.Identifier(elName) => {
                        let elNameCopy = $"{elName}"
                        let varType = this._lookupVarTypeRef(elNameCopy)
                        let elTag = this._typeRefToTag(varType)
                        let isNonCopy = false
                        if elTag == "string" { isNonCopy = true }
                        if elTag == "array" { isNonCopy = true }
                        if elTag == "map" { isNonCopy = true }
                        if elTag == "set" { isNonCopy = true }
                        if elTag == "class" { isNonCopy = true }
                        if isNonCopy {
                            this._emitExpr(e)
                            this._write(".clone()")
                            cloned = true
                        }
                    }
                }
                if not cloned {
                    this._emitExpr(e)
                }
                aIdx += 1
            }
            this._write("]")
        }
    }

    // -- Map literal --

    _emitMapLiteral(entries: [MapEntry]) {
        if entries.length == 0 {
            this._write("HashMap::new()")
        } else {
            this._write("{ let mut _map = HashMap::new(); ")
            for e in entries {
                this._write("_map.insert(")
                this._emitExpr(e.key)
                this._write(", ")
                this._emitExpr(e.value)
                this._write("); ")
            }
            this._write("_map }")
        }
    }

    // -- Set literal --

    _emitSetLiteral(elements: [Expr]) {
        if elements.length == 0 {
            this._write("HashSet::new()")
        } else {
            this._write("{ let mut _set = HashSet::new(); ")
            for e in elements {
                this._write("_set.insert(")
                this._emitExpr(e)
                this._write("); ")
            }
            this._write("_set }")
        }
    }

    // -- Lambda --

    // Emit only the body of a lambda as an expression (no |params| header).
    // Used by stdlib synthesizers (sortBy/groupBy) that wrap the body
    // in their own scope and parameter bindings.
    _emitLambdaBodyInline(lam: LambdaExpr) {
        switch lam.body {
            LambdaBody.Expr(lamExprs) => {
                if lamExprs.length == 1 {
                    for le in lamExprs { this._emitExpr(le); break }
                } else {
                    this._write("{ ")
                    for e in lamExprs {
                        this._emitExpr(e)
                        this._write("; ")
                    }
                    this._write("}")
                }
            },
            LambdaBody.Block(lamBlock) => {
                this._write("{")
                this._newline()
                this._indent()
                this._emitBlock(lamBlock)
                this._dedent()
                this._writeIndent()
                this._write("}")
            }
        }
    }

    _emitLambda(lam: LambdaExpr) {
        if lam.isMove {
            this._write("move ")
        }
        this._write("|")
        let pIdx = 0
        let needDeref = this._derefClosureParams
        this._derefClosureParams = false
        for p in lam.params {
            if pIdx > 0 { this._write(", ") }
            let pName = switch p.pattern {
                BindingPattern.Identifier(n) => n,
                _ => "_"
            }
            let snP = this._sanitizeName(pName)
            if needDeref {
                this._write("&" + snP)
            } else {
                this._write(snP)
            }
            pIdx += 1
        }
        this._write("| ")
        switch lam.body {
            LambdaBody.Expr(lamExprs) => {
                if lamExprs.length == 1 {
                    for le in lamExprs { this._emitExpr(le); break }
                } else {
                    this._write("{ ")
                    for e in lamExprs {
                        this._emitExpr(e)
                        this._write("; ")
                    }
                    this._write("}")
                }
            },
            LambdaBody.Block(lamBlock) => {
                this._write("{")
                this._newline()
                this._indent()
                this._emitBlock(lamBlock)
                this._dedent()
                this._writeIndent()
                this._write("}")
            }
        }
    }

    // -- String template --

    _emitStringTemplate(parts: [StringTemplatePart]) {
        // Phase 8.7: single-expression template $"{x}" → x.to_string() instead of format!("{}", x)
        if parts.length == 1 {
            let isSingleExpr = false
            switch parts[0] {
                StringTemplatePart.ExprPart(_) => { isSingleExpr = true }
            }
            if isSingleExpr {
                switch parts[0] {
                    StringTemplatePart.ExprPart(expr) => {
                        this._emitExpr(expr)
                        this._write(".to_string()")
                    }
                }
                return
            }
        }
        // Multi-part template: format!("...", args)
        this._write("format!(")
        this._emitStringTemplateInner(parts)
        this._write(")")
    }

    // Phase 8: emit string template format string + args WITHOUT format!() wrapper
    // Used for println!($"...") → println!("fmt", args) optimization
    _emitStringTemplateInline(expr: Expr) {
        switch expr {
            Expr.StringTemplate(parts) => {
                this._emitStringTemplateInner(parts)
            },
            _ => { this._emitExpr(expr) }
        }
    }

    _emitStringTemplateInner(parts: [StringTemplatePart]) {
        let fmtStr = ""
        let fmtArgs: [string] = []

        for p in parts {
            switch p {
                StringTemplatePart.Text(text) => {
                    // Escape inner double quotes and braces for format!
                    let escaped = text.replace("\\", "\\\\")
                    escaped = escaped.replace("\"", "\\\"")
                    escaped = escaped.replace("{", "{{")
                    escaped = escaped.replace("}", "}}")
                    fmtStr += escaped
                },
                StringTemplatePart.ExprPart(spExpr) => {
                    // Use {:?} for types that only impl Debug (Vec, HashMap, HashSet)
                    let pTag = this._getExprTypeName(spExpr)
                    if pTag == "array" || pTag == "map" || pTag == "set" {
                        fmtStr += "{:?}"
                    } else {
                        fmtStr += "{}"
                    }
                    // Capture expr to string — simplified: inline the expr
                    // We'll write args after the format string
                    fmtArgs.push("__arg__")
                }
            }
        }

        // Emit format string and inline expressions
        this._write($"\"{fmtStr}\"")
        for p in parts {
            switch p {
                StringTemplatePart.ExprPart(spExpr) => {
                    this._write(", ")
                    // Option<Error> err-bindings: unwrap with as_ref().map().unwrap_or_default()
                    let isErrBinding = false
                    switch spExpr {
                        Expr.Identifier(spName) => {
                            let snErr = this._sanitizeName(spName)
                            if this._errBindings.has(snErr) {
                                isErrBinding = true
                            }
                        }
                    }
                    if isErrBinding {
                        this._emitExpr(spExpr)
                        this._write(".as_ref().map(|e| format!(\"{}\", e)).unwrap_or_default()")
                    } else {
                        this._emitExpr(spExpr)
                    }
                }
            }
        }
    }

    // -- Switch expression (match) --

    _isStringSwitchPattern(arms: [SwitchArm]): bool {
        if arms.length == 0 { return false }
        let isStr = false
        for arm in arms {
            switch arm.pattern {
                Pattern.LiteralPat(lit) => {
                    switch lit {
                        Literal.Str(_) => { isStr = true }
                    }
                },
                Pattern.OrPat(patterns) => {
                    // Check first sub-pattern in OR pattern
                    for subP in patterns {
                        switch subP {
                            Pattern.LiteralPat(lit2) => {
                                switch lit2 {
                                    Literal.Str(_) => { isStr = true }
                                }
                            }
                        }
                        break
                    }
                }
            }
            break
        }
        return isStr
    }

    // B130 (gen-2 truthy narrow): detect `if errBinding { ... }` so the
    // then-branch can rewrite `err.message` to the unwrapped form, AND emit
    // the condition expression. We do both inside this helper because `cond`
    // is bound as a method parameter — bootstrap auto-clones parameters at
    // every use, but does NOT auto-clone field accesses (`stmt.condition`),
    // so doing match + emit at the call-site would E0382. Returns the
    // sanitized binding name (or "" if not applicable).
    _emitIfConditionAndDetectTruthy(cond: Expr): string {
        let result = ""
        switch cond {
            Expr.Identifier(condName) => {
                let sn2 = this._sanitizeName(condName)
                if this._errBindings.has(sn2) {
                    result = sn2
                }
            }
        }
        this._inIfCondition = true
        this._emitExpr(cond)
        this._inIfCondition = false
        return result
    }

    // Helper: emit `match <disc>` or `match &<disc>` (with optional `.as_str()`)
    // depending on whether it's a string switch or a Copy-type discriminant.
    // Taking `disc` as a parameter lets bootstrap codegen auto-clone the value
    // across multiple uses inside this method (B135).
    _emitSwitchHead(disc: Expr, isStringSwitch: bool) {
        if isStringSwitch {
            this._write("match ")
            this._emitExpr(disc)
            if !this._lastEmittedStrRef {
                this._write(".as_str()")
            }
            return
        }
        // B135 fix: Copy-type (number/bool/float) discriminants don't need `&`.
        let discTag = this._getExprTypeName(disc)
        if discTag == "number" || discTag == "bool" || discTag == "float" {
            this._write("match ")
            this._emitExpr(disc)
        } else {
            this._write("match &")
            this._emitExpr(disc)
        }
    }

    _emitSwitchExpr(disc: Expr, arms: [SwitchArm]) {
        // Detect string switch from first arm pattern (inline to avoid moving arms)
        let stringSwitch = false
        for arm in arms {
            switch arm.pattern {
                Pattern.LiteralPat(lit) => {
                    switch lit {
                        Literal.Str(_) => { stringSwitch = true }
                    }
                },
                Pattern.OrPat(patterns) => {
                    for subP in patterns {
                        switch subP {
                            Pattern.LiteralPat(lit2) => {
                                switch lit2 {
                                    Literal.Str(_) => { stringSwitch = true }
                                }
                            }
                        }
                        break
                    }
                }
            }
            break
        }

        let cloneDisc = true
        if stringSwitch { cloneDisc = false }
        // Use shared head emitter (B135 — Copy-type discriminants skip `&`).
        this._emitSwitchHead(disc, stringSwitch)
        this._write(" { ")

        for arm in arms {
            this._emitSwitchArm(arm)
        }

        // Statement-position switch: if the user did not write a catch-all
        // `_ => ...` arm, synthesize `_ => {}`. Otherwise Rust's match would
        // be non-exhaustive (E0004). For expression-position switches the
        // user must still provide all arms (they produce a value).
        if this._switchInStmtPosition {
            let hasWildcard = false
            for arm in arms {
                switch arm.pattern {
                    Pattern.Wildcard => { hasWildcard = true }
                }
            }
            if not hasWildcard {
                this._write("_ => {}, ")
            }
        }

        this._write("}")
    }

    _emitSwitchArm(arm: SwitchArm) {
        // Clear pending derefs/clones before emitting pattern
        this._pendingDerefs = []
        this._pendingRefClones = []
        this._emitPattern(arm.pattern)

        let guardExpr = arm.guard
        if guardExpr != null {
            this._write(" if ")
            this._emitExpr(guardExpr)
        }

        this._write(" => ")

        // Fields become references due to match &x.
        // Boxed fields need *field.clone(), non-boxed need field.clone()
        let hasDerefs = this._pendingDerefs.length > 0
        let hasClones = this._pendingRefClones.length > 0
        let derefs = this._pendingDerefs
        let clones = this._pendingRefClones
        switch arm.body {
            SwitchArmBody.Expr(armExpr) => {
                if this._switchInStmtPosition {
                    // Force `()`-typed arm so a statement-position match unifies.
                    this._write("{ ")
                    for d in derefs {
                        this._write("let " + d + " = *" + d + ".clone(); ")
                    }
                    for c in clones {
                        this._write("let " + c + " = " + c + ".clone(); ")
                    }
                    this._emitExpr(armExpr)
                    this._write("; }, ")
                } else if hasDerefs || hasClones {
                    this._write("{ ")
                    for d in derefs {
                        this._write("let " + d + " = *" + d + ".clone(); ")
                    }
                    for c in clones {
                        this._write("let " + c + " = " + c + ".clone(); ")
                    }
                    this._emitExpr(armExpr)
                    this._write(" }, ")
                } else {
                    this._emitExpr(armExpr)
                    this._write(", ")
                }
            },
            SwitchArmBody.Block(armStmts) => {
                this._write("{ ")
                for d2 in derefs {
                    this._write("let " + d2 + " = *" + d2 + ".clone(); ")
                }
                for c2 in clones {
                    this._write("let " + c2 + " = " + c2 + ".clone(); ")
                }
                if this._switchInStmtPosition {
                    // Statement-position arm: every stmt (incl. last) terminates
                    // with its normal `;`, so the block evaluates to `()`.
                    let savedExprBlock = this._inExprBlock
                    this._inExprBlock = false
                    for s in armStmts {
                        this._stmtIsLastInBlock = false
                        this._emitStmt(s)
                    }
                    this._inExprBlock = savedExprBlock
                } else {
                    // Switch arm bodies are expression positions — the last stmt is a tail expr.
                    let savedExprBlock = this._inExprBlock
                    this._inExprBlock = true
                    let aTotal = armStmts.length
                    let aIdx = 0
                    for s in armStmts {
                        this._stmtIsLastInBlock = (aIdx == aTotal - 1)
                        this._emitStmt(s)
                        aIdx += 1
                    }
                    this._stmtIsLastInBlock = false
                    this._inExprBlock = savedExprBlock
                }
                this._write("}, ")
            }
        }
    }

    // Emit literal in pattern context — no .to_string() for strings
    _emitLiteralPattern(lit: Literal) {
        switch lit {
            Literal.Int(v) => { this._write($"{v}") },
            Literal.Float(v) => { this._write($"{v}") },
            Literal.Str(v) => {
                let escaped = this._escapeRustStr(v)
                this._write("\"" + escaped + "\"")
            },
            Literal.Char(v) => {
                let escapedC = this._escapeRustChar(v)
                this._write("'" + escapedC + "'")
            },
            Literal.Bool(v) => {
                if v { this._write("true") } else { this._write("false") }
            },
            Literal.Null => { this._write("None") }
        }
    }

    _emitPattern(pat: Pattern) {
        switch pat {
            Pattern.LiteralPat(lit) => { this._emitLiteralPattern(lit) },
            Pattern.Wildcard => { this._write("_") },
            Pattern.Binding(name) => {
                let snBind = this._sanitizeName(name)
                this._write(snBind)
            },
            Pattern.Typed(name, typeRef) => {
                let snTyped = this._sanitizeName(name)
                this._write(snTyped)
            },
            Pattern.Range(rangeStart, rangeEnd, inclusive) => {
                let rs = rangeStart
                if rs != null { this._emitExpr(rs) }
                if inclusive {
                    this._write("..=")
                } else {
                    this._write("..")
                }
                let re = rangeEnd
                if re != null { this._emitExpr(re) }
            },
            Pattern.TuplePat(patterns) => {
                this._write("(")
                let tpIdx = 0
                for tp in patterns {
                    if tpIdx > 0 { this._write(", ") }
                    this._emitPattern(tp)
                    tpIdx += 1
                }
                this._write(")")
            },
            Pattern.ArrayPat(patterns) => {
                this._write("[")
                let apIdx = 0
                for ap in patterns {
                    if apIdx > 0 { this._write(", ") }
                    this._emitPattern(ap)
                    apIdx += 1
                }
                this._write("]")
            },
            Pattern.OrPat(patterns) => {
                let opIdx = 0
                for op in patterns {
                    if opIdx > 0 { this._write(" | ") }
                    this._emitPattern(op)
                    opIdx += 1
                }
            },
            Pattern.EnumVariant(enumName, variantName, bindings) => {
                this._write($"{enumName}::{variantName}")
                if bindings.length > 0 {
                    // Check if all bindings are wildcards
                    let allWildcard = true
                    for bnd in bindings {
                        if bnd != "_" { allWildcard = false }
                    }
                    if allWildcard {
                        this._write(" { .. }")
                    } else {
                        // Look up field names and boxing info
                        let variantKey = enumName + "::" + variantName
                        let fieldNames: [string] = []
                        let fieldBoxed: [bool] = []
                        if this._enumVariantFields.has(variantKey) {
                            fieldNames = this._enumVariantFields.get(variantKey)
                        }
                        if this._enumVariantFieldBoxed.has(variantKey) {
                            fieldBoxed = this._enumVariantFieldBoxed.get(variantKey)
                        }
                        this._write(" { ")
                        let bIdx = 0
                        for bnd in bindings {
                            if bIdx > 0 { this._write(", ") }
                            if bnd == "_" {
                                // Use field_name: _ if we know the field name
                                if bIdx < fieldNames.length {
                                    this._write(fieldNames[bIdx] + ": _")
                                } else {
                                    this._write("_")
                                }
                            } else {
                                let sanitized = this._sanitizeName(bnd)
                                if bIdx < fieldNames.length {
                                    let fieldName = fieldNames[bIdx]
                                    if fieldName != sanitized {
                                        this._write(fieldName + ": " + sanitized)
                                    } else {
                                        this._write(sanitized)
                                    }
                                } else {
                                    this._write(sanitized)
                                }
                                // Register pending deref if field is boxed
                                let isBoxed = false
                                if bIdx < fieldBoxed.length {
                                    isBoxed = fieldBoxed[bIdx]
                                }
                                if isBoxed {
                                    this._pendingDerefs.push(sanitized)
                                } else {
                                    // Non-boxed field: needs .clone() when matching by reference
                                    this._pendingRefClones.push(sanitized)
                                }
                            }
                            bIdx += 1
                        }
                        this._write(" }")
                    }
                }
            }
        }
    }

    // =====================================================================
    //  Phase 3.7 — Cargo.toml generation
    // =====================================================================

    generateCargoToml(projectName: string, usesAsync: bool, usesRegex: bool,
                      usesHttp: bool, usesDb: bool, usesJson: bool,
                      usesChrono: bool, usesRandom: bool, usesCrypto: bool,
                      usesRayon: bool, usesHttpClient: bool): string {
        let lines: [string] = []
        lines.push("[package]")
        lines.push($"name = \"{projectName}\"")
        lines.push("version = \"0.1.0\"")
        lines.push("edition = \"2021\"")
        lines.push("")
        lines.push("[dependencies]")

        // Core async runtime
        if usesAsync {
            lines.push("tokio = { version = \"1\", features = [\"full\"] }")
        }

        // HTTP server
        if usesHttp {
            lines.push("axum = \"0.8\"")
            lines.push("tower = \"0.4\"")
            lines.push("tower-http = { version = \"0.5\", features = [\"cors\"] }")
            // HTTP implies async
            if not usesAsync {
                lines.push("tokio = { version = \"1\", features = [\"full\"] }")
            }
        }

        // Database
        if usesDb {
            lines.push("rusqlite = { version = \"0.31\", features = [\"bundled\"] }")
        }

        // JSON
        if usesJson {
            lines.push("serde = { version = \"1\", features = [\"derive\"] }")
            lines.push("serde_json = \"1\"")
        }

        // Regex
        if usesRegex {
            lines.push("regex = \"1\"")
        }

        // Date/Time
        if usesChrono {
            lines.push("chrono = \"0.4\"")
        }

        // Random (includes uuid)
        if usesRandom {
            lines.push("rand = \"0.8\"")
            lines.push("uuid = { version = \"1\", features = [\"v4\"] }")
        }

        // Crypto
        if usesCrypto {
            lines.push("sha2 = \"0.10\"")
            lines.push("hmac = \"0.12\"")
            lines.push("hex = \"0.4\"")
            lines.push("md5 = \"0.7\"")
            lines.push("base64 = \"0.22\"")
        }

        // Parallel
        if usesRayon {
            lines.push("rayon = \"1\"")
        }

        // HTTP Client
        if usesHttpClient {
            lines.push("reqwest = { version = \"0.11\", features = [\"blocking\"] }")
        }

        return lines.join("\n")
    }

}
// =====================================================================
//  Public API
// =====================================================================

generateRust(program: Program, typeCtx: TypeContext, liveCtx: LivenessContext, enumFields: Map<string, [string]>, enumFieldBoxed: Map<string, [bool]>, enumFieldOptional: Map<string, [bool]>, globalBorrow: Map<string, bool>): string {
    let emitter = RustEmitter(typeCtx, liveCtx)
    // Cross-module enum registry — each enum name appears as a key in enumFields
    // (registered as "EnumName::Variant"). Extract enum names BEFORE assigning
    // enumFields away (move semantics) so field-type checks (Default-derive)
    // recognize cross-module enums.
    for vk in enumFields.keys() {
        let vkCopy = $"{vk}"
        let cIdx = vkCopy.indexOf("::")
        if cIdx > 0 {
            let eName = vkCopy.substring(0, cIdx)
            emitter.primeGlobalEnum(eName)
        }
    }
    emitter._enumVariantFields = enumFields
    emitter._enumVariantFieldBoxed = enumFieldBoxed
    emitter._enumVariantFieldOptional = enumFieldOptional
    // Phase 10.5 Bloque 1: prime cross-module borrow registry so call sites in
    // this module can detect that free functions defined in OTHER modules take
    // their String params as `&str`.
    for k in globalBorrow.keys() {
        let kCopy = $"{k}"
        emitter.primeBorrowedParam(kCopy)
    }
    return emitter.generate(program)
}

generateModuleRust(program: Program, typeCtx: TypeContext, liveCtx: LivenessContext, enumFields: Map<string, [string]>, enumFieldBoxed: Map<string, [bool]>, enumFieldOptional: Map<string, [bool]>, globalBorrow: Map<string, bool>): string {
    let emitter = RustEmitter(typeCtx, liveCtx)
    emitter.setIsMainModule(false)
    // Cross-module enum registry (see generateRust).
    for vk in enumFields.keys() {
        let vkCopy = $"{vk}"
        let cIdx = vkCopy.indexOf("::")
        if cIdx > 0 {
            let eName = vkCopy.substring(0, cIdx)
            emitter.primeGlobalEnum(eName)
        }
    }
    emitter._enumVariantFields = enumFields
    emitter._enumVariantFieldBoxed = enumFieldBoxed
    emitter._enumVariantFieldOptional = enumFieldOptional
    // Phase 10.5 Bloque 1: prime cross-module borrow registry (see generateRust).
    for k in globalBorrow.keys() {
        let kCopy = $"{k}"
        emitter.primeBorrowedParam(kCopy)
    }
    return emitter.generate(program)
}

// Phase 10.5 Bloque 1: collect borrowable (&str) free-function params for one
// module. Returns a Map<bKey, bool> where bKey = "{sanFuncName}:{paramIdx}".
// Run by main.liva once per module BEFORE codegen, then merged into a global
// registry shared across all modules so cross-module call sites see borrow info.
//
// Standalone implementation (no TypeContext needed) — matches TypeRef directly.
// Mirrors the gate in `_buildParam`: param type must be `string` (Simple) and
// liveness must say paramBorrow=1 && paramEscapes=0. `main` excluded.
collectBorrowedParams(program: Program, liveCtx: LivenessContext): Map<string, bool> {
    let registry: Map<string, bool> = Map {}
    for item in program.items {
        switch item {
            TopLevel.Function(fd) => {
                if fd.name != "main" {
                    let rawFK = $"{fd.name}"
                    let sanFK = sanitizeName(fd.name)
                    let pIdx = 0
                    for p in fd.params {
                        let rawName = switch p.pattern {
                            BindingPattern.Identifier(n) => n,
                            _ => "_"
                        }
                        let isBorrowable = paramTypeIsBorrowable(p.typeRef)
                        if isBorrowable {                            let livenessKey = $"{rawFK}:{rawName}"
                            let isBorrow = 0
                            if liveCtx.paramBorrow.has(livenessKey) {
                                isBorrow = liveCtx.paramBorrow.get(livenessKey)
                            }
                            let isEscape = 0
                            if liveCtx.paramEscapes.has(livenessKey) {
                                isEscape = liveCtx.paramEscapes.get(livenessKey)
                            }
                            if isBorrow == 1 && isEscape == 0 {
                                let bKey = $"{sanFK}:{pIdx}"
                                registry.set(bKey, true)
                            }
                        }
                        pIdx += 1
                    }
                }
            }
        }
    }
    return registry
}

// Cycle 42 PoC — free function operating on a RustEmitter instance via
// `e: RustEmitter` and accessing private fields via `e._field`. Mirrors the
// pattern that A1 (modularize codegen.liva into multiple files) will use to
// move methods out of the class without needing partial-class support.
// Pattern validated: Liva already permits `e._privateField` access from
// outside the class (see `generateRust` which writes `emitter._enumVariantFields`).
inferArrowReturnType(e: RustEmitter, expr: Expr): string {
    let inferred = ""
    switch expr {
        Expr.Literal(lit) => {
            switch lit {
                Literal.Int(_) => { inferred = " -> i32" },
                Literal.Float(_) => { inferred = " -> f64" },
                Literal.Bool(_) => { inferred = " -> bool" },
                Literal.Str(_) => { inferred = " -> String" }
            }
        },
        Expr.Binary(op, _, _) => {
            switch op {
                BinOp.Lt => { inferred = " -> bool" },
                BinOp.Le => { inferred = " -> bool" },
                BinOp.Gt => { inferred = " -> bool" },
                BinOp.Ge => { inferred = " -> bool" },
                BinOp.Eq => { inferred = " -> bool" },
                BinOp.Ne => { inferred = " -> bool" },
                BinOp.And => { inferred = " -> bool" },
                BinOp.Or => { inferred = " -> bool" },
                _ => { inferred = " -> i32" }
            }
        },
        Expr.StringTemplate(_) => { inferred = " -> String" },
        Expr.Unary(_, _) => { inferred = " -> i32" },
        // `this.field` lookup using per-class field map populated by
        // `_emitClassImpl`. Only fires inside an `impl` block.
        Expr.MemberAccess(obj, prop) => {
            let isThis = false
            switch obj {
                Expr.Identifier(name) => {
                    if name == "this" {
                        isThis = true
                    }
                }
            }
            if isThis {
                if e._currentClassFieldRetSuffix.has(prop) {
                    inferred = e._currentClassFieldRetSuffix.get(prop)
                }
            }
        }
    }
    return inferred
}

// Cycle 43 (A1 step 1): pure helper `_isAllUnitEnum` extracted to a
// free function. Doesn't access RustEmitter state.
//
// NOTE on bootstrap limitation: the frozen Rust-based bootstrap has a
// latent bug — defining a SECOND free function in this file that
// `switch`-es on `Expr` corrupts the codegen state used by the
// `+=` → `.push_str(&...)` String concatenation optimization,
// producing invalid Rust (`String += String`) downstream. Until the
// bootstrap is regenerated, only ONE switch-on-Expr free function is
// supported (currently `inferArrowReturnType`). Other helpers that
// need pattern matching on Expr/Literal must remain class methods.
// See BACKLOG § Cycle 43 for the bisect log.

// Cycle 51 (A1 step 7) — pure TypeRef helpers extracted to free functions.
// Switch on TypeRef (not Expr) so BS-FRAG-1 safe.

// Cycle 53 — buildParamType extracted using e: RustEmitter pattern
// (proven by inferArrowReturnType in Cycle 42).
buildParamType(e: RustEmitter, optRef: TypeRef?): string {
    if optRef != null {
        return e._emitType(optRef)
    }
    return "/* inferred */"
}

buildReturnType(e: RustEmitter, optRef: TypeRef?, isFallible: bool): string {
    if optRef != null {
        let isAlreadyFallible = false
        switch optRef {
            TypeRef.Fallible(_) => { isAlreadyFallible = true }
        }
        let typeStr = e._emitType(optRef)
        if isFallible && not isAlreadyFallible {
            return $" -> Result<{typeStr}, liva_rt::Error>"
        }
        return $" -> {typeStr}"
    }
    if isFallible {
        return " -> Result<(), liva_rt::Error>"
    }
    return ""
}

fieldNeedsDebug(e: RustEmitter, optRef: TypeRef?): bool {
    if optRef != null {
        let needs = false
        switch optRef {
            TypeRef.Array(_) => { needs = true },
            TypeRef.MapType(_, _) => { needs = true },
            TypeRef.SetType(_) => { needs = true },
            TypeRef.OptionalType(_) => { needs = true },
            TypeRef.Tuple(_) => { needs = true },
            TypeRef.Simple(name) => {
                if e._globalEnums.has(name) { needs = true }
            }
        }
        return needs
    }
    return false
}

emitTupleType(em: RustEmitter, elems: [TypeRef]): string {
    let parts: [string] = []
    for e in elems {
        parts.push(em._emitType(e))
    }
    return $"({parts.join(", ")})"
}

emitGenericType(em: RustEmitter, base: string, args: [TypeRef]): string {
    let argParts: [string] = []
    for a in args {
        argParts.push(em._emitType(a))
    }
    return $"{base}<{argParts.join(", ")}>"
}

inAsyncContext(e: RustEmitter): bool {
    let cf = e._currentFunc
    if cf == "main" { return e._mainNeedsAsync }
    return e._asyncFnNames.has(cf)
}

isIndexExprCopyType(e: RustEmitter, obj: Expr): bool {
    let elem = e._getArrayElemTypeRef(obj)
    return isCopyType(elem)
}

warn(e: RustEmitter, msg: string) {
    e._warnings.push(msg)
}

writeRaw(e: RustEmitter, text: string) {
    e._lines.push(text)
}

indent(e: RustEmitter) {
    e._indentLevel += 1
}

dedent(e: RustEmitter) {
    if e._indentLevel > 0 {
        e._indentLevel -= 1
    }
}

writeIndent(e: RustEmitter) {
    let i = 0
    while i < e._indentLevel {
        e._currentLine += "    "
        i += 1
    }
}

main() {
    print("codegen module loaded")
}
