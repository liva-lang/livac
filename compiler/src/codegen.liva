                this._write("{ use rand::Rng; rand::thread_rng().gen_range(")
                this._emitExpr(args[0])
                this._write("..=")
                this._emitExpr(args[1])
                this._write(") }")
                return
            }
            if method == "nextFloat" {
                if args.length >= 2 {
                    this._write("{ use rand::Rng; let __min: f64 = ")
                    this._emitExpr(args[0])
                    this._write(" as f64; let __max: f64 = ")
                    this._emitExpr(args[1])
                    this._write(" as f64; rand::thread_rng().gen_range(__min..__max) }")
                } else {
                    this._write("rand::random::<f64>()")
                }
                return
            }
            if method == "bool" { this._write("rand::random::<bool>()"); return }
            if method == "choice" {
                this._write("{ use rand::Rng; let __arr = &")
                this._emitExpr(args[0])
                this._write("; if __arr.is_empty() { panic!(\"Random.choice: empty array\") } else { __arr[rand::thread_rng().gen_range(0..__arr.len())].clone() } }")
                return
            }
            if method == "shuffle" {
                this._write("{ use rand::seq::SliceRandom; let mut __v = ")
                this._emitExpr(args[0])
                this._write(".clone(); __v.shuffle(&mut rand::thread_rng()); __v }")
                return
            }
            if method == "uuid" {
                this._write("uuid::Uuid::new_v4().to_string()")
                return
            }
            if method == "int" { this._write("(rand::random::<i32>() % "); this._emitExpr(args[1]); this._write(").abs()"); return }
            if method == "float" { this._write("rand::random::<f64>()"); return }
        }
        // Crypto module
        if stdlibName == "Crypto" {
            if method == "sha256" {
                this._write("{ use sha2::Digest; let mut hasher = sha2::Sha256::new(); hasher.update(")
                this._emitExpr(args[0])
                this._write(".as_bytes()); format!(\"{:x}\", hasher.finalize()) }")
                return
            }
            if method == "md5" {
                this._write("{ use md5::Digest; let mut hasher = md5::Md5::new(); hasher.update(")
                this._emitExpr(args[0])
                this._write(".as_bytes()); format!(\"{:x}\", hasher.finalize()) }")
                return
            }
            if method == "base64Encode" {
                this._write("{ use base64::Engine; base64::engine::general_purpose::STANDARD.encode(")
                this._emitExpr(args[0])
                this._write(".as_bytes()) }")
                return
            }
            if method == "base64Decode" {
                this._write("{ let (opt, err) = { use base64::Engine; match base64::engine::general_purpose::STANDARD.decode(")
                this._emitExpr(args[0])
                this._write(".as_bytes()) { Ok(bytes) => match String::from_utf8(bytes) { Ok(s) => (Some(s), String::new()), Err(e) => (None, format!(\"Crypto.base64Decode UTF-8 error: {}\", e)) }, Err(e) => (None, format!(\"Crypto.base64Decode error: {}\", e)) } }; (opt.unwrap_or_default(), err) }")
                return
            }
            if method == "uuid" { this._write("format!(\"{:x}\", rand::random::<u128>())"); return }
            if method == "hash" { this._write("format!(\"{:x}\", { let mut __h: u64 = 5381; for __b in "); this._emitExpr(args[0]); this._write(".as_bytes() { __h = __h.wrapping_mul(33).wrapping_add(*__b as u64); } __h })"); return }
        }
        // Date module
        if stdlibName == "Date" {
            if method == "now" {
                this._write("chrono::Local::now().naive_local()")
                return
            }
            if method == "new" {
                this._write("chrono::NaiveDate::from_ymd_opt(")
                this._emitExpr(args[0])
                this._write(", ")
                this._emitExpr(args[1])
                this._write(" as u32, ")
                this._emitExpr(args[2])
                this._write(" as u32).unwrap()")
                if args.length >= 6 {
                    this._write(".and_hms_opt(")
                    this._emitExpr(args[3])
                    this._write(" as u32, ")
                    this._emitExpr(args[4])
                    this._write(" as u32, ")
                    this._emitExpr(args[5])
                    this._write(" as u32).unwrap()")
                } else {
                    this._write(".and_hms_opt(0, 0, 0).unwrap()")
                }
                return
            }
            if method == "timestamp" {
                this._write("(chrono::Local::now().timestamp_millis() as i32)")
                return
            }
        }
        // Regex module
        if stdlibName == "Regex" {
            if method == "isMatch" || method == "test" {
                this._write("regex::Regex::new(&")
                this._emitExpr(args[0])
                this._write(").map(|re| re.is_match(&")
                this._emitExpr(args[1])
                this._write(")).unwrap_or(false)")
                return
            }
            if method == "findAll" {
                this._write("regex::Regex::new(&")
                this._emitExpr(args[0])
                this._write(").map(|re| re.find_iter(&")
                this._emitExpr(args[1])
                this._write(").map(|m| m.as_str().to_string()).collect::<Vec<String>>()).unwrap_or_default()")
                return
            }
            if method == "split" {
                this._write("regex::Regex::new(&")
                this._emitExpr(args[0])
                this._write(").map(|re| re.split(&")
                this._emitExpr(args[1])
                this._write(").map(|s| s.to_string()).collect::<Vec<String>>()).unwrap_or_else(|_| vec![")
                this._emitExpr(args[1])
                this._write(".to_string()])")
                return
            }
            if method == "replace" {
                this._write("{ let __repl = (")
                this._emitExpr(args[2])
                this._write(").to_string(); regex::Regex::new(&")
                this._emitExpr(args[0])
                this._write(").map(|re| re.replace_all(&")
                this._emitExpr(args[1])
                this._write(", __repl.as_str()).to_string()).unwrap_or_else(|_| ")
                this._emitExpr(args[1])
                this._write(".to_string()) }")
                return
            }
        }

        // Enum variant constructor: EnumName.Variant(args) → EnumName::Variant(args)
        let isEnumVariant = false
        let enumNameMC = ""
        let _ = switch obj {
            Expr.Identifier(name) => {
                if name.length > 0 {
                    let fc = name.charAt(0)
                    if fc >= "A" && fc <= "Z" {
                        isEnumVariant = true
                        enumNameMC = name
                    }
                }
                0
            },
            _ => { 0 }
        }
        if isEnumVariant {
            // Look up field names for struct-style variant constructor
            let variantKey = enumNameMC + "::" + method
            if this._enumVariantFields.has(variantKey) {
                let fieldNames = this._enumVariantFields.get(variantKey)
                // Check boxing and optional info
                let fieldBoxed: [bool] = []
                let fieldOptional: [bool] = []
                if this._enumVariantFieldBoxed.has(variantKey) {
                    fieldBoxed = this._enumVariantFieldBoxed.get(variantKey)
                }
                if this._enumVariantFieldOptional.has(variantKey) {
                    fieldOptional = this._enumVariantFieldOptional.get(variantKey)
                }
                this._write(enumNameMC + "::" + method + " { ")
                let mcIdx = 0
                for a in args {
                    if mcIdx > 0 { this._write(", ") }
                    if mcIdx < fieldNames.length {
                        this._write(fieldNames[mcIdx] + ": ")
                    }
                    // Check if field is boxed or optional
                    let isBoxed = false
                    if mcIdx < fieldBoxed.length {
                        isBoxed = fieldBoxed[mcIdx]
                    }
                    let isOptional = false
                    if mcIdx < fieldOptional.length {
                        isOptional = fieldOptional[mcIdx]
                    }
                    // Check if arg is already null (None) — don't wrap with Some
                    let isNullArg = this._isNullExpr(a)
                    if isBoxed && isOptional {
                        if isNullArg {
                            this._write("None")
                        } else {
                            this._write("Some(Box::new(")
                            this._emitExpr(a)
                            this._write("))")
                        }
                    } else if isBoxed {
                        this._write("Box::new(")
                        this._emitExpr(a)
                        this._write(")")
                    } else if isOptional {
                        if isNullArg {
                            this._write("None")
                        } else {
                            this._write("Some(")
                            this._emitExpr(a)
                            this._write(")")
                        }
                    } else {
                        this._emitExpr(a)
                    }
                    mcIdx += 1
                }
                this._write(" }")
            } else {
                // Fallback: tuple-style (for unknown variants or unit variants)
                this._write(enumNameMC + "::" + method + "(")
                let mcIdx = 0
                for a in args {
                    if mcIdx > 0 { this._write(", ") }
                    this._emitExpr(a)
                    mcIdx += 1
                }
                this._write(")")
            }
            return
        }

        let objTag = this._getExprTypeName(obj)

        // Classify method target without consuming args
        let target = "generic"
        if objTag == "string" && this._isKnownStringMethod(method) {
            target = "string"
        } else if objTag == "array" && this._isKnownArrayMethod(method) {
            target = "array"
        } else if objTag == "map" && this._isKnownMapMethod(method) {
            target = "map"
        } else if objTag == "set" && this._isKnownSetMethod(method) {
            target = "set"
        } else if this._isKnownDateMethod(method) {
            target = "date"
        }
        // Secondary dispatch: if target is still generic but method is a known array-only method,
        // assume array (type detection often fails for array variables)
        // Exclude methods that overlap with Map/Set/user (insert, remove, has, get, set, forEach, isEmpty, contains, clear, count)
        if target == "generic" && this._isKnownArrayMethod(method) {
            if method != "insert" && method != "remove" && method != "has" && method != "get" && method != "set" && method != "forEach" && method != "isEmpty" && method != "contains" && method != "clear" && method != "count" {
                target = "array"
            }
        }
        // Same for set methods — if generic and method is a known set-only method, assume set
        // Exclude common user-defined method names like 'add'
        if target == "generic" && this._isKnownSetMethod(method) {
            if method != "has" && method != "delete" && method != "clear" && method != "values" && method != "forEach" && method != "isEmpty" && method != "add" {
                target = "set"
            }
        }
        // Tertiary: if still generic, try runtime variable tracking for Map/String fallback
        if target == "generic" {
            let objIdName = ""
            let _ = switch obj {
                Expr.Identifier(oName) => { objIdName = this._sanitizeName(oName); 0 },
                _ => { 0 }
            }
            if objIdName != "" {
                if this._mapVars.has(objIdName) && this._isKnownMapMethod(method) { target = "map" }
                else if this._setVars.has(objIdName) && this._isKnownSetMethod(method) { target = "set" }
                else if this._stringVars.has(objIdName) && this._isKnownStringMethod(method) { target = "string" }
            }
        }

        // Dispatch — args consumed in exactly ONE branch
        if target == "string" {
            this._emitStringMethod(obj, method, args)
        } else if target == "array" {
            this._emitArrayMethod(obj, method, args)
        } else if target == "map" {
            this._emitMapMethod(obj, method, args)
        } else if target == "set" {
            this._emitSetMethod(obj, method, args)
        } else if target == "date" {
            this._emitDateMethod(obj, method, args)
        } else {
            this._emitGenericMethodCall(obj, method, args)
        }
        // RC3: reset the mutating flag after dispatch
        if isMutatingCall {
            this._inAssignTarget = false
        }
    }

    _isKnownStringMethod(m: string): bool {
        return m == "contains" || m == "replace" || m == "replaceAll" || m == "split" || m == "trim" || m == "trimStart" || m == "trimEnd" || m == "startsWith" || m == "endsWith" || m == "toUpperCase" || m == "toLowerCase" || m == "substring" || m == "indexOf" || m == "lastIndexOf" || m == "slice" || m == "padStart" || m == "padEnd" || m == "repeat" || m == "charAt" || m == "chars" || m == "capitalize" || m == "isBlank" || m == "isEmpty" || m == "removePrefix" || m == "removeSuffix" || m == "countMatches" || m == "truncate" || m == "reverse" || m == "toInt" || m == "toFloat" || m == "toString"
    }

    _isKnownArrayMethod(m: string): bool {
        return m == "push" || m == "pop" || m == "map" || m == "filter" || m == "forEach" || m == "join" || m == "includes" || m == "indexOf" || m == "find" || m == "findIndex" || m == "some" || m == "every" || m == "reduce" || m == "slice" || m == "concat" || m == "sort" || m == "reverse" || m == "reversed" || m == "flat" || m == "flatMap" || m == "flatten" || m == "first" || m == "last" || m == "count" || m == "min" || m == "max" || m == "isEmpty" || m == "contains" || m == "distinct" || m == "sum" || m == "take" || m == "drop" || m == "zip" || m == "chunks" || m == "insert" || m == "remove"
    }

    _isKnownMapMethod(m: string): bool {
        return m == "get" || m == "set" || m == "has" || m == "delete" || m == "keys" || m == "values" || m == "entries" || m == "clear" || m == "forEach" || m == "isEmpty"
    }

    _isKnownSetMethod(m: string): bool {
        return m == "add" || m == "has" || m == "delete" || m == "clear" || m == "values" || m == "forEach" || m == "union" || m == "intersection" || m == "difference" || m == "isEmpty"
    }

    _isKnownDateMethod(m: string): bool {
        return m == "format" || m == "add" || m == "diff"
    }

    // -- Date methods → Rust equivalents (chrono) --

    _emitDateMethod(obj: Expr, method: string, args: [Expr]) {
        if method == "format" && args.length >= 1 {
            this._emitExpr(obj)
            this._write(".format(&")
            this._emitExpr(args[0])
            this._write(".replace(\"YYYY\", \"%Y\").replace(\"MM\", \"%m\").replace(\"DD\", \"%d\").replace(\"HH\", \"%H\").replace(\"mm\", \"%M\").replace(\"ss\", \"%S\")).to_string()")
            return
        }
        if method == "add" && args.length >= 2 {
            this._write("{ let __liva_unit = (")
            this._emitExpr(args[1])
            this._write(").to_string(); let __liva_n = ")
            this._emitExpr(args[0])
            this._write(" as i64; let __liva_dur = match __liva_unit.as_str() { \"days\" => chrono::Duration::days(__liva_n), \"hours\" => chrono::Duration::hours(__liva_n), \"minutes\" => chrono::Duration::minutes(__liva_n), \"seconds\" => chrono::Duration::seconds(__liva_n), \"weeks\" => chrono::Duration::weeks(__liva_n), _ => chrono::Duration::days(__liva_n), }; ")
            this._emitExpr(obj)
            this._write(" + __liva_dur }")
            return
        }
        if method == "diff" && args.length >= 2 {
            this._write("{ let __liva_diff = ")
            this._emitExpr(obj)
            this._write(".signed_duration_since(")
            this._emitExpr(args[0])
            this._write("); let __liva_unit = (")
            this._emitExpr(args[1])
            this._write(").to_string(); (match __liva_unit.as_str() { \"days\" => __liva_diff.num_days(), \"hours\" => __liva_diff.num_hours(), \"minutes\" => __liva_diff.num_minutes(), \"seconds\" => __liva_diff.num_seconds(), \"weeks\" => __liva_diff.num_weeks(), \"years\" => __liva_diff.num_days() / 365, \"months\" => __liva_diff.num_days() / 30, _ => __liva_diff.num_days(), }) as i32 }")
            return
        }
        // Fallback — user method on a Date-like object
        let sanitizedMethod = this._sanitizeName(method)
        this._emitExpr(obj)
        this._write($".{sanitizedMethod}(")
        let aIdx = 0
        for a in args {
            if aIdx > 0 { this._write(", ") }
            this._emitExpr(a)
            aIdx += 1
        }
        this._write(")")
    }

    // -- Generic fallback for user-defined methods + unknown types --

    _emitGenericMethodCall(obj: Expr, method: string, args: [Expr]) {
        // Map/Set .get() with runtime tracking — can't resolve at dispatch time
        if method == "get" {
            let getObjIdName = ""
            let _ = switch obj {
                Expr.Identifier(gn) => { getObjIdName = this._sanitizeName(gn); 0 },
                _ => { 0 }
            }
            if getObjIdName != "" && this._mapVars.has(getObjIdName) {
                this._emitExpr(obj)
                this._write(".get(&(")
                if args.length > 0 { this._emitExpr(args[0]) }
                this._write(")).cloned().unwrap()")
            } else {
                this._emitExpr(obj)
                this._write(".get(")
                let gi = 0
                for ga in args {
                    if gi > 0 { this._write(", ") }
                    this._emitExpr(ga)
                    gi += 1
                }
                this._write(")")
            }
            return
        }
        // Map/Set .has() with runtime tracking
        if method == "has" {
            let objIdName = ""
            let _ = switch obj {
                Expr.Identifier(hn) => { objIdName = this._sanitizeName(hn); 0 },
                _ => { 0 }
            }
            if objIdName != "" && this._mapVars.has(objIdName) {
                this._emitExpr(obj)
                this._write(".contains_key(&(")
                if args.length > 0 { this._emitExpr(args[0]) }
                this._write("))")
            } else {
                this._emitExpr(obj)
                this._write(".contains(&(")
                if args.length > 0 { this._emitExpr(args[0]) }
                this._write("))")
            }
            return
        }
        // .length/.len — works for any collection
        if method == "length" || method == "len" {
            this._emitExpr(obj)
            this._write(".len() as i32")
            return
        }

        // Catch-all: user-defined method → obj.method(args...)
        let sanitizedMethod = this._sanitizeName(method)
        this._emitExpr(obj)
        this._write($".{sanitizedMethod}(")
        let aIdx = 0
        for a in args {
            if aIdx > 0 { this._write(", ") }
            this._emitClonedArg(a)
            aIdx += 1
        }
        this._write(")")
    }

    // -- String methods → Rust equivalents --

    _emitStringMethod(obj: Expr, method: string, args: [Expr]): bool {
        if method == "contains" {
            this._emitExpr(obj)
            this._write(".contains(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "replace" {
            this._emitExpr(obj)
            this._write(".replace(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            if args.length > 1 {
                this._write(", ")
                this._emitRefArg(args[1])
            }
            this._write(")")
            return true
        }
        if method == "replaceAll" {
            this._emitExpr(obj)
            this._write(".replace(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            if args.length > 1 {
                this._write(", ")
                this._emitRefArg(args[1])
            }
            this._write(")")
            return true
        }
        if method == "split" {
            this._emitExpr(obj)
            this._write(".split(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(").map(|s| s.to_string()).collect::<Vec<String>>()")
            return true
        }
        if method == "trim" {
            this._emitExpr(obj)
            this._write(".trim().to_string()")
            return true
        }
        if method == "trimStart" {
            this._emitExpr(obj)
            this._write(".trim_start().to_string()")
            return true
        }
        if method == "trimEnd" {
            this._emitExpr(obj)
            this._write(".trim_end().to_string()")
            return true
        }
        if method == "toUpperCase" {
            this._emitExpr(obj)
            this._write(".to_uppercase()")
            return true
        }
        if method == "toLowerCase" {
            this._emitExpr(obj)
            this._write(".to_lowercase()")
            return true
        }
        if method == "startsWith" {
            this._emitExpr(obj)
            this._write(".starts_with(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "endsWith" {
            this._emitExpr(obj)
            this._write(".ends_with(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "charAt" {
            this._emitExpr(obj)
            this._write(".chars().nth((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize).map(|c| c.to_string()).unwrap_or_default()")
            return true
        }
        if method == "substring" {
            this._emitExpr(obj)
            this._write("[(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize..(")
            if args.length > 1 { this._emitExpr(args[1]) }
            this._write(") as usize].to_string()")
            return true
        }
        if method == "indexOf" {
            this._emitExpr(obj)
            this._write(".find(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(").map(|i| i as i32).unwrap_or(-1)")
            return true
        }
        if method == "lastIndexOf" {
            this._emitExpr(obj)
            this._write(".rfind(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(").map(|i| i as i32).unwrap_or(-1)")
            return true
        }
        if method == "repeat" {
            this._emitExpr(obj)
            this._write(".repeat((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize)")
            return true
        }
        if method == "isEmpty" {
            this._emitExpr(obj)
            this._write(".is_empty()")
            return true
        }
        if method == "reverse" {
            this._emitExpr(obj)
            this._write(".chars().rev().collect::<String>()")
            return true
        }
        if method == "toInt" {
            this._emitExpr(obj)
            this._write(".parse::<i32>().unwrap_or(0)")
            return true
        }
        if method == "toFloat" {
            this._emitExpr(obj)
            this._write(".parse::<f64>().unwrap_or(0.0)")
            return true
        }
        if method == "toString" {
            this._emitExpr(obj)
            this._write(".to_string()")
            return true
        }
        if method == "chars" {
            this._emitExpr(obj)
            this._write(".chars().map(|c| c.to_string()).collect::<Vec<String>>()")
            return true
        }
        if method == "slice" {
            this._emitExpr(obj)
            this._write("[(")
            if args.length > 0 { this._emitExpr(args[0]) }
            if args.length > 1 {
                this._write(") as usize..(")
                this._emitExpr(args[1])
                this._write(") as usize].to_string()")
            } else {
                this._write(") as usize..].to_string()")
            }
            return true
        }
        if method == "capitalize" {
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); let mut __c = __s.chars(); match __c.next() { None => String::new(), Some(__f) => __f.to_uppercase().to_string() + __c.as_str() } }")
            return true
        }
        if method == "countMatches" {
            this._emitExpr(obj)
            this._write(".matches(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(").count() as i32")
            return true
        }
        if method == "padStart" {
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); let __len = (")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize; if __s.len() >= __len { __s.to_string() } else { ")
            if args.length > 1 {
                this._emitExpr(args[1])
            } else {
                this._write("\" \"")
            }
            this._write(".repeat(__len - __s.len()) + __s } }")
            return true
        }
        if method == "padEnd" {
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); let __len = (")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize; if __s.len() >= __len { __s.to_string() } else { __s.to_string() + &")
            if args.length > 1 {
                this._emitExpr(args[1])
            } else {
                this._write("\" \"")
            }
            this._write(".repeat(__len - __s.len()) } }")
            return true
        }
        if method == "isBlank" {
            this._emitExpr(obj)
            this._write(".trim().is_empty()")
            return true
        }
        if method == "truncate" {
            this._emitExpr(obj)
            this._write(".chars().take((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize).collect::<String>()")
            return true
        }
        if method == "removePrefix" {
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); match __s.strip_prefix(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(") { Some(r) => r.to_string(), None => __s.to_string() } }")
            return true
        }
        if method == "removeSuffix" {
            this._write("{ let __s = &(")
            this._emitExpr(obj)
            this._write("); match __s.strip_suffix(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(") { Some(r) => r.to_string(), None => __s.to_string() } }")
            return true
        }
        // Not a known string method
        return false
    }

    // -- Helper: emit iterator prefix, detecting .par() chains --
    _emitIterPrefix(obj: Expr, withCloned: bool) {
        // Check if obj is arr.par() → use par_iter instead of iter
        let isPar = false
        let _ = switch obj {
            Expr.MethodCall(inner, m, _) => {
                if m == "par" {
                    isPar = true
                    this._emitExpr(inner)
                }
                0
            },
            _ => { 0 }
        }
        if not isPar {
            this._emitExpr(obj)
        }
        if isPar {
            this._write(".par_iter()")
        } else {
            this._write(".iter()")
        }
        if withCloned { this._write(".cloned()") }
    }

    // -- Array methods → Rust equivalents --

    _emitArrayMethod(obj: Expr, method: string, args: [Expr]): bool {
        if method == "push" {
            this._emitExpr(obj)
            this._write(".push(")
            if args.length > 0 { this._emitClonedArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "pop" {
            this._emitExpr(obj)
            this._write(".pop().expect(\"pop from empty array\")")
            return true
        }
        if method == "join" {
            this._emitExpr(obj)
            this._write(".join(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "reverse" {
            this._emitExpr(obj)
            this._write(".reverse()")
            return true
        }
        if method == "reversed" {
            this._write("{ let mut __v = ")
            this._emitExpr(obj)
            this._write(".clone(); __v.reverse(); __v }")
            return true
        }
        if method == "sort" {
            this._write("{ let mut __v = ")
            this._emitExpr(obj)
            this._write(".clone(); __v.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal)); __v }")
            return true
        }
        if method == "isEmpty" {
            this._emitExpr(obj)
            this._write(".is_empty()")
            return true
        }
        if method == "contains" {
            this._emitExpr(obj)
            this._write(".contains(")
            if args.length > 0 { this._emitRefArg(args[0]) }
            this._write(")")
            return true
        }
        if method == "remove" {
            this._emitExpr(obj)
            this._write(".remove((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize)")
            return true
        }
        if method == "insert" {
            this._emitExpr(obj)
            this._write(".insert((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize, ")
            if args.length > 1 { this._emitExpr(args[1]) }
            this._write(")")
            return true
        }
        if method == "first" {
            this._emitExpr(obj)
            this._write(".first().cloned().unwrap()")
            return true
        }
        if method == "last" {
            this._emitExpr(obj)
            this._write(".last().cloned().unwrap()")
            return true
        }
        if method == "slice" {
            this._emitExpr(obj)
            this._write("[(")
            if args.length > 0 { this._emitExpr(args[0]) }
            if args.length > 1 {
                this._write(") as usize..(")
                this._emitExpr(args[1])
                this._write(") as usize].to_vec()")
            } else {
                this._write(") as usize..].to_vec()")
            }
            return true
        }
        if method == "take" {
            this._emitExpr(obj)
            this._write("[..(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize].to_vec()")
            return true
        }
        if method == "drop" {
            this._emitExpr(obj)
            this._write("[(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize..].to_vec()")
            return true
        }
        if method == "flat" {
            this._emitExpr(obj)
            this._write(".concat()")
            return true
        }
        if method == "flatten" {
            this._emitExpr(obj)
            this._write(".concat()")
            return true
        }
        if method == "sum" {
            this._emitExpr(obj)
            this._write(".iter().sum::<i32>()")
            return true
        }
        // Iterator pipeline methods: map, filter, forEach, find, reduce, some, every, etc.
        if method == "map" {
            this._emitIterPrefix(obj, true)
            this._write(".map(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(").collect::<Vec<_>>()")
            return true
        }
        if method == "filter" {
            this._emitIterPrefix(obj, true)
            this._write(".filter(")
            // Check if arg is a point-free function ref (Identifier) vs Lambda
            let filterArgIsRef = false
            if args.length > 0 {
                let _ = switch args[0] {
                    Expr.Lambda(_) => { 0 },
                    _ => { filterArgIsRef = true; 0 }
                }
            }
            if filterArgIsRef {
                // Wrap point-free ref: filter(|&x| fn(x))
                this._write("|&__x| ")
                if args.length > 0 { this._emitExpr(args[0]) }
                this._write("(__x)")
            } else {
                this._derefClosureParams = true
                if args.length > 0 { this._emitExpr(args[0]) }
                this._derefClosureParams = false
            }
            this._write(").collect::<Vec<_>>()")
            return true
        }
        if method == "forEach" {
            this._emitIterPrefix(obj, true)
            this._write(".for_each(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")")
            return true
        }
        if method == "find" {
            this._emitIterPrefix(obj, true)
            this._write(".find(")
            this._derefClosureParams = true
            if args.length > 0 { this._emitExpr(args[0]) }
            this._derefClosureParams = false
            this._write(").unwrap()")
            return true
        }
        if method == "includes" {
            this._emitExpr(obj)
            this._write(".iter().any(|__x| __x == &(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("))")
            return true
        }
        if method == "indexOf" {
            this._emitExpr(obj)
            this._write(".iter().position(|__x| __x == &(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")).map(|i| i as i32).unwrap_or(-1)")
            return true
        }
        if method == "some" {
            this._emitIterPrefix(obj, true)
            this._write(".any(")
            // any() passes T directly (not &T), so no deref needed
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")")
            return true
        }
        if method == "every" {
            this._emitIterPrefix(obj, true)
            this._write(".all(")
            // all() passes T directly (not &T), so no deref needed
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")")
            return true
        }
        if method == "reduce" {
            this._emitIterPrefix(obj, false)
            this._write(".fold(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(", ")
            if args.length > 1 { this._emitExpr(args[1]) }
            this._write(")")
            return true
        }
        if method == "flatMap" {
            this._emitIterPrefix(obj, false)
            this._write(".flat_map(|x| ")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("(x.clone())).collect::<Vec<_>>()")
            return true
        }
        if method == "findIndex" {
            this._emitExpr(obj)
            this._write(".iter().position(|x| { let x = x.clone(); ")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("(x) }).map(|i| i as i32).unwrap_or(-1)")
            return true
        }
        if method == "count" {
            this._emitExpr(obj)
            this._write(".iter().filter(|x| { let x = (*x).clone(); ")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("(x) }).count() as i32")
            return true
        }
        if method == "distinct" {
            this._write("{ let mut __seen = std::collections::HashSet::new(); ")
            this._emitExpr(obj)
            this._write(".iter().filter(|x| __seen.insert((*x).clone())).cloned().collect::<Vec<_>>() }")
            return true
        }
        if method == "chunks" {
            this._emitExpr(obj)
            this._write(".chunks((")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(") as usize).map(|c| c.to_vec()).collect::<Vec<Vec<_>>>()")
            return true
        }
        if method == "zip" {
            this._emitExpr(obj)
            this._write(".iter().zip(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(".iter()).map(|(a, b)| (a.clone(), b.clone())).collect::<Vec<_>>()")
            return true
        }
        if method == "concat" {
            this._write("{ let mut __v = ")
            this._emitExpr(obj)
            this._write(".clone(); __v.extend(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("); __v }")
            return true
        }
        if method == "min" {
            this._emitExpr(obj)
            this._write(".iter().min_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal)).cloned().unwrap()")
            return true
        }
        if method == "max" {
            this._emitExpr(obj)
            this._write(".iter().max_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal)).cloned().unwrap()")
            return true
        }
        // Not a known array method
        return false
    }

    // -- Map methods → Rust equivalents --

    _emitMapMethod(obj: Expr, method: string, args: [Expr]): bool {
        if method == "get" {
            this._emitExpr(obj)
            this._write(".get(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")).cloned().unwrap()")
            return true
        }
        if method == "set" {
            this._emitExpr(obj)
            this._write(".insert(")
            if args.length > 0 {
                this._emitExpr(args[0])
                this._write(".clone()")
            }
            this._write(", ")
            if args.length > 1 {
                this._emitExpr(args[1])
                this._write(".clone()")
            }
            this._write(")")
            return true
        }
        if method == "has" {
            this._emitExpr(obj)
            this._write(".contains_key(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("))")
            return true
        }
        if method == "delete" {
            this._emitExpr(obj)
            this._write(".remove(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("))")
            return true
        }
        if method == "keys" {
            this._emitExpr(obj)
            this._write(".keys().cloned().collect::<Vec<_>>()")
            return true
        }
        if method == "values" {
            this._emitExpr(obj)
            this._write(".values().cloned().collect::<Vec<_>>()")
            return true
        }
        if method == "entries" {
            this._emitExpr(obj)
            this._write(".iter().map(|(k, v)| (k.clone(), v.clone())).collect::<Vec<_>>()")
            return true
        }
        if method == "clear" {
            this._emitExpr(obj)
            this._write(".clear()")
            return true
        }
        if method == "forEach" {
            this._emitExpr(obj)
            this._write(".iter().for_each(|(k, v)| { (")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")(k.clone(), v.clone()); })")
            return true
        }
        if method == "isEmpty" {
            this._emitExpr(obj)
            this._write(".is_empty()")
            return true
        }
        // Not a known map method
        return false
    }

    // -- Set methods → Rust equivalents --

    _emitSetMethod(obj: Expr, method: string, args: [Expr]): bool {
        if method == "add" {
            this._emitExpr(obj)
            this._write(".insert(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")")
            return true
        }
        if method == "has" {
            this._emitExpr(obj)
            this._write(".contains(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("))")
            return true
        }
        if method == "delete" {
            this._emitExpr(obj)
            this._write(".remove(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write("))")
            return true
        }
        if method == "clear" {
            this._emitExpr(obj)
            this._write(".clear()")
            return true
        }
        if method == "values" {
            this._emitExpr(obj)
            this._write(".iter().cloned().collect::<Vec<_>>()")
            return true
        }
        if method == "forEach" {
            this._emitExpr(obj)
            this._write(".iter().for_each(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")")
            return true
        }
        if method == "union" {
            this._emitExpr(obj)
            this._write(".union(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")).cloned().collect::<std::collections::HashSet<_>>()")
            return true
        }
        if method == "intersection" {
            this._emitExpr(obj)
            this._write(".intersection(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")).cloned().collect::<std::collections::HashSet<_>>()")
            return true
        }
        if method == "difference" {
            this._emitExpr(obj)
            this._write(".difference(&(")
            if args.length > 0 { this._emitExpr(args[0]) }
            this._write(")).cloned().collect::<std::collections::HashSet<_>>()")
            return true
        }
        if method == "isEmpty" {
            this._emitExpr(obj)
            this._write(".is_empty()")
            return true
        }
        // Not a known set method
        return false
    }

    // -- Member access (type-directed) --

    _emitMemberAccess(obj: Expr, prop: string) {
        let objTag = this._getExprTypeName(obj)

        // Stdlib module property access before generic enum/class handling
        let stdlibPropName = ""
        let _ = switch obj {
            Expr.Identifier(sn) => { stdlibPropName = sn; 0 },
            _ => { 0 }
        }
        // Math constants: Math.PI, Math.E
        if stdlibPropName == "Math" && prop == "PI" { this._write("std::f64::consts::PI"); return }
        if stdlibPropName == "Math" && prop == "E" { this._write("std::f64::consts::E"); return }
        // Date property access: d.year, d.month, d.day, d.hour, d.minute, d.second
        if prop == "year" { this._write("(chrono::Datelike::year(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "month" { this._write("(chrono::Datelike::month(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "day" { this._write("(chrono::Datelike::day(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "hour" { this._write("(chrono::Timelike::hour(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "minute" { this._write("(chrono::Timelike::minute(&"); this._emitExpr(obj); this._write(") as i32)"); return }
        if prop == "second" { this._write("(chrono::Timelike::second(&"); this._emitExpr(obj); this._write(") as i32)"); return }

        // Enum variant access: EnumName.Variant → EnumName::Variant
        // Heuristic: PascalCase identifier = enum/class → use :: syntax
        let isEnumAccess = false
        let enumName = ""
        let _ = switch obj {
            Expr.Identifier(name) => {
                if name.length > 0 {
                    let firstChar = name.charAt(0)
                    if firstChar >= "A" && firstChar <= "Z" {
                        isEnumAccess = true
                        enumName = name
                    }
                }
                0
            },
            _ => { 0 }
        }
        if isEnumAccess {
            this._write(enumName + "::" + prop)
            return
        }

        // .length → .len() as i32 for strings and arrays
        if prop == "length" {
            this._write("(")
            this._emitExpr(obj)
            this._write(".len() as i32)")
            return
        }

        // .size → .len() as i32 for maps and sets
        if prop == "size" {
            if objTag == "map" {
                this._write("(")
                this._emitExpr(obj)
                this._write(".len() as i32)")
                return
            }
            if objTag == "set" {
                this._write("(")
                this._emitExpr(obj)
                this._write(".len() as i32)")
                return
            }
        }

        // Default: emit as field access
        // If accessing self fields in a method, clone to avoid move-from-borrow
        let isSelfAccess = false
        let _ = switch obj {
            Expr.Identifier(oName) => {
                if oName == "this" {
                    isSelfAccess = true
                }
                0
            },
            _ => { 0 }
        }
        this._emitExpr(obj)
        let snField = this._sanitizeName(prop)
        this._write($".{snField}")
        if isSelfAccess && not this._inAssignTarget {
            this._write(".clone()")
        }
    }

    // =====================================================================
    //  Phase 3.6 — Ownership emission helpers
    // =====================================================================
    // Emit &arg for String/Vec args to methods that take references.
    // Uses a simple heuristic: if the arg is a variable (not a literal),
    // emit &arg. For literals, emit directly (refs created automatically).

    _emitRefArg(argExpr: Expr) {
        // String literals don't need & prefix (auto-refs) but must suppress .to_string()
        let isLiteral = false
        let _ = switch argExpr {
            Expr.Literal(_) => { isLiteral = true; 0 },
            Expr.StringTemplate(_) => { isLiteral = true; 0 },
            _ => { 0 }
        }
        if isLiteral {
            this._suppressToString = true
            this._emitExpr(argExpr)
            this._suppressToString = false
        } else {
            this._write("&")
            this._emitExpr(argExpr)
        }
    }

    // Emit expression with .clone() for non-Copy types (identifiers, member access)
    _emitClonedArg(argExpr: Expr) {
        let needsClone = false
        let _ = switch argExpr {
            Expr.Identifier(name) => {
                // Don't clone literals-like identifiers (this is handled by emitExpr)
                if name != "true" && name != "false" && name != "null" {
                    needsClone = true
                    // Liveness optimization: if variable is used only once, move is safe
                    let key = this._currentFunc + ":" + name
                    if this._liveCtx.useCounts.has(key) {
                        let count = this._liveCtx.useCounts.get(key)
                        if count <= 1 { needsClone = false }
                    }
                }
                0
            },
            Expr.MemberAccess(_, _) => { needsClone = true; 0 },
            _ => { 0 }
        }
        this._emitExpr(argExpr)
        if needsClone {
            this._write(".clone()")
        }
    }

    // -- Struct literal (constructor call) --

    _emitStructLiteral(typeName: string, fields: [ObjField]) {
        this._write($"{typeName}::new(")
        let fIdx = 0
        for f in fields {
            if fIdx > 0 { this._write(", ") }
            this._emitClonedArg(f.value)
            fIdx += 1
        }
        this._write(")")
    }

    // -- Object literal (anonymous Map) --

    _emitObjectLiteral(fields: [ObjField]) {
        this._write("{ let mut _map = HashMap::new(); ")
        for f in fields {
            let key = $"{f.key}"
            this._write($"_map.insert(\"{key}\".to_string(), ")
            this._emitExpr(f.value)
            this._write("); ")
        }
        this._write("_map }")
    }

    // -- Array literal --

    _emitArrayLiteral(elements: [Expr]) {
        if elements.length == 0 {
            this._write("vec![]")
        } else {
            this._write("vec![")
            let aIdx = 0
            for e in elements {
                if aIdx > 0 { this._write(", ") }
                this._emitExpr(e)
                aIdx += 1
            }
            this._write("]")
        }
    }

    // -- Map literal --

    _emitMapLiteral(entries: [MapEntry]) {
        if entries.length == 0 {
            this._write("HashMap::new()")
        } else {
            this._write("{ let mut _map = HashMap::new(); ")
            for e in entries {
                this._write("_map.insert(")
                this._emitExpr(e.key)
                this._write(", ")
                this._emitExpr(e.value)
                this._write("); ")
            }
            this._write("_map }")
        }
    }

    // -- Set literal --

    _emitSetLiteral(elements: [Expr]) {
        if elements.length == 0 {
            this._write("HashSet::new()")
        } else {
            this._write("{ let mut _set = HashSet::new(); ")
            for e in elements {
                this._write("_set.insert(")
                this._emitExpr(e)
                this._write("); ")
            }
            this._write("_set }")
        }
    }

    // -- Lambda --

    _emitLambda(lam: LambdaExpr) {
        if lam.isMove {
            this._write("move ")
        }
        this._write("|")
        let pIdx = 0
        let needDeref = this._derefClosureParams
        this._derefClosureParams = false
        for p in lam.params {
            if pIdx > 0 { this._write(", ") }
            let pName = switch p.pattern {
                BindingPattern.Identifier(n) => n,
                _ => "_"
            }
            let snP = this._sanitizeName(pName)
            if needDeref {
                this._write("&" + snP)
            } else {
                this._write(snP)
            }
            pIdx += 1
        }
        this._write("| ")
        let _ = switch lam.body {
            LambdaBody.Expr(lamExprs) => {
                if lamExprs.length == 1 {
                    for le in lamExprs { this._emitExpr(le); break }
                } else {
                    this._write("{ ")
                    for e in lamExprs {
                        this._emitExpr(e)
                        this._write("; ")
                    }
                    this._write("}")
                }
                0
            },
            LambdaBody.Block(lamBlock) => {
                this._write("{")
                this._newline()
                this._indent()
                this._emitBlock(lamBlock)
                this._dedent()
                this._writeIndent()
                this._write("}")
                0
            }
        }
    }

    // -- String template --

    _emitStringTemplate(parts: [StringTemplatePart]) {
        // Generate format!("...", args)
        let fmtStr = ""
        let fmtArgs: [string] = []

        for p in parts {
            let _ = switch p {
                StringTemplatePart.Text(text) => {
                    // Escape inner double quotes and braces for format!
                    let escaped = text.replace("\\", "\\\\")
                    escaped = escaped.replace("\"", "\\\"")
                    escaped = escaped.replace("{", "{{")
                    escaped = escaped.replace("}", "}}")
                    fmtStr += escaped
                    0
                },
                StringTemplatePart.ExprPart(spExpr) => {
                    fmtStr += "{}"
                    // Capture expr to string — simplified: inline the expr
                    // We'll write args after the format string
                    fmtArgs.push("__arg__")
                    0
                }
            }
        }

        // Actually emit format! with inline expressions
        this._write($"format!(\"{fmtStr}\"")
        for p in parts {
            let _ = switch p {
                StringTemplatePart.ExprPart(spExpr) => {
                    this._write(", ")
                    this._emitExpr(spExpr)
                    0
                },
                _ => { 0 }
            }
        }
        this._write(")")
    }

    // -- Switch expression (match) --

    _isStringSwitchPattern(arms: [SwitchArm]): bool {
        if arms.length == 0 { return false }
        let isStr = false
        for arm in arms {
            let _ = switch arm.pattern {
                Pattern.LiteralPat(lit) => {
                    let _ = switch lit {
                        Literal.Str(_) => { isStr = true; 0 },
                        _ => { 0 }
                    }
                    0
                },
                Pattern.OrPat(patterns) => {
                    // Check first sub-pattern in OR pattern
                    for subP in patterns {
                        let _ = switch subP {
                            Pattern.LiteralPat(lit2) => {
                                let _ = switch lit2 {
                                    Literal.Str(_) => { isStr = true; 0 },
                                    _ => { 0 }
                                }
                                0
                            },
                            _ => { 0 }
                        }
                        break
                    }
                    0
                },
                _ => { 0 }
            }
            break
        }
        return isStr
    }

    _emitSwitchExpr(disc: Expr, arms: [SwitchArm]) {
        // Detect string switch from first arm pattern (inline to avoid moving arms)
        let stringSwitch = false
        for arm in arms {
            let _ = switch arm.pattern {
                Pattern.LiteralPat(lit) => {
                    let _ = switch lit {
                        Literal.Str(_) => { stringSwitch = true; 0 },
                        _ => { 0 }
                    }
                    0
                },
                Pattern.OrPat(patterns) => {
                    for subP in patterns {
                        let _ = switch subP {
                            Pattern.LiteralPat(lit2) => {
                                let _ = switch lit2 {
                                    Literal.Str(_) => { stringSwitch = true; 0 },
                                    _ => { 0 }
                                }
                                0
                            },
                            _ => { 0 }
                        }
                        break
                    }
                    0
                },
                _ => { 0 }
            }
            break
        }

        let cloneDisc = true
        this._write("match ")
        if stringSwitch {
            this._emitExpr(disc)
            this._write(".as_str()")
            cloneDisc = false
        } else {
            this._emitExpr(disc)
            this._write(".clone()")
        }
        this._write(" { ")

        for arm in arms {
            this._emitSwitchArm(arm)
        }

        this._write("}")
    }

    _emitSwitchArm(arm: SwitchArm) {
        // Clear pending derefs before emitting pattern
        this._pendingDerefs = []
        this._emitPattern(arm.pattern)

        let guardExpr = arm.guard
        if guardExpr != null {
            this._write(" if ")
            this._emitExpr(guardExpr)
        }

        this._write(" => ")

        // If there are pending derefs from boxed pattern fields, wrap in block
        let hasDerefs = this._pendingDerefs.length > 0
        let derefs = this._pendingDerefs
        let _ = switch arm.body {
            SwitchArmBody.Expr(armExpr) => {
                if hasDerefs {
                    this._write("{ ")
                    for d in derefs {
                        this._write("let " + d + " = *" + d + "; ")
                    }
                    this._emitExpr(armExpr)
                    this._write(" }, ")
                } else {
                    this._emitExpr(armExpr)
                    this._write(", ")
                }
                0
            },
            SwitchArmBody.Block(armStmts) => {
                this._write("{ ")
                for d2 in derefs {
                    this._write("let " + d2 + " = *" + d2 + "; ")
                }
                for s in armStmts {
                    this._emitStmt(s)
                }
                this._write("}, ")
                0
            }
        }
    }

    // Emit literal in pattern context — no .to_string() for strings
    _emitLiteralPattern(lit: Literal) {
        let _ = switch lit {
            Literal.Int(v) => { this._write($"{v}"); 0 },
            Literal.Float(v) => { this._write($"{v}"); 0 },
            Literal.Str(v) => {
                let escaped = this._escapeRustStr(v)
                this._write("\"" + escaped + "\"")
                0
            },
            Literal.Char(v) => {
                let escaped = this._escapeRustChar(v)
                this._write("'" + escaped + "'")
                0
            },
            Literal.Bool(v) => {
                if v { this._write("true") } else { this._write("false") }
                0
            },
            Literal.Null => { this._write("None"); 0 }
        }
    }

    _emitPattern(pat: Pattern) {
        let _ = switch pat {
            Pattern.LiteralPat(lit) => { this._emitLiteralPattern(lit); 0 },
            Pattern.Wildcard => { this._write("_"); 0 },
            Pattern.Binding(name) => {
                let snBind = this._sanitizeName(name)
                this._write(snBind)
                0
            },
            Pattern.Typed(name, typeRef) => {
                let snTyped = this._sanitizeName(name)
                this._write(snTyped)
                0
            },
            Pattern.Range(rangeStart, rangeEnd, inclusive) => {
                let rs = rangeStart
                if rs != null { this._emitExpr(rs) }
                if inclusive {
                    this._write("..=")
                } else {
                    this._write("..")
                }
                let re = rangeEnd
                if re != null { this._emitExpr(re) }
                0
            },
            Pattern.TuplePat(patterns) => {
                this._write("(")
                let tpIdx = 0
                for tp in patterns {
                    if tpIdx > 0 { this._write(", ") }
                    this._emitPattern(tp)
                    tpIdx += 1
                }
                this._write(")")
                0
            },
            Pattern.ArrayPat(patterns) => {
                this._write("[")
                let apIdx = 0
                for ap in patterns {
                    if apIdx > 0 { this._write(", ") }
                    this._emitPattern(ap)
                    apIdx += 1
                }
                this._write("]")
                0
            },
            Pattern.OrPat(patterns) => {
                let opIdx = 0
                for op in patterns {
                    if opIdx > 0 { this._write(" | ") }
                    this._emitPattern(op)
                    opIdx += 1
                }
                0
            },
            Pattern.EnumVariant(enumName, variantName, bindings) => {
                this._write($"{enumName}::{variantName}")
                if bindings.length > 0 {
                    // Check if all bindings are wildcards
                    let allWildcard = true
                    for bnd in bindings {
                        if bnd != "_" { allWildcard = false }
                    }
                    if allWildcard {
                        this._write(" { .. }")
                    } else {
                        // Look up field names and boxing info
                        let variantKey = enumName + "::" + variantName
                        let fieldNames: [string] = []
                        let fieldBoxed: [bool] = []
                        if this._enumVariantFields.has(variantKey) {
                            fieldNames = this._enumVariantFields.get(variantKey)
                        }
                        if this._enumVariantFieldBoxed.has(variantKey) {
                            fieldBoxed = this._enumVariantFieldBoxed.get(variantKey)
                        }
                        this._write(" { ")
                        let bIdx = 0
                        for bnd in bindings {
                            if bIdx > 0 { this._write(", ") }
                            if bnd == "_" {
                                // Use field_name: _ if we know the field name
                                if bIdx < fieldNames.length {
                                    this._write(fieldNames[bIdx] + ": _")
                                } else {
                                    this._write("_")
                                }
                            } else {
                                let sanitized = this._sanitizeName(bnd)
                                if bIdx < fieldNames.length {
                                    let fieldName = fieldNames[bIdx]
                                    if fieldName != sanitized {
                                        this._write(fieldName + ": " + sanitized)
                                    } else {
                                        this._write(sanitized)
                                    }
                                } else {
                                    this._write(sanitized)
                                }
                                // Register pending deref if field is boxed
                                let isBoxed = false
                                if bIdx < fieldBoxed.length {
                                    isBoxed = fieldBoxed[bIdx]
                                }
                                if isBoxed {
                                    this._pendingDerefs.push(sanitized)
                                }
                            }
                            bIdx += 1
                        }
                        this._write(" }")
                    }
                }
                0
            }
        }
    }

    // =====================================================================
    //  Phase 3.7 — Cargo.toml generation
    // =====================================================================

    generateCargoToml(projectName: string, usesAsync: bool, usesRegex: bool,
                      usesHttp: bool, usesDb: bool, usesJson: bool,
                      usesChrono: bool, usesRandom: bool, usesCrypto: bool,
                      usesRayon: bool, usesHttpClient: bool): string {
        let lines: [string] = []
        lines.push("[package]")
        lines.push($"name = \"{projectName}\"")
        lines.push("version = \"0.1.0\"")
        lines.push("edition = \"2021\"")
        lines.push("")
        lines.push("[dependencies]")

        // Core async runtime
        if usesAsync {
            lines.push("tokio = { version = \"1\", features = [\"full\"] }")
        }

        // HTTP server
        if usesHttp {
            lines.push("axum = \"0.7\"")
            lines.push("tower = \"0.4\"")
            lines.push("tower-http = { version = \"0.5\", features = [\"cors\"] }")
            // HTTP implies async
            if not usesAsync {
                lines.push("tokio = { version = \"1\", features = [\"full\"] }")
            }
        }

        // Database
        if usesDb {
            lines.push("rusqlite = { version = \"0.31\", features = [\"bundled\"] }")
        }

        // JSON
        if usesJson {
            lines.push("serde = { version = \"1\", features = [\"derive\"] }")
            lines.push("serde_json = \"1\"")
        }

        // Regex
        if usesRegex {
            lines.push("regex = \"1\"")
        }

        // Date/Time
        if usesChrono {
            lines.push("chrono = \"0.4\"")
        }

        // Random (includes uuid)
        if usesRandom {
            lines.push("rand = \"0.8\"")
            lines.push("uuid = { version = \"1\", features = [\"v4\"] }")
        }

        // Crypto
        if usesCrypto {
            lines.push("sha2 = \"0.10\"")
            lines.push("hmac = \"0.12\"")
            lines.push("hex = \"0.4\"")
            lines.push("md5 = \"0.7\"")
            lines.push("base64 = \"0.22\"")
        }

        // Parallel
        if usesRayon {
            lines.push("rayon = \"1\"")
        }

        // HTTP Client
        if usesHttpClient {
            lines.push("reqwest = { version = \"0.11\", features = [\"blocking\"] }")
        }

        return lines.join("\n")
    }
}

// =====================================================================
//  Public API
// =====================================================================

generateRust(program: Program, typeCtx: TypeContext, liveCtx: LivenessContext, enumFields: Map<string, [string]>, enumFieldBoxed: Map<string, [bool]>, enumFieldOptional: Map<string, [bool]>): string {
    let emitter = RustEmitter(typeCtx, liveCtx)
    emitter._enumVariantFields = enumFields
    emitter._enumVariantFieldBoxed = enumFieldBoxed
    emitter._enumVariantFieldOptional = enumFieldOptional
    return emitter.generate(program)
}

generateModuleRust(program: Program, typeCtx: TypeContext, liveCtx: LivenessContext, enumFields: Map<string, [string]>, enumFieldBoxed: Map<string, [bool]>, enumFieldOptional: Map<string, [bool]>): string {
    let emitter = RustEmitter(typeCtx, liveCtx)
    emitter.setIsMainModule(false)
    emitter._enumVariantFields = enumFields
    emitter._enumVariantFieldBoxed = enumFieldBoxed
    emitter._enumVariantFieldOptional = enumFieldOptional
    return emitter.generate(program)
}

// Reusable name sanitization: camelCase → snake_case + keyword escaping
sanitizeFieldName(name: string): string {
    // camelCase → snake_case: insert _ before uppercase, then lowercase
    let result = ""
    let i = 0
    for ch in name {
        if ch >= "A" && ch <= "Z" {
            if i > 0 {
                result += "_"
            }
            result += ch.toLowerCase()
        } else {
            result += ch
        }
        i += 1
    }
    return result
}

main() {
    print("codegen module loaded")
}
