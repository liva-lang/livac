// ============================================================================
// codegen.liva — Rust Code Generator for the Liva self-hosting compiler
// ============================================================================
// Phase 3: Clean codegen that generates Rust mechanically from AST + TypeContext.
//
// Unlike the bootstrap codegen (~16K lines with ~20 HashSets guessing types),
// this codegen is TYPE-DIRECTED: every decision is based on resolved types
// from the semantic analyzer. No guessing, no heuristics, no name-based hacks.
//
// Architecture:
//   AST + TypeContext + LivenessContext → RustEmitter.generate() → String (Rust code)
//
// The RustEmitter accumulates output in a string buffer with indent management.
// Each AST node type has a dedicated emit method that writes Rust syntax.
//
// Codegen compat notes (bootstrap limitations — same as previous modules):
//   - W-001: No return inside switch arm blocks
//   - W-002: Variable name collisions across switch arms — use unique names
//   - W-003: $"{field}" for string copies to avoid move
//   - W-005: option_value_vars leak — use unique param names for Optional
//   - W-006: No bare return after => — use { return } blocks

import { TokenKind, Token } from "./token"
import {
    TypeRef, Expr, Stmt, BlockStmt, TopLevel, Program,
    FunctionDecl, ClassDecl, EnumDecl, EnumVariant, EnumField,
    MethodDecl, FieldDecl, Param, Member, Visibility,
    VarDeclStmt, VarBinding, ConstDecl, AssignStmt,
    IfStmt, IfBody, WhileStmt, ForStmt, SwitchStmt, TryCatchStmt,
    LambdaExpr, LambdaParam, LambdaBody, BindingPattern,
    SwitchArm, SwitchArmBody, Pattern, Literal, BinOp, UnOp,
    ExecPolicy, TypeParameter, TypeAliasDecl, ObjField, MapEntry,
    StringTemplatePart, ImportDecl, CaseClause
} from "./ast"
import {
    TypeContext, SemanticAnalyzer, FunctionSig, ParamSig,
    ClassInfo, FieldInfo, EnumInfo, VariantInfo, EnumFieldInfo,
    TypeAliasInfo, Symbol, SymbolKind, DiagnosticLevel, Diagnostic
} from "./semantic"
import {
    LivenessContext, isCopyTypeName
} from "./liveness"

// =====================================================================
//  RustEmitter — accumulates Rust source code with indent management
// =====================================================================
// Design: output is a [string] buffer (one entry per write call).
// Final output is joined at the end. This avoids repeated string concat.
// Indent is tracked as a number; write_indent pushes spaces.

RustEmitter {
    _lines: [string]
    _currentLine: string
    _indentLevel: number
    _typeCtx: TypeContext
    _liveCtx: LivenessContext
    _currentFunc: string
    _inMethod: bool
    _currentClassName: string
    _classTypeParamStr: string
    _classTypeParamStrNoBounds: string
    _isMainModule: bool
    _inCompoundAdd: bool
    _suppressToString: bool
    _enumVariantFields: Map<string, [string]>
    _enumVariantFieldBoxed: Map<string, [bool]>
    _enumVariantFieldOptional: Map<string, [bool]>
    _pendingDerefs: [string]
    _optionalVars: Map<string, bool>
    _mapVars: Map<string, bool>
    _setVars: Map<string, bool>
    _stringVars: Map<string, bool>
    _currentReturnOptional: bool
    _currentReturnFallible: bool
    _inIfCondition: bool
    _inTestBlock: bool
    _derefClosureParams: bool
    _inAssignTarget: bool
    _usedTestNames: Map<string, int>
    _functionParamCount: Map<string, int>
    _functionDefaultStrs: Map<string, string>
    _warnings: [string]

    constructor(typeCtx: TypeContext, liveCtx: LivenessContext) {
        this._lines = []
        this._currentLine = ""
        this._indentLevel = 0
        this._typeCtx = typeCtx
        this._liveCtx = liveCtx
        this._currentFunc = ""
        this._inMethod = false
        this._currentClassName = ""
        this._classTypeParamStr = ""
        this._classTypeParamStrNoBounds = ""
        this._isMainModule = true
        this._inCompoundAdd = false
        this._suppressToString = false
        this._enumVariantFields = Map {}
        this._enumVariantFieldBoxed = Map {}
        this._enumVariantFieldOptional = Map {}
        this._pendingDerefs = []
        this._optionalVars = Map {}
        this._mapVars = Map {}
        this._setVars = Map {}
        this._stringVars = Map {}
        this._currentReturnOptional = false
        this._currentReturnFallible = false
        this._inIfCondition = false
        this._inTestBlock = false
        this._derefClosureParams = false
        this._inAssignTarget = false
        this._usedTestNames = Map {}
        this._functionParamCount = Map {}
        this._functionDefaultStrs = Map {}
        this._warnings = []
    }

    setIsMainModule(isMain: bool) {
        this._isMainModule = isMain
    }

    getWarnings(): [string] {
        return this._warnings
    }

    _warn(msg: string) {
        this._warnings.push(msg)
    }

    // -- Output primitives --

    _write(text: string) {
        this._currentLine += text
    }

    _writeln(text: string) {
        this._writeIndent()
        this._currentLine += text
        this._lines.push($"{this._currentLine}")
        this._currentLine = ""
    }

    _writeRaw(text: string) {
        this._lines.push(text)
    }

    _newline() {
        this._lines.push($"{this._currentLine}")
        this._currentLine = ""
    }

    _writeIndent() {
        let i = 0
        while i < this._indentLevel {
            this._currentLine += "    "
            i += 1
        }
    }

    _indent() {
        this._indentLevel += 1
    }

    _dedent() {
        if this._indentLevel > 0 {
            this._indentLevel -= 1
        }
    }

    _getOutput(): string {
        // Flush any remaining current line
        if this._currentLine != "" {
            this._lines.push($"{this._currentLine}")
            this._currentLine = ""
        }
        return this._lines.join("\n")
    }

    // -- Name sanitization --
    // Converts Liva identifiers to valid Rust identifiers.
    // camelCase → snake_case, keywords → r#keyword or renamed.

    _sanitizeName(name: string): string {
        // Rust keywords that need escaping
        if name == "type" { return "r#type" }
        if name == "match" { return "r#match" }
        if name == "ref" { return "r#ref" }
        if name == "mod" { return "r#mod" }
        if name == "use" { return "r#use" }
        if name == "impl" { return "r#impl" }
        if name == "trait" { return "r#trait" }
        if name == "where" { return "r#where" }
        if name == "async" { return "r#async" }
        if name == "await" { return "r#await" }
        if name == "move" { return "r#move" }
        if name == "self" { return "self_" }
        if name == "default" { return "default_val" }
        return this._toSnakeCase(name)
    }

    _toSnakeCase(name: string): string {
        // If the name is ALL_CAPS (constant style e.g. VERSION, MAX_SIZE), keep as-is
        let allCaps = true
        for ch in name {
            let isUpper = ch >= "A" && ch <= "Z"
            let isUnderscore = ch == "_"
            let isDigit = ch >= "0" && ch <= "9"
            if not isUpper && not isUnderscore && not isDigit {
                allCaps = false
            }
        }
        if allCaps && name.length > 1 {
            return name
        }
        // camelCase → snake_case: insert _ before uppercase, then lowercase
        let result = ""
        let i = 0
        for ch in name {
            if ch >= "A" && ch <= "Z" {
                if i > 0 {
                    result += "_"
                }
                result += ch.toLowerCase()
            } else {
                result += ch
            }
            i += 1
        }
        return result
    }

    // -- Type emission --
    // Converts Liva TypeRef to Rust type string.

    _emitType(t: TypeRef): string {
        let result = "/* unknown */"
        let _ = switch t {
            TypeRef.Simple(name) => {
                result = this._emitSimpleType(name)
                0
            },
            TypeRef.Array(inner) => {
                let arrInner = this._emitType(inner)
                result = "Vec<" + arrInner + ">"
                0
            },
            TypeRef.MapType(k, v) => {
                let kStr = this._emitType(k)
                let vStr = this._emitType(v)
                result = "HashMap<" + kStr + ", " + vStr + ">"
                0
            },
            TypeRef.SetType(inner) => {
                let setInner = this._emitType(inner)
                result = "HashSet<" + setInner + ">"
                0
            },
            TypeRef.OptionalType(inner) => {
                let optInner = this._emitType(inner)
                result = "Option<" + optInner + ">"
                0
            },
            TypeRef.Fallible(inner) => {
                let failInner = this._emitType(inner)
                result = "Result<" + failInner + ", String>"
                0
            },
            TypeRef.Tuple(elems) => {
                result = this._emitTupleType(elems)
                0
            },
            TypeRef.Generic(base, args) => {
                result = this._emitGenericType(base, args)
                0
            },
            TypeRef.Union(types) => {
                // Rust doesn't have union types; use first type as approximation
                this._warn("Union type approximated to first variant")
                for t in types {
                    result = this._emitType(t)
                    break
                }
                0
            }
        }
        return result
    }

    _emitSimpleType(name: string): string {
        if name == "string" { return "String" }
        if name == "number" { return "i32" }
        if name == "int" { return "i32" }
        if name == "float" { return "f64" }
        if name == "bool" { return "bool" }
        if name == "char" { return "char" }
        if name == "void" { return "()" }
        if name == "never" { return "!" }
        if name == "any" { return "serde_json::Value" }
        // User-defined type (class, enum) — keep PascalCase
        return name
    }

    _emitTupleType(elems: [TypeRef]): string {
        let parts: [string] = []
        for e in elems {
            parts.push(this._emitType(e))
        }
        return $"({parts.join(", ")})"
    }

    _emitGenericType(base: string, args: [TypeRef]): string {
        let argParts: [string] = []
        for a in args {
            argParts.push(this._emitType(a))
        }
        return $"{base}<{argParts.join(", ")}>"
    }

    // -- Top-level generation --

    generate(program: Program): string {
        // Pre-populate enum variant field registry from AST items
        // This registers field names for all enums defined in this module
        for item in program.items {
            let _ = switch item {
                TopLevel.Enum(decl) => {
                    this._registerEnumDeclFields(decl)
                    0
                },
                _ => { 0 }
            }
        }

        // Preamble: suppress common warnings and standard imports
        this._writeln("#![allow(unused_imports, unused_variables, unused_mut, unused_parens, dead_code, unused_assignments, unreachable_code, non_snake_case, while_true)]")
        this._writeln("use std::collections::{HashMap, HashSet};")
        this._writeln("use std::fmt::Write;")
        this._writeRaw("")

        // Generate all top-level items
        for item in program.items {
            this._emitTopLevel(item)
        }

        return this._getOutput()
    }

    _registerEnumDeclFields(decl: EnumDecl) {
        let enumName = $"{decl.name}"
        for v in decl.variants {
            let key = enumName + "::" + v.name
            let fieldNames: [string] = []
            let fieldBoxed: [bool] = []
            let fieldOptional: [bool] = []
            for f in v.fields {
                fieldNames.push(this._sanitizeName(f.name))
                // Check boxing and optional in a single pass
                let needsBox = false
                let isOpt = false
                let _ = switch f.typeRef {
                    TypeRef.Simple(typeName) => {
                        if this._typeCtx.enums.has(typeName) {
                            needsBox = true
                        }
                        0
                    },
                    TypeRef.OptionalType(_) => { isOpt = true; 0 },
                    _ => { 0 }
                }
                fieldBoxed.push(needsBox)
                fieldOptional.push(isOpt)
            }
            this._enumVariantFields.set(key, fieldNames)
            this._enumVariantFieldBoxed.set(key, fieldBoxed)
            this._enumVariantFieldOptional.set(key, fieldOptional)
        }
    }

    // Register enum variant fields for cross-module enums
    // Called externally before generate() for enums defined in other modules
    registerExternalEnumFields(enumName: string, variantName: string, fieldNames: [string]) {
        let key = enumName + "::" + variantName
        this._enumVariantFields.set(key, fieldNames)
    }

    _emitTopLevel(item: TopLevel) {
        let _ = switch item {
            TopLevel.Function(decl) => { this._emitFunction(decl); 0 },
            TopLevel.Class(decl) => { this._emitClass(decl); 0 },
            TopLevel.Enum(decl) => { this._emitEnum(decl); 0 },
            TopLevel.TypeAlias(decl) => { this._emitTypeAlias(decl); 0 },
            TopLevel.ConstDecl(decl) => { this._emitConstDecl(decl); 0 },
            TopLevel.Import(decl) => { this._emitImport(decl); 0 },
            TopLevel.Test(decl) => { 0 },
            TopLevel.ExprStmt(expr) => { this._emitTopLevelExpr(expr); 0 },
            _ => { 0 }
        }
    }

    // =====================================================================
    //  Phase 3.1 complete — infrastructure + type emission + name sanitization
    //  Phase 3.2 starts here — declarations
    // =====================================================================

    // -- Top-level expression statement (describe, etc.) --

    _emitTopLevelExpr(expr: Expr) {
        // Check if this is a describe() call
        let _ = switch expr {
            Expr.Call(callee, callArgs, _, _) => {
                let fnName = ""
                let _ = switch callee {
                    Expr.Identifier(n) => { fnName = n; 0 },
                    _ => { 0 }
                }
                if fnName == "describe" {
                    this._emitDescribe(callArgs)
                }
                0
            },
            _ => {
                // Generic top-level expr
                this._writeIndent()
                this._emitExpr(expr)
                this._write(";")
                this._newline()
                0
            }
        }
    }

    // -- Test framework: describe() --

    _emitDescribe(args: [Expr]) {
        if args.length < 2 { return }

        // Extract the name string
        let modName = "unnamed"
        let _ = switch args[0] {
            Expr.Literal(lit) => {
                let _ = switch lit {
                    Literal.Str(s) => { modName = this._sanitizeTestName(s); 0 },
                    _ => { 0 }
                }
                0
            },
            _ => { 0 }
        }

        this._writeln("#[cfg(test)]")
        this._writeln($"mod test_{modName} {{")
        this._indent()
        this._writeln("use super::*;")
        this._writeRaw("")

        let wasInTest = this._inTestBlock
        this._inTestBlock = true

        // Extract lambda body and emit its statements
        let _ = switch args[1] {
            Expr.Lambda(lambda) => {
                let _ = switch lambda.body {
                    LambdaBody.Block(block) => {
                        for stmt in block.stmts {
                            this._emitTestStmt(stmt)
                        }
                        0
                    },
                    LambdaBody.Expr(exprs) => {
                        for e in exprs {
                            this._writeIndent()
                            this._emitExpr(e)
                            this._write(";")
                            this._newline()
                        }
                        0
                    }
                }
                0
            },
            _ => { 0 }
        }

        this._inTestBlock = wasInTest
        this._dedent()
        this._writeln("}")
    }

    // -- Helper: emit a statement inside a describe block --
    // Detects test() and other calls, delegates the rest to _emitStmt

    _emitTestStmt(stmt: Stmt) {
        let _ = switch stmt {
            Stmt.ExprStmt(expr) => {
                let _ = switch expr {
                    Expr.Call(callee, callArgs, _, _) => {
                        let fnName = ""
                        let _ = switch callee {
                            Expr.Identifier(n) => { fnName = n; 0 },
                            _ => { 0 }
                        }
                        if fnName == "test" {
                            this._emitTestCase(callArgs)
                        } else if fnName == "describe" {
                            // Nested describe
                            this._emitDescribe(callArgs)
                        } else {
                            this._emitStmt(stmt)
                        }
                        0
                    },
                    _ => { this._emitStmt(stmt); 0 }
                }
                0
            },
            _ => { this._emitStmt(stmt); 0 }
        }
    }

    // -- Test framework: test() --

    _emitTestCase(args: [Expr]) {
        if args.length < 2 { return }

        // Extract and deduplicate test name
        let testName = "unnamed"
        let _ = switch args[0] {
            Expr.Literal(lit) => {
                let _ = switch lit {
                    Literal.Str(s) => { testName = this._sanitizeTestName(s); 0 },
                    _ => { 0 }
                }
                0
            },
            _ => { 0 }
        }
        // Deduplicate
        if this._usedTestNames.has(testName) {
            let count = this._usedTestNames.get(testName)
            count += 1
            this._usedTestNames.set(testName, count)
            testName = $"{testName}_{count}"
        } else {
            this._usedTestNames.set(testName, 1)
        }

        this._writeln("#[test]")
        this._writeln($"fn test_{testName}() {{")
        this._indent()

        // Emit body
        let _ = switch args[1] {
            Expr.Lambda(lambda) => {
                let _ = switch lambda.body {
                    LambdaBody.Block(block) => {
                        this._emitBlock(block)
                        0
                    },
                    LambdaBody.Expr(exprs) => {
                        for e in exprs {
                            this._writeIndent()
                            this._emitExpr(e)
                            this._write(";")
                            this._newline()
                        }
                        0
                    }
                }
                0
            },
            _ => { 0 }
        }

        this._dedent()
        this._writeln("}")
    }

    // -- Test name sanitizer: "my test name!" → "my_test_name" --

    _sanitizeTestName(name: string): string {
        let result = ""
        for ch in name {
            let isLetter = ch >= "a" and ch <= "z"
            let isUpperLetter = ch >= "A" and ch <= "Z"
            let isDigit = ch >= "0" and ch <= "9"
            if isLetter or isUpperLetter or isDigit {
                result += ch.toLowerCase()
            } else if ch == " " or ch == "-" or ch == "/" {
                result += "_"
            }
            // skip other characters
        }
        return result
    }

    // -- Import emission --

    _emitImport(decl: ImportDecl) {
        // Skip virtual module imports (liva/test, etc.)
        if decl.source.startsWith("liva/") {
            return
        }

        // Imports become mod/use statements in Rust
        // Only main module should emit 'mod X;' declarations
        let modName = this._extractModuleName(decl.source)
        if this._isMainModule {
            this._writeln("mod " + modName + ";")
        }        // Sub-modules need crate:: prefix to reference sibling modules
        let usePrefix = "crate::"
        if this._isMainModule {
            usePrefix = ""
        }
        if decl.isWildcard {
            this._writeln("use " + usePrefix + modName + "::*;")
        } else {
            let names: [string] = []
            for n in decl.imports {
                // Sanitize function names (lowercase start) to snake_case
                // Keep type/class names (uppercase start) as-is
                if n.length > 0 {
                    let fc = n.charAt(0)
                    if fc >= "A" && fc <= "Z" {
                        names.push(n)
                    } else {
                        names.push(this._sanitizeName(n))
                    }
                } else {
                    names.push(n)
                }
            }
            if names.length > 0 {
                let joined = names.join(", ")
                this._writeln("use " + usePrefix + modName + "::{" + joined + "};")
            }
        }
        this._writeRaw("")
    }

    _extractModuleName(source: string): string {
        // "./token.liva" → "token", "../utils.liva" → "utils"
        let name = $"{source}"
        // Strip path prefixes
        let lastSlash = -1
        let idx = 0
        for ch in name {
            if ch == "/" {
                lastSlash = idx
            }
            idx += 1
        }
        if lastSlash >= 0 {
            // Take everything after the last slash
            name = name.slice(lastSlash + 1, name.length)
        }
        // Strip .liva extension
        if name.endsWith(".liva") {
            name = name.slice(0, name.length - 5)
        }
        return name
    }

    // -- Function declaration --

    _emitFunction(decl: FunctionDecl) {
        let funcName = this._sanitizeName(decl.name)
        let prevFunc = $"{this._currentFunc}"
        this._currentFunc = $"{decl.name}"
        let prevRetOpt = this._currentReturnOptional
        let prevRetFail = this._currentReturnFallible
        this._currentReturnOptional = false
        this._currentReturnFallible = false

        // Register default parameter values for call-site injection
        this._functionParamCount.set(funcName, decl.params.length)
        let dIdx = 0
        for dp in decl.params {
            let dv = dp.defaultVal
            if dv != null {
                // Detect if default is a string literal via AST tag
                let isStrLit = false
                let _ = switch dv {
                    Expr.Literal(lit) => {
                        let _ = switch lit {
                            Literal.Str(_) => { isStrLit = true; 0 },
                            _ => { 0 }
                        }
                        0
                    },
                    _ => { 0 }
                }
                let dvStr = this._exprToString(dv)
                if isStrLit {
                    dvStr = dvStr + ".to_string()"
                }
                let key = funcName + ":" + dIdx.toString()
                this._functionDefaultStrs.set(key, dvStr)
            }
            dIdx += 1
        }

        // Build parameter list
        let paramList = this._buildParamList(decl.params)

        // Build return type and detect Optional return
        let retStr = this._buildReturnType(decl.returnType, decl.containsFail)
        if retStr.contains("Option<") {
            this._currentReturnOptional = true
        }
        if retStr.contains("Result<") {
            this._currentReturnFallible = true
        }

        // Build generic type params: <T: Clone, U: Clone>
        let typeParamStr = this._buildTypeParamStr(decl.typeParams)

        // Extract expression body once
        let feb = decl.exprBody

        if feb != null {
            // One-liner function: infer return type if not explicit
            if retStr == "" {
                let _ = switch feb {
                    Expr.Literal(lit) => {
                        let _ = switch lit {
                            Literal.Int(_) => { retStr = " -> i32"; 0 },
                            Literal.Float(_) => { retStr = " -> f64"; 0 },
                            Literal.Bool(_) => { retStr = " -> bool"; 0 },
                            Literal.Str(_) => { retStr = " -> String"; 0 },
                            _ => { 0 }
                        }
                        0
                    },
                    Expr.Binary(op, _, _) => {
                        let _ = switch op {
                            BinOp.Lt => { retStr = " -> bool"; 0 },
                            BinOp.Le => { retStr = " -> bool"; 0 },
                            BinOp.Gt => { retStr = " -> bool"; 0 },
                            BinOp.Ge => { retStr = " -> bool"; 0 },
                            BinOp.Eq => { retStr = " -> bool"; 0 },
                            BinOp.Ne => { retStr = " -> bool"; 0 },
                            BinOp.And => { retStr = " -> bool"; 0 },
                            BinOp.Or => { retStr = " -> bool"; 0 },
                            _ => { retStr = " -> i32"; 0 }
                        }
                        0
                    },
                    Expr.StringTemplate(_) => { retStr = " -> String"; 0 },
                    Expr.Unary(_, _) => { retStr = " -> i32"; 0 },
                    _ => { retStr = " -> i32"; 0 }
                }
            }
            // Determine async keyword
            let asyncKw = ""
            if decl.isAsyncInferred {
                asyncKw = "async "
                if funcName == "main" {
                    this._writeln("#[tokio::main]")
                }
            }
            // Emit function signature
            this._writeln("pub " + asyncKw + "fn " + funcName + typeParamStr + "(" + paramList + ")" + retStr + " {")
            this._indent()
            // Emit one-liner body
            this._writeIndent()
            this._write("return ")
            if this._currentReturnOptional {
                this._emitSomeWrapped(feb)
            } else {
                this._emitExpr(feb)
            }
            this._write(";")
            this._newline()
        } else {
            // Block-bodied function
            let asyncKw2 = ""
            if decl.isAsyncInferred {
                asyncKw2 = "async "
                if funcName == "main" {
                    this._writeln("#[tokio::main]")
                }
            }
            this._writeln("pub " + asyncKw2 + "fn " + funcName + typeParamStr + "(" + paramList + ")" + retStr + " {")
            this._indent()
            this._emitBlockOpt(decl.body)
        }

        this._dedent()
        this._writeln("}")
        this._writeRaw("")

        this._currentFunc = prevFunc
        this._currentReturnOptional = prevRetOpt
        this._currentReturnFallible = prevRetFail
    }

    _buildParamList(params: [Param]): string {
        let parts: [string] = []
        for p in params {
            let paramStr = this._buildParam(p)
            parts.push(paramStr)
        }
        return parts.join(", ")
    }

    _buildTypeParamStr(typeParams: [TypeParameter]): string {
        if typeParams.length == 0 { return "" }
        let parts: [string] = []
        for tp in typeParams {
            // Each type param needs Clone + Debug + PartialEq to work in Rust
            let tpName = tp.name
            if tp.constraints.length > 0 {
                // Map Liva constraint names to Rust traits
                let mappedBounds: [string] = []
                for c in tp.constraints {
                    if c == "Numeric" || c == "Number" {
                        mappedBounds.push("std::ops::Add<Output = " + tpName + "> + std::ops::Sub<Output = " + tpName + "> + PartialOrd + Default + Copy")
                    } else if c == "Comparable" {
                        mappedBounds.push("PartialOrd")
                    } else if c == "Printable" {
                        mappedBounds.push("std::fmt::Display")
                    } else {
                        mappedBounds.push(c)
                    }
                }
                let bounds = mappedBounds.join(" + ")
                parts.push(tpName + ": Clone + std::fmt::Debug + PartialEq + " + bounds)
            } else {
                parts.push(tpName + ": Clone + std::fmt::Debug + PartialEq")
            }
        }
        let joined = parts.join(", ")
        return "<" + joined + ">"
    }

    _buildParam(p: Param): string {
        let paramName = switch p.pattern {
            BindingPattern.Identifier(n) => n,
            _ => "_"
        }
        let sanitized = this._sanitizeName(paramName)
        let typeStr = this._buildParamType(p.typeRef)
        return $"{sanitized}: {typeStr}"
    }

    _buildParamType(optRef: TypeRef?): string {
        if optRef != null {
            return this._emitType(optRef)
        }
        return "/* inferred */"
    }

    _buildReturnType(optRef: TypeRef?, isFallible: bool): string {
        if optRef != null {
            let typeStr = this._emitType(optRef)
            if isFallible {
                return $" -> Result<{typeStr}, String>"
            }
            return $" -> {typeStr}"
        }
        if isFallible {
            return " -> Result<(), String>"
        }
        return ""
    }

    // Infer Rust type from an expression (for one-liner functions without explicit return type)
    _inferExprType(expr: Expr): string {
        let result = ""
        let _ = switch expr {
            Expr.Literal(lit) => {
                let _ = switch lit {
                    Literal.Int(_) => { result = "i32"; 0 },
                    Literal.Float(_) => { result = "f64"; 0 },
                    Literal.Bool(_) => { result = "bool"; 0 },
                    Literal.Str(_) => { result = "String"; 0 },
                    _ => { 0 }
                }
                0
            },
            Expr.Binary(op, left, right) => {
                let _ = switch op {
                    BinOp.Lt => { result = "bool"; 0 },
                    BinOp.Le => { result = "bool"; 0 },
                    BinOp.Gt => { result = "bool"; 0 },
                    BinOp.Ge => { result = "bool"; 0 },
                    BinOp.Eq => { result = "bool"; 0 },
                    BinOp.Ne => { result = "bool"; 0 },
                    BinOp.And => { result = "bool"; 0 },
                    BinOp.Or => { result = "bool"; 0 },
                    _ => {
                        // Arithmetic ops: infer from operands
                        result = this._inferExprType(left)
                        if result == "" { result = this._inferExprType(right) }
                        0
                    }
                }
                0
            },
            Expr.StringTemplate(_) => { result = "String"; 0 },
            Expr.ArrayLiteral(_) => { result = "Vec<i32>"; 0 },
            Expr.Unary(_, inner) => {
                result = this._inferExprType(inner)
                0
            },
            _ => { 0 }
        }
        return result
    }

    // -- Class declaration --

    _emitClass(decl: ClassDecl) {
        let className = $"{decl.name}"

        // Build type param string via for-loop (auto-clones, avoids partial move of decl)
        let tpParts: [string] = []
        let tpNames: [string] = []
        for tp in decl.typeParams {
            tpNames.push(tp.name)
            let bnds = "Clone + std::fmt::Debug + PartialEq"
            for c in tp.constraints {
                if c == "Numeric" || c == "Number" {
                    bnds = bnds + " + std::ops::Add<Output = " + tp.name + "> + std::ops::Sub<Output = " + tp.name + "> + PartialOrd + Default + Copy"
                } else if c == "Comparable" {
                    bnds = bnds + " + PartialOrd"
                } else if c == "Printable" {
                    bnds = bnds + " + std::fmt::Display"
                } else {
                    bnds = bnds + " + " + c
                }
            }
            tpParts.push(tp.name + ": " + bnds)
        }
        if tpParts.length > 0 {
            this._classTypeParamStr = "<" + tpParts.join(", ") + ">"
            this._classTypeParamStrNoBounds = "<" + tpNames.join(", ") + ">"
        } else {
            this._classTypeParamStr = ""
            this._classTypeParamStrNoBounds = ""
        }

        // Emit struct definition
        this._emitClassStruct(className, decl)

        // Emit impl block with constructor + methods
        this._emitClassImpl(className, decl)

        this._classTypeParamStr = ""
        this._classTypeParamStrNoBounds = ""
    }

    _emitClassStruct(className: string, decl: ClassDecl) {
        // Derive clause — include PartialEq so enum variants containing this struct support ==
        this._writeln("#[derive(Clone, Debug, PartialEq)]")
        let typeParamStr = this._classTypeParamStr
        this._writeln("pub struct " + className + typeParamStr + " {")
        this._indent()

        for m in decl.members {
            let _ = switch m {
                Member.Field(f) => {
                    this._emitField(f)
                    0
                },
                _ => { 0 }
            }
        }

        this._dedent()
        this._writeln("}")
        this._writeRaw("")
    }

    _emitField(f: FieldDecl) {
        let fieldName = this._sanitizeName(f.name)
        let typeStr = this._buildParamType(f.typeRef)
        this._writeln($"pub {fieldName}: {typeStr},")
    }

    _emitClassImpl(className: string, decl: ClassDecl) {
        let typeParamStr = this._classTypeParamStr
        let typeParamStrNoBounds = this._classTypeParamStrNoBounds
        if typeParamStr != "" {
            this._writeln("impl" + typeParamStr + " " + className + typeParamStrNoBounds + " {")
        } else {
            this._writeln("impl " + className + " {")
        }
        this._indent()

        let prevClass = $"{this._currentClassName}"
        let prevMethod = this._inMethod
        this._currentClassName = $"{className}"
        this._inMethod = true

        // Emit constructor (if class has fields, generate new() method)
        this._emitConstructor($"{className}", decl)

        // Emit methods
        for m in decl.members {
            let _ = switch m {
                Member.Method(md) => {
                    this._emitMethod($"{className}", md)
                    0
                },
                _ => { 0 }
            }
        }

        this._currentClassName = prevClass
        this._inMethod = prevMethod

        this._dedent()
        this._writeln("}")
        this._writeRaw("")
    }

    _emitConstructor(className: string, decl: ClassDecl) {
        // Find all fields
        let fields: [FieldDecl] = []
        for m in decl.members {
            let _ = switch m {
                Member.Field(f) => { fields.push(f); 0 },
                _ => { 0 }
            }
        }

        if fields.length == 0 { return }

        // Find constructor method (if exists)
        let hasConstructor = false
        let ctorParams: [Param] = []
        let ctorStmts: [Stmt] = []
        for m in decl.members {
            let _ = switch m {
                Member.Method(md) => {
                    if md.name == "constructor" {
                        hasConstructor = true
                        ctorParams = md.params
                        let body = md.body
                        if body != null {
                            ctorStmts = this._blockStmts(body)
                        }
                    }
                    0
                },
                _ => { 0 }
            }
        }

        if hasConstructor {
            // Class has explicit constructor — use ctor params and body
            let paramStr = this._buildParamList(ctorParams)

            this._writeln("pub fn new(" + paramStr + ") -> Self {")
            this._indent()

            // Emit constructor body as __field__ declarations
            for stmt in ctorStmts {
                let _ = switch stmt {
                    Stmt.Assign(asgn) => {
                        let _ = switch asgn.target {
                            Expr.MemberAccess(obj, prop) => {
                                let isThis = false
                                let _ = switch obj {
                                    Expr.Identifier(name) => {
                                        if name == "this" || name == "self" {
                                            isThis = true
                                        }
                                        0
                                    },
                                    _ => { 0 }
                                }
                                if isThis {
                                    let fname = this._sanitizeName(prop)
                                    this._writeIndent()
                                    this._write($"let __field__{fname} = ")
                                    this._emitExpr(asgn.value)
                                    this._write(";")
                                    this._newline()
                                }
                                // Non-this assignments skipped (shouldn't appear in constructors)
                                0
                            },
                            _ => { 0 }
                        }
                        0
                    },
                    _ => { 0 }
                }
            }

            // Emit Self { ... } initializer
            this._writeln("Self {")
            this._indent()
            for f in fields {
                let fname = this._sanitizeName(f.name)
                this._writeln($"{fname}: __field__{fname},")
            }
            this._dedent()
            this._writeln("}")

            this._dedent()
            this._writeln("}")
            this._writeRaw("")
        } else {
            // No explicit constructor — generate new() with all fields as params
            let paramParts: [string] = []
            for f in fields {
                let fname = this._sanitizeName(f.name)
                let ftype = this._buildParamType(f.typeRef)
                paramParts.push($"{fname}: {ftype}")
            }
            let paramStr = paramParts.join(", ")

            this._writeln("pub fn new(" + paramStr + ") -> Self {")
            this._indent()
            this._writeln("Self {")
            this._indent()
            for f in fields {
                let fname = this._sanitizeName(f.name)
                this._writeln($"{fname},")
            }
            this._dedent()
            this._writeln("}")
            this._dedent()
            this._writeln("}")
            this._writeRaw("")
        }
    }

    _emitMethod(className: string, decl: MethodDecl) {
        let methodName = this._sanitizeName(decl.name)
        let prevFunc = $"{this._currentFunc}"
        this._currentFunc = $"{className}.{decl.name}"
        let prevRetOpt = this._currentReturnOptional
        let prevRetFail = this._currentReturnFallible
        this._currentReturnOptional = false
        this._currentReturnFallible = false

        // Determine self receiver (all methods get &mut self to allow field mutations)
        let selfParam = "&mut self"

        let paramList = this._buildParamList(decl.params)
        let fullParams = $"{selfParam}"
        if paramList != "" {
            fullParams = $"{selfParam}, {paramList}"
        }

        let retStr = this._buildReturnType(decl.returnType, decl.containsFail)
        if retStr.contains("Option<") {
            this._currentReturnOptional = true
        }
        if retStr.contains("Result<") {
            this._currentReturnFallible = true
        }

        let asyncKw = ""
        if decl.isAsyncInferred {
            asyncKw = "async "
        }
        this._writeln("pub " + asyncKw + "fn " + methodName + "(" + fullParams + ")" + retStr + " {")
        this._indent()

        // Handle one-liner methods (=> expr)
        let eb = decl.exprBody
        if eb != null {
            this._writeIndent()
            this._write("return ")
            if this._currentReturnOptional {
                this._emitSomeWrapped(eb)
            } else if this._currentReturnFallible {
                this._write("Ok(")
                this._emitExpr(eb)
                this._write(")")
            } else {
                this._emitExpr(eb)
            }
            this._write(";")
            this._newline()
        } else {
            this._emitBlockOpt(decl.body)
        }

        this._dedent()
        this._writeln("}")
        this._writeRaw("")

        this._currentFunc = prevFunc
        this._currentReturnOptional = prevRetOpt
        this._currentReturnFallible = prevRetFail
    }

    // -- Enum declaration --

    _emitEnum(decl: EnumDecl) {
        let enumName = $"{decl.name}"

        // Check if all variants are unit (no data) — can derive Copy
        let allUnit = this._isAllUnitEnum(decl)

        if allUnit {
            this._writeln("#[derive(Clone, Copy, Debug, PartialEq)]")
        } else {
            this._writeln("#[derive(Clone, Debug, PartialEq)]")
        }

        this._writeln("pub enum " + enumName + " {")
        this._indent()

        for v in decl.variants {
            this._emitVariant(enumName, v)
        }

        this._dedent()
        this._writeln("}")
        this._writeRaw("")
    }

    _isAllUnitEnum(decl: EnumDecl): bool {
        for v in decl.variants {
            if v.fields.length > 0 { return false }
        }
        return true
    }

    _emitVariant(enumName: string, v: EnumVariant) {
        if v.fields.length == 0 {
            this._writeln($"{v.name},")
            // Register empty variant
            let key = enumName + "::" + v.name
            this._enumVariantFields.set(key, [])
        } else {
            let fieldParts: [string] = []
            let fieldNames: [string] = []
            for f in v.fields {
                let fname = this._sanitizeName(f.name)
                fieldNames.push(fname)
                // W-003: Call _emitType first, then check boxing via enum name lookup
                // This avoids double-use of f.typeRef (move semantics)
                let ftype = this._emitType(f.typeRef)
                let needsBox = this._typeCtx.enums.has(ftype)
                if needsBox {
                    fieldParts.push($"{fname}: Box<{ftype}>")
                } else {
                    fieldParts.push($"{fname}: {ftype}")
                }
            }
            let fieldsStr = fieldParts.join(", ")
            this._writeln(v.name + " { " + fieldsStr + " },")
            // Register variant field names
            let key2 = enumName + "::" + v.name
            this._enumVariantFields.set(key2, fieldNames)
        }
    }

    _needsBoxing(t: TypeRef): bool {
        // Recursive enum field detection — simplified heuristic
        // If the field's type matches a known enum name, it might be recursive
        let result = false
        let _ = switch t {
            TypeRef.Simple(name) => {
                if this._typeCtx.enums.has(name) {
                    result = true
                }
                0
            },
            TypeRef.Array(inner) => { 0 },
            _ => { 0 }
        }
        return result
    }

    // -- Type alias --

    _emitTypeAlias(decl: TypeAliasDecl) {
        let aliasName = $"{decl.name}"
        let targetStr = this._emitType(decl.targetType)
        this._writeln($"pub type {aliasName} = {targetStr};")
        this._writeRaw("")
    }

    // -- Const declaration --

    _emitConstDecl(decl: ConstDecl) {
        let constName = this._sanitizeName(decl.name)
        let typeStr = this._buildParamType(decl.typeRef)
        let initExpr = decl.init
        // Infer const type from init expression when not explicit
        if typeStr == "/* inferred */" {
            let _ = switch initExpr {
                Expr.Literal(lit) => {
                    let _ = switch lit {
                        Literal.Int(_) => { typeStr = "i32"; 0 },
                        Literal.Float(_) => { typeStr = "f64"; 0 },
                        Literal.Bool(_) => { typeStr = "bool"; 0 },
                        Literal.Str(_) => { typeStr = "&str"; 0 },
                        _ => { 0 }
                    }
                    0
                },
                _ => { 0 }
            }
        }
        // Const string must be &str, not String
        let isConstStr = typeStr == "&str"
        this._writeIndent()
        if isConstStr {
            this._write($"const {constName}: &str = ")
            // Emit string literal without .to_string() using buffer
            let initStr = this._exprToString(initExpr)
            if initStr.endsWith(".to_string()") {
                initStr = initStr.slice(0, initStr.length - 12)
            }
            this._write(initStr)
        } else {
            this._write($"pub const {constName}: {typeStr} = ")
            this._emitExpr(initExpr)
        }
        this._write(";")
        this._newline()
        this._writeRaw("")
    }

    // =====================================================================
    //  Phase 3.3 — Statements
    // =====================================================================

    // Helper: check if an expression is a simple non-reserved identifier
    // NOTE: This helper is not used inline due to move semantics.
    // Instead, .clone() is added unconditionally to match discriminants.

    _emitBlockOpt(body: BlockStmt?) {
        if body != null {
            this._emitBlock(body)
        }
    }

    _emitBlock(block: BlockStmt) {
        for s in block.stmts {
            this._emitStmt(s)
        }
    }

    _blockStmts(block: BlockStmt): [Stmt] {
        return block.stmts
    }

    _emitStmt(stmt: Stmt) {
        let _ = switch stmt {
            Stmt.VarDecl(decl) => { this._emitVarDecl(decl); 0 },
            Stmt.ConstDecl(cdecl) => { this._emitConstDecl(cdecl); 0 },
            Stmt.Assign(asgn) => { this._emitAssign(asgn); 0 },
            Stmt.If(ifStmt) => { this._emitIf(ifStmt); 0 },
            Stmt.While(wStmt) => { this._emitWhile(wStmt); 0 },
            Stmt.For(fStmt) => { this._emitFor(fStmt); 0 },
            Stmt.Switch(swStmt) => { this._emitSwitch(swStmt); 0 },
            Stmt.TryCatch(tcStmt) => { this._emitTryCatch(tcStmt); 0 },
            Stmt.Throw(throwExpr) => {
                this._writeIndent()
                this._write("panic!(\"{}\"")
                // Simplified: just panic with the expression
                this._write(", ")
                this._emitExpr(throwExpr)
                this._write(");")
                this._newline()
                0
            },
            Stmt.Fail(failExpr, line) => {
                this._writeIndent()
                this._write("return Err(format!(\"{}\", ")
                this._emitExpr(failExpr)
                this._write("));")
                this._newline()
                0
            },
            Stmt.Return(retExpr) => { this._emitReturn(retExpr); 0 },
            Stmt.Break => { this._writeln("break;"); 0 },
            Stmt.Continue => { this._writeln("continue;"); 0 },
            Stmt.ExprStmt(expr) => {
                this._writeIndent()
                this._emitExpr(expr)
                this._write(";")
                this._newline()
                0
            },
            Stmt.Block(blk) => {
                this._writeln("{")
                this._indent()
                this._emitBlock(blk)
                this._dedent()
                this._writeln("}")
                0
            },
            Stmt.Defer(deferStmt) => {
                // Defer uses a guard pattern in Rust
                this._writeln("// defer (simplified — full impl in Phase 3 refinement)")
                this._emitStmt(deferStmt)
                0
            }
        }
    }

    // -- Variable declaration --

    _emitVarDecl(decl: VarDeclStmt) {
        // Special case: let val, err = fallibleFn() — 2 Identifier bindings with isFallible
        if decl.isFallible && decl.bindings.length == 2 {
            let bName0 = ""
            let bName1 = ""
            let bIdx = 0
            for b in decl.bindings {
                let _ = switch b.pattern {
                    BindingPattern.Identifier(bn) => {
                        if bIdx == 0 { bName0 = bn }
                        else { bName1 = bn }
                        0
                    },
                    _ => { 0 }
                }
                bIdx += 1
            }
            if bName0 != "" && bName1 != "" {
                let valName = this._sanitizeName(bName0)
                let errName = this._sanitizeName(bName1)
                this._writeIndent()
                this._write("let (mut ")
                this._write(valName)
                this._write(", mut ")
                this._write(errName)
                this._write(") = match ")
                this._emitExpr(decl.init)
                this._write(" { Ok(v) => (v, None), Err(e) => (Default::default(), Some(e)) };")
                this._newline()
                return
            }
        }
        for b in decl.bindings {
            this._emitBinding(b, decl)
        }
    }

    _emitBinding(b: VarBinding, decl: VarDeclStmt) {
        let _ = switch b.pattern {
            BindingPattern.Identifier(name) => {
                this._emitSimpleBinding(name, b.typeRef, decl)
                0
            },
            BindingPattern.TuplePat(elements) => {
                this._emitTupleBinding(elements, decl)
                0
            },
            BindingPattern.ObjectPat(fields) => {
                // Destructuring — emit let { field1, field2, .. } = expr;
                this._writeIndent()
                this._write("let ")
                // Simplified: treat as separate let bindings
                this._emitExpr(decl.init)
                this._write(";")
                this._newline()
                0
            },
            BindingPattern.ArrayPat(elements, rest) => {
                this._writeIndent()
                this._write("let [")
                let idx = 0
                for e in elements {
                    if idx > 0 { this._write(", ") }
                    // W-010: e is string? — extract to local for null-check
                    let eName = e
                    if eName != null {
                        let sn = this._sanitizeName(eName)
                        this._write(sn)
                    }
                    idx += 1
                }
                this._write("] = ")
                this._emitExpr(decl.init)
                this._write(";")
                this._newline()
                0
            }
        }
    }

    _emitSimpleBinding(name: string, optTypeRef: TypeRef?, decl: VarDeclStmt) {
        let sanitized = this._sanitizeName(name)
        this._writeIndent()

        // Determine mutability — skip mut for _ (Rust doesn't allow let mut _)
        if sanitized == "_" {
            this._write("let _")
        } else {
            this._write($"let mut {sanitized}")
        }

        // Emit type annotation if present, and detect Optional/Map/Set/String types
        let isOptionalType = false
        let initExprTag = ""
        if optTypeRef != null {
            let typeStr = this._emitType(optTypeRef)
            this._write($": {typeStr}")
            if typeStr.startsWith("Option<") {
                isOptionalType = true
            }
            // Track var type from annotation
            if typeStr.contains("HashMap") { initExprTag = "map" }
            else if typeStr.contains("HashSet") { initExprTag = "set" }
            else if typeStr == "String" || typeStr == "&str" { initExprTag = "string" }
        }
        if isOptionalType {
            this._optionalVars.set(sanitized, true)
        }
        if initExprTag == "map" { this._mapVars.set(sanitized, true) }
        if initExprTag == "set" { this._setVars.set(sanitized, true) }
        if initExprTag == "string" { this._stringVars.set(sanitized, true) }

        this._write(" = ")

        // Handle fallible init (or fail / or value)
        if decl.isFallible {
            let orVal = decl.orValue
            if orVal != null {
                // or <value> → expr.unwrap_or(fallback) — works for both Option AND Result
                this._emitExpr(decl.init)
                // Strip trailing .unwrap() if present (Map.get etc add it)
                let lineCheck = $"{this._currentLine}"
                if lineCheck.endsWith(".unwrap()") {
                    this._currentLine = lineCheck.substring(0, lineCheck.length - 9)
                }
                this._write(".unwrap_or(")
                this._emitExpr(orVal)
                this._write(")")
            } else {
                // or fail → In test blocks: match + panic (no Result return type)
                // In normal functions: expr?
                if this._inTestBlock || not this._currentReturnFallible {
                    this._write("match ")
                    this._emitExpr(decl.init)
                    this._write(" { Ok(v) => v, Err(e) => panic!(\"{}\", e) }")
                } else {
                    this._emitExpr(decl.init)
                    this._write("?")
                }
            }
        } else {
            // Wrap non-null init with Some() if type is Optional
            if isOptionalType {
                this._emitSomeWrapped(decl.init)
            } else {
                this._emitExpr(decl.init)
            }
        }

        // Detect Set/Map from emitted init expression (for untyped bindings like let s = Set {...})
        if initExprTag == "" && sanitized != "_" {
            if this._currentLine.contains("HashSet") { this._setVars.set(sanitized, true) }
            else if this._currentLine.contains("HashMap") { this._mapVars.set(sanitized, true) }
        }

        // Clone all let binding inits to avoid move issues (E0382, E0507)
        // Safe because .clone() on any Clone type returns the same type
        if sanitized != "_" {
            this._write(".clone()")
        }

        this._write(";")
        this._newline()
    }

    _emitTupleBinding(elements: [string], decl: VarDeclStmt) {
        // Special case: let val, err = fallibleFn() → match expr { Ok(v) => (v, None), Err(e) => (Default, Some(e)) }
        if decl.isFallible && elements.length == 2 {
            this._writeIndent()
            let valName = this._sanitizeName(elements[0])
            let errName = this._sanitizeName(elements[1])
            this._write("let (mut ")
            this._write(valName)
            this._write(", mut ")
            this._write(errName)
            this._write(") = match ")
            this._emitExpr(decl.init)
            this._write(" { Ok(v) => (v, None), Err(e) => (Default::default(), Some(e)) };")
            this._newline()
            return
        }
        this._writeIndent()
        this._write("let (")
        let idx = 0
        for e in elements {
            if idx > 0 { this._write(", ") }
            let sn = this._sanitizeName(e)
            this._write(sn)
            idx += 1
        }
        this._write(") = ")
        this._emitExpr(decl.init)
        this._write(";")
        this._newline()
    }

    // -- Some() wrapping for optional values --
    // Emits expression wrapped with Some() unless it's a Null literal (emits None)
    // Handles each Expr variant in ONE pass to avoid double-consume

    _emitSomeWrapped(expr: Expr) {
        let _ = switch expr {
            Expr.Literal(lit) => {
                let _ = switch lit {
                    Literal.Null => { this._write("None"); 0 },
                    _ => { this._write("Some("); this._emitLiteral(lit); this._write(")"); 0 }
                }
                0
            },
            Expr.Identifier(iName) => {
                let san = this._sanitizeName(iName)
                if san == "null" or san == "None" {
                    this._write("None")
                } else if this._optionalVars.has(san) {
                    // Already Optional — don't double-wrap
                    this._write($"{san}.clone()")
                } else {
                    this._write($"Some({san}.clone())")
                }
                0
            },
            Expr.Binary(op, left, right) => {
                this._write("Some(")
                this._emitBinary(op, left, right)
                this._write(")")
                0
            },
            Expr.Call(callee, args, ep, ta) => {
                this._write("Some(")
                this._emitExpr(Expr.Call(callee, args, ep, ta))
                this._write(")")
                0
            },
            Expr.MethodCall(mcObj, mcMethod, mcArgs) => {
                this._write("Some(")
                this._emitExpr(Expr.MethodCall(mcObj, mcMethod, mcArgs))
                this._write(")")
                0
            },
            Expr.MemberAccess(maObj, maProp) => {
                this._write("Some(")
                this._emitExpr(Expr.MemberAccess(maObj, maProp))
                this._write(")")
                0
            },
            Expr.StructLiteral(slName, slFields) => {
                this._write("Some(")
                this._emitExpr(Expr.StructLiteral(slName, slFields))
                this._write(")")
                0
            },
            Expr.StringTemplate(parts) => {
                this._write("Some(")
                this._emitExpr(Expr.StringTemplate(parts))
                this._write(")")
                0
            },
            Expr.Unary(op, operand) => {
                this._write("Some(")
                this._emitExpr(Expr.Unary(op, operand))
                this._write(")")
                0
            },
            Expr.ArrayLiteral(elements) => {
                this._write("Some(")
                this._emitExpr(Expr.ArrayLiteral(elements))
                this._write(")")
                0
            },
            Expr.SwitchExpr(disc, arms) => {
                this._write("Some(")
                this._emitExpr(Expr.SwitchExpr(disc, arms))
                this._write(")")
                0
            },
            Expr.Lambda(lam) => {
                this._write("Some(")
                this._emitExpr(Expr.Lambda(lam))
                this._write(")")
                0
            },
            Expr.Index(idxObj, idxExpr) => {
                this._write("Some(")
                this._emitExpr(Expr.Index(idxObj, idxExpr))
                this._write(")")
                0
            },
            Expr.Ternary(cond, thenE, elseE) => {
                this._write("Some(")
                this._emitExpr(Expr.Ternary(cond, thenE, elseE))
                this._write(")")
                0
            },
            _ => {
                // Rare cases — emit without wrapping (may need manual fix)
                this._warn("Optional wrapping for complex expression may need review")
                this._write("Some(todo!(\"optional\"))")
                0
            }
        }
    }

    // -- Assignment --

    _emitAssign(stmt: AssignStmt) {
        this._writeIndent()

        let assignOp = stmt.op
        if assignOp != null {
            let opStr = this._binOpToRust(assignOp)
            if opStr == "+" {
                this._emitCompoundAdd(stmt.target, stmt.value)
            } else {
                this._inAssignTarget = true
                this._emitExpr(stmt.target)
                this._inAssignTarget = false
                this._write($" {opStr}= ")
                this._emitExpr(stmt.value)
            }
        } else {
            // Handle assignment — check if target is an optional variable
            // We destructure stmt.target in ONE pass to avoid double-consume
            let _ = switch stmt.target {
                Expr.Identifier(varName) => {
                    let vnCopy = $"{varName}"
                    let san = this._sanitizeName(varName)
                    this._write(san)
                    this._write(" = ")
                    if this._optionalVars.has(san) {
                        this._emitSomeWrapped(stmt.value)
                    } else {
                        // Fallback: check type context for Optional
                        let varTypeRef = this._lookupVarTypeRef(vnCopy)
                        let varTag = this._typeRefToTag(varTypeRef)
                        if varTag == "optional" {
                            this._optionalVars.set(san, true)
                            this._emitSomeWrapped(stmt.value)
                        } else {
                            this._emitExpr(stmt.value)
                        }
                    }
                    0
                },
                Expr.MemberAccess(maObj, maProp) => {
                    this._emitExpr(maObj)
                    let snProp = this._sanitizeName(maProp)
                    this._write($".{snProp}")
                    this._write(" = ")
                    this._emitExpr(stmt.value)
                    0
                },
                Expr.Index(idxObj, idxExpr) => {
                    this._emitExpr(idxObj)
                    this._write("[(")
                    this._emitExpr(idxExpr)
                    this._write(") as usize]")
                    this._write(" = ")
                    this._emitExpr(stmt.value)
                    0
                },
                _ => {
                    // Fallback — emit without Some wrapping
                    this._write("/* assign */ ")
                    this._emitExpr(stmt.value)
                    0
                }
            }
        }

        this._write(";")
        this._newline()
    }

    _emitCompoundAdd(target: Expr, value: Expr) {
        // Check TARGET type to determine string vs numeric +=
        // Default to numeric unless target is known to be a string
        let isString = this._isStringExpr(target)
        // Also check if VALUE is a string — implies target must be string too
        if not isString {
            isString = this._isStringExpr(value)
        }

        if isString {
            // String compound add: target.push_str(&value)
            this._inAssignTarget = true
            this._emitExpr(target)
            this._inAssignTarget = false
            let isLitStr = false
            let _ = switch value {
                Expr.Literal(lit2) => {
                    let _ = switch lit2 {
                        Literal.Str(_) => { isLitStr = true; 0 },
                        _ => { 0 }
                    }
                    0
                },
                _ => { 0 }
            }
            if isLitStr {
                this._write(".push_str(")
                this._inCompoundAdd = true
                this._emitExpr(value)
                this._inCompoundAdd = false
                this._write(")")
            } else {
                this._write(".push_str(&")
                this._inCompoundAdd = true
                this._emitExpr(value)
                this._inCompoundAdd = false
                this._write(")")
            }
        } else {
            // Numeric (default): target += value
            this._inAssignTarget = true
            this._emitExpr(target)
            this._inAssignTarget = false
            this._write(" += ")
            this._emitExpr(value)
        }
    }

    // -- If statement --

    _emitIf(stmt: IfStmt) {
        this._writeIndent()
        this._write("if ")
        this._inIfCondition = true
        this._emitExpr(stmt.condition)
        this._inIfCondition = false
        this._write(" {")
        this._newline()
        this._indent()
        this._emitIfBody(stmt.thenBranch)
        this._dedent()

        let elsePart = stmt.elseBranch
        if elsePart != null {
            this._writeln("} else {")
            this._indent()
            this._emitIfBody(elsePart)
            this._dedent()
        }
        this._writeln("}")
    }

    _emitIfBody(body: IfBody) {
        let _ = switch body {
            IfBody.Block(block) => { this._emitBlock(block); 0 },
            IfBody.SingleStmt(stmts) => {
                for s in stmts {
                    this._emitStmt(s)
                }
                0
            }
        }
    }

    // -- While loop --

    _emitWhile(stmt: WhileStmt) {
        this._writeIndent()
        this._write("while ")
        this._inIfCondition = true
        this._emitExpr(stmt.condition)
        this._inIfCondition = false
        this._write(" {")
        this._newline()
        this._indent()
        this._emitBlock(stmt.body)
        this._dedent()
        this._writeln("}")
    }

    // -- For loop --

    _emitFor(stmt: ForStmt) {
        this._writeIndent()
        let varName = this._sanitizeName(stmt.variable)
        let iterableExpr = stmt.iterable

        // Check if there's an index variable (for i, item in array)
        let var2 = stmt.variable2
        let hasVar2 = var2 != null
        let var2Name = ""
        if var2 != null {
            var2Name = this._sanitizeName(var2)
        }
        if hasVar2 {
            // Two-variable for loop
            let idxName = $"{varName}"
            let itemName = $"{var2Name}"
            // Detect Map iteration: for key, value in map → .iter()
            let isMapIteration = false
            let _ = switch iterableExpr {
                Expr.Identifier(iterName) => {
                    let sn = this._sanitizeName(iterName)
                    if this._mapVars.has(sn) {
                        isMapIteration = true
                    }
                    0
                },
                _ => { 0 }
            }
            if isMapIteration {
                this._write($"for ({idxName}, {itemName}) in ")
                this._emitExpr(iterableExpr)
                this._write(".iter()")
            } else {
                // Array: for i, item → .iter().cloned().enumerate()
                this._write($"for ({idxName}, {itemName}) in ")
                this._emitExpr(iterableExpr)
                this._write(".iter().cloned().enumerate()")
            }
        } else {
            this._write($"for {varName} in ")
            this._emitForIterable(iterableExpr)
        }

        this._write(" {")
        this._newline()
        this._indent()
        // If two-variable enumerate loop, shadow index var as i32
        if hasVar2 {
            this._writeln($"let {varName} = {varName} as i32;")
            // Clone item to avoid move issues
            this._writeln($"let {var2Name} = {var2Name}.clone();")
        }
        this._emitBlock(stmt.body)
        this._dedent()
        this._writeln("}")
    }

    // Helper: emit iterable expression with appropriate iteration suffix
    // Handles iterator methods (.keys/.values), ranges, and default (array) cases
    // Everything in one switch to avoid double-consuming the value
    _emitForIterable(iterable: Expr) {
        let _ = switch iterable {
            Expr.Identifier(name) => {
                // Check if variable is a string type → use .chars() instead of .iter()
                let varType = this._lookupVarTypeRef(name)
                let tag = this._typeRefToTag(varType)
                let sanitized = this._sanitizeName(name)
                if tag == "string" {
                    this._write(sanitized)
                    this._write(".chars().map(|c| c.to_string())")
                } else {
                    this._write(sanitized)
                    this._write(".iter().cloned()")
                }
                0
            },
            Expr.MethodCall(obj, m, args) => {
                if m == "keys" {
                    // map.keys() already returns an iterator
                    this._emitExpr(obj)
                    this._write(".keys().cloned()")
                } else if m == "values" {
                    this._emitExpr(obj)
                    this._write(".values().cloned()")
                } else if m == "chars" {
                    this._emitExpr(obj)
                    this._write(".chars().map(|c| c.to_string())")
                } else {
                    // Other method call returns a collection
                    this._emitMethodCall(obj, m, args)
                    this._write(".iter().cloned()")
                }
                0
            },
            // Range expressions: 1..5 or 1..=5 — don't add .iter().cloned()
            Expr.Binary(op, left, right) => {
                let isRange = false
                let _ = switch op {
                    BinOp.Range => { isRange = true; 0 },
                    BinOp.RangeInclusive => { isRange = true; 0 },
                    _ => { 0 }
                }
                if isRange {
                    this._emitExpr(left)
                    let opStr = switch op {
                        BinOp.Range => " .. ",
                        BinOp.RangeInclusive => " ..= ",
                        _ => " .. "
                    }
                    this._write(opStr)
                    this._emitExpr(right)
                } else {
                    this._emitExpr(iterable)
                    this._write(".iter().cloned()")
                }
                0
            },
            Expr.ArrayLiteral(_) => {
                // Inline array literal: [1, 2, 3] → vec![...].iter().cloned()
                this._emitExpr(iterable)
                this._write(".iter().cloned()")
                0
            },
            _ => {
                this._emitExpr(iterable)
                this._write(".iter().cloned()")
                0
            }
        }
    }

    // -- Switch statement (match) --

    _isStringSwitchStmt(cases: [CaseClause]): bool {
        // NOTE: this method does NOT consume 'cases' — it only checks the first element
        if cases.length > 0 {
            let isStr = false
            // Using a simple heuristic: we'll check after we know
            return false  // Determined below from first case
        }
        return false
    }

    _emitSwitch(stmt: SwitchStmt) {
        // Detect string switch: if first case value is a string literal, use .as_str()
        let isStringSwitch = false
        for c in stmt.cases {
            let _ = switch c.value {
                Expr.Literal(lit) => {
                    let _ = switch lit {
                        Literal.Str(_) => { isStringSwitch = true; 0 },
                        _ => { 0 }
                    }
                    0
                },
                _ => { 0 }
            }
            break
        }

        this._writeIndent()
        this._write("match ")
        this._emitExpr(stmt.discriminant)
        if isStringSwitch {
            this._write(".as_str()")
        } else {
            this._write(".clone()")
        }
        this._write(" {")
        this._newline()
        this._indent()

        for c in stmt.cases {
            this._emitCaseClause(c, false)
        }

        // Default arm
        let defBody = stmt.defaultBody
        if defBody != null {
            this._writeln("_ => {")
            this._indent()
            for s in defBody {
                this._emitStmt(s)
            }
            this._dedent()
            this._writeln("}")
        }

        this._dedent()
        this._writeln("}")
    }

    _emitCaseClause(c: CaseClause, isStrSwitch: bool) {
        this._writeIndent()
        this._emitExpr(c.value)
        this._write(" => {")
        this._newline()
        this._indent()
        for s in c.body {
            this._emitStmt(s)
        }
        this._dedent()
        this._writeln("}")
    }

    // -- Try/catch --

    _emitTryCatch(stmt: TryCatchStmt) {
        // Rust doesn't have try/catch — use a closure + match on Result
        this._writeln("match (|| -> Result<(), String> {")
        this._indent()
        this._emitBlock(stmt.tryBlock)
        this._writeln("Ok(())")
        this._dedent()
        this._writeln("})() {")
        this._indent()
        this._writeln("Ok(()) => {}")
        let catchVar = this._sanitizeName(stmt.catchVar)
        this._writeln("Err(" + catchVar + ") => {")
        this._indent()
        this._emitBlock(stmt.catchBlock)
        this._dedent()
        this._writeln("}")
        this._dedent()
        this._writeln("}")
    }

    // -- Return --

    _emitReturn(optExpr: Expr?) {
        if optExpr != null {
            this._writeIndent()
            this._write("return ")
            if this._currentReturnOptional {
                this._emitSomeWrapped(optExpr)
            } else if this._currentReturnFallible {
                this._write("Ok(")
                this._emitExpr(optExpr)
                this._write(")")
            } else {
                this._emitExpr(optExpr)
            }
            this._write(";")
            this._newline()
        } else {
            if this._currentReturnFallible {
                this._writeln("return Ok(());")
            } else {
                this._writeln("return;")
            }
        }
    }

    // =====================================================================
    //  Phase 3.4 — Expressions
    // =====================================================================

    _emitExpr(expr: Expr) {
        let _ = switch expr {
            Expr.Literal(lit) => { this._emitLiteral(lit); 0 },
            Expr.Identifier(name) => { this._emitIdentifier(name); 0 },
            Expr.Binary(op, left, right) => {
                this._emitBinary(op, left, right)
                0
            },
            Expr.Unary(op, operand) => {
                this._emitUnary(op, operand)
                0
            },
            Expr.Ternary(cond, thenE, elseE) => {
                this._write("if ")
                this._emitExpr(cond)
                this._write(" { ")
                this._emitExpr(thenE)
                this._write(" } else { ")
                this._emitExpr(elseE)
                this._write(" }")
                0
            },
            Expr.Call(callee, callArgs, policy, tArgs) => {
                this._emitCall(callee, callArgs)
                0
            },
            Expr.MethodCall(mcObj, method, mcArgs) => {
                this._emitMethodCall(mcObj, method, mcArgs)
                0
            },
            Expr.MemberAccess(maObj, prop) => {
                this._emitMemberAccess(maObj, prop)
                0
            },
            Expr.Index(idxObj, idxExpr) => {
                this._emitExpr(idxObj)
                this._write("[(")
                this._emitExpr(idxExpr)
                this._write(") as usize].clone()")
                0
            },
            Expr.ObjectLiteral(objFields) => {
                this._emitObjectLiteral(objFields)
                0
            },
            Expr.StructLiteral(typeName, sFields) => {
                this._emitStructLiteral(typeName, sFields)
                0
            },
            Expr.ArrayLiteral(arrElems) => {
                this._emitArrayLiteral(arrElems)
                0
            },
            Expr.MapLiteral(entries) => {
                this._emitMapLiteral(entries)
                0
            },
            Expr.SetLiteral(setElems) => {
                this._emitSetLiteral(setElems)
                0
            },
            Expr.TupleLiteral(tupElems) => {
                this._write("(")
                let tIdx = 0
                for e in tupElems {
                    if tIdx > 0 { this._write(", ") }
                    this._emitExpr(e)
                    tIdx += 1
                }
                this._write(")")
                0
            },
            Expr.Lambda(lam) => { this._emitLambda(lam); 0 },
            Expr.StringTemplate(parts) => { this._emitStringTemplate(parts); 0 },
            Expr.Fail(fExpr) => {
                this._write("return Err(format!(\"{}\", ")
                this._emitExpr(fExpr)
                this._write("))")
                0
            },
            Expr.SwitchExpr(disc, arms) => {
                this._emitSwitchExpr(disc, arms)
                0
            },
            Expr.MethodRef(refObj, refMethod) => {
                // Point-free method reference
                let sanitizedMethod = this._sanitizeName(refMethod)
                this._write($"{refObj}::{sanitizedMethod}")
                0
            },
            Expr.Unwrap(uwExpr) => {
                this._emitExpr(uwExpr)
                this._write(".unwrap()")
                0
            },
            Expr.OptionalChain(ocObj, ocProp) => {
                this._emitExpr(ocObj)
                let snOc = this._sanitizeName(ocProp)
                this._write($".as_ref().map(|v| v.{snOc})")
                0
            },
            Expr.RustBlock(code) => {
                this._write(code)
                0
            }
        }
    }

    // -- Escape helpers for Rust output --

    _escapeRustStr(s: string): string {
        let result = s
        result = result.replace("\\", "\\\\")
        result = result.replace("\"", "\\\"")
        result = result.replace("\n", "\\n")
        result = result.replace("\t", "\\t")
        result = result.replace("\r", "\\r")
        result = result.replace("\0", "\\0")
        return result
    }

    _escapeRustChar(s: string): string {
        let result = s
        result = result.replace("\\", "\\\\")
        result = result.replace("'", "\\'")
        result = result.replace("\n", "\\n")
        result = result.replace("\t", "\\t")
        result = result.replace("\r", "\\r")
        result = result.replace("\0", "\\0")
        return result
    }

    // -- Literals --

    _emitLiteral(lit: Literal) {
        let _ = switch lit {
            Literal.Int(v) => {
                this._write($"{v}")
                0
            },
            Literal.Float(v) => {
                let floatStr = $"{v}"
                if not floatStr.contains(".") {
                    floatStr += ".0"
                }
                this._write(floatStr)
                0
            },
            Literal.Str(v) => {
                let escaped = this._escapeRustStr(v)
                if this._inCompoundAdd || this._suppressToString {
                    this._write("\"" + escaped + "\"")
                } else {
                    this._write("\"" + escaped + "\".to_string()")
                }
                0
            },
            Literal.Char(v) => {
                let escaped = this._escapeRustChar(v)
                this._write("'" + escaped + "'")
                0
            },
            Literal.Bool(v) => {
                if v {
                    this._write("true")
                } else {
                    this._write("false")
                }
                0
            },
            Literal.Null => {
                this._write("None")
                0
            }
        }
    }

    // -- Identifier --

    _emitIdentifier(name: string) {
        if name == "this" {
            this._write("self")
        } else {
            let sn = this._sanitizeName(name)
            this._write(sn)
        }
    }

    // -- Binary operations --

    _emitBinary(op: BinOp, left: Expr, right: Expr) {
        let opStr = this._binOpToRust(op)
        // `||` is always logical OR now — `or <value>` is handled at parser level
        if opStr == "||" {
            this._emitExpr(left)
            this._write(" || ")
            this._emitExpr(right)
            return
        }
        // Delegate to helper that classifies + emits right in ONE switch
        this._emitBinaryWithRight(opStr, left, right)
    }

    _emitBinaryWithRight(opStr: string, left: Expr, right: Expr) {
        // Single switch on right that both classifies and handles output
        let _ = switch right {
            Expr.Literal(rLit) => {
                // Check if right is null
                let rIsNull = false
                let rIsString = false
                let _ = switch rLit {
                    Literal.Null => { rIsNull = true; 0 },
                    Literal.Str(_) => { rIsString = true; 0 },
                    _ => { 0 }
                }
                if rIsNull && opStr == "==" {
                    this._emitExpr(left)
                    this._write(".is_none()")
                } else if rIsNull && opStr == "!=" {
                    // Detect variable for if-let narrowing (x != null → let Some(x) = x)
                    // ONLY valid directly in if/while conditions
                    if this._inIfCondition {
                        let _ = switch left {
                            Expr.Identifier(lName) => {
                                let san = this._sanitizeName(lName)
                                this._write($"let Some({san}) = {san}")
                                0
                            },
                            Expr.MemberAccess(maObj, maProp) => {
                                this._emitExpr(Expr.MemberAccess(maObj, maProp))
                                this._write(".is_some()")
                                0
                            },
                            _ => {
                                this._write("true /* != null */")
                                0
                            }
                        }
                    } else {
                        this._emitExpr(left)
                        this._write(".is_some()")
                    }
                } else if rIsString && opStr == "+" {
                    this._write("format!(\"{}{}\", ")
                    this._emitExpr(left)
                    this._write(", ")
                    this._emitLiteral(rLit)
                    this._write(")")
                } else {
                    // Right is a non-null, non-string literal — check left for null
                    this._emitBinaryLeftCheck(opStr, left, rLit)
                }
                0
            },
            Expr.StringTemplate(rParts) => {
                // Right is a string template — string concat
                if opStr == "+" {
                    this._write("format!(\"{}{}\", ")
                    this._emitExpr(left)
                    this._write(", ")
                    this._emitStringTemplate(rParts)
                    this._write(")")
                } else {
                    this._emitExpr(left)
                    this._write($" {opStr} ")
                    this._emitStringTemplate(rParts)
                }
                0
            },
            _ => {
                // Right is a general expression — check left for null/string
                this._emitBinaryLeftDefault(opStr, left, right)
                0
            }
        }
    }

    _emitBinaryLeftCheck(opStr: string, left: Expr, rightLit: Literal) {
        // Right was a normal literal. Check left for null.
        let leftIsNull = false
        let _ = switch left {
            Expr.Literal(lLit) => {
                let _ = switch lLit {
                    Literal.Null => { leftIsNull = true; 0 },
                    _ => { 0 }
                }
                0
            },
            _ => { 0 }
        }
        if leftIsNull && opStr == "==" {
            this._emitLiteral(rightLit)
            this._write(".is_none()")
        } else if leftIsNull && opStr == "!=" {
            this._emitLiteral(rightLit)
            this._write(".is_some()")
        } else {
            this._emitExpr(left)
            this._write($" {opStr} ")
            this._emitLiteral(rightLit)
        }
    }

    _emitBinaryLeftDefault(opStr: string, left: Expr, right: Expr) {
        // Right is a general expr. Check left for null/string.
        let _ = switch left {
            Expr.Literal(lLit) => {
                let lIsNull = false
                let lIsString = false
                let _ = switch lLit {
                    Literal.Null => { lIsNull = true; 0 },
                    Literal.Str(_) => { lIsString = true; 0 },
                    _ => { 0 }
                }
                if lIsNull && opStr == "==" {
                    this._emitExpr(right)
                    this._write(".is_none()")
                } else if lIsNull && opStr == "!=" {
                    this._emitExpr(right)
                    this._write(".is_some()")
                } else if lIsString && opStr == "+" {
                    this._write("format!(\"{}{}\", ")
                    this._emitLiteral(lLit)
                    this._write(", ")
                    this._emitExpr(right)
                    this._write(")")
                } else {
                    this._emitLiteral(lLit)
                    this._write($" {opStr} ")
                    this._emitExpr(right)
                }
                0
            },
            Expr.StringTemplate(lParts) => {
                if opStr == "+" {
                    this._write("format!(\"{}{}\", ")
                    this._emitStringTemplate(lParts)
                    this._write(", ")
                    this._emitExpr(right)
                    this._write(")")
                } else {
                    this._emitStringTemplate(lParts)
                    this._write($" {opStr} ")
                    this._emitExpr(right)
                }
                0
            },
            _ => {
                if opStr == "+" and (this._isStringExpr(left) or this._isStringExpr(right)) {
                    // String concat: left + right → format!("{}{}", left, right)
                    this._write("format!(\"{}{}\", ")
                    this._emitExpr(left)
                    this._write(", ")
                    this._emitExpr(right)
                    this._write(")")
                } else {
                    this._emitExpr(left)
                    this._write($" {opStr} ")
                    this._emitExpr(right)
                }
                0
            }
        }
    }

    _isNullExpr(expr: Expr): bool {
        let result = false
        let _ = switch expr {
            Expr.Literal(lit) => {
                let _ = switch lit {
                    Literal.Null => { result = true; 0 },
                    _ => { 0 }
                }
                0
            },
            _ => { 0 }
        }
        return result
    }

    _isStringExpr(expr: Expr): bool {
        let result = false
        let _ = switch expr {
            Expr.Literal(lit) => {
                let _ = switch lit {
                    Literal.Str(_) => { result = true; 0 },
                    _ => { 0 }
                }
                0
            },
            Expr.StringTemplate(_) => { result = true; 0 },
            Expr.Binary(op, left, right) => {
                let opCheck = this._binOpToRust(op)
                if opCheck == "+" && (this._isStringExpr(left) || this._isStringExpr(right)) {
                    result = true
                }
                0
            },
            Expr.MethodCall(_, method, _) => {
                if method == "toString" { result = true }
                0
            },
            Expr.Identifier(name) => {
                let tag = this._getExprTypeName(expr)
                if tag == "string" { result = true }
                0
            },
            _ => { 0 }
        }
        return result
    }

    _binOpToRust(op: BinOp): string {
        let result = switch op {
            BinOp.Add => "+",
            BinOp.Sub => "-",
            BinOp.Mul => "*",
            BinOp.Div => "/",
            BinOp.Mod => "%",
            BinOp.Lt => "<",
            BinOp.Le => "<=",
            BinOp.Gt => ">",
            BinOp.Ge => ">=",
            BinOp.Eq => "==",
            BinOp.Ne => "!=",
            BinOp.And => "&&",
            BinOp.Or => "||",
            BinOp.Range => "..",
            BinOp.RangeInclusive => "..=",
            _ => "/* op */"
        }
        return result
    }

    // -- Unary operations --

    _emitUnary(op: UnOp, operand: Expr) {
        let _ = switch op {
            UnOp.Neg => {
                this._write("-")
                this._emitExpr(operand)
                0
            },
            UnOp.Not => {
                // RC9 fix: wrap operand in parens if it's a compound expression
                // to avoid `!a == b` instead of `!(a == b)`
                let needsParens = switch operand {
                    Expr.Binary(_, _, _) => true,
                    Expr.Ternary(_, _, _) => true,
                    Expr.Unary(_, _) => true,
                    _ => false
                }
                if needsParens {
                    this._write("!(")
                    this._emitExpr(operand)
                    this._write(")")
                } else {
                    this._write("!")
                    this._emitExpr(operand)
                }
                0
            },
            UnOp.Await => {
                this._emitExpr(operand)
                this._write(".await")
                0
            }
        }
    }

    // =====================================================================
    //  Phase 3.5 — Type-directed stdlib method dispatch
    // =====================================================================

    // -- Type lookup helpers --
    // These let codegen query TypeContext to know what type a variable/expr has.

    _lookupVarTypeRef(name: string): TypeRef {
        // Search scopes from highest to lowest for this variable name
        let scopeCount = this._typeCtx.scopes.length
        let sid = scopeCount - 1
        while sid >= 0 {
            let key = $"{sid}:{name}"
            if this._typeCtx.varTypes.has(key) {
                let idx = this._typeCtx.varTypes.get(key)
                return this._typeCtx.typePool[idx]
            }
            sid -= 1
        }
        return TypeRef.Simple("unknown")
    }

    _typeRefToTag(t: TypeRef): string {
        // Returns a simple tag string for dispatch: "string", "array", "map", "set", etc.
        let tag = "unknown"
        let _ = switch t {
            TypeRef.Simple(name) => {
                if name == "string" { tag = "string" }
                if name == "number" { tag = "number" }
                if name == "int" { tag = "number" }
                if name == "float" { tag = "float" }
                if name == "bool" { tag = "bool" }
                if name == "char" { tag = "char" }
                0
            },
            TypeRef.Array(_) => { tag = "array"; 0 },
            TypeRef.MapType(_, _) => { tag = "map"; 0 },
            TypeRef.SetType(_) => { tag = "set"; 0 },
            TypeRef.OptionalType(_) => { tag = "optional"; 0 },
            TypeRef.Fallible(_) => { tag = "fallible"; 0 },
            _ => { 0 }
        }
        return tag
    }

    _getLiteralTypeName(lit: Literal): string {
        let litTag = "unknown"
        let _ = switch lit {
            Literal.Str(_) => { litTag = "string"; 0 },
            Literal.Int(_) => { litTag = "number"; 0 },
            Literal.Float(_) => { litTag = "float"; 0 },
            Literal.Bool(_) => { litTag = "bool"; 0 },
            Literal.Char(_) => { litTag = "char"; 0 },
            _ => { 0 }
        }
        return litTag
    }

    _getExprTypeName(expr: Expr): string {
        // Lightweight type inference for codegen dispatch
        let tag = "unknown"
        let _ = switch expr {
            Expr.Identifier(name) => {
                let varType = this._lookupVarTypeRef(name)
                tag = this._typeRefToTag(varType)
                // Fallback: check runtime tracking maps
                if tag == "unknown" {
                    let sn = this._sanitizeName(name)
                    if this._mapVars.has(sn) { tag = "map" }
                    else if this._setVars.has(sn) { tag = "set" }
                    else if this._stringVars.has(sn) { tag = "string" }
                }
                0
            },
            Expr.Literal(lit) => {
                tag = this._getLiteralTypeName(lit)
                0
            },
            Expr.StringTemplate(_) => { tag = "string"; 0 },
            Expr.ArrayLiteral(_) => { tag = "array"; 0 },
            Expr.MapLiteral(_) => { tag = "map"; 0 },
            Expr.SetLiteral(_) => { tag = "set"; 0 },
            _ => { 0 }
        }
        return tag
    }

    // -- Function calls (with free function mapping) --

    _emitCall(callee: Expr, args: [Expr]) {
        // Classify the call type without consuming args
        let callType = ""
        let _ = switch callee {
            Expr.Identifier(fnName) => {
                if fnName == "print" { callType = "print" }
                else if fnName == "println" { callType = "println" }
                else if fnName == "toString" { callType = "toString" }
                else if fnName == "toInt" { callType = "toInt" }
                else if fnName == "toFloat" { callType = "toFloat" }
                else if fnName == "parseInt" { callType = "parseInt" }
                else if fnName == "parseFloat" { callType = "parseFloat" }
                0
            },
            _ => { 0 }
        }

        // Dispatch — args consumed in exactly one branch
        if callType == "print" {
            this._emitPrintCall(args)
        } else if callType == "println" {
            this._emitPrintlnCall(args)
        } else if callType == "toString" && args.length > 0 {
            this._write("format!(\"{}\", ")
            this._emitExpr(args[0])
            this._write(")")
        } else if callType == "toInt" && args.length > 0 {
            this._emitExpr(args[0])
            this._write(".to_string().parse::<i32>().unwrap_or(0)")
        } else if callType == "toFloat" && args.length > 0 {
            this._emitExpr(args[0])
            this._write(".to_string().parse::<f64>().unwrap_or(0.0)")
        } else if callType == "parseInt" && args.length > 0 {
            // parseInt(x) → x.parse::<i32>() — returns Result
            this._emitExpr(args[0])
            this._write(".to_string().parse::<i32>()")
        } else if callType == "parseFloat" && args.length > 0 {
            // parseFloat(x) → x.parse::<f64>() — returns Result
            this._emitExpr(args[0])
            this._write(".to_string().parse::<f64>()")
        } else {
            // Check if this is a constructor call (class name starts with uppercase)
            let isConstructor = false
            let className = ""
            let _ = switch callee {
                Expr.Identifier(fnName) => {
                    if fnName.length > 0 {
                        let firstChar = fnName.substring(0, 1)
                        if firstChar >= "A" && firstChar <= "Z" {
                            isConstructor = true
                            className = fnName
                        }
                    }
                    0
                },
                _ => { 0 }
            }
            if isConstructor {
                this._write(className + "::new(")
            } else {
                this._emitExpr(callee)
                this._write("(")
            }
            let aIdx = 0
            for a in args {
                if aIdx > 0 { this._write(", ") }
                this._emitClonedArg(a)
                aIdx += 1
            }
            // Inject default parameter values for missing arguments
            let calleeFnName = ""
            let _ = switch callee {
                Expr.Identifier(fn2) => { calleeFnName = this._sanitizeName(fn2); 0 },
                _ => { 0 }
            }
            if calleeFnName != "" && this._functionParamCount.has(calleeFnName) {
                let totalParams = this._functionParamCount.get(calleeFnName)
                let provided = args.length
                let fillIdx = provided
                while fillIdx < totalParams {
                    let dKey = calleeFnName + ":" + fillIdx.toString()
                    if this._functionDefaultStrs.has(dKey) {
                        if provided > 0 || fillIdx > 0 {
                            this._write(", ")
                        }
                        this._write(this._functionDefaultStrs.get(dKey))
                    }
                    fillIdx += 1
                }
            }
            this._write(")")
        }
    }

    _emitPrintCall(args: [Expr]) {
        if args.length == 0 {
            this._write("println!()")
        } else if args.length == 1 {
            this._write("println!(\"{}\", ")
            this._emitExpr(args[0])
            this._write(")")
        } else {
            // Multiple args: print each separated by space
            let fmtParts = ""
            let pIdx = 0
            while pIdx < args.length {
                if pIdx > 0 { fmtParts += " " }
                fmtParts += "{}"
                pIdx += 1
            }
            this._write("println!(\"" + fmtParts + "\"")
            for a in args {
                this._write(", ")
                this._emitExpr(a)
            }
            this._write(")")
        }
    }

    _emitPrintlnCall(args: [Expr]) {
        if args.length == 0 {
            this._write("println!()")
        } else if args.length == 1 {
            this._write("println!(\"{}\", ")
            this._emitExpr(args[0])
            this._write(")")
        } else {
            let fmtParts = ""
            let pIdx = 0
            while pIdx < args.length {
                if pIdx > 0 { fmtParts += " " }
                fmtParts += "{}"
                pIdx += 1
            }
            this._write("println!(\"" + fmtParts + "\"")
            for a in args {
                this._write(", ")
                this._emitExpr(a)
            }
            this._write(")")
        }
    }

    // -- Self method call with extracted args (avoids E0499 double mutable borrow) --

    _emitSelfMethodExtracted(method: string, args: [Expr]) {
        // For self.method(args) where args might contain self.other() calls,
        // use block expression: {let __t0 = arg0; let __t1 = arg1; self.method(__t0, __t1)}
        this._write("{ ")
        let tempNames: [string] = []
        let idx = 0
        for a in args {
            let tempName = $"__self_arg_{idx}"
            this._write($"let {tempName} = ")
            this._emitExpr(a)
            this._write("; ")
            tempNames.push(tempName)
            idx += 1
        }
        let sanitized = this._sanitizeName(method)
        this._write($"self.{sanitized}(")
        let i2 = 0
        for t in tempNames {
            if i2 > 0 { this._write(", ") }
            this._write(t)
            i2 += 1
        }
        this._write(") }")
    }

    // =====================================================================
    //  liva/test: expect(x).matcher(y) → assert_eq!/assert!/assert_ne! etc.
    // =====================================================================

    _tryEmitExpectChain(obj: Expr, method: string, args: [Expr]): bool {
        // Pattern: expect(actual).toBe(expected) or expect(actual).not.toBe(expected)
        // Generate actual code and expected code into buffers, then emit assertion

        let actualCode = ""
        let isNegated = false
        let isExpect = false
        let isOption = false

        // Direct: expect(x).toBe(y) — obj is Call(Identifier("expect"), [x])
        let _ = switch obj {
            Expr.Call(callee, cArgs, _, _) => {
                let fnName = ""
                let _ = switch callee {
                    Expr.Identifier(n) => { fnName = n; 0 },
                    _ => { 0 }
                }
                if fnName == "expect" and cArgs.length > 0 {
                    isExpect = true
                    for ca in cArgs {
                        // Check if actual expr is Option type BEFORE consuming expr
                        let _ = switch ca {
                            Expr.Identifier(varName) => {
                                let vt = this._lookupVarTypeRef(varName)
                                let _ = switch vt {
                                    TypeRef.OptionalType(_) => { isOption = true; 0 },
                                    _ => { 0 }
                                }
                                0
                            },
                            _ => { 0 }
                        }
                        actualCode = this._exprToString(ca)
                        break
                    }
                }
                0
            },
            // Negated: expect(x).not.toBe(y)
            Expr.MemberAccess(maObj, prop) => {
                if prop == "not" {
                    let _ = switch maObj {
                        Expr.Call(callee2, cArgs2, _, _) => {
                            let fnName2 = ""
                            let _ = switch callee2 {
                                Expr.Identifier(n2) => { fnName2 = n2; 0 },
                                _ => { 0 }
                            }
                            if fnName2 == "expect" and cArgs2.length > 0 {
                                isExpect = true
                                isNegated = true
                                for ca2 in cArgs2 {
                                    let _ = switch ca2 {
                                        Expr.Identifier(varName2) => {
                                            let vt2 = this._lookupVarTypeRef(varName2)
                                            let _ = switch vt2 {
                                                TypeRef.OptionalType(_) => { isOption = true; 0 },
                                                _ => { 0 }
                                            }
                                            0
                                        },
                                        _ => { 0 }
                                    }
                                    actualCode = this._exprToString(ca2)
                                    break
                                }
                            }
                            0
                        },
                        _ => { 0 }
                    }
                }
                0
            },
            _ => { 0 }
        }

        if not isExpect { return false }

        let expectedCode = ""
        if args.length > 0 {
            for a in args { expectedCode = this._exprToString(a); break }
        }

        // Check if expected is null
        let expectedIsNull = false
        if args.length > 0 {
            for a2 in args {
                let _ = switch a2 {
                    Expr.Literal(lit) => {
                        let _ = switch lit {
                            Literal.Null => { expectedIsNull = true; 0 },
                            _ => { 0 }
                        }
                        0
                    },
                    _ => { 0 }
                }
                break
            }
        }

        // Emit the appropriate assertion
        this._emitExpectAssertion(method, actualCode, expectedCode, isNegated, expectedIsNull, isOption)
        return true
    }

    // Helper: emit an expr into a string buffer without writing to output
    _exprToString(expr: Expr): string {
        let savedLine = $"{this._currentLine}"
        let savedLines: [string] = []
        for ln in this._lines { savedLines.push(ln) }
        this._currentLine = ""
        this._lines = []
        this._emitExpr(expr)
        let result = $"{this._currentLine}"
        this._currentLine = savedLine
        this._lines = savedLines
        return result
    }

    // Emit the correct assert_* macro
    _emitExpectAssertion(method: string, actual: string, expected: string, neg: bool, isNull: bool, isOption: bool) {
        if method == "toBe" or method == "toEqual" {
            if isNull {
                if neg { this._write($"assert!({actual}.is_some())") }
                else { this._write($"assert!({actual}.is_none())") }
            } else if neg {
                this._write($"assert_ne!({actual}, {expected})")
            } else {
                this._write($"assert_eq!({actual}, {expected})")
            }
        } else if method == "toBeTruthy" {
            if isOption {
                if neg { this._write($"assert!({actual}.is_none())") }
                else { this._write($"assert!({actual}.is_some())") }
            } else {
                if neg { this._write($"assert!(!({actual}))") }
                else { this._write($"assert!({actual})") }
            }
        } else if method == "toBeFalsy" {
            if isOption {
                if neg { this._write($"assert!({actual}.is_some())") }
                else { this._write($"assert!({actual}.is_none())") }
            } else {
                if neg { this._write($"assert!({actual})") }
                else { this._write($"assert!(!({actual}))") }
            }
        } else if method == "toBeGreaterThan" {
            if neg { this._write($"assert!({actual} <= {expected})") }
            else { this._write($"assert!({actual} > {expected})") }
        } else if method == "toBeLessThan" {
            if neg { this._write($"assert!({actual} >= {expected})") }
            else { this._write($"assert!({actual} < {expected})") }
        } else if method == "toBeGreaterThanOrEqual" {
            if neg { this._write($"assert!({actual} < {expected})") }
            else { this._write($"assert!({actual} >= {expected})") }
        } else if method == "toBeLessThanOrEqual" {
            if neg { this._write($"assert!({actual} > {expected})") }
            else { this._write($"assert!({actual} <= {expected})") }
        } else if method == "toContain" {
            if neg { this._write($"assert!(!{actual}.contains(&{expected}))") }
            else { this._write($"assert!({actual}.contains(&{expected}))") }
        } else if method == "toBeNull" {
            if neg { this._write($"assert!({actual}.is_some())") }
            else { this._write($"assert!({actual}.is_none())") }
        }
    }

    // -- Method calls (type-directed dispatch) --

    _emitMethodCall(obj: Expr, method: string, args: [Expr]) {
        // ── liva/test: expect(x).toBe(y) chain → assert_eq!(x, y) ──
        // Check first WITHOUT consuming args (avoids E0382 move error)
        let isExpectChain = false
        let _ = switch obj {
            Expr.Call(callee, _, _, _) => {
                let fnName = ""
                let _ = switch callee {
                    Expr.Identifier(n) => { fnName = n; 0 },
                    _ => { 0 }
                }
                if fnName == "expect" { isExpectChain = true }
                0
            },
            Expr.MemberAccess(maObj, prop) => {
                if prop == "not" {
                    let _ = switch maObj {
                        Expr.Call(callee2, _, _, _) => {
                            let fnName2 = ""
                            let _ = switch callee2 {
                                Expr.Identifier(n2) => { fnName2 = n2; 0 },
                                _ => { 0 }
                            }
                            if fnName2 == "expect" { isExpectChain = true }
                            0
                        },
                        _ => { 0 }
                    }
                }
                0
            },
            _ => { 0 }
        }
        if isExpectChain {
            this._tryEmitExpectChain(obj, method, args)
            return
        }

        // RC3 fix: Detect mutating method calls on self.field → skip .clone()
        // Methods like push/pop/insert/remove/clear/reverse/sort mutate the receiver.
        // If obj is self.field, we must NOT clone it (otherwise mutation is lost).
        let isMutatingCall = method == "push" or method == "pop" or method == "insert" or method == "remove" or method == "clear" or method == "reverse" or method == "sort" or method == "set"
        if isMutatingCall {
            // Check if obj is MemberAccess(Identifier("this"), _)
            let isSelfField = false
            let _ = switch obj {
                Expr.MemberAccess(maInner, _) => {
                    let _ = switch maInner {
                        Expr.Identifier(iName) => {
                            if iName == "this" { isSelfField = true }
                            0
                        },
                        _ => { 0 }
                    }
                    0
                },
                _ => { 0 }
            }
            if isSelfField {
                this._inAssignTarget = true
            }
        }

        // Handle stdlib type static calls (File, Dir, Process, Sys, Config, CSV, JSON, DB, Server, Http, Response)
        let stdlibName = ""
        let _ = switch obj {
            Expr.Identifier(sn) => { stdlibName = sn; 0 },
            _ => { 0 }
        }

        // ── File module (11 functions) ──
        if stdlibName == "File" {
            if method == "read" {
                this._write("match std::fs::read_to_string(&")
                this._emitExpr(args[0])
                this._write(") { Ok(content) => (Some(content), String::new()), Err(e) => (None, format!(\"File read error: {}\", e)) }")
                return
            }
            if method == "write" {
                this._write("match std::fs::write(&")
                this._emitExpr(args[0])
                this._write(", &")
                this._emitExpr(args[1])
                this._write(") { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"File write error: {}\", e)) }")
                return
            }
            if method == "append" {
                this._write("match std::fs::OpenOptions::new().create(true).append(true).open(&")
                this._emitExpr(args[0])
                this._write(").and_then(|mut file| { use std::io::Write; file.write_all(")
                this._emitExpr(args[1])
                this._write(".as_bytes()) }) { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"File append error: {}\", e)) }")
                return
            }
            if method == "exists" {
                this._write("{ let __arg = (")
                this._emitExpr(args[0])
                this._write(").to_string(); std::path::Path::new(&__arg).exists() }")
                return
            }
            if method == "delete" {
                this._write("(match std::fs::remove_file(&")
                this._emitExpr(args[0])
                this._write(") { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"File delete error: {}\", e)) })")
                return
            }
            if method == "copy" {
                this._write("match std::fs::copy(&")
                this._emitExpr(args[0])
                this._write(", &")
                this._emitExpr(args[1])
                this._write(") { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"File copy error: {}\", e)) }")
                return
            }
            if method == "move" {
                this._write("match std::fs::rename(&")
                this._emitExpr(args[0])
                this._write(", &")
                this._emitExpr(args[1])
                this._write(") { Ok(_) => (Some(true), String::new()), Err(e) => (Some(false), format!(\"File move error: {}\", e)) }")
                return
            }
            if method == "size" {
                this._write("match std::fs::metadata(&")
                this._emitExpr(args[0])
                this._write(") { Ok(m) => (Some(m.len() as i64), String::new()), Err(e) => (None, format!(\"File size error: {}\", e)) }")
                return
            }
            if method == "extension" {
                this._write("{ let __arg = (")
                this._emitExpr(args[0])
                this._write(").to_string(); std::path::Path::new(&__arg).extension().and_then(|e| e.to_str()).unwrap_or(\"\").to_string() }")
                return
            }
            if method == "readLines" {
                this._write("match std::fs::read_to_string(&")
                this._emitExpr(args[0])
                this._write(") { Ok(content) => (Some(content.lines().map(|l| l.to_string()).collect::<Vec<String>>()), String::new()), Err(e) => (None, format!(\"File readLines error: {}\", e)) }")
                return
            }
            if method == "writeLines" {
                this._write("match std::fs::write(&")
                this._emitExpr(args[0])
                this._write(", ")
                this._emitExpr(args[1])
