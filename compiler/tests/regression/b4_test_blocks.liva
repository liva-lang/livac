// B.4: gen-2 must emit `test "name" { }` blocks as Rust `#[test]` functions.
// Bootstrap and gen-2 must agree.
// EXPECT: tests-pass

main() {
    // Trivially run as `livac test b4_test_blocks.test.liva` would generate
    // `#[test] fn test_addition_works()` etc. But for regression purposes,
    // we just verify that compiling a file containing `test "..." { }` does
    // not fail and produces SOMETHING runnable. The actual test harness
    // (cargo test path) is exercised via the gen-2 livac test runner.
    print("tests-pass")
}

test "addition works" {
    let r = 2 + 3
    if r != 5 {
        throw "expected 5"
    }
}

test "subtraction works" {
    let r = 5 - 2
    if r != 3 {
        throw "expected 3"
    }
}
