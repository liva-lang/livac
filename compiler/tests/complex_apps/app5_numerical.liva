// App: Numerical algorithms — primes, factorial chain, integer math
// Heavy compute, no I/O dependencies. Tests integer arithmetic, recursion,
// loops, array building, simple stats.

isPrime(n: number): bool {
    if n < 2 { return false }
    if n < 4 { return true }
    if n % 2 == 0 { return false }
    let i = 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    return true
}

primesBelow(limit: number): [number] {
    let result: [number] = []
    let n = 2
    while n < limit {
        if isPrime(n) {
            result = result.concat([n])
        }
        n = n + 1
    }
    return result
}

gcd(a: number, b: number): number {
    let x = a
    let y = b
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

lcm(a: number, b: number): number {
    return (a * b) / gcd(a, b)
}

fib(n: number): number {
    if n < 2 { return n }
    let a = 0
    let b = 1
    let i = 2
    while i <= n {
        let c = a + b
        a = b
        b = c
        i = i + 1
    }
    return b
}

sumOfDigits(n: number): number {
    let x = n
    if x < 0 { x = -x }
    let s = 0
    while x > 0 {
        s = s + (x % 10)
        x = x / 10
    }
    return s
}

reverseDigits(n: number): number {
    let x = n
    let r = 0
    while x > 0 {
        r = r * 10 + (x % 10)
        x = x / 10
    }
    return r
}

main() {
    print("=== numerical demo ===")

    // 1) Primes below 50
    let primes = primesBelow(50)
    let pStr = primes.map(p => $"{p}").join(",")
    print($"primes < 50: {pStr}")
    print($"count: {primes.len()}")

    // Sum of primes
    let sumP = primes.reduce(0, (acc, p) => acc + p)
    print($"sum: {sumP}")

    // 2) GCD/LCM
    print($"gcd(48, 36) = {gcd(48, 36)}")
    print($"lcm(4, 6) = {lcm(4, 6)}")
    print($"gcd(101, 7) = {gcd(101, 7)}")

    // 3) First 15 fibonacci
    let fibs: [number] = []
    let i = 0
    while i < 15 {
        fibs = fibs.concat([fib(i)])
        i = i + 1
    }
    let fStr = fibs.map(f => $"{f}").join(",")
    print($"fib(0..14): {fStr}")

    // 4) Sum / reverse digits
    print($"sumDigits(12345) = {sumOfDigits(12345)}")
    print($"reverse(12345) = {reverseDigits(12345)}")
    print($"reverse(987) = {reverseDigits(987)}")

    // 5) Goldbach pairs: every even n>=4 = p1+p2 with both prime
    print("--- goldbach (even 4..20) ---")
    let n = 4
    while n <= 20 {
        let found = false
        let foundP = 0
        let foundQ = 0
        for p in primes {
            if !found {
                let q = n - p
                if q >= p {
                    if isPrime(q) {
                        found = true
                        foundP = p
                        foundQ = q
                    }
                }
            }
        }
        if found {
            print($"{n} = {foundP} + {foundQ}")
        } else {
            print($"{n} = (none)")
        }
        n = n + 2
    }

    // 6) Heavy compute: count primes up to 1000 (loop intensive)
    let bigPrimes = primesBelow(1000)
    print($"primes < 1000: {bigPrimes.len()}")
    print($"sum primes < 1000: {bigPrimes.reduce(0, (a, p) => a + p)}")
}
