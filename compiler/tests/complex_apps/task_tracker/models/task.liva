// Task model — value object representing a single task.
// Exposes Task class, Status and Priority enums, plus helpers.

enum Status {
    Open,
    InProgress,
    Done
}

enum Priority {
    Low,
    Medium,
    High
}

statusLabel(s: Status): string => switch s {
    Status.Open => "open",
    Status.InProgress => "in-progress",
    Status.Done => "done"
}

priorityLabel(p: Priority): string => switch p {
    Priority.Low => "low",
    Priority.Medium => "medium",
    Priority.High => "high"
}

// Enums don't auto-derive PartialOrd, so weight is needed for ordering.
priorityWeight(p: Priority): number => switch p {
    Priority.Low => 1,
    Priority.Medium => 2,
    Priority.High => 3
}

// `==` works directly on enums (PartialEq is auto-derived).
sameStatus(a: Status, b: Status): bool => a == b
samePriority(a: Priority, b: Priority): bool => a == b

statusFromString(label: string): Status => switch label {
    "open" => Status.Open,
    "in-progress" => Status.InProgress,
    "done" => Status.Done,
    _ => Status.Open
}

priorityFromString(label: string): Priority => switch label {
    "low" => Priority.Low,
    "medium" => Priority.Medium,
    "high" => Priority.High,
    _ => Priority.Low
}

Task {
    id: number
    title: string
    status: Status
    priority: Priority

    constructor(id: number, title: string, status: Status, priority: Priority) {
        this.id = id
        this.title = title
        this.status = status
        this.priority = priority
    }

    summary(): string => $"#{this.id} [{statusLabel(this.status)}/{priorityLabel(this.priority)}] {this.title}"

    isOpen(): bool => this.status != Status.Done

    withStatus(s: Status): Task => Task(this.id, this.title, s, this.priority)
}
