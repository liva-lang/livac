// Syntax Test: Rust Interop — rust { } blocks
import { describe, test, expect } from "liva/test"

describe("Rust Interop", () => {
    test("rust block simple expression", () => {
        let result = rust { 21 * 2 }
        expect(result).toBe(42)
    })

    test("liva variable in rust block", () => {
        let my_value = 10
        let doubled = rust { my_value * 2 }
        expect(doubled).toBe(20)
    })

    test("rust block string", () => {
        let msg = rust { String::from("hello") }
        expect(msg).toBe("hello")
    })
})
