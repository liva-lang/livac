// Syntax Test: Rust Interop — rust { } blocks, use rust
import { describe, test, expect } from "liva/test"

describe("Rust Interop", () => {
    test("rust block as expression", () => {
        let result = rust {
            let x: i32 = 42;
            x * 2
        }
        expect(result).toBe(84)
    })

    test("rust block with std lib", () => {
        let reversed = rust {
            let s = String::from("hello");
            s.chars().rev().collect::<String>()
        }
        expect(reversed).toBe("olleh")
    })

    test("liva variable in rust block", () => {
        let my_value = 10
        let doubled = rust {
            my_value * 2
        }
        expect(doubled).toBe(20)
    })
})
