// Syntax Test: Error Handling
// Covers: fail, error binding, or value (default), or fail (propagation), try/catch

// Fallible function using fail
divide(a: number, b: number): number {
    if b == 0 {
        fail "Division by zero"
    }
    return a / b
}

// Another fallible function
parsePositive(s: string): number {
    let val, err = parseInt(s)
    if err {
        fail $"Cannot parse: {s}"
    }
    if val < 0 {
        fail "Value must be positive"
    }
    return val
}

// or fail propagation
safeDivide(a: number, b: number): number {
    let result = divide(a, b) or fail "Division failed"
    return result
}

// or value (default fallback)
safeParse(s: string): number {
    let val = parseInt(s) or 0
    return val
}

main() {
    // Error binding — success case
    let val1, err1 = divide(10, 2)
    if err1 {
        print($"Error: {err1}")
    } else {
        print($"10 / 2 = {val1}")
    }

    // Error binding — failure case
    let val2, err2 = divide(10, 0)
    if err2 {
        print($"Expected error: {err2}")
    }

    // or value — default on failure
    let parsed = safeParse("abc")
    print($"safeParse abc: {parsed}")

    let parsedOk = safeParse("42")
    print($"safeParse 42: {parsedOk}")

    // or fail — propagation (called safely)
    let val3, err3 = safeDivide(100, 5)
    if err3 {
        print($"Error: {err3}")
    } else {
        print($"safeDivide: {val3}")
    }

    // try/catch
    try {
        let r, e = divide(1, 0)
        if e {
            print($"Caught in try: {e}")
        }
    } catch (err) {
        print($"Caught: {err}")
    }

    // Ignore error with _
    let val4, _ = divide(10, 3)
    print($"Ignoring error: {val4}")

    // parsePositive
    let val5, err5 = parsePositive("25")
    if err5 {
        print($"Error: {err5}")
    } else {
        print($"Parsed positive: {val5}")
    }

    let val6, err6 = parsePositive("-5")
    if err6 {
        print($"Expected: {err6}")
    }
}
