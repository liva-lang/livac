// Syntax Test: Rust Interop
// Covers: rust { } blocks, use rust crate declaration

// Crate dependency declaration (top-level)
use rust "uuid" version "1.0" features ["v4"]

main() {
    // Simple rust block as expression
    let result = rust {
        let x: i32 = 42;
        x * 2
    }
    print($"Rust result: {result}")

    // Rust block with use statement (hoisted to file top)
    let hash_size = rust {
        use std::collections::HashMap;
        let mut map = HashMap::new();
        map.insert("a", 1);
        map.insert("b", 2);
        map.len()
    }
    print($"HashMap size: {hash_size}")

    // Liva variable accessible in rust block (snake_case transform)
    let my_value = 10
    let doubled = rust {
        my_value * 2
    }
    print($"Doubled from Rust: {doubled}")
}
