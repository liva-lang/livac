// Syntax Test: Enums
// Covers: unit enum, tuple variants, struct variants, recursive enum,
//         switch on enum, enum as return type

// Unit enum
enum Direction {
    North,
    South,
    East,
    West
}

// Enum with tuple variants
enum Shape {
    Circle(radius: number),
    Rectangle(width: number, height: number),
    Point
}

// Recursive enum (auto-boxing)
enum Expr {
    Num(value: number),
    Add(left: Expr, right: Expr),
    Neg(inner: Expr)
}

// Enum as return type
directionLabel(d: Direction): string {
    return switch d {
        Direction.North => "N",
        Direction.South => "S",
        Direction.East => "E",
        Direction.West => "W"
    }
}

// Function taking enum param
area(s: Shape): number {
    return switch s {
        Shape.Circle(r) => 3 * r * r,
        Shape.Rectangle(w, h) => w * h,
        Shape.Point => 0
    }
}

// Recursive enum evaluation
eval(e: Expr): number {
    return switch e {
        Expr.Num(v) => v,
        Expr.Add(l, r) => eval(l) + eval(r),
        Expr.Neg(inner) => 0 - eval(inner)
    }
}

// Function returning an enum
makeShape(kind: string): Shape {
    if kind == "circle" {
        return Shape.Circle(10)
    }
    if kind == "rect" {
        return Shape.Rectangle(5, 3)
    }
    return Shape.Point
}

main() {
    // Unit enum
    let dir = Direction.North
    print($"Direction: {directionLabel(dir)}")

    // Tuple variants
    let circle = Shape.Circle(5)
    let rect = Shape.Rectangle(4, 6)
    let point = Shape.Point
    print($"Circle area: {area(circle)}")
    print($"Rect area: {area(rect)}")
    print($"Point area: {area(point)}")

    // Recursive enum
    let expr = Expr.Add(Expr.Num(1), Expr.Neg(Expr.Num(3)))
    print($"Expr result: {eval(expr)}")

    // Enum as return type
    let s = makeShape("circle")
    print($"Made shape area: {area(s)}")

    // Switch with wildcard
    let label = switch dir {
        Direction.North => "up",
        _ => "other"
    }
    print($"Label: {label}")
}
