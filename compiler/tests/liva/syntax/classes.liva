// Syntax Test: Classes
// Covers: constructor, methods, fields, visibility (_prefix),
//         data classes (auto-constructor)

// Regular class with constructor
Animal {
    name: string
    _sound: string
    legs: number

    constructor(name: string, sound: string, legs: number) {
        this.name = name
        this._sound = sound
        this.legs = legs
    }

    speak(): string {
        return $"{this.name} says {this._sound}"
    }

    describe() => $"{this.name} has {this.legs} legs"
}

// Data class (no constructor → auto-generated positional constructor)
Point { x: number; y: number }

// Data class with more fields
Color { r: number; g: number; b: number }

// Class with methods that use private fields
Counter {
    _count: number

    constructor() {
        this._count = 0
    }

    increment() {
        this._count = this._count + 1
    }

    decrement() {
        this._count = this._count - 1
    }

    getCount(): number => this._count
}

// Class using another class
Zoo {
    _name: string
    _animals: [string]

    constructor(name: string) {
        this._name = name
        this._animals = []
    }

    addAnimal(animalName: string) {
        this._animals.push(animalName)
    }

    count(): number => this._animals.length

    getName(): string => this._name
}

main() {
    // Regular class
    let dog = Animal("Rex", "Woof", 4)
    print(dog.speak())
    print(dog.describe())

    // Data classes
    let p = Point(10, 20)
    print($"Point: {p}")
    let c = Color(255, 128, 0)
    print($"Color: {c}")

    // Data class equality
    let p2 = Point(10, 20)
    print($"Points equal: {p == p2}")

    // Counter with private field
    let counter = Counter()
    counter.increment()
    counter.increment()
    counter.increment()
    counter.decrement()
    print($"Counter: {counter.getCount()}")

    // Zoo class using arrays
    let zoo = Zoo("City Zoo")
    zoo.addAnimal("Lion")
    zoo.addAnimal("Tiger")
    zoo.addAnimal("Bear")
    print($"{zoo.getName()} has {zoo.count()} animals")
}
