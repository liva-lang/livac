// Syntax Test: Compound Assignment
// Covers: +=, -=, *=, /=, %=

main() {
    // += (add and assign)
    let a = 10
    a += 5
    print($"a += 5: {a}")

    // -= (subtract and assign)
    let b = 20
    b -= 7
    print($"b -= 7: {b}")

    // *= (multiply and assign)
    let c = 3
    c *= 4
    print($"c *= 4: {c}")

    // /= (divide and assign)
    let d = 100
    d /= 5
    print($"d /= 5: {d}")

    // %= (modulo and assign)
    let e = 17
    e %= 5
    print($"e %= 5: {e}")

    // Chained compound assignments
    let x = 1
    x += 10
    x *= 2
    x -= 3
    print($"x = 1, +10, *2, -3: {x}")

    // In a loop
    let sum = 0
    for i in 1..=10 {
        sum += i
    }
    print($"Sum 1..=10: {sum}")

    // Float compound assignment
    let f = 1.0
    f += 0.5
    f *= 2.0
    print($"Float: {f}")
}
