// Syntax Test: Types
// Covers: type alias, optional T?, tuples, arrays, maps, sets

// Type aliases
type IntList = [number]
type StringMap = Map<string, string>
type Pair = (number, number)
type Matrix = [[number]]

main() {
    // Primitives
    let n: number = 42
    let f: float = 3.14
    let s: string = "hello"
    let b: bool = true

    // Rust numeric types
    let i: i32 = 100
    let u: u64 = 999
    let fl: f64 = 2.718

    // Optional T?
    let maybe: number? = null
    let present: string? = "yes"
    print($"maybe: {maybe}")
    print($"present: {present}")

    // Arrays
    let nums: [number] = [1, 2, 3]
    let strs: [string] = ["a", "b", "c"]
    print($"nums: {nums.length}, strs: {strs.length}")

    // Tuples
    let point: (number, number) = (10, 20)
    print($"point: {point}")

    // Map
    let ages: Map<string, number> = Map { "Alice": 30, "Bob": 25 }
    print($"ages: {ages.length}")

    // Set
    let ids: Set<number> = Set { 1, 2, 3, 4
    }
    print($"ids: {ids.length}")

    // Type alias usage
    let list: IntList = [10, 20, 30]
    print($"IntList length: {list.length}")

    let config: StringMap = Map { "key": "value" }
    print($"StringMap: {config.length}")

    let p: Pair = (5, 10)
    print($"Pair: {p}")

    // Nested array (matrix)
    let grid: Matrix = [[1, 2], [3, 4]]
    print($"Matrix rows: {grid.length}")

    // Type inference still works
    let inferred = [1, 2, 3]
    let inferredMap = Map { "x": 1 }
    print($"Inferred array: {inferred.length}")
    print($"Inferred map: {inferredMap.length}")
}
