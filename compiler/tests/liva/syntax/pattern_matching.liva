// Syntax Test: Pattern Matching
// Covers: switch expression with value binding, or-patterns, range patterns,
//         wildcard, enum destructuring, guards

enum Shape {
    Circle(radius: number),
    Rectangle(width: number, height: number),
    Point
}

enum Priority {
    Critical,
    High,
    Normal,
    Low
}

// Switch with enum destructuring
describeShape(s: Shape): string {
    return switch s {
        Shape.Circle(r) => $"circle r={r}",
        Shape.Rectangle(w, h) => $"rect {w}x{h}",
        Shape.Point => "point"
    }
}

// Switch with or-patterns
priorityLevel(p: Priority): string {
    return switch p {
        Priority.Critical => "urgent",
        Priority.High => "important",
        Priority.Normal => "standard",
        Priority.Low => "optional"
    }
}

main() {
    // Range patterns
    let score = 87
    let grade = switch score {
        90..=100 => "A",
        80..=89 => "B",
        70..=79 => "C",
        60..=69 => "D",
        _ => "F"
    }
    print($"Score {score} => Grade {grade}")

    // Value binding
    let num = 42
    let label = switch num {
        0 => "zero",
        n => $"other: {n}"
    }
    print($"Label: {label}")

    // Guards
    let x = -5
    let kind = switch x {
        0 => "zero",
        n if n < 0 => "negative",
        n if n > 100 => "big positive",
        _ => "small positive"
    }
    print($"Kind: {kind}")

    // Or-patterns
    let day = "Saturday"
    let dayType = switch day {
        "Saturday" | "Sunday" => "Weekend",
        _ => "Weekday"
    }
    print($"Day type: {dayType}")

    // Or-patterns with numbers
    let code = 200
    let tier = switch code {
        200 | 201 | 204 => "Success",
        400 | 404 => "Client error",
        500 => "Server error",
        _ => "Other"
    }
    print($"HTTP tier: {tier}")

    // Enum destructuring
    let shapes = [Shape.Circle(5), Shape.Rectangle(3, 4), Shape.Point]
    for shape in shapes {
        print($"Shape: {describeShape(shape)}")
    }

    // Wildcard
    let val = 999
    let msg = switch val {
        1 => "one",
        2 => "two",
        _ => "many"
    }
    print($"Message: {msg}")

    // Guards with enum
    let p = Priority.Critical
    print($"Priority: {priorityLevel(p)}")
}
