// Syntax Test: Variables
// Covers: let, const, type inference, explicit types, optionals,
//         top-level const, Map, Set, tuple, reassignment

const MAX_SIZE: number = 100
const APP_NAME = "LivaApp"

main() {
    // Type inference
    let x = 42
    let name = "Alice"
    let active = true
    let pi = 3.14

    // Explicit types
    let count: number = 10
    let label: string = "test"
    let flag: bool = false
    let ratio: float = 2.718

    // Reassignment
    let score = 0
    score = 95

    // Optionals
    let maybe: number? = null
    let present: string? = "hello"

    // Arrays
    let nums: [number] = [1, 2, 3]
    let names = ["Alice", "Bob", "Carol"]

    // Map
    let ages = Map { "Alice": 30, "Bob": 25 }
    let config: Map<string, string> = Map { "host": "localhost", "port": "8080" }

    // Set
    let colors = Set { "red", "green", "blue" }
    let ids: Set<number> = Set { 1, 2, 3 }

    // Tuple
    let pair: (number, number) = (10, 20)

    // Top-level const usage
    print($"Max size: {MAX_SIZE}")
    print($"App: {APP_NAME}")

    // Print variables to confirm
    print($"x={x}, name={name}, active={active}")
    print($"count={count}, label={label}, flag={flag}")
    print($"score={score}")
    print($"maybe={maybe}, present={present}")
    print($"nums length: {nums.length}")
    print($"ages: {ages.length} entries")
    print($"colors: {colors.length} items")
    print($"pair: {pair}")
    print($"ratio: {ratio}")
}
