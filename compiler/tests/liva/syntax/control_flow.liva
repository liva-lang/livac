// Syntax Test: Control Flow
// Covers: if/else, if one-liner, switch expression (ranges, guards),
//         switch statement (case/default), for range, for inclusive,
//         for array, for i/v in array, while, break, continue

main() {
    // --- if/else ---
    let age = 25
    if age >= 18 {
        print("Adult")
    } else {
        print("Minor")
    }

    // --- if/else if/else ---
    let score = 85
    if score >= 90 {
        print("A")
    } else if score >= 80 {
        print("B")
    } else if score >= 70 {
        print("C")
    } else {
        print("F")
    }

    // --- if one-liner ---
    if age >= 18 => print("Old enough")

    // --- Switch expression with ranges ---
    let grade = switch score {
        90..=100 => "A",
        80..=89 => "B",
        70..=79 => "C",
        60..=69 => "D",
        _ => "F"
    }
    print($"Grade: {grade}")

    // --- Switch expression with guards ---
    let n = 42
    let desc = switch n {
        0 => "zero",
        x if x < 0 => "negative",
        x if x > 100 => "big",
        _ => "normal"
    }
    print($"Desc: {desc}")

    // --- Switch statement (case/default) ---
    let status = "active"
    switch status {
        case "active": print("Status is active")
        case "inactive": print("Status is inactive")
        default: print("Unknown status")
    }

    // --- for range (exclusive) ---
    print("Range 0..5:")
    for i in 0..5 {
        print($"  {i}")
    }

    // --- for inclusive range ---
    print("Range 1..=3:")
    for i in 1..=3 {
        print($"  {i}")
    }

    // --- for array ---
    let fruits = ["apple", "banana", "cherry"]
    for fruit in fruits {
        print($"Fruit: {fruit}")
    }

    // --- for i, v in array (enumerate) ---
    for i, fruit in fruits {
        print($"  [{i}] {fruit}")
    }

    // --- while loop ---
    let count = 0
    while count < 3 {
        print($"count: {count}")
        count = count + 1
    }

    // --- break ---
    let total = 0
    for i in 0..100 {
        if i >= 5 {
            break
        }
        total = total + i
    }
    print($"Total (0..5): {total}")

    // --- continue ---
    print("Odd numbers 0..10:")
    for i in 0..10 {
        if i % 2 == 0 {
            continue
        }
        print($"  {i}")
    }
}
