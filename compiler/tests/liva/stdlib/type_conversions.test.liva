// Stdlib Test: Type conversions — toString, parseInt, parseFloat
// NOTE: Uses `or` pattern instead of error binding due to B101/B102
import { describe, test, expect } from "liva/test"

describe("toString", () => {
    test("number to string", () => {
        expect(toString(42)).toBe("42")
        expect(toString(0)).toBe("0")
        expect(toString(-7)).toBe("-7")
    })

    test("bool to string", () => {
        expect(toString(true)).toBe("true")
        expect(toString(false)).toBe("false")
    })
})

describe("parseInt", () => {
    test("valid integer", () => {
        let val = parseInt("42") or -1
        expect(val).toBe(42)
    })

    test("negative integer", () => {
        let val = parseInt("-10") or 0
        expect(val).toBe(-10)
    })

    test("zero", () => {
        let val = parseInt("0") or -1
        expect(val).toBe(0)
    })

    test("invalid returns default", () => {
        let val = parseInt("abc") or -999
        expect(val).toBe(-999)
    })

    test("empty string returns default", () => {
        let val = parseInt("") or -999
        expect(val).toBe(-999)
    })

    test("or default on success", () => {
        let val = parseInt("99") or 0
        expect(val).toBe(99)
    })
})

describe("parseFloat", () => {
    test("valid float", () => {
        let val = parseFloat("3.14") or 0.0
        expect(val).toBe(3.14)
    })

    test("integer as float", () => {
        let val = parseFloat("42") or 0.0
        expect(val).toBe(42.0)
    })

    test("negative float", () => {
        let val = parseFloat("-2.5") or 0.0
        expect(val).toBe(-2.5)
    })

    test("invalid returns default", () => {
        let val = parseFloat("xyz") or -1.0
        expect(val).toBe(-1.0)
    })
})
