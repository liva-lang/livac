// Stdlib Test: Set methods
// B110 FIXED: union/intersection/difference results now tracked as Set — .has()/.size() work
import { describe, test, expect } from "liva/test"

describe("Set Creation and Access", () => {
    test("literal creation", () => {
        let s = Set { "red", "green", "blue" }
        expect(s.has("red")).toBeTruthy()
        expect(s.has("green")).toBeTruthy()
        expect(s.has("blue")).toBeTruthy()
    })

    test("no duplicates", () => {
        let s = Set { 1, 1, 2, 2, 3 }
        expect(s.has(1)).toBeTruthy()
        expect(s.has(2)).toBeTruthy()
        expect(s.has(3)).toBeTruthy()
    })
})

describe("Set Mutation", () => {
    test("add", () => {
        let s = Set { "a", "b" }
        s.add("c")
        expect(s.has("c")).toBeTruthy()
    })

    test("delete", () => {
        let s = Set { "a", "b", "c" }
        s.delete("b")
        expect(s.has("b")).toBeFalsy()
        expect(s.has("a")).toBeTruthy()
    })

    test("clear", () => {
        let s = Set { 1, 2, 3 }
        s.clear()
        expect(s.has(1)).toBeFalsy()
    })
})

describe("Set Iteration", () => {
    test("values returns array", () => {
        let s = Set { "x", "y", "z" }
        let v = s.values()
        expect(v.length()).toBe(3)
    })

    test("forEach iterates all elements", () => {
        let s = Set { 10, 20, 30 }
        let count = 0
        s.forEach((item) => {
            count += 1
        })
        expect(count).toBe(3)
    })
})

// B110: Set operations — previously .has() failed on union/intersection/difference results
describe("Set Operations", () => {
    test("union combines sets", () => {
        let a = Set { 1, 2, 3 }
        let b = Set { 3, 4, 5 }
        let combined = a.union(b)
        expect(combined.has(1)).toBeTruthy()
        expect(combined.has(4)).toBeTruthy()
        expect(combined.has(3)).toBeTruthy()
    })

    test("intersection finds common elements", () => {
        let a = Set { 1, 2, 3, 4 }
        let b = Set { 3, 4, 5, 6 }
        let common = a.intersection(b)
        expect(common.has(3)).toBeTruthy()
        expect(common.has(4)).toBeTruthy()
        expect(common.has(1)).toBeFalsy()
    })

    test("difference finds unique elements", () => {
        let a = Set { 1, 2, 3, 4 }
        let b = Set { 3, 4, 5, 6 }
        let diff = a.difference(b)
        expect(diff.has(1)).toBeTruthy()
        expect(diff.has(2)).toBeTruthy()
        expect(diff.has(3)).toBeFalsy()
    })
})
