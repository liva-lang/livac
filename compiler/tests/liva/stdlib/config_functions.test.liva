// Stdlib Test: Config — load, get, getInt, getBool, getAll
// Uses rust {} block to create a temp .env file for testing
import { describe, test, expect } from "liva/test"

// Helper: create a temp .env file and return its path
createTempEnv(): string {
    let path = rust {
        let dir = std::env::temp_dir().join("liva_config_test");
        std::fs::create_dir_all(&dir).unwrap();
        let path = dir.join(".env");
        std::fs::write(&path, "APP_NAME=TestApp\nPORT=8080\nDEBUG=true\nVERBOSE=false\nMAX_RETRIES=3\n").unwrap();
        path.to_string_lossy().to_string()
    }
    return path
}

describe("Config", () => {
    test("load and get string value", () => {
        let path = createTempEnv()
        let config, err = Config.load(path)
        let name, err2 = Config.get(config, "APP_NAME")
        expect(name).toBe("TestApp")
    })

    test("getInt returns number", () => {
        let path = createTempEnv()
        let config, err = Config.load(path)
        let port, err2 = Config.getInt(config, "PORT")
        expect(port).toBe(8080)
    })

    test("getBool returns boolean", () => {
        let path = createTempEnv()
        let config, err = Config.load(path)
        let debug, err2 = Config.getBool(config, "DEBUG")
        expect(debug).toBe(true)
    })

    test("getBool false value", () => {
        let path = createTempEnv()
        let config, err = Config.load(path)
        let verbose, err2 = Config.getBool(config, "VERBOSE")
        expect(verbose).toBe(false)
    })
})
