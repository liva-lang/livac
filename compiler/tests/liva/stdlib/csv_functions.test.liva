// Stdlib Test: CSV — parse, stringify (pure functions, no I/O)
import { describe, test, expect } from "liva/test"

describe("CSV", () => {
    test("parse simple CSV", () => {
        let rows = CSV.parse("a,b,c\n1,2,3\n4,5,6")
        expect(rows.length).toBe(3)
    })

    test("parse single row", () => {
        let rows = CSV.parse("hello,world")
        expect(rows.length).toBe(1)
    })

    test("stringify rows", () => {
        let rows = [["name", "age"], ["Alice", "30"], ["Bob", "25"]]
        let csv = CSV.stringify(rows)
        expect(csv.contains("name,age")).toBe(true)
        expect(csv.contains("Alice,30")).toBe(true)
        expect(csv.contains("Bob,25")).toBe(true)
    })

    test("stringify empty array", () => {
        let rows: [[string]] = []
        let csv = CSV.stringify(rows)
        expect(csv).toBe("")
    })

    test("parse then stringify roundtrip", () => {
        let original = "a,b\n1,2\n3,4"
        let rows = CSV.parse(original)
        let result = CSV.stringify(rows)
        expect(result.contains("a,b")).toBe(true)
        expect(result.contains("1,2")).toBe(true)
    })
})
