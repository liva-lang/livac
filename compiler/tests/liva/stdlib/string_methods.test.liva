// Stdlib Test: String methods — comprehensive coverage
import { describe, test, expect } from "liva/test"

describe("String Search", () => {
    test("contains", () => {
        expect("Hello, World!".contains("World")).toBeTruthy()
        expect("Hello, World!".contains("world")).toBeFalsy()
    })

    test("startsWith", () => {
        expect("document.pdf".startsWith("document")).toBeTruthy()
        expect("Hello".startsWith("hello")).toBeFalsy()
    })

    test("endsWith", () => {
        expect("document.pdf".endsWith(".pdf")).toBeTruthy()
        expect("document.pdf".endsWith(".doc")).toBeFalsy()
    })

    test("indexOf", () => {
        expect("hello world".indexOf("world")).toBe(6)
        expect("hello world".indexOf("cat")).toBe(-1)
    })

    test("lastIndexOf", () => {
        expect("hello world hello".lastIndexOf("hello")).toBe(12)
        expect("hello".lastIndexOf("xyz")).toBe(-1)
    })

    test("countMatches", () => {
        expect("banana".countMatches("an")).toBe(2)
        expect("a,b,c,d".countMatches(",")).toBe(3)
        expect("hello".countMatches("xyz")).toBe(0)
    })
})

describe("String Transformation", () => {
    test("replace", () => {
        expect("hello world".replace("world", "Liva")).toBe("hello Liva")
    })

    test("replaceAll", () => {
        expect("hello world hello".replaceAll("hello", "hi")).toBe("hi world hi")
    })

    test("split", () => {
        expect("a,b,c".split(",")).toBe(["a", "b", "c"])
        expect("hello".split(",")).toBe(["hello"])
    })

    test("trim", () => {
        expect("  hello  ".trim()).toBe("hello")
    })

    test("toUpperCase", () => {
        expect("hello".toUpperCase()).toBe("HELLO")
    })

    test("toLowerCase", () => {
        expect("HELLO".toLowerCase()).toBe("hello")
    })

    test("capitalize", () => {
        expect("hello world".capitalize()).toBe("Hello world")
        expect("".capitalize()).toBe("")
    })

    test("reverse", () => {
        expect("hello".reverse()).toBe("olleh")
        expect("racecar".reverse()).toBe("racecar")
    })

    test("truncate", () => {
        expect("Hello, World!".truncate(5)).toBe("Hello")
        expect("Hi".truncate(10)).toBe("Hi")
    })

    test("repeat", () => {
        expect("ha".repeat(3)).toBe("hahaha")
        expect("x".repeat(0)).toBe("")
    })

    test("removePrefix", () => {
        expect("prefix_value".removePrefix("prefix_")).toBe("value")
        expect("hello".removePrefix("xyz")).toBe("hello")
    })

    test("removeSuffix", () => {
        expect("document.txt".removeSuffix(".txt")).toBe("document")
        expect("hello".removeSuffix(".pdf")).toBe("hello")
    })
})

describe("String Padding", () => {
    test("padStart", () => {
        expect("5".padStart(3, "0")).toBe("005")
        expect("hello".padStart(3, "x")).toBe("hello")
    })

    test("padEnd", () => {
        expect("hi".padEnd(5, ".")).toBe("hi...")
    })
})

describe("String Access", () => {
    test("charAt", () => {
        expect("Hello".charAt(0)).toBe("H")
        expect("Hello".charAt(4)).toBe("o")
    })

    test("substring", () => {
        expect("Hello World".substring(0, 5)).toBe("Hello")
        expect("Hello World".substring(6, 11)).toBe("World")
    })

    test("slice", () => {
        expect("Hello, World!".slice(0, 5)).toBe("Hello")
        expect("Hello, World!".slice(7)).toBe("World!")
    })

    test("chars", () => {
        expect("hello".chars()).toBe(["h", "e", "l", "l", "o"])
    })
})

describe("String Query", () => {
    test("isBlank", () => {
        expect("   ".isBlank()).toBeTruthy()
        expect("".isBlank()).toBeTruthy()
        expect("hello".isBlank()).toBeFalsy()
    })

    test("isEmpty", () => {
        expect("".isEmpty()).toBeTruthy()
        expect("   ".isEmpty()).toBeFalsy()
        expect("hello".isEmpty()).toBeFalsy()
    })
})
