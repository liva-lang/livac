// Stdlib Test: Process — exec (self-hosted subset)
// NOTE: Process.pid excluded (no codegen in self-hosted)
// NOTE: using printf instead of echo to avoid trailing newline
import { describe, test, expect } from "liva/test"

describe("Process Exec", () => {
    test("exec printf command", () => {
        let output, err = Process.exec("printf hello")
        expect(output).toBe("hello")
    })

    test("exec printf with args", () => {
        let output, err = Process.exec("printf '%s %s' hello world")
        expect(output).toBe("hello world")
    })

    test("exec with or default", () => {
        let output = Process.exec("printf works") or "FAILED"
        expect(output).toBe("works")
    })
})
