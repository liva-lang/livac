// Stdlib Test: Random — nextInt, nextFloat, choice, shuffle, uuid
import { describe, test, expect } from "liva/test"

describe("Random", () => {
    test("nextInt within range", () => {
        let n = Random.nextInt(1, 10)
        expect(n >= 1).toBe(true)
        expect(n <= 10).toBe(true)
    })

    test("nextInt same min max", () => {
        let n = Random.nextInt(5, 5)
        expect(n).toBe(5)
    })

    test("nextFloat returns value", () => {
        let f = Random.nextFloat()
        expect(f >= 0.0).toBe(true)
        expect(f < 1.0).toBe(true)
    })

    test("nextFloat with range", () => {
        let f = Random.nextFloat(10.0, 20.0)
        expect(f >= 10.0).toBe(true)
        expect(f <= 20.0).toBe(true)
    })

    test("choice picks from array", () => {
        let items = ["a", "b", "c"]
        let picked = Random.choice(items)
        // picked must be one of the items
        let valid = picked == "a" || picked == "b" || picked == "c"
        expect(valid).toBe(true)
    })

    test("shuffle preserves length", () => {
        let arr = [1, 2, 3, 4, 5]
        let shuffled = Random.shuffle(arr)
        expect(shuffled.length).toBe(5)
    })

    test("uuid format", () => {
        let id = Random.uuid()
        // UUID v4 is 36 chars: 8-4-4-4-12
        expect(id.length).toBe(36)
        expect(id.contains("-")).toBe(true)
    })
})
