// Error Detection Tests — verify compiler reports correct error codes
// Uses Process.exec to invoke livac check/lint and capture output
import { describe, test, expect } from "liva/test"

// Helper: Run livac check on an error file and return combined output
checkError(filename: string): string {
    let base = rust { env!("CARGO_MANIFEST_DIR").replace("/target/liva_test", "").replace("/target/liva_build", "") }
    let livac = $"{base}/target/release/livac"
    let file = $"{base}/compiler/tests/liva/errors/{filename}"
    let cmd = $"{livac} check {file} 2>&1"
    let result = Process.exec(cmd) or ""
    return result
}

// Helper: Run livac lint on a file and return combined output
lintFile(filename: string): string {
    let base = rust { env!("CARGO_MANIFEST_DIR").replace("/target/liva_test", "").replace("/target/liva_build", "") }
    let livac = $"{base}/target/release/livac"
    let file = $"{base}/compiler/tests/liva/errors/{filename}"
    let cmd = $"{livac} lint {file} 2>&1"
    let result = Process.exec(cmd) or ""
    return result
}

describe("Error Detection", () => {
    test("E0001: duplicate variable in scope", () => {
        let output = checkError("e0001_duplicate_variable.liva")
        expect(output).toContain("E0001")
    })

    test("E0310: duplicate function parameter", () => {
        let output = checkError("e0310_duplicate_param.liva")
        expect(output).toContain("E0310")
    })

    test("E0701: unhandled fallible call", () => {
        let output = checkError("e0701_unhandled_fallible.liva")
        expect(output).toContain("E0701")
    })

    test("E0901: non-exhaustive bool switch", () => {
        let output = checkError("e0901_bool_exhaustiveness.liva")
        expect(output).toContain("E0901")
    })

    test("E0902: non-exhaustive int switch", () => {
        let output = checkError("e0902_int_exhaustiveness.liva")
        expect(output).toContain("E0902")
    })

    test("E0903: non-exhaustive string switch", () => {
        let output = checkError("e0903_string_exhaustiveness.liva")
        expect(output).toContain("E0903")
    })

    test("E0904: non-exhaustive enum switch", () => {
        let output = checkError("e0904_enum_exhaustiveness.liva")
        expect(output).toContain("E0904")
    })

    test("E1000: lexer error", () => {
        let output = checkError("e1000_lexer_error.liva")
        expect(output).toContain("E1000")
    })

    test("E2000: parse error", () => {
        let output = checkError("e2000_parse_error.liva")
        expect(output).toContain("E2000")
    })

    test("E4004: module not found", () => {
        let output = checkError("e4004_module_not_found.liva")
        expect(output).toContain("E4004")
    })

    test("W001: unused variable warning", () => {
        let output = lintFile("w001_unused_var.liva")
        expect(output).toContain("W001")
    })

    test("W002: unused import warning", () => {
        let output = lintFile("w002_unused_import.liva")
        expect(output).toContain("W002")
    })

    test("W003: unreachable code warning", () => {
        let output = lintFile("w003_unreachable_code.liva")
        expect(output).toContain("W003")
    })

    test("W004: always true comparison", () => {
        let output = lintFile("w004_always_true.liva")
        expect(output).toContain("W004")
    })
})
