// Stdlib-IO Test: File — read, write, append, exists, delete, copy, move, size, extension, readLines
// Uses rust {} for setup/cleanup of test files within the project directory
import { describe, test, expect } from "liva/test"

// Helper: get a test directory path inside the project
getTestDir(): string {
    let dir = rust {
        let root = std::path::Path::new(env!("CARGO_MANIFEST_DIR"))
            .ancestors().nth(6).expect("cannot find repo root");
        let dir = root.join("compiler/tests/liva/stdlib-io/.test_data");
        std::fs::create_dir_all(&dir).unwrap();
        dir.to_string_lossy().to_string()
    }
    return dir
}

// Helper: build a path inside test dir
testPath(dir: string, name: string): string {
    return dir + "/" + name
}

describe("File", () => {
    test("write and read", () => {
        let dir = getTestDir()
        let path = testPath(dir, "test_rw.txt")
        let ok, writeErr = File.write(path, "hello liva")
        let content, readErr = File.read(path)
        expect(content).toBe("hello liva")
        let ok2, delErr = File.delete(path)
    })

    test("exists returns true for existing file", () => {
        let dir = getTestDir()
        let path = testPath(dir, "test_exists.txt")
        let ok, writeErr = File.write(path, "data")
        let found = File.exists(path)
        expect(found).toBe(true)
        let ok2, delErr = File.delete(path)
    })

    test("exists returns false for missing file", () => {
        let dir = getTestDir()
        let path = testPath(dir, "nonexistent_file.txt")
        let found = File.exists(path)
        expect(found).toBe(false)
    })

    test("append adds content", () => {
        let dir = getTestDir()
        let path = testPath(dir, "test_append.txt")
        let ok, writeErr = File.write(path, "line1")
        let ok2, appendErr = File.append(path, "\nline2")
        let content, readErr = File.read(path)
        expect(content).toBe("line1\nline2")
        let ok3, delErr = File.delete(path)
    })

    test("delete removes file", () => {
        let dir = getTestDir()
        let path = testPath(dir, "test_delete.txt")
        let ok, writeErr = File.write(path, "temp")
        let ok2, delErr = File.delete(path)
        let found = File.exists(path)
        expect(found).toBe(false)
    })

    test("copy duplicates file", () => {
        let dir = getTestDir()
        let src = testPath(dir, "test_copy_src.txt")
        let dest = testPath(dir, "test_copy_dest.txt")
        let ok, writeErr = File.write(src, "copy me")
        let ok2, copyErr = File.copy(src, dest)
        let content, readErr = File.read(dest)
        expect(content).toBe("copy me")
        let ok3, del1 = File.delete(src)
        let ok4, del2 = File.delete(dest)
    })

    test("move renames file", () => {
        let dir = getTestDir()
        let src = testPath(dir, "test_move_src.txt")
        let dest = testPath(dir, "test_move_dest.txt")
        let ok, writeErr = File.write(src, "move me")
        let ok2, moveErr = File.move(src, dest)
        let srcExists = File.exists(src)
        let destExists = File.exists(dest)
        expect(srcExists).toBe(false)
        expect(destExists).toBe(true)
        let ok3, delErr = File.delete(dest)
    })

    test("size returns file length", () => {
        let dir = getTestDir()
        let path = testPath(dir, "test_size.txt")
        let ok, writeErr = File.write(path, "12345")
        let sz, sizeErr = File.size(path)
        expect(sz).toBe(5)
        let ok2, delErr = File.delete(path)
    })

    test("extension extracts file extension", () => {
        let ext = File.extension("photo.jpg")
        expect(ext).toBe("jpg")
    })

    test("readLines splits by newline", () => {
        let dir = getTestDir()
        let path = testPath(dir, "test_lines.txt")
        let ok, writeErr = File.write(path, "a\nb\nc")
        let lines, readErr = File.readLines(path)
        expect(lines.length).toBe(3)
        let ok2, delErr = File.delete(path)
    })
})
