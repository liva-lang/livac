// Stdlib-IO Test: DB (SQLite) — open, exec, query, close
// Uses :memory: SQLite database (no file I/O needed)
import { describe, test, expect } from "liva/test"

describe("DB", () => {
    test("open in-memory database", () => {
        let db, err = DB.open(":memory:")
        // If we get here without crash, open succeeded
        expect(true).toBe(true)
    })

    test("exec creates table", () => {
        let db, err = DB.open(":memory:")
        let ok, execErr = DB.exec(db, "CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, age INTEGER)")
        expect(execErr).toBe("")
    })

    test("exec insert and query", () => {
        let db, err = DB.open(":memory:")
        let ok1, e1 = DB.exec(db, "CREATE TABLE items (id INTEGER PRIMARY KEY, name TEXT)")
        let ok2, e2 = DB.exec(db, "INSERT INTO items (name) VALUES (?)", ["apple"])
        let ok3, e3 = DB.exec(db, "INSERT INTO items (name) VALUES (?)", ["banana"])
        let rows, queryErr = DB.query(db, "SELECT name FROM items ORDER BY name")
        expect(rows.length).toBe(2)
    })

    test("query returns column values as strings", () => {
        let db, err = DB.open(":memory:")
        let ok1, e1 = DB.exec(db, "CREATE TABLE kv (key TEXT, value TEXT)")
        let ok2, e2 = DB.exec(db, "INSERT INTO kv (key, value) VALUES (?, ?)", ["color", "blue"])
        let rows, queryErr = DB.query(db, "SELECT key, value FROM kv")
        expect(rows.length).toBe(1)
    })

    test("query empty table returns empty array", () => {
        let db, err = DB.open(":memory:")
        let ok1, e1 = DB.exec(db, "CREATE TABLE empty_table (id INTEGER)")
        let rows, queryErr = DB.query(db, "SELECT * FROM empty_table")
        expect(rows.length).toBe(0)
    })
})
