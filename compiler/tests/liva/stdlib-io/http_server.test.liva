// Stdlib-IO Test: HTTP Server — compile-only verification
// Server tests can't actually start/listen (would block forever in cargo test)
// We verify ALL server API patterns compile correctly with livac check
import { describe, test, expect } from "liva/test"

// Resolve project root: env var or pwd-based fallback
_resolveBase(): string {
    let envBase = Sys.env("LIVAC_PROJECT_ROOT")
    if envBase.length > 0 { return envBase }
    let pwd = Sys.env("PWD")
    return pwd.replace("/target/liva_test", "").replace("/target/liva_build", "").trim()
}

// Helper: Run livac check on the fixture file
checkFixture(): string {
    let base = _resolveBase()
    let livac = $"{base}/target/release/livac"
    let file = $"{base}/compiler/tests/liva/stdlib-io/http_server_fixture.liva"
    let cmd = $"{livac} check {file} 2>&1"
    let output = Process.exec(cmd) or ""
    return output
}

describe("HTTP Server Compile-Only", () => {
    test("fixture covers all API patterns and compiles", () => {
        let output = checkFixture()
        // livac check should NOT contain "Error"
        expect(output.contains("Error")).toBe(false)
        // Should report check passed
        expect(output.contains("Check passed")).toBe(true)
    })
})
