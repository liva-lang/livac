// HTTP Server fixture — complete coverage of all Server API features
// Used by http_server.test.liva for compile + integration testing
// Port 18787 to avoid conflicts

main() {
    let app = Server.create()

    // GET — Response.text
    app.get("/hello", (req) => {
        Response.text("Hello from Liva!")
    })

    // GET — Response.json
    app.get("/api/status", (req) => {
        Response.json("{\"status\": \"ok\"}")
    })

    // GET — path params via req.params.get
    app.get("/users/:id", (req) => {
        let id = req.params.get("id")
        Response.json("{\"id\": \"" + id + "\"}")
    })

    // GET — multiple path params
    app.get("/users/:userId/posts/:postId", (req) => {
        let userId = req.params.get("userId")
        let postId = req.params.get("postId")
        Response.text(userId + ":" + postId)
    })

    // POST — req.body + Response.text
    app.post("/data", (req) => {
        let body = req.body
        Response.text("Received: " + body)
    })

    // PUT — req.params + req.body
    app.put("/users/:id", (req) => {
        let id = req.params.get("id")
        let body = req.body
        Response.text("Updated " + id + ": " + body)
    })

    // DELETE — Response.status
    app.delete("/users/:id", (req) => {
        Response.status(204)
    })

    app.listen(18787)
}
