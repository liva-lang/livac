// Compile Test: Collections
// Covers: arrays with map/filter/reduce, Map with get/set/has,
//         Set with add/has, iteration with for loops

main() {
    // ── Arrays ──────────────────────────────────────────

    let nums = [1, 2, 3, 4, 5]
    print($"nums: {nums}")
    print($"length: {nums.length}")

    // map
    let doubled = nums.map(x => x * 2)
    print($"doubled: {doubled}")

    // filter
    let evens = nums.filter(x => x % 2 == 0)
    print($"evens: {evens}")

    // reduce (initial value FIRST)
    let total = nums.reduce(0, (acc, x) => acc + x)
    print($"total: {total}")

    // push
    let items = [10, 20]
    items.push(30)
    print($"after push: {items}")

    // includes
    print($"includes 3: {nums.includes(3)}")
    print($"includes 9: {nums.includes(9)}")

    // indexOf
    print($"indexOf 4: {nums.indexOf(4)}")

    // Array iteration
    for item in nums {
        print($"  num: {item}")
    }

    // For with index
    let names = ["Alice", "Bob", "Carol"]
    for i, name in names {
        print($"  {i}: {name}")
    }

    // ── Map ─────────────────────────────────────────────

    let ages = Map { "Alice": 30, "Bob": 25, "Carol": 35 }

    // get with or default
    let aliceAge = ages.get("Alice") or 0
    print($"Alice age: {aliceAge}")

    let unknownAge = ages.get("Dave") or 0
    print($"Dave age (default): {unknownAge}")

    // has
    print($"has Bob: {ages.has("Bob")}")
    print($"has Dave: {ages.has("Dave")}")

    // set
    ages.set("Dave", 28)
    print($"has Dave now: {ages.has("Dave")}")

    // delete
    ages.delete("Carol")
    print($"has Carol after delete: {ages.has("Carol")}")

    // Map iteration
    for key, value in ages {
        print($"  {key}: {value}")
    }

    // ── Set ─────────────────────────────────────────────

    let colors = Set { "red", "green", "blue" }

    // has
    print($"has red: {colors.has("red")}")
    print($"has yellow: {colors.has("yellow")}")

    // add
    colors.add("yellow")
    print($"has yellow now: {colors.has("yellow")}")

    // delete
    colors.delete("green")
    print($"has green after delete: {colors.has("green")}")

    // Set iteration
    for color in colors {
        print($"  color: {color}")
    }
}
