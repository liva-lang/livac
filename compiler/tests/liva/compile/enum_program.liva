// Compile Test: Enums
// Covers: unit enum, data enum, switch expression, exhaustive matching,
//         enum as return type, enum construction

// Unit enum
enum Direction { North, South, East, West }

// Enum with data variants
enum Shape {
    Circle(radius: number),
    Rectangle(width: number, height: number),
    Point
}

// Enum as return type (exhaustive switch)
directionName(d: Direction): string {
    return switch d {
        Direction.North => "north",
        Direction.South => "south",
        Direction.East => "east",
        Direction.West => "west"
    }
}

// Function taking enum param with destructuring
area(s: Shape): number {
    return switch s {
        Shape.Circle(r) => 3 * r * r,
        Shape.Rectangle(w, h) => w * h,
        Shape.Point => 0
    }
}

// Function returning enum
makeShape(kind: number): Shape {
    if kind == 1 {
        return Shape.Circle(10)
    }
    if kind == 2 {
        return Shape.Rectangle(5, 3)
    }
    return Shape.Point
}

// Wildcard matching
describeShape(s: Shape): string {
    return switch s {
        Shape.Circle(r) => $"circle with radius {r}",
        Shape.Rectangle(w, _) => $"rectangle with width {w}",
        Shape.Point => "just a point"
    }
}

main() {
    // Unit enum
    let dir = Direction.North
    print($"Direction: {directionName(dir)}")
    print($"Opposite: {directionName(Direction.South)}")

    // Data enum
    let circle = Shape.Circle(5)
    let rect = Shape.Rectangle(4, 6)
    let point = Shape.Point
    print($"Circle area: {area(circle)}")
    print($"Rect area: {area(rect)}")
    print($"Point area: {area(point)}")

    // Function returning enum
    let s1 = makeShape(1)
    let s2 = makeShape(2)
    let s3 = makeShape(3)
    print($"s1: {describeShape(s1)}")
    print($"s2: {describeShape(s2)}")
    print($"s3: {describeShape(s3)}")
}
