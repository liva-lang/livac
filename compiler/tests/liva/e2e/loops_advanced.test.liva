// E2E Test: For loop patterns — for-in, while, break/continue
import { describe, test, expect } from "liva/test"

describe("For-In Loops", () => {
    test("sum array elements", () => {
        let total = 0
        for item in [1, 2, 3, 4, 5] {
            total += item
        }
        expect(total).toBe(15)
    })

    test("count elements", () => {
        let count = 0
        for item in [10, 20, 30] {
            count += 1
        }
        expect(count).toBe(3)
    })

    test("collect in new array", () => {
        let items: [number] = []
        for x in [1, 2, 3] {
            items.push(x * 10)
        }
        expect(items.length).toBe(3)
    })
})

describe("While Loops", () => {
    test("basic while countdown", () => {
        let x = 5
        let count = 0
        while x > 0 {
            x -= 1
            count += 1
        }
        expect(count).toBe(5)
    })

    test("while with condition", () => {
        let sum = 0
        let n = 1
        while n <= 10 {
            sum += n
            n += 1
        }
        expect(sum).toBe(55)
    })
})

describe("Break and Continue", () => {
    test("break exits loop", () => {
        let count = 0
        for i in [1, 2, 3, 4, 5] {
            if i == 4 {
                break
            }
            count += 1
        }
        expect(count).toBe(3)
    })

    test("continue skips iteration", () => {
        let sum = 0
        for x in [1, 2, 3, 4, 5] {
            if x % 2 == 0 {
                continue
            }
            sum += x
        }
        // 1 + 3 + 5 = 9
        expect(sum).toBe(9)
    })
})
