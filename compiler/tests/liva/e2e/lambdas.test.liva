// E2E Test: Lambdas — closures, map/filter/reduce, forEach, find, some/every
// B105 FIXED: toBe([]) with empty vec now uses .is_empty()
// B106 FIXED: string reduce/fold — initial value gets .to_string()
// B107 FIXED: point-free filter — (*_x).clone() dereferences argument
import { describe, test, expect } from "liva/test"

double(x: number): number => x * 2
isEven(n: number): bool => n % 2 == 0

describe("Map", () => {
    test("transforms each element", () => {
        expect([1, 2, 3].map(x => x * 2)).toBe([2, 4, 6])
    })

    test("with string transformation", () => {
        expect(["hello", "world"].map(s => s.toUpperCase())).toBe(["HELLO", "WORLD"])
    })
})

describe("Filter", () => {
    test("keeps matching elements", () => {
        expect([1, 2, 3, 4, 5, 6].filter(x => x % 2 == 0)).toBe([2, 4, 6])
    })

    test("filters with greater than", () => {
        expect([10, 20, 30, 40].filter(x => x > 20)).toBe([30, 40])
    })
})

describe("Reduce", () => {
    test("sum with initial value", () => {
        expect([1, 2, 3, 4, 5].reduce(0, (acc, x) => acc + x)).toBe(15)
    })

    test("product", () => {
        expect([1, 2, 3, 4, 5].reduce(1, (acc, x) => acc * x)).toBe(120)
    })
})

describe("Find", () => {
    test("finds first matching element", () => {
        let result = [1, 2, 3, 4, 5].find(x => x > 3)
        expect(result).toBe(4)
    })
})

describe("Some and Every", () => {
    test("some returns true if any match", () => {
        expect([1, 2, 3].some(x => x > 2)).toBeTruthy()
    })

    test("some returns false if none match", () => {
        expect([1, 2, 3].some(x => x > 10)).toBeFalsy()
    })

    test("every returns true if all match", () => {
        expect([2, 4, 6].every(x => x % 2 == 0)).toBeTruthy()
    })

    test("every returns false if any fails", () => {
        expect([2, 4, 5].every(x => x % 2 == 0)).toBeFalsy()
    })
})

describe("Closures", () => {
    test("captures outer variable", () => {
        let factor = 3
        let result = [1, 2, 3].map(x => x * factor)
        expect(result).toBe([3, 6, 9])
    })

    test("captures string variable", () => {
        let prefix = "item"
        let result = [1, 2, 3].map(n => $"{prefix}_{n}")
        expect(result).toBe(["item_1", "item_2", "item_3"])
    })
})

describe("Point-Free Map", () => {
    test("function ref in map", () => {
        expect([1, 2, 3].map(double)).toBe([2, 4, 6])
    })
})

// B105: toBe([]) with empty array — previously failed with E0282
describe("Empty Array Comparison", () => {
    test("filter returning empty array", () => {
        expect([1, 3, 5].filter(x => x > 10)).toBe([])
    })

    test("negated empty array", () => {
        expect([1, 2, 3].filter(x => x > 0)).not.toBe([])
    })
})

// B106: reduce with string accumulator — previously &str vs String mismatch
describe("String Reduce", () => {
    test("join with reduce", () => {
        let result = ["a", "b", "c"].reduce("", (acc, s) => $"{acc}{s}")
        expect(result).toBe("abc")
    })
})

// B107: point-free function reference in filter — previously &&i32 deref mismatch
describe("Point-Free Filter", () => {
    test("function ref in filter", () => {
        expect([1, 2, 3, 4, 5, 6].filter(isEven)).toBe([2, 4, 6])
    })
})
