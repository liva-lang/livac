// E2E Test: Collections — arrays, maps, sets
import { describe, test, expect } from "liva/test"

describe("Arrays", () => {
    test("push and length", () => {
        let nums = [1, 2, 3]
        nums.push(4)
        expect(nums.length()).toBe(4)
        expect(nums).toBe([1, 2, 3, 4])
    })

    test("sort", () => {
        expect([3, 1, 4, 1, 5].sort()).toBe([1, 1, 3, 4, 5])
    })

    test("includes", () => {
        expect([1, 2, 3].includes(2)).toBeTruthy()
        expect([1, 2, 3].includes(9)).toBeFalsy()
    })

    test("indexOf", () => {
        expect([10, 20, 30].indexOf(20)).toBe(1)
        expect([10, 20, 30].indexOf(99)).toBe(-1)
    })

    test("join", () => {
        expect(["a", "b", "c"].join(", ")).toBe("a, b, c")
        expect(["hello"].join("-")).toBe("hello")
    })
})

describe("Maps", () => {
    test("get with or default", () => {
        let ages = Map { "Alice": 30, "Bob": 25 }
        expect(ages.get("Alice") or 0).toBe(30)
        expect(ages.get("Unknown") or 0).toBe(0)
    })

    test("set and has", () => {
        let m = Map { "a": 1 }
        m.set("b", 2)
        expect(m.has("a")).toBeTruthy()
        expect(m.has("b")).toBeTruthy()
        expect(m.has("c")).toBeFalsy()
    })

    test("delete", () => {
        let m = Map { "a": 1, "b": 2 }
        m.delete("a")
        expect(m.has("a")).toBeFalsy()
        expect(m.has("b")).toBeTruthy()
    })

    test("keys and values", () => {
        let m = Map { "x": 10, "y": 20 }
        let k = m.keys()
        let v = m.values()
        expect(k.length()).toBe(2)
        expect(v.length()).toBe(2)
    })
})

describe("Sets", () => {
    test("add and has", () => {
        let s = Set { "red", "green" }
        s.add("blue")
        expect(s.has("red")).toBeTruthy()
        expect(s.has("blue")).toBeTruthy()
        expect(s.has("yellow")).toBeFalsy()
    })

    test("delete", () => {
        let s = Set { "a", "b", "c" }
        s.delete("b")
        expect(s.has("b")).toBeFalsy()
        expect(s.has("a")).toBeTruthy()
    })
})
