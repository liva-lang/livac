// E2E Test: Fibonacci — recursion, expressions
import { describe, test, expect } from "liva/test"

fib(n: number): number {
    if n <= 0 {
        return 0
    }
    if n == 1 {
        return 1
    }
    return fib(n - 1) + fib(n - 2)
}

describe("Fibonacci", () => {
    test("base cases", () => {
        expect(fib(0)).toBe(0)
        expect(fib(1)).toBe(1)
    })

    test("small values", () => {
        expect(fib(2)).toBe(1)
        expect(fib(3)).toBe(2)
        expect(fib(4)).toBe(3)
        expect(fib(5)).toBe(5)
    })

    test("larger values", () => {
        expect(fib(6)).toBe(8)
        expect(fib(7)).toBe(13)
        expect(fib(8)).toBe(21)
        expect(fib(9)).toBe(34)
        expect(fib(10)).toBe(55)
    })
})
