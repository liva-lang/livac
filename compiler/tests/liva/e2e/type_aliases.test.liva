// E2E Test: Type Aliases — basic, generic, nested, usage in functions
import { describe, test, expect } from "liva/test"

type IntList = [number]
type StringList = [string]
type Pair = (number, number)

sumList(items: IntList): number {
    return items.reduce(0, (acc, x) => acc + x)
}

describe("Type Aliases", () => {
    test("array type alias", () => {
        let nums: IntList = [1, 2, 3, 4, 5]
        expect(nums.length).toBe(5)
        expect(sumList(nums)).toBe(15)
    })

    test("string list alias", () => {
        let names: StringList = ["Alice", "Bob"]
        expect(names.length).toBe(2)
    })

    test("alias used in function param", () => {
        let data: IntList = [10, 20, 30]
        expect(sumList(data)).toBe(60)
    })

    test("type alias for tuple", () => {
        let p: Pair = (5, 10)
        expect(p.0).toBe(5)
        expect(p.1).toBe(10)
    })
})
