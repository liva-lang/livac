// E2E Test: Nested Loops — break, continue in nested structures
import { describe, test, expect } from "liva/test"

describe("Nested For Loops", () => {
    test("nested for with accumulator", () => {
        let total = 0
        for i in 0..3 {
            for j in 0..3 {
                total += 1
            }
        }
        expect(total).toBe(9)
    })

    test("inner break does not exit outer", () => {
        let count = 0
        for i in 0..3 {
            for j in 0..10 {
                if j == 2 {
                    break
                }
                count += 1
            }
        }
        expect(count).toBe(6)
    })

    test("inner continue skips iteration", () => {
        let count = 0
        for i in 0..3 {
            for j in 0..5 {
                if j == 2 {
                    continue
                }
                count += 1
            }
        }
        expect(count).toBe(12)
    })
})

describe("While with Break", () => {
    test("while with early break", () => {
        let i = 0
        let sum = 0
        while i < 100 {
            if i >= 5 {
                break
            }
            sum += i
            i += 1
        }
        expect(sum).toBe(10)
    })

    test("while with continue", () => {
        let i = 0
        let sum = 0
        while i < 10 {
            i += 1
            if i % 2 == 0 {
                continue
            }
            sum += i
        }
        expect(sum).toBe(25)
    })
})

describe("Complex Loop Patterns", () => {
    test("for with conditional accumulation", () => {
        let evens = 0
        let odds = 0
        for i in 1..=10 {
            if i % 2 == 0 {
                evens += 1
            } else {
                odds += 1
            }
        }
        expect(evens).toBe(5)
        expect(odds).toBe(5)
    })

    test("nested loop multiplication table sum", () => {
        let sum = 0
        for i in 1..=3 {
            for j in 1..=3 {
                sum += i * j
            }
        }
        expect(sum).toBe(36)
    })
})
