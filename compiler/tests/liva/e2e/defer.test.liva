// E2E Test: Defer — basic usage with function calls
// NOTE: B112 (defer borrow conflict) still limits testing deferred mutations in same scope.
//   B108 FIXED: Parser now supports `defer <stmt>` (assignments, compound assignments)
import { describe, test, expect } from "liva/test"

describe("Defer Smoke", () => {
    test("basic value unchanged in body", () => {
        let x = 10
        expect(x).toBe(10)
    })

    test("defer with compound assignment parses", () => {
        let counter = 0
        defer counter += 1
        // B112: can't inspect counter due to borrow conflict
        // But this proves `defer <stmt>` parses and compiles
        expect(true).toBeTruthy()
    })

    test("defer with simple assignment parses", () => {
        let flag = false
        defer flag = true
        expect(true).toBeTruthy()
    })
})
