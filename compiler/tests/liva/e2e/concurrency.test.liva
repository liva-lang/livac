// E2E Test: Concurrency — functional array patterns
// NOTE: par() has codegen limitation in self-hosted compiler, testing sequential equivalents
import { describe, test, expect } from "liva/test"

double(x: number): number => x * 2

describe("Array Functional Patterns", () => {
    test("map doubles", () => {
        let nums = [1, 2, 3, 4, 5]
        let doubled = nums.map(x => x * 2)
        expect(doubled.length).toBe(5)
        expect(doubled.sum()).toBe(30)
    })

    test("filter selects evens", () => {
        let nums = [1, 2, 3, 4, 5, 6]
        let evens = nums.filter(x => x % 2 == 0)
        expect(evens.length).toBe(3)
    })

    test("reduce sums", () => {
        let nums = [1, 2, 3, 4, 5]
        let sum = nums.reduce(0, (acc, x) => acc + x)
        expect(sum).toBe(15)
    })

    test("point-free map", () => {
        let nums = [1, 2, 3]
        let result = nums.map(double)
        expect(result.length).toBe(3)
    })
})
