// Jest-style tests for Map/Set collections + control flow.
// (Async/await are call-site operators in Liva — `async someFn()()`, `await task`,
//  not declaration modifiers — so test bodies stay synchronous.)
import { describe, test, expect } from "liva/test"

addOne(n: int): int => n + 1
double(n: int): int => n * 2

describe("function composition", () => {
    test("nested calls", () => {
        expect(double(addOne(4))).toBe(10)
        expect(addOne(double(4))).toBe(9)
    })
    test("repeated application", () => {
        let x = 0
        for i in 0..5 {
            x = addOne(x)
        }
        expect(x).toBe(5)
    })
})

describe("Map/Set sanity", () => {
    test("Map insert + get", () => {
        let m: Map<string, int> = {}
        m.set("one", 1)
        m.set("two", 2)
        expect(m.length()).toBe(2)
        expect(m.get("one") or 0).toBe(1)
    })
    test("Set dedupes", () => {
        let s: Set<int> = {}
        s.add(1)
        s.add(1)
        s.add(2)
        expect(s.length()).toBe(2)
    })
})

describe("control flow", () => {
    test("if/else branches", () => {
        let label = "no"
        if 5 > 3 {
            label = "yes"
        }
        expect(label).toBe("yes")
    })
    test("switch matches arm", () => {
        let n = 2
        let name = "other"
        switch n {
            1 => { name = "one" }
            2 => { name = "two" }
            _ => { name = "other" }
        }
        expect(name).toBe("two")
    })
})

