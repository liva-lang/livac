#!/bin/bash
# postinst — Debian post-install script for livac
# 1. Checks that a Rust toolchain is available (informational only)
# 2. Installs AI skill symlinks for all coding agents
#
# IMPORTANT: postinst MUST NOT fail. Anything we can't do non-interactively
# is reduced to a printed hint so `dpkg -i` / `apt install` always succeed
# and `dpkg -l livac` ends in state `ii`, not `iF`.
set -e

case "$1" in
    configure)
        # --- Rust toolchain (informational) ---
        # We declare `rustc, cargo` in Recommends so apt pulls them in by
        # default. For `dpkg -i` users without apt, or for systems where
        # Recommends were disabled, just print a hint — never download
        # rustup from the postinst (that breaks offline installs and CI).
        if command -v cargo >/dev/null 2>&1; then
            echo "livac: Rust toolchain found ($(cargo --version 2>/dev/null || echo cargo))"
        else
            echo "livac: NOTE — Rust toolchain (rustc, cargo) not found on PATH."
            echo "livac:        livac compiles to Rust and needs cargo to build output."
            echo "livac:        Install via your package manager (e.g. 'apt install rustc cargo')"
            echo "livac:        or rustup: https://rustup.rs"
        fi

        # --- AI Skills (best-effort, never fail the install) ---
        if [ -x /usr/share/livac/scripts/install-skills.sh ]; then
            /usr/share/livac/scripts/install-skills.sh || true
        fi

        # --- Migration: clean up legacy ~/.liva/bin shadow ---
        # The pre-v2.4.1 install.sh dropped livac in ~/.liva/bin and prepended
        # it to PATH in ~/.bashrc / ~/.zshrc / ~/.profile, so it shadowed the
        # packaged /usr/bin/livac forever. Detect and back it up so the new
        # version on /usr/bin/livac takes effect immediately.
        for HOMEDIR in /home/* /root; do
            [ -d "$HOMEDIR" ] || continue
            LEGACY="$HOMEDIR/.liva/bin/livac"
            if [ -f "$LEGACY" ]; then
                BACKUP="$LEGACY.pre-2.4.1.bak"
                mv -f "$LEGACY" "$BACKUP" 2>/dev/null || true
                USER_NAME=$(basename "$HOMEDIR")
                echo "livac: migrated legacy install for ${USER_NAME}:"
                echo "livac:   moved ${LEGACY} -> ${BACKUP}"
                echo "livac:   /usr/bin/livac (this package) is now the active livac."
                echo "livac:   You may also want to remove the '~/.liva/bin' PATH"
                echo "livac:   line from ~/.bashrc / ~/.zshrc / ~/.profile."
            fi
        done
        ;;
esac

exit 0
