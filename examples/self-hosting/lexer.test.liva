// Lexer tests
import { Token, Span, TokenWithSpan } from "../src/token.liva"
import { Lexer } from "../src/lexer.liva"
import { describe, test, expect } from "liva/test"

// Helper: tokenize and return just the Token values (excluding Eof)
_tokens(source: string): [Token] {
    let lexer = Lexer(source)
    let all = lexer.tokenize()
    let result: [Token] = []
    for tw in all {
        switch tw.token {
            case Token.Eof: { break }
            default: { result.push(tw.token) }
        }
    }
    return result
}

// Helper: count tokens (excluding Eof)
_count(source: string): number {
    let toks = _tokens(source)
    return toks.length
}

// Helper: get first token
_first(source: string): Token {
    let toks = _tokens(source)
    return toks[0]
}

// Helper: tokenize and return full TokenWithSpan list (excluding Eof)
_tokenize(source: string): [TokenWithSpan] {
    let lexer = Lexer(source)
    let all = lexer.tokenize()
    let result: [TokenWithSpan] = []
    for tw in all {
        switch tw.token {
            case Token.Eof: { break }
            default: { result.push(tw) }
        }
    }
    return result
}

describe("Lexer — Keywords", () => {
    test("recognizes let", () => {
        expect(_first("let")).toEqual(Token.LetKw)
    })

    test("recognizes const", () => {
        expect(_first("const")).toEqual(Token.ConstKw)
    })

    test("recognizes import/from", () => {
        let toks = _tokens("import from")
        expect(toks[0]).toEqual(Token.ImportKw)
        expect(toks[1]).toEqual(Token.FromKw)
    })

    test("recognizes control flow keywords", () => {
        let toks = _tokens("if else while for in switch case default")
        expect(toks[0]).toEqual(Token.IfKw)
        expect(toks[1]).toEqual(Token.ElseKw)
        expect(toks[2]).toEqual(Token.WhileKw)
        expect(toks[3]).toEqual(Token.ForKw)
        expect(toks[4]).toEqual(Token.InKw)
        expect(toks[5]).toEqual(Token.SwitchKw)
        expect(toks[6]).toEqual(Token.CaseKw)
        expect(toks[7]).toEqual(Token.DefaultKw)
    })

    test("recognizes return/break/continue", () => {
        let toks = _tokens("return break continue")
        expect(toks[0]).toEqual(Token.ReturnKw)
        expect(toks[1]).toEqual(Token.BreakKw)
        expect(toks[2]).toEqual(Token.ContinueKw)
    })

    test("recognizes error handling keywords", () => {
        let toks = _tokens("throw try catch fail")
        expect(toks[0]).toEqual(Token.ThrowKw)
        expect(toks[1]).toEqual(Token.TryKw)
        expect(toks[2]).toEqual(Token.CatchKw)
        expect(toks[3]).toEqual(Token.FailKw)
    })

    test("recognizes async keywords", () => {
        let toks = _tokens("async par task await")
        expect(toks[0]).toEqual(Token.AsyncKw)
        expect(toks[1]).toEqual(Token.ParKw)
        expect(toks[2]).toEqual(Token.TaskKw)
        expect(toks[3]).toEqual(Token.AwaitKw)
    })

    test("recognizes type keywords", () => {
        let toks = _tokens("number float bool char string bytes")
        expect(toks[0]).toEqual(Token.NumberKw)
        expect(toks[1]).toEqual(Token.FloatKw)
        expect(toks[2]).toEqual(Token.BoolKw)
        expect(toks[3]).toEqual(Token.CharKw)
        expect(toks[4]).toEqual(Token.StringKw)
        expect(toks[5]).toEqual(Token.BytesKw)
    })

    test("recognizes logical keywords", () => {
        let toks = _tokens("and or not")
        expect(toks[0]).toEqual(Token.AndKw)
        expect(toks[1]).toEqual(Token.OrKw)
        expect(toks[2]).toEqual(Token.NotKw)
    })

    test("recognizes true/false/null", () => {
        let toks = _tokens("true false null")
        expect(toks[0]).toEqual(Token.TrueKw)
        expect(toks[1]).toEqual(Token.FalseKw)
        expect(toks[2]).toEqual(Token.NullKw)
    })

    test("recognizes enum/use/rust/type/defer", () => {
        let toks = _tokens("enum use rust type defer")
        expect(toks[0]).toEqual(Token.EnumKw)
        expect(toks[1]).toEqual(Token.UseKw)
        expect(toks[2]).toEqual(Token.RustKw)
        expect(toks[3]).toEqual(Token.TypeKw)
        expect(toks[4]).toEqual(Token.DeferKw)
    })
})

describe("Lexer — Identifiers", () => {
    test("simple identifier", () => {
        expect(_first("foo")).toEqual(Token.Ident("foo"))
    })

    test("identifier with numbers", () => {
        expect(_first("foo123")).toEqual(Token.Ident("foo123"))
    })

    test("private identifier", () => {
        expect(_first("_secret")).toEqual(Token.PrivateIdent("_secret"))
    })

    test("camelCase identifier", () => {
        expect(_first("myVariable")).toEqual(Token.Ident("myVariable"))
    })

    test("PascalCase identifier", () => {
        expect(_first("MyClass")).toEqual(Token.Ident("MyClass"))
    })
})

describe("Lexer — Number Literals", () => {
    test("simple integer", () => {
        expect(_first("42")).toEqual(Token.IntLit("42"))
    })

    test("zero", () => {
        expect(_first("0")).toEqual(Token.IntLit("0"))
    })

    test("float literal", () => {
        expect(_first("3.14")).toEqual(Token.FloatLit("3.14"))
    })

    test("integer with underscores", () => {
        expect(_first("1_000_000")).toEqual(Token.IntLit("1_000_000"))
    })

    test("float with underscores", () => {
        expect(_first("1_000.50")).toEqual(Token.FloatLit("1_000.50"))
    })
})

describe("Lexer — String Literals", () => {
    test("simple string", () => {
        expect(_first("\"hello\"")).toEqual(Token.StringLit("hello"))
    })

    test("empty string", () => {
        expect(_first("\"\"")).toEqual(Token.StringLit(""))
    })

    test("string with spaces", () => {
        expect(_first("\"hello world\"")).toEqual(Token.StringLit("hello world"))
    })

    test("string template", () => {
        expect(_first("$\"hello {name}\"")).toEqual(Token.StringTemplate("hello {name}"))
    })

    test("char literal", () => {
        expect(_first("'a'")).toEqual(Token.CharLit("a"))
    })
})

describe("Lexer — Operators", () => {
    test("arithmetic operators", () => {
        let toks = _tokens("+ - * / %")
        expect(toks[0]).toEqual(Token.Plus)
        expect(toks[1]).toEqual(Token.Minus)
        expect(toks[2]).toEqual(Token.Star)
        expect(toks[3]).toEqual(Token.Slash)
        expect(toks[4]).toEqual(Token.Percent)
    })

    test("comparison operators", () => {
        let toks = _tokens("< <= > >= == !=")
        expect(toks[0]).toEqual(Token.Lt)
        expect(toks[1]).toEqual(Token.Le)
        expect(toks[2]).toEqual(Token.Gt)
        expect(toks[3]).toEqual(Token.Ge)
        expect(toks[4]).toEqual(Token.EqEq)
        expect(toks[5]).toEqual(Token.Ne)
    })

    test("logical operators", () => {
        let toks = _tokens("&& ||")
        expect(toks[0]).toEqual(Token.AndAnd)
        expect(toks[1]).toEqual(Token.OrOr)
    })

    test("assignment operators", () => {
        let toks = _tokens("= += -= *= /= %=")
        expect(toks[0]).toEqual(Token.Assign)
        expect(toks[1]).toEqual(Token.PlusAssign)
        expect(toks[2]).toEqual(Token.MinusAssign)
        expect(toks[3]).toEqual(Token.StarAssign)
        expect(toks[4]).toEqual(Token.SlashAssign)
        expect(toks[5]).toEqual(Token.PercentAssign)
    })

    test("arrow operator", () => {
        expect(_first("=>")).toEqual(Token.Arrow)
    })

    test("bang operator", () => {
        expect(_first("!")).toEqual(Token.Bang)
    })
})

describe("Lexer — Delimiters", () => {
    test("parentheses", () => {
        let toks = _tokens("()")
        expect(toks[0]).toEqual(Token.LParen)
        expect(toks[1]).toEqual(Token.RParen)
    })

    test("braces", () => {
        let toks = _tokens("{}")
        expect(toks[0]).toEqual(Token.LBrace)
        expect(toks[1]).toEqual(Token.RBrace)
    })

    test("brackets", () => {
        let toks = _tokens("[]")
        expect(toks[0]).toEqual(Token.LBracket)
        expect(toks[1]).toEqual(Token.RBracket)
    })

    test("comma, colon, semicolon", () => {
        let toks = _tokens(", : ;")
        expect(toks[0]).toEqual(Token.Comma)
        expect(toks[1]).toEqual(Token.Colon)
        expect(toks[2]).toEqual(Token.Semicolon)
    })

    test("dot variants", () => {
        let toks = _tokens(". .. ..= ...")
        expect(toks[0]).toEqual(Token.Dot)
        expect(toks[1]).toEqual(Token.DotDot)
        expect(toks[2]).toEqual(Token.DotDotEq)
        expect(toks[3]).toEqual(Token.DotDotDot)
    })

    test("question mark", () => {
        expect(_first("?")).toEqual(Token.Question)
    })

    test("double colon", () => {
        expect(_first("::")).toEqual(Token.DoubleColon)
    })
})

describe("Lexer — Comments", () => {
    test("line comment skipped", () => {
        let toks = _tokens("foo // this is a comment\nbar")
        expect(toks.length).toBe(2)
        expect(toks[0]).toEqual(Token.Ident("foo"))
        expect(toks[1]).toEqual(Token.Ident("bar"))
    })

    test("block comment skipped", () => {
        let toks = _tokens("foo /* block */ bar")
        expect(toks.length).toBe(2)
        expect(toks[0]).toEqual(Token.Ident("foo"))
        expect(toks[1]).toEqual(Token.Ident("bar"))
    })

    test("only comments produces empty", () => {
        expect(_count("// just a comment")).toBe(0)
    })
})

describe("Lexer — Whitespace", () => {
    test("empty source", () => {
        expect(_count("")).toBe(0)
    })

    test("only whitespace", () => {
        expect(_count("   \n\t  \r\n  ")).toBe(0)
    })

    test("tokens separated by various whitespace", () => {
        let toks = _tokens("a\nb\tc  d")
        expect(toks.length).toBe(4)
    })
})

describe("Lexer — Complex Expressions", () => {
    test("function signature", () => {
        let toks = _tokens("add(a: number, b: number): number")
        expect(toks[0]).toEqual(Token.Ident("add"))
        expect(toks[1]).toEqual(Token.LParen)
        expect(toks[2]).toEqual(Token.Ident("a"))
        expect(toks[3]).toEqual(Token.Colon)
        expect(toks[4]).toEqual(Token.NumberKw)
    })

    test("let declaration", () => {
        let toks = _tokens("let x = 42")
        expect(toks[0]).toEqual(Token.LetKw)
        expect(toks[1]).toEqual(Token.Ident("x"))
        expect(toks[2]).toEqual(Token.Assign)
        expect(toks[3]).toEqual(Token.IntLit("42"))
    })

    test("method call chain", () => {
        let toks = _tokens("items.filter(x => x > 0).length")
        expect(toks[0]).toEqual(Token.Ident("items"))
        expect(toks[1]).toEqual(Token.Dot)
        expect(toks[2]).toEqual(Token.Ident("filter"))
    })

    test("enum construction", () => {
        let toks = _tokens("Shape.Circle(5)")
        expect(toks[0]).toEqual(Token.Ident("Shape"))
        expect(toks[1]).toEqual(Token.Dot)
        expect(toks[2]).toEqual(Token.Ident("Circle"))
        expect(toks[3]).toEqual(Token.LParen)
        expect(toks[4]).toEqual(Token.IntLit("5"))
        expect(toks[5]).toEqual(Token.RParen)
    })

    test("import statement", () => {
        let toks = _tokens("import { Token, Span } from \"./token.liva\"")
        expect(toks[0]).toEqual(Token.ImportKw)
        expect(toks[1]).toEqual(Token.LBrace)
        expect(toks[2]).toEqual(Token.Ident("Token"))
        expect(toks[3]).toEqual(Token.Comma)
        expect(toks[4]).toEqual(Token.Ident("Span"))
        expect(toks[5]).toEqual(Token.RBrace)
        expect(toks[6]).toEqual(Token.FromKw)
        expect(toks[7]).toEqual(Token.StringLit("./token.liva"))
    })

    test("optional type annotation", () => {
        let toks = _tokens("name: string?")
        expect(toks[0]).toEqual(Token.Ident("name"))
        expect(toks[1]).toEqual(Token.Colon)
        expect(toks[2]).toEqual(Token.StringKw)
        expect(toks[3]).toEqual(Token.Question)
    })

    test("array type", () => {
        let toks = _tokens("[number]")
        expect(toks[0]).toEqual(Token.LBracket)
        expect(toks[1]).toEqual(Token.NumberKw)
        expect(toks[2]).toEqual(Token.RBracket)
    })

    test("range expression", () => {
        let toks = _tokens("1..=10")
        expect(toks[0]).toEqual(Token.IntLit("1"))
        expect(toks[1]).toEqual(Token.DotDotEq)
        expect(toks[2]).toEqual(Token.IntLit("10"))
    })
})

describe("Lexer — Spans", () => {
    test("span tracks position correctly", () => {
        let all = _tokenize("let x")
        expect(all[0].span.start).toBe(0)
        expect(all[0].span.end).toBe(3)
        expect(all[1].span.start).toBe(4)
        expect(all[1].span.end).toBe(5)
    })
})
