// Parser tests — type-checking only approach (workaround for BUG-003)
// BUG-003: Field access on enum variant payloads generates get_field()
// So we only check: does parsing succeed? Is top-level type correct? How many items?
import { Token, Span, TokenWithSpan } from "../src/token.liva"
import {
    Program, TopLevel, FuncDecl, Param, ClassDef, FieldDef, MethodDef,
    EnumDef, EnumVariantDef, EnumFieldDef, ImportDef, ConstDef, TestDef,
    TypeRef, Stmt, VarDeclStmt, ConstDeclStmt, AssignStmt, AssignOp,
    IfStmt, WhileStmt, ForStmt, SwitchStmt, CaseClause, Pattern, ReturnStmt,
    Expr, BinOp, UnaryOp, MapEntry, SwitchArm
} from "../src/ast.liva"
import { Parser } from "../src/parser.liva"
import { describe, test, expect } from "liva/test"

// ─── Helpers ───────────────────────────────────────────────

_parse(source: string): Program {
    let parser = Parser([], 0)
    return parser.parse(source)
}

_count(source: string): number {
    let prog = _parse(source)
    return prog.items.length
}

// Type checkers — return string tag for the first top-level item
_topType(source: string): string {
    let prog = _parse(source)
    for item in prog.items {
        switch item {
            case TopLevel.ImportDecl(decl): { return "import" }
            case TopLevel.FunctionDecl(decl): { return "function" }
            case TopLevel.ClassDecl(decl): { return "class" }
            case TopLevel.EnumDecl(decl): { return "enum" }
            case TopLevel.ConstDecl(decl): { return "const" }
            default: { return "unknown" }
        }
    }
    return "empty"
}

// Statement type checker — return tag for first statement in first function
_stmtType(source: string): string {
    let prog = _parse(source)
    for item in prog.items {
        switch item {
            case TopLevel.FunctionDecl(decl): {
                // Can't access decl.body due to BUG-003
                // Instead, we'll return "function" and a separate check
                return "function"
            }
            default: { }
        }
    }
    return "none"
}

// Parse and verify it doesn't throw — returns true if parse succeeds
_parses(source: string): bool {
    let parser = Parser([], 0)
    let prog = parser.parse(source)
    return prog.items.length > 0
}

// Parse and verify it produces N items
_parsesN(source: string, n: number): bool {
    let parser = Parser([], 0)
    let prog = parser.parse(source)
    return prog.items.length == n
}

// ─── Tests ─────────────────────────────────────────────────

describe("Parser — Imports", () => {
    test("simple import parses", () => {
        expect(_parses("import { Foo } from \"./foo.liva\"")).toBe(true)
    })

    test("import detected as import", () => {
        expect(_topType("import { Foo } from \"./foo.liva\"")).toBe("import")
    })

    test("multi-name import parses", () => {
        expect(_parses("import { A, B, C } from \"./mod.liva\"")).toBe(true)
    })
})

describe("Parser — Functions", () => {
    test("simple function parses", () => {
        expect(_parses("main() { }")).toBe(true)
    })

    test("function detected as function", () => {
        expect(_topType("main() { }")).toBe("function")
    })

    test("function with params parses", () => {
        expect(_parses("add(a: number, b: number): number { return a + b }")).toBe(true)
    })

    test("private function parses", () => {
        expect(_parses("_helper(x: number): number { return x * 2 }")).toBe(true)
    })

    test("async function parses", () => {
        expect(_parses("async fetchData(): string { return \"data\" }")).toBe(true)
    })

    test("function with body parses", () => {
        expect(_parses("greet(name: string) { let msg = \"hello\" }")).toBe(true)
    })

    test("function with multiple statements", () => {
        expect(_parses("calc() { let x = 1  let y = 2  return x + y }")).toBe(true)
    })

    test("function with optional return type", () => {
        expect(_parses("find(): string? { return null }")).toBe(true)
    })

    test("function with array return type", () => {
        expect(_parses("items(): [number] { return [1, 2, 3] }")).toBe(true)
    })
})

describe("Parser — Classes", () => {
    test("simple class parses", () => {
        expect(_parses("Point { x: number  y: number }")).toBe(true)
    })

    test("class detected as class", () => {
        expect(_topType("Point { x: number  y: number }")).toBe("class")
    })

    test("class with method parses", () => {
        let src = "Counter { _count: number  increment() { this._count = this._count + 1 } }"
        expect(_parses(src)).toBe(true)
    })

    test("class with private fields parses", () => {
        expect(_parses("Foo { _bar: string  _baz: number }")).toBe(true)
    })

    test("class with method returning value", () => {
        expect(_parses("Box { _value: number  get(): number { return this._value } }")).toBe(true)
    })
})

describe("Parser — Enums", () => {
    test("simple enum parses", () => {
        expect(_parses("enum Color { Red  Green  Blue }")).toBe(true)
    })

    test("enum detected as enum", () => {
        expect(_topType("enum Color { Red  Green  Blue }")).toBe("enum")
    })

    test("enum with fields parses", () => {
        expect(_parses("enum Shape { Circle(radius: number)  Rect(w: number, h: number) }")).toBe(true)
    })

    test("enum with mixed variants parses", () => {
        expect(_parses("enum Option { None  Some(value: number) }")).toBe(true)
    })
})

describe("Parser — Statements", () => {
    test("let declaration parses", () => {
        expect(_parses("main() { let x = 42 }")).toBe(true)
    })

    test("let with type annotation parses", () => {
        expect(_parses("main() { let x: number = 42 }")).toBe(true)
    })

    test("const declaration parses", () => {
        expect(_parses("main() { const PI = 3.14 }")).toBe(true)
    })

    test("if statement parses", () => {
        expect(_parses("main() { if x > 0 { return x } }")).toBe(true)
    })

    test("if-else statement parses", () => {
        expect(_parses("main() { if x > 0 { return 1 } else { return 0 } }")).toBe(true)
    })

    test("if-else if parses", () => {
        expect(_parses("main() { if x > 0 { return 1 } else if x < 0 { return -1 } else { return 0 } }")).toBe(true)
    })

    test("while loop parses", () => {
        expect(_parses("main() { while x > 0 { x = x - 1 } }")).toBe(true)
    })

    test("for loop parses", () => {
        expect(_parses("main() { for item in items { print(item) } }")).toBe(true)
    })

    test("for loop with index parses", () => {
        expect(_parses("main() { for i, item in items { print(i) } }")).toBe(true)
    })

    test("return statement parses", () => {
        expect(_parses("main(): number { return 42 }")).toBe(true)
    })

    test("return void parses", () => {
        expect(_parses("main() { return }")).toBe(true)
    })

    test("break statement parses", () => {
        expect(_parses("main() { while true { break } }")).toBe(true)
    })

    test("continue statement parses", () => {
        expect(_parses("main() { while true { continue } }")).toBe(true)
    })

    test("assignment parses", () => {
        expect(_parses("main() { x = 42 }")).toBe(true)
    })

    test("compound plus-assign parses", () => {
        expect(_parses("main() { x += 1 }")).toBe(true)
    })

    test("compound minus-assign parses", () => {
        expect(_parses("main() { x -= 1 }")).toBe(true)
    })

    test("compound star-assign parses", () => {
        expect(_parses("main() { x *= 2 }")).toBe(true)
    })

    test("compound slash-assign parses", () => {
        expect(_parses("main() { x /= 2 }")).toBe(true)
    })

    test("switch statement parses", () => {
        expect(_parses("main() { switch x { case 1: { } default: { } } }")).toBe(true)
    })

    test("switch with enum pattern parses", () => {
        expect(_parses("main() { switch shape { case Shape.Circle(r): { print(r) } default: { } } }")).toBe(true)
    })

    test("throw statement parses", () => {
        expect(_parses("main() { throw \"error\" }")).toBe(true)
    })

    test("fail statement parses", () => {
        expect(_parses("main() { fail \"something went wrong\" }")).toBe(true)
    })

    test("defer statement parses", () => {
        expect(_parses("main() { defer { cleanup() } }")).toBe(true)
    })
})

describe("Parser — Expressions", () => {
    test("integer literal", () => {
        expect(_parses("main() { 42 }")).toBe(true)
    })

    test("float literal", () => {
        expect(_parses("main() { 3.14 }")).toBe(true)
    })

    test("string literal", () => {
        expect(_parses("main() { \"hello\" }")).toBe(true)
    })

    test("string template", () => {
        expect(_parses("main() { $\"hello {name}\" }")).toBe(true)
    })

    test("char literal", () => {
        expect(_parses("main() { 'a' }")).toBe(true)
    })

    test("boolean true", () => {
        expect(_parses("main() { true }")).toBe(true)
    })

    test("boolean false", () => {
        expect(_parses("main() { false }")).toBe(true)
    })

    test("null literal", () => {
        expect(_parses("main() { null }")).toBe(true)
    })

    test("identifier", () => {
        expect(_parses("main() { x }")).toBe(true)
    })

    test("binary addition", () => {
        expect(_parses("main() { a + b }")).toBe(true)
    })

    test("binary subtraction", () => {
        expect(_parses("main() { a - b }")).toBe(true)
    })

    test("binary multiplication", () => {
        expect(_parses("main() { a * b }")).toBe(true)
    })

    test("binary division", () => {
        expect(_parses("main() { a / b }")).toBe(true)
    })

    test("binary modulo", () => {
        expect(_parses("main() { a % b }")).toBe(true)
    })

    test("comparison operators", () => {
        expect(_parses("main() { a > b }")).toBe(true)
        expect(_parses("main() { a < b }")).toBe(true)
        expect(_parses("main() { a >= b }")).toBe(true)
        expect(_parses("main() { a <= b }")).toBe(true)
        expect(_parses("main() { a == b }")).toBe(true)
        expect(_parses("main() { a != b }")).toBe(true)
    })

    test("logical and/or", () => {
        expect(_parses("main() { a and b }")).toBe(true)
        expect(_parses("main() { a or b }")).toBe(true)
    })

    test("unary negation", () => {
        expect(_parses("main() { -42 }")).toBe(true)
    })

    test("not expression", () => {
        expect(_parses("main() { not true }")).toBe(true)
    })

    test("function call", () => {
        expect(_parses("main() { print(\"hello\") }")).toBe(true)
    })

    test("method call", () => {
        expect(_parses("main() { items.push(42) }")).toBe(true)
    })

    test("chained method call", () => {
        expect(_parses("main() { items.filter(x).map(y).length }")).toBe(true)
    })

    test("member access", () => {
        expect(_parses("main() { point.x }")).toBe(true)
    })

    test("index expression", () => {
        expect(_parses("main() { items[0] }")).toBe(true)
    })

    test("array literal", () => {
        expect(_parses("main() { [1, 2, 3] }")).toBe(true)
    })

    test("empty array literal", () => {
        expect(_parses("main() { [] }")).toBe(true)
    })

    test("nested expression", () => {
        expect(_parses("main() { (a + b) * c }")).toBe(true)
    })

    // NOTE: lambda expressions (x => x > 0) not yet handled in parser
    test("complex expression", () => {
        expect(_parses("main() { items.map(transform).filter(check).length + 1 }")).toBe(true)
    })
})

describe("Parser — Multiple Items", () => {
    test("import + function", () => {
        expect(_parsesN("import { Foo } from \"./foo.liva\"  main() { }", 2)).toBe(true)
    })

    test("multiple functions", () => {
        expect(_parsesN("add(a: number, b: number): number { return a + b }  main() { let r = add(1, 2) }", 2)).toBe(true)
    })

    test("enum + function", () => {
        expect(_parsesN("enum Color { Red Green Blue }  main() { let c = Color.Red }", 2)).toBe(true)
    })

    test("class + function", () => {
        expect(_parsesN("Point { x: number  y: number }  main() { let p = Point(1, 2) }", 2)).toBe(true)
    })

    test("import + enum + function", () => {
        expect(_parsesN("import { Foo } from \"./foo.liva\"  enum Color { Red }  main() { }", 3)).toBe(true)
    })
})

describe("Parser — Complex Programs", () => {
    test("function with all statement types", () => {
        let src = "main() { let x = 0  const MAX = 100  if x < MAX { while x < 10 { x += 1 } } for i in [1, 2] { print(i) } return x }"
        expect(_parses(src)).toBe(true)
    })

    test("enum + switch function", () => {
        let src = "enum Shape { Circle(r: number) Rect(w: number, h: number) }  area(s: Shape): number { switch s { case Shape.Circle(r): { return r * r } case Shape.Rect(w, h): { return w * h } default: { return 0 } } }"
        expect(_parses(src)).toBe(true)
    })

    test("class with multiple methods", () => {
        let src = "Stack { _items: [number]  push(val: number) { this._items.push(val) }  pop(): number { return this._items.pop() }  size(): number { return this._items.length } }"
        expect(_parses(src)).toBe(true)
    })
})
