// Stdlib Arrays — assertion-based tests
// Every assertion matches a claim in docs/language-reference/stdlib/arrays.md
import { describe, test, expect } from "liva/test"

describe("Array Core Methods", () => {
    test("map", () => {
        expect([1, 2, 3].map(x => x * 2)).toBe([2, 4, 6])
    })

    test("filter", () => {
        expect([1, 2, 3, 4, 5, 6].filter(x => x % 2 == 0)).toBe([2, 4, 6])
    })

    test("reduce", () => {
        expect([1, 2, 3, 4, 5].reduce(0, (acc, x) => acc + x)).toBe(15)
        expect([1, 2, 3, 4, 5].reduce(1, (acc, x) => acc * x)).toBe(120)
    })

    test("find", () => {
        let result = [1, 2, 3, 4, 5].find(x => x > 3)
        expect(result).toBe(4)
    })

    test("some", () => {
        expect([1, 2, 3, 4, 5].some(x => x % 2 == 0)).toBe(true)
        expect([1, 3, 5].some(x => x % 2 == 0)).toBe(false)
    })

    test("every", () => {
        expect([2, 4, 6, 8].every(x => x % 2 == 0)).toBe(true)
        expect([2, 4, 5, 8].every(x => x % 2 == 0)).toBe(false)
    })

    test("indexOf", () => {
        expect([10, 20, 30, 40].indexOf(30)).toBe(2)
        expect([10, 20, 30].indexOf(100)).toBe(-1)
    })

    test("includes", () => {
        expect([1, 2, 3, 4, 5].includes(3)).toBe(true)
        expect([1, 2, 3].includes(10)).toBe(false)
    })
})

describe("Array Callback Methods", () => {
    test("flatMap", () => {
        expect([1, 2, 3].flatMap(n => [n, n * 10])).toBe([1, 10, 2, 20, 3, 30])
    })

    test("count", () => {
        expect([1, 2, 3, 4, 5].count(x => x % 2 == 0)).toBe(2)
        expect([1, 3, 5].count(x => x % 2 == 0)).toBe(0)
    })

    test("findIndex", () => {
        expect([10, 20, 30, 40].findIndex(x => x > 25)).toBe(2)
        expect([10, 20, 30].findIndex(x => x > 100)).toBe(-1)
    })
})

describe("Array Access and Slicing", () => {
    test("first", () => {
        let result = [10, 20, 30].first()
        expect(result).toBe(10)
    })

    test("last", () => {
        let result = [10, 20, 30].last()
        expect(result).toBe(30)
    })

    test("slice", () => {
        expect([1, 2, 3, 4, 5].slice(1, 3)).toBe([2, 3])
        expect([1, 2, 3, 4, 5].slice(2)).toBe([3, 4, 5])
    })

    test("take", () => {
        expect([1, 2, 3, 4, 5].take(3)).toBe([1, 2, 3])
    })

    test("drop", () => {
        expect([1, 2, 3, 4, 5].drop(2)).toBe([3, 4, 5])
    })
})

describe("Array Transformation", () => {
    test("sort", () => {
        expect([3, 1, 4, 1, 5].sort()).toBe([1, 1, 3, 4, 5])
    })

    test("reversed", () => {
        expect([1, 2, 3].reversed()).toBe([3, 2, 1])
    })

    test("distinct", () => {
        expect([1, 2, 2, 3, 3, 3].distinct()).toBe([1, 2, 3])
    })

    test("flat", () => {
        expect([[1, 2], [3, 4], [5]].flat()).toBe([1, 2, 3, 4, 5])
    })

    test("zip", () => {
        let result = [1, 2, 3].zip(["a", "b", "c"])
        expect(result.length()).toBe(3)
    })

    test("chunks", () => {
        let result = [1, 2, 3, 4, 5].chunks(2)
        expect(result.length()).toBe(3)
    })
})

describe("Array Aggregation", () => {
    test("sum", () => {
        expect([1, 2, 3, 4, 5].sum()).toBe(15)
    })

    test("min", () => {
        let result = [3, 1, 4, 1, 5].min()
        expect(result).toBe(1)
    })

    test("max", () => {
        let result = [3, 1, 4, 1, 5].max()
        expect(result).toBe(5)
    })

    test("isEmpty", () => {
        expect([1, 2, 3].isEmpty()).toBe(false)
    })
})
